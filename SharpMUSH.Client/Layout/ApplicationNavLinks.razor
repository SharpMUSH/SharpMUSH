@using SharpMUSH.Client.Models.Applications
@using SharpMUSH.Client.Services
@using SharpMUSH.Library.Models.Portal.Applications
@using Microsoft.AspNetCore.Components.Routing
@inject ApplicationRegistryClient Registry

@* Dynamic nav links for registered full-page applications the current user may access, placed under the
   sidebar section named by each app's NavPlacement. Pass a Section to render only the apps for that section;
   widget apps are placed via the layout editor instead. *@

@foreach (var app in _apps)
{
    <NavLink class="phosphor-nav-link" href="@($"/apps/{app.Slug}")" Match="NavLinkMatch.Prefix">
        <MudIcon Icon="@(string.IsNullOrWhiteSpace(app.Icon) ? Icons.Material.Filled.Apps : app.Icon)"
                 Class="phosphor-nav-icon" />
        @if (!IsCollapsed)
        {
            <span class="phosphor-nav-text">@app.DisplayName</span>
        }
    </NavLink>
}

@code {
    [Parameter] public bool IsCollapsed { get; set; }

    /// <summary>The sidebar section (NavPlacement) whose apps this instance renders. Built-in or novel.</summary>
    [Parameter] public string Section { get; set; } = "Build";

    /// <summary>Pre-fetched application list; when null the component fetches it from the registry itself.</summary>
    [Parameter] public IReadOnlyList<PortalApplication>? Applications { get; set; }

    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private IReadOnlyList<PortalApplication> _apps = [];

    protected override async Task OnParametersSetAsync()
    {
        var role = AuthState is null
            ? SharpMUSH.Library.Authorization.PortalRole.Guest
            : PortalRoleHelper.CurrentRole((await AuthState).User);

        var all = Applications ?? await Registry.ListAsync();
        _apps = PortalNavSections.AppsForSection(all, role, Section);
    }
}
