@inherits LayoutComponentBase
@layout MainLayout
@using SharpMUSH.Client.Components

@* Configuration shell — prototype AdminScreen layout: centered two-column grid
   (230px section nav + content), rendered inside the main app shell. No pop-out drawer. *@
<div class="config-shell">
    <aside class="config-section-nav">
        <ConfigNavDrawer />
    </aside>
    <div class="config-section-body">
        @Body
    </div>
</div>
