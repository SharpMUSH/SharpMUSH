@* NavMenu — Phosphor Refined sidebar: logo · Play/World/Build/Manage groups · profile card *@
@using SharpMUSH.Client.Services
@using SharpMUSH.Client.Models
@using Microsoft.AspNetCore.Components.Routing
@inject IStringLocalizer<SharedResource> Loc
@inject ITerminalService Terminal
@inject IPlayTerminalService PlayTerminal
@inject NavigationManager Nav
@inject AccountAuthService AccountAuth
@implements IDisposable

<div class="phosphor-sidebar @(IsCollapsed ? "phosphor-sidebar--collapsed" : "")">

    @* ── Logo / brand ── *@
    <a href="/" class="phosphor-logo">
        <svg width="26" height="26" viewBox="0 0 512 512" class="phosphor-logo-mark">
            <g fill="var(--accent)">
                <path d="m345.16-0.31-88.2 163.24-88.13-163.1-167.67 252.72 87.98 234.7-1.24-233.41 64.74-117.99 104.11 196.48 0.27-0.37 0.51 0.0 104.11-196.48 64.74 117.99-1.25 233.41 87.98-234.7z" />
                <path d="m143.1 228.96 65.57 113.27v170.77l-65.99-166.48z" />
                <path d="m370.64 227.45-65.57 113.27v170.77l65.99-166.48z" />
            </g>
        </svg>
        @if (!IsCollapsed)
        {
            <div style="line-height:1.1;overflow:hidden;">
                <div class="phosphor-brand">@Loc["AppTitle"]</div>
                <div class="phosphor-brand-tag">GAME&nbsp;NAME</div>
            </div>
        }
    </a>

    @* ── Nav groups ── *@
    <nav class="phosphor-nav">

        @* PLAY *@
        <div class="nav-group">
            <div class="nav-group-label">Play</div>
            @NavItem("/", Icons.Material.Filled.Home, Loc["Home"], NavLinkMatch.All)
            @if (_characterActive)
            {
                <NavLink class="phosphor-nav-link" href="/play" Match="NavLinkMatch.Prefix">
                    <MudIcon Icon="@Icons.Material.Filled.SportsEsports" Class="phosphor-nav-icon" />
                    @if (!IsCollapsed)
                    {
                        <span class="phosphor-nav-text">@Loc["Play"]</span>
                    }
                    @if (_playActive)
                    {
                        <span class="phosphor-nav-dot @(_playUnread ? "phosphor-nav-dot--unread" : "")"
                              title="@(_playUnread ? "Unread play activity" : "Play session active")"></span>
                    }
                </NavLink>
            }
            @NavItem("/scenes", Icons.Material.Filled.Movie, Loc["SceneArchive"])
            @if (_characterActive)
            {
                @NavItem("/mail", Icons.Material.Filled.Mail, Loc["Mail"])
            }
        </div>

        @* WORLD *@
        <div class="nav-group">
            <div class="nav-group-label">World</div>
            @NavItem("/wiki", Icons.Material.Filled.MenuBook, Loc["Wiki"])
            @NavItem("/characters", Icons.Material.Filled.Groups, Loc["Characters"])
        </div>

        @* BUILD *@
        <div class="nav-group">
            <div class="nav-group-label">Build</div>
            @NavItem("/softcode", Icons.Material.Filled.Code, Loc["SoftcodeEditor"])
            <ApplicationNavLinks IsCollapsed="IsCollapsed" />
            <AuthorizeView Policy="applications.admin">
                <Authorized>@NavItem("/admin/applications", Icons.Material.Filled.Apps, "Applications")</Authorized>
            </AuthorizeView>
            <AuthorizeView Policy="layout.admin">
                <Authorized>@NavItem("/admin/layout", Icons.Material.Filled.Dashboard, "Layout")</Authorized>
            </AuthorizeView>
            <AuthorizeView Policy="packages.admin">
                <Authorized>@NavItem("/admin/packages", Icons.Material.Filled.Inventory2, "Packages")</Authorized>
            </AuthorizeView>
        </div>

        @* MANAGE *@
        <div class="nav-group">
            <div class="nav-group-label">Manage</div>
            <AuthorizeView Policy="players.view">
                <Authorized>@NavItem("/admin", Icons.Material.Filled.Dashboard, "Admin", NavLinkMatch.All)</Authorized>
            </AuthorizeView>
            <AuthorizeView Policy="roles.admin">
                <Authorized>@NavItem("/admin/roles", Icons.Material.Filled.Shield, "Roles")</Authorized>
            </AuthorizeView>
            <AuthorizeView Policy="wiki.admin">
                <Authorized>@NavItem("/admin/wiki", Icons.Material.Filled.AdminPanelSettings, "Wiki Admin")</Authorized>
            </AuthorizeView>
            <AuthorizeView Policy="media.admin">
                <Authorized>@NavItem("/admin/media", Icons.Material.Filled.PermMedia, "Image Library")</Authorized>
            </AuthorizeView>
            <AuthorizeView Policy="config.admin">
                <Authorized>@NavItem("/admin/config", Icons.Material.Filled.Tune, Loc["Config"])</Authorized>
            </AuthorizeView>
            @NavItem("/help", Icons.Material.Filled.Help, Loc["Help"])
        </div>
    </nav>

    @* ── Bottom profile card ── *@
    <div class="phosphor-profile-wrap">
        <a href="/account" class="phosphor-profile-card" title="@DisplayName">
            <div class="phosphor-avatar-wrap">
                <div class="phosphor-avatar"
                     style="@($"background:linear-gradient(140deg,hsl({AvatarHue} 38% 32%),hsl({AvatarHue} 32% 22%));color:hsl({AvatarHue} 45% 82%);")">
                    @AvatarInitial
                </div>
                <span class="phosphor-avatar-dot @(_characterActive ? "phosphor-avatar-dot--online" : "phosphor-avatar-dot--offline")"></span>
            </div>
            @if (!IsCollapsed)
            {
                <div style="text-align:left;line-height:1.2;overflow:hidden;">
                    <div class="phosphor-profile-name">@DisplayName</div>
                    <div class="phosphor-profile-sub">@UserTag · @(_characterActive ? "online" : "offline")</div>
                </div>
            }
        </a>
    </div>
</div>

@code {
    [Parameter]
    public bool IsCollapsed { get; set; } = true;

    private bool _characterActive;

    // Play-session terminal status, surfaced as a dot on the Play nav item.
    private bool _playActive;
    private bool _playUnread;

    // Avatar hue palette mirrors the prototype's AV_HUES.
    private static readonly int[] AvHues = [168, 28, 264, 210, 340, 130, 50];

    private RenderFragment NavItem(string href, string icon, string label, NavLinkMatch match = NavLinkMatch.Prefix) =>
        @<NavLink class="phosphor-nav-link" href="@href" Match="match">
            <MudIcon Icon="@icon" Class="phosphor-nav-icon" />
            @if (!IsCollapsed)
            {
                <span class="phosphor-nav-text">@label</span>
            }
        </NavLink>;

    private string AvatarInitial
    {
        get
        {
            var ch = AccountAuth.Characters.FirstOrDefault();
            if (ch is not null && ch.Name.Length > 0)
                return ch.Name[0].ToString().ToUpper();
            var user = AccountAuth.Username;
            return !string.IsNullOrEmpty(user) ? user[0].ToString().ToUpper() : "?";
        }
    }

    private int AvatarHue
    {
        get
        {
            var name = DisplayName;
            var code = name.Length > 0 ? name[0] : 'A';
            return AvHues[code % AvHues.Length];
        }
    }

    private string DisplayName
    {
        get
        {
            var ch = AccountAuth.Characters.FirstOrDefault();
            return ch?.Name ?? AccountAuth.Username ?? "DebugAdmin";
        }
    }

    private string UserTag
    {
        get
        {
            var ch = AccountAuth.Characters.FirstOrDefault();
            return ch is not null ? $"#{ch.DbrefNumber}" : "account";
        }
    }

    protected override void OnInitialized()
    {
        _characterActive = Terminal.IsConnected;
        Terminal.ConnectionStateChanged += OnConnectionChanged;

        _playActive = PlayTerminal.IsConnected;
        PlayTerminal.ConnectionStateChanged += OnPlayConnectionChanged;
        PlayTerminal.LineReceived += OnPlayLine;
        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnConnectionChanged(bool connected)
        => InvokeAsync(() =>
        {
            _characterActive = connected;
            StateHasChanged();
        });

    private void OnPlayConnectionChanged(bool connected)
        => InvokeAsync(() =>
        {
            _playActive = connected;
            if (!connected)
            {
                _playUnread = false;
            }
            StateHasChanged();
        });

    // New play output while the player isn't looking at /play → mark the dot as unread (brighter glow).
    private void OnPlayLine(TerminalLine _)
        => InvokeAsync(() =>
        {
            if (!IsOnPlay())
            {
                _playUnread = true;
                StateHasChanged();
            }
        });

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
        => InvokeAsync(() =>
        {
            if (IsOnPlay() && _playUnread)
            {
                _playUnread = false;
                StateHasChanged();
            }
        });

    private bool IsOnPlay()
        => new Uri(Nav.Uri).AbsolutePath.TrimEnd('/').Equals("/play", StringComparison.OrdinalIgnoreCase);

    public void Dispose()
    {
        Terminal.ConnectionStateChanged -= OnConnectionChanged;
        PlayTerminal.ConnectionStateChanged -= OnPlayConnectionChanged;
        PlayTerminal.LineReceived -= OnPlayLine;
        Nav.LocationChanged -= OnLocationChanged;
    }
}
