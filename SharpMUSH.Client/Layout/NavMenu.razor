@* NavMenu with support for collapsed (icon-only) mode *@
@inject IStringLocalizer<SharedResource> Loc

<MudPaper Width="@(IsCollapsed ? "60px" : "250px")" Class="py-3" Elevation="0">
    <MudNavMenu>
        @if (!IsCollapsed)
        {
            <MudText Typo="Typo.h6" Class="px-4">@Loc["AppTitle"]</MudText>
            <MudText Typo="Typo.body2" Class="px-4">@Loc["AdminPanel"]</MudText>
            <MudDivider Class="my-2"/>
        }
        
        <MudNavLink Href="/" Icon="@Icons.Material.Filled.Home" IconColor="Color.Secondary">
            @if (!IsCollapsed) { <text>@Loc["Home"]</text> }
        </MudNavLink>
        
        <MudNavLink Href="/softcode" Icon="@Icons.Material.Filled.Code" IconColor="Color.Secondary">
            @if (!IsCollapsed) { <text>@Loc["SoftcodeEditor"]</text> }
        </MudNavLink>

        <MudNavLink Href="/account" Icon="@Icons.Material.Filled.ManageAccounts" IconColor="Color.Secondary">
            @if (!IsCollapsed) { <text>My Account</text> }
        </MudNavLink>
        
        @if (!IsCollapsed)
        {
            <MudNavGroup Title="@Loc["Settings"].Value" Icon="@Icons.Material.Filled.Settings" IconColor="Color.Secondary" Expanded="true">
                <MudNavLink Href="/admin/config" Icon="@Icons.Material.Filled.Tune">@Loc["Config"]</MudNavLink>
                <MudNavLink Href="/admin/suggestions" Icon="@Icons.Material.Filled.Lightbulb">@Loc["Suggestions"]</MudNavLink>
                <MudNavLink Href="/security" Icon="@Icons.Material.Filled.Security">@Loc["Security"]</MudNavLink>
            </MudNavGroup>
        }
        else
        {
            <MudNavLink Href="/admin/config" Icon="@Icons.Material.Filled.Settings" IconColor="Color.Secondary" />
            <MudNavLink Href="/softcode" Icon="@Icons.Material.Filled.Code" IconColor="Color.Secondary" />
        }
    </MudNavMenu>
</MudPaper>

@code {
    [Parameter]
    public bool IsCollapsed { get; set; } = false;
}
