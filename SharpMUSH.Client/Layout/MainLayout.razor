@using MudBlazor.Utilities
@using SharpMUSH.Client.Components
@using SharpMUSH.Client.Services
@using Microsoft.AspNetCore.Components.Authorization
@inherits LayoutComponentBase
@inject NavigationManager NavigationManager
@inject IStringLocalizer<SharedResource> Loc
@inject ITerminalService Terminal
@inject AccountAuthService AccountAuth
@inject AuthenticationStateProvider AuthStateProvider
@inject ThemeService ThemeService

<MudThemeProvider @bind-IsDarkMode="@_isDarkMode" Theme="@ThemeService.CurrentTheme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Dense="true">
        @if (!_isConfigRoute)
        {
            <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@(_ => DrawerToggle())" />
        }
        @if (_isConfigRoute)
        {
            <MudText Typo="Typo.h6" Color="Color.Secondary">@Loc["Configuration"]</MudText>
        }
        <MudSpacer />
        <LanguagePicker />

        @* Character / Account switcher — shown when logged in to an account or in debug mode *@
        @if (AccountAuth.IsLoggedIn || _isDebugAuth)
        {
            <MudMenu Dense="true" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                <ActivatorContent>
                    <MudButton Variant="Variant.Text" Color="Color.Inherit"
                               EndIcon="@Icons.Material.Filled.ArrowDropDown"
                               Style="text-transform:none;font-size:13px;"
                               OnClick="@context.ToggleAsync">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Class="mr-1" />
                        @(_terminalPlayerName ?? AccountAuth.Username ?? "DebugAdmin")
                    </MudButton>
                </ActivatorContent>
                <ChildContent>
                    @if (_isDebugAuth)
                    {
                        <MudMenuItem Disabled="true">
                            <MudText Typo="Typo.caption" Style="color:#888;">Dev Mode (DebugAdmin)</MudText>
                        </MudMenuItem>
                    }
                    else
                    {
                        <MudMenuItem Disabled="true">
                            <MudText Typo="Typo.caption" Style="color:#888;">
                                Account: @AccountAuth.Username
                            </MudText>
                        </MudMenuItem>
                        @if (AccountAuth.Characters.Count > 0)
                        {
                            <MudDivider />
                            <MudMenuItem Disabled="true">
                                <MudText Typo="Typo.caption" Style="color:#888;">Play as:</MudText>
                            </MudMenuItem>
                            @foreach (var c in AccountAuth.Characters)
                            {
                                var character = c;
                                <MudMenuItem OnClick="() => SwitchCharacterAsync(character)">
                                    @character.Name (#@character.DbrefNumber)
                                </MudMenuItem>
                            }
                        }
                    }
                    <MudDivider />
                    <MudMenuItem Href="/account">
                        <MudIcon Icon="@Icons.Material.Filled.ManageAccounts" Size="Size.Small" Class="mr-2" />
                        Account Settings
                    </MudMenuItem>
                    <MudDivider />
                    <ThemePicker />
                    @if (!_isDebugAuth)
                    {
                        <MudMenuItem OnClick="AccountLogoutAsync">
                            <MudIcon Icon="@Icons.Material.Filled.Logout" Size="Size.Small" Class="mr-2" />
                            Disconnect
                        </MudMenuItem>
                    }
                </ChildContent>
            </MudMenu>
        }

        <MudTooltip Text="@(_terminalOpen ? "Close Terminal" : "Open Terminal")">
            <MudIconButton Icon="@Icons.Material.Filled.Terminal"
                           Color="@(_terminalOpen ? Color.Success : Color.Inherit)"
                           OnClick="ToggleTerminal"
                           title="Terminal" />
        </MudTooltip>
        <LoginDisplay />
    </MudAppBar>
    
    @* Primary Drawer - Collapses to mini when in config route *@
    <MudDrawer Open="@(_isConfigRoute ? true : _drawerOpen)"
               ClipMode="DrawerClipMode.Always" 
               Elevation="2"
               Variant="@(_isConfigRoute ? DrawerVariant.Mini : DrawerVariant.Responsive)"
               OpenMiniOnHover="true">
        <NavMenu IsCollapsed="@_isConfigRoute" />
    </MudDrawer>
    
    @* Config Drawer - Shows when on config route *@
    @if (_isConfigRoute)
    {
        <MudDrawer Open="true"
                   ClipMode="DrawerClipMode.Docked"
                   Variant="DrawerVariant.Persistent"
                   Anchor="Anchor.Left"
                   Width="280px"
                   Elevation="0"
                   Class="config-secondary-drawer"
                   Style="margin-left: 60px;">
            <ConfigNavDrawer />
        </MudDrawer>
    }
    
    <MudMainContent Class="@(_isConfigRoute ? "config-main-content" : "")"
                    Style="@(_terminalOpen ? "padding-bottom: 320px;" : "")">
        <MudContainer MaxWidth="MaxWidth.False" Class="@(_isConfigRoute ? "pa-0" : "")">
            @Body
        </MudContainer>
    </MudMainContent>

    @* Global bottom terminal drawer *@
    <MudDrawer @bind-Open="_terminalOpen"
               Anchor="Anchor.Bottom"
               Elevation="4"
               Variant="DrawerVariant.Temporary"
               ClipMode="DrawerClipMode.Never"
               Class="terminal-bottom-drawer"
               Width="100%"
               Height="300px">
        <MudDrawerHeader Style="padding:4px 12px;background:#111;border-bottom:1px solid #333;display:flex;align-items:center;">
            <MudIcon Icon="@Icons.Material.Filled.Terminal" Size="Size.Small" Color="Color.Secondary" Style="margin-right:8px;" />
            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Terminal</MudText>
            <MudSpacer />
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                           Color="Color.Default" OnClick="ToggleTerminal" />
        </MudDrawerHeader>
        <div style="flex:1;min-height:0;overflow:hidden;display:flex;flex-direction:column;">
            <GlobalTerminal />
        </div>
    </MudDrawer>
</MudLayout>

@code {
    private bool _isDarkMode = true;
    private bool _drawerOpen = false;
    private bool _isConfigRoute = false;
    private bool _terminalOpen = false;
    private string? _terminalPlayerName;
    private bool _isDebugAuth;

    protected override async Task OnInitializedAsync()
    {
        // Initialize themes before render
        await ThemeService.InitializeAsync();
        
        NavigationManager.LocationChanged += OnLocationChanged;
        UpdateConfigRouteState();
        await AccountAuth.InitAsync();
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();

        // In debug mode, auto-fetch an account session for the account linked to #1
        // so IsLoggedIn becomes true before we compute _isDebugAuth
        if (authState.User.Identity?.IsAuthenticated == true && !AccountAuth.IsLoggedIn)
            await AccountAuth.GetDebugOttAsync();

        // Load characters if logged in and not yet populated
        if (AccountAuth.IsLoggedIn && AccountAuth.Characters.Count == 0)
            await AccountAuth.GetCharactersAsync();

        _isDebugAuth = authState.User.Identity?.IsAuthenticated == true && !AccountAuth.IsLoggedIn;
        await EnsureAccountRoutingAsync();
    }

    private async Task SwitchCharacterAsync(AccountAuthService.CharacterSummary character)
    {
        var token = await AccountAuth.GetOttForCharacterAsync(character);
        if (token is null) return;
        await Terminal.DisconnectAsync();
        await Task.Delay(200);

        var serverUri = Terminal.ServerUri ?? "ws://localhost:4202/ws";
        await Terminal.ConnectWithOttAsync(serverUri, token);
        _terminalPlayerName = character.Name;
        _terminalOpen = true;
        StateHasChanged();
    }

    private async Task AccountLogoutAsync()
    {
        await AccountAuth.LogoutAsync();
        await Terminal.DisconnectAsync();
        _terminalPlayerName = null;
        StateHasChanged();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _ = InvokeAsync(async () =>
        {
            UpdateConfigRouteState();
            await EnsureAccountRoutingAsync();
            StateHasChanged();
        });
    }

    private void UpdateConfigRouteState()
    {
        _isConfigRoute = NavigationManager.Uri.Contains("/admin/config");
    }

    private async Task EnsureAccountRoutingAsync()
    {
        var currentPath = new Uri(NavigationManager.Uri).AbsolutePath;

        if (AccountAuth.IsLoggedIn && AccountAuth.MustChangePassword)
        {
            if (!string.Equals(currentPath, "/account", StringComparison.OrdinalIgnoreCase))
                NavigationManager.NavigateTo("/account");
            return;
        }

        if (AccountAuth.IsLoggedIn || _isDebugAuth || !IsHomePath(currentPath))
            return;

        if (await AccountAuth.NeedsSetupAsync())
            NavigationManager.NavigateTo("/setup");
    }

    private static bool IsHomePath(string currentPath)
        => string.IsNullOrEmpty(currentPath) || currentPath == "/";

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    void ToggleTerminal()
    {
        _terminalOpen = !_terminalOpen;
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}

<style>
    .config-main-content {
        margin-left: 340px !important; /* 60px mini drawer + 280px config drawer */
    }
</style>