@using SharpMUSH.Client.Components
@using SharpMUSH.Client.Services
@using Microsoft.AspNetCore.Components.Authorization
@using SharpMUSH.Library.Models.Portal.Widgets
@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager NavigationManager
@inject IStringLocalizer<SharedResource> Loc
@inject ITerminalService Terminal
@inject AccountAuthService AccountAuth
@inject AuthenticationStateProvider AuthStateProvider
@inject ILayoutService LayoutService
@inject IJSRuntime JS

<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@* Forces a hard browser refresh whenever the server unloads/reloads a plugin DLL (generic signal). *@
<PluginChangeReloader />

<div class="phosphor-shell @(_mobileNavOpen ? "phosphor-shell--nav-open" : "") @(_isPlayRoute ? "" : "phosphor-shell--bottomnav")">

    @* Mobile-only: tapping the dimmed backdrop closes the off-canvas nav drawer. *@
    <div class="phosphor-nav-backdrop" @onclick="CloseMobileNav"></div>

    <NavMenu IsCollapsed="@_sidebarCollapsed" />

    @if (_layout is not null && _layout.Settings.LeftSidebarEnabled && !_isConfigRoute)
    {
        <div class="phosphor-widget-aside" style="@($"width:{_layout.Settings.LeftSidebarWidth};")">
            <ZoneRenderer Zone="WidgetZone.LeftSidebar" Layout="_layout" Grid="true" />
        </div>
    }

    <div class="phosphor-content-col">

        <header class="phosphor-topbar">
            <button class="phosphor-icon-btn" @onclick="ToggleSidebar" title="Toggle navigation">
                <MudIcon Icon="@Icons.Material.Filled.Menu" Style="font-size:1.25rem;" />
            </button>
            <div class="phosphor-topbar-title">@PageTitle()</div>

            @if (_layout is not null)
            {
                <ZoneRenderer Zone="WidgetZone.TopBar" Layout="_layout" />
            }

            <div style="flex:1;"></div>

            <div class="phosphor-search">
                <span class="phosphor-search-icon">⌕</span>
                <input type="search"
                       placeholder="Search…"
                       @bind="_searchQuery"
                       @bind:event="oninput"
                       @onkeydown="HandleSearchKeyDown" />
                <span class="phosphor-search-kbd">⌘K</span>
            </div>

            <span class="phosphor-lang"><LanguagePicker /></span>

            <button class="@($"phosphor-icon-btn{(_terminalOpen ? " phosphor-icon-btn--active" : "")}")"
                    @onclick="ToggleTerminal"
                    title="@(_terminalOpen ? "Close Terminal" : "Open Terminal")">
                <MudIcon Icon="@Icons.Material.Filled.Terminal" Style="font-size:1.125rem;" />
            </button>

            <div class="phosphor-topbar-divider"></div>

            <AccountChrome IsLoggedIn="AccountAuth.IsLoggedIn"
                           IsDebugAuth="_isDebugAuth"
                           DisplayName="@(_terminalPlayerName ?? AccountAuth.Username ?? "DebugAdmin")"
                           UserInitial="@UserInitial"
                           AccountUsername="@AccountAuth.Username"
                           Characters="AccountAuth.Characters"
                           OnSwitchCharacter="SwitchCharacterAsync"
                           OnLogout="AccountLogoutAsync" />
        </header>

        <main class="phosphor-main @(_terminalOpen ? "phosphor-main--terminal" : "")">
            @Body
        </main>

        @if (_layout is not null && _layout.Settings.FooterEnabled)
        {
            <div class="phosphor-footer">
                <ZoneRenderer Zone="WidgetZone.Footer" Layout="_layout" Grid="true" />
            </div>
        }

        @if (_terminalOpen)
        {
            <div class="phosphor-terminal">
                <div class="phosphor-terminal-header">
                    <MudIcon Icon="@Icons.Material.Filled.Terminal" Style="font-size:0.9375rem;color:var(--accent);margin-right:0.5625rem;" />
                    <span style="font-family:'JetBrains Mono',monospace;font-size:0.75rem;color:var(--accent);letter-spacing:0.05em;">command terminal</span>
                    <span style="font-family:'JetBrains Mono',monospace;font-size:0.6875rem;color:var(--text-faint);margin-left:0.5rem;">
                        · @(Terminal.IsConnected ? "connected" : "disconnected")
                    </span>
                    <div style="flex:1;"></div>
                    <button class="phosphor-icon-btn" @onclick="ToggleTerminal" title="Close Terminal">
                        <MudIcon Icon="@Icons.Material.Filled.Close" Style="font-size:1.125rem;" />
                    </button>
                </div>
                <div style="flex:1;min-height:0;overflow:hidden;display:flex;flex-direction:column;">
                    <GlobalTerminal />
                </div>
            </div>
        }

        @* Mobile-only hybrid bottom navigation. The primary destinations stay visible (the
           research-backed pattern for engagement/discoverability); "Menu" opens the full
           grouped drawer for the long tail. Suppressed on /play so it doesn't fight that
           page's terminal input at the bottom of the screen. *@
        @if (!_isPlayRoute)
        {
            <nav class="phosphor-bottomnav">
                @BottomTab("/", Icons.Material.Filled.Home, Loc["Home"], exact: true)
                @* Gated like the sidebar's Play link: only when a character session is active. *@
                @if (_characterActive)
                {
                    @BottomTab("/play", Icons.Material.Filled.SportsEsports, Loc["Play"])
                }
                @BottomTab("/wiki", Icons.Material.Filled.MenuBook, Loc["Wiki"])
                @BottomTab("/characters", Icons.Material.Filled.Groups, "Chars")
                <button type="button"
                        class="phosphor-bottomtab @(_mobileNavOpen ? "phosphor-bottomtab--on" : "")"
                        @onclick="ToggleMobileNav">
                    <MudIcon Icon="@Icons.Material.Filled.Menu" Class="phosphor-bottomtab-icon" />
                    <span class="phosphor-bottomtab-label">Menu</span>
                </button>
            </nav>
        }
    </div>

    @if (_layout is not null && _layout.Settings.RightSidebarEnabled && !_isConfigRoute)
    {
        <div class="phosphor-widget-aside phosphor-widget-aside--right" style="@($"width:{_layout.Settings.RightSidebarWidth};")">
            <ZoneRenderer Zone="WidgetZone.RightSidebar" Layout="_layout" Grid="true" />
        </div>
    }
</div>

@code {
    private bool _sidebarCollapsed = false;
    private bool _mobileNavOpen = false;
    private bool _isConfigRoute = false;
    private bool _isPlayRoute = false;
    private bool _terminalOpen = false;
    private bool _characterActive = false;
    private string? _terminalPlayerName;
    private bool _isDebugAuth;
    private LayoutConfiguration? _layout;
    private string _searchQuery = string.Empty;

    private string UserInitial
    {
        get
        {
            var name = _terminalPlayerName ?? AccountAuth.Username ?? "DebugAdmin";
            return name.Length > 0 ? name[0].ToString().ToUpper() : "?";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        NavigationManager.LocationChanged += OnLocationChanged;
        // Mirror the sidebar's Play gating on the bottom nav: a character session is
        // "active" when the command terminal is connected.
        _characterActive = Terminal.IsConnected;
        Terminal.ConnectionStateChanged += OnCharacterConnectionChanged;
        UpdateConfigRouteState();
        await AccountAuth.InitAsync();
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();

        // DebugAuthStateProvider sets AuthenticationType = "Server authentication".
        // In debug mode, always refresh the session so server restarts (which clear the
        // in-memory AccountSessionStore) don't leave the client with a stale token.
        // Guarded by ExplicitlyLoggedOut: without this, a dev who logs out would be silently
        // re-authenticated as the debug admin on the very next reload/navigation, since the
        // debug identity is always "authenticated" in Development. The latch sticks until the
        // next real login (via /login, or a fresh tab — sessionStorage is tab-scoped).
        var isDebugMode = authState.User.Identity?.AuthenticationType == "Server authentication";
        if (!AccountAuth.ExplicitlyLoggedOut && (isDebugMode || (authState.User.Identity?.IsAuthenticated == true && !AccountAuth.IsLoggedIn)))
        {
            var debugOtt = await AccountAuth.GetDebugOttAsync();
            if (debugOtt is not null && !Terminal.IsConnected)
                _ = Terminal.ConnectWithOttAsync("ws://localhost:4202/ws", debugOtt.Token);

            // Auto-start the command terminal on load: open the docked drawer once a connection exists/begins.
            _terminalOpen = true;
        }
        else if (Terminal.IsConnected)
        {
            _terminalOpen = true;
        }

        if (AccountAuth.IsLoggedIn && AccountAuth.Characters.Count == 0)
            await AccountAuth.GetCharactersAsync();

        // Same latch here: otherwise the topbar would keep showing the "Dev Mode" menu (and
        // hide the Disconnect item) even after an explicit logout, since the debug identity's
        // IsAuthenticated never flips to false on its own.
        _isDebugAuth = !AccountAuth.ExplicitlyLoggedOut && authState.User.Identity?.IsAuthenticated == true && !AccountAuth.IsLoggedIn;
        await EnsureAccountRoutingAsync();

        LayoutService.OnLayoutChanged += HandleLayoutChanged;
        _layout = await LayoutService.GetLayoutAsync(LayoutScopes.Global);
    }

    private void HandleLayoutChanged(string scope)
    {
        if (!string.Equals(scope, LayoutScopes.Global, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        _ = InvokeAsync(async () =>
        {
            _layout = await LayoutService.GetLayoutAsync(LayoutScopes.Global);
            StateHasChanged();
        });
    }

    private async Task SwitchCharacterAsync(AccountAuthService.CharacterSummary character)
    {
        var token = await AccountAuth.GetOttForCharacterAsync(character);
        if (token is null) return;
        await Terminal.DisconnectAsync();
        await Task.Delay(200);

        var serverUri = Terminal.ServerUri ?? "ws://localhost:4202/ws";
        await Terminal.ConnectWithOttAsync(serverUri, token);
        _terminalPlayerName = character.Name;
        // Deliberately do NOT open the terminal drawer: switching characters connects in the
        // background; the toolbar toggle opens the terminal when the player wants it.
        StateHasChanged();
    }

    private async Task AccountLogoutAsync()
    {
        await AccountAuth.LogoutAsync();
        await Terminal.DisconnectAsync();
        _terminalPlayerName = null;
        // _isDebugAuth is computed once in OnInitializedAsync and otherwise never flips back to
        // false on its own (the debug identity's IsAuthenticated never changes), so without this
        // the topbar keeps showing the "DebugAdmin" chip (ADMIN with a different icon) after an
        // explicit logout. Navigate to "/" (the anonymous home, which has no [Authorize]) rather
        // than /login: logging out should return a visitor to anonymous browsing, not force them
        // onto a sign-in screen. EnsureAccountRoutingAsync won't re-trigger debug re-auth here
        // because ExplicitlyLoggedOut is now latched (set by AccountAuth.LogoutAsync above).
        _isDebugAuth = false;
        StateHasChanged();
        NavigationManager.NavigateTo("/", forceLoad: false);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _ = InvokeAsync(async () =>
        {
            _mobileNavOpen = false;
            UpdateConfigRouteState();
            await EnsureAccountRoutingAsync();
            StateHasChanged();
        });
    }

    private void UpdateConfigRouteState()
    {
        _isConfigRoute = NavigationManager.Uri.Contains("/admin/config");
        _isPlayRoute = new Uri(NavigationManager.Uri).AbsolutePath.TrimEnd('/')
            .Equals("/play", StringComparison.OrdinalIgnoreCase);
    }

    // Bottom-nav tab: a link that highlights when its route is active.
    private RenderFragment BottomTab(string href, string icon, string label, bool exact = false) =>
        @<a href="@href" class="phosphor-bottomtab @(IsNavActive(href, exact) ? "phosphor-bottomtab--on" : "")">
            <MudIcon Icon="@icon" Class="phosphor-bottomtab-icon" />
            <span class="phosphor-bottomtab-label">@label</span>
        </a>;

    private bool IsNavActive(string href, bool exact)
    {
        var path = new Uri(NavigationManager.Uri).AbsolutePath.TrimEnd('/');
        if (string.IsNullOrEmpty(path)) path = "/";
        if (exact) return path == "/";
        return path.Equals(href, StringComparison.OrdinalIgnoreCase)
            || path.StartsWith(href + "/", StringComparison.OrdinalIgnoreCase);
    }

    private void ToggleMobileNav() => _mobileNavOpen = !_mobileNavOpen;

    private void OnCharacterConnectionChanged(bool connected)
        => InvokeAsync(() =>
        {
            _characterActive = connected;
            StateHasChanged();
        });

    private string PageTitle()
    {
        if (_isConfigRoute) return Loc["Configuration"];
        var path = new Uri(NavigationManager.Uri).AbsolutePath.Trim('/');
        if (string.IsNullOrEmpty(path)) return Loc["Home"];
        var seg = path.Split('/');
        return seg switch
        {
            ["play"] => Loc["Play"],
            ["scenes", ..] => Loc["SceneArchive"],
            ["characters", ..] => Loc["Characters"],
            ["mail", ..] => Loc["Mail"],
            ["wiki", ..] => Loc["Wiki"],
            ["softcode", ..] => Loc["SoftcodeEditor"],
            ["apps", ..] => "Applications",
            ["account"] => Loc["MyAccount"],
            ["settings"] => Loc["Settings"],
            ["help", ..] => Loc["Help"],
            ["admin", "packages", ..] => "Packages",
            ["admin", "wiki", ..] => "Wiki Admin",
            ["admin", "media", ..] => "Image Library",
            ["admin", "applications", ..] => "Applications",
            _ => Capitalize(seg[^1].Replace('-', ' ')),
        };
    }

    private static string Capitalize(string s)
        => string.IsNullOrEmpty(s) ? s : char.ToUpper(s[0]) + s[1..];

    private bool? _needsSetup;

    private async Task EnsureAccountRoutingAsync()
    {
        var currentPath = new Uri(NavigationManager.Uri).AbsolutePath;

        // First-run wizard: while the game is unclaimed, every route funnels to /setup.
        // Cache only the negative — once claimed, stop asking the server on each navigation.
        //
        // !_isDebugAuth is intentional, not a bug: in dev mode a debug-auth'd user who explicitly
        // logs out on an unclaimed game drops out of debug auth and lands here, which now routes
        // them to /setup. That's the correct destination — on an unclaimed game there's no
        // "anonymous portal" to fall back to, since onboarding is the only meaningful place to
        // send anyone. Do not special-case _isDebugAuth further to try to keep them off /setup.
        if (_needsSetup != false && !_isDebugAuth)
        {
            // null means the status check failed (transient error, cold server, stale proxy,
            // etc.) — leave _needsSetup as-is so the next navigation retries instead of
            // latching a false negative that would hide the wizard for the rest of the session.
            var result = await AccountAuth.NeedsSetupAsync();
            if (result is not null)
                _needsSetup = result;

            if (_needsSetup == true)
            {
                if (!string.Equals(currentPath, "/setup", StringComparison.OrdinalIgnoreCase))
                    NavigationManager.NavigateTo("/setup");
                return;
            }
        }

        if (AccountAuth.IsLoggedIn && AccountAuth.MustChangePassword)
        {
            if (!string.Equals(currentPath, "/account", StringComparison.OrdinalIgnoreCase))
                NavigationManager.NavigateTo("/account");
        }
    }

    // One hamburger, two behaviors by viewport: on a phone it opens the off-canvas
    // drawer; on desktop it toggles the icon rail (unchanged). matchMedia keeps the
    // breakpoint decision in JS so it always matches the 760px CSS breakpoint.
    private async Task ToggleSidebar()
    {
        var narrow = await JS.InvokeAsync<bool>("sharpmushLayout.isTouchChrome");
        if (narrow)
            _mobileNavOpen = !_mobileNavOpen;
        else
            _sidebarCollapsed = !_sidebarCollapsed;
    }

    private void CloseMobileNav()
    {
        if (_mobileNavOpen)
            _mobileNavOpen = false;
    }

    private void ToggleTerminal() => _terminalOpen = !_terminalOpen;

    private void HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_searchQuery))
        {
            NavigationManager.NavigateTo($"/wiki?q={Uri.EscapeDataString(_searchQuery.Trim())}");
            _searchQuery = string.Empty;
        }
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
        LayoutService.OnLayoutChanged -= HandleLayoutChanged;
        Terminal.ConnectionStateChanged -= OnCharacterConnectionChanged;
    }
}
