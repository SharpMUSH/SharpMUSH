@* Header account area, extracted out of MainLayout so it can be exercised directly in bUnit
   without dragging in MainLayout's heavy OnInitializedAsync (setup-status HTTP call, layout
   service, terminal wiring, location-changed routing, etc.). Renders one of two states:
   the account/character menu when a session is active (real login or dev-mode debug auth),
   or a modest "Sign in" link for anonymous visitors — anonymous browsing is the default, so
   sign-in is an opt-in affordance, never forced. *@

@if (IsLoggedIn || IsDebugAuth)
{
    <MudMenu Dense="true" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
        <ActivatorContent>
            <button class="phosphor-user-btn" @onclick="@context.ToggleAsync">
                <span class="phosphor-user-avatar">@UserInitial</span>
                <span class="phosphor-user-name">@DisplayName</span>
                <MudIcon Icon="@Icons.Material.Filled.ArrowDropDown" Style="font-size:0.9375rem;color:var(--text-faint);" />
            </button>
        </ActivatorContent>
        <ChildContent>
            @if (IsDebugAuth)
            {
                <MudMenuItem Disabled="true">
                    <MudText Typo="Typo.caption" Style="color:#888;">Dev Mode (DebugAdmin)</MudText>
                </MudMenuItem>
            }
            else
            {
                <MudMenuItem Disabled="true">
                    <MudText Typo="Typo.caption" Style="color:#888;">
                        Account: @AccountUsername
                    </MudText>
                </MudMenuItem>
                @if (Characters.Count > 0)
                {
                    <MudDivider />
                    <MudMenuItem Disabled="true">
                        <MudText Typo="Typo.caption" Style="color:#888;">Play as:</MudText>
                    </MudMenuItem>
                    @foreach (var c in Characters)
                    {
                        var character = c;
                        <MudMenuItem OnClick="() => OnSwitchCharacter.InvokeAsync(character)">
                            @character.Name (#@character.DbrefNumber)
                        </MudMenuItem>
                    }
                }
            }
            <MudDivider />
            <MudMenuItem Href="/account">
                <MudIcon Icon="@Icons.Material.Filled.ManageAccounts" Size="Size.Small" Class="mr-2" />
                Account Settings
            </MudMenuItem>
            @if (!IsDebugAuth)
            {
                <MudMenuItem OnClick="() => OnLogout.InvokeAsync()">
                    <MudIcon Icon="@Icons.Material.Filled.Logout" Size="Size.Small" Class="mr-2" />
                    Disconnect
                </MudMenuItem>
            }
        </ChildContent>
    </MudMenu>
}
else
{
    <MudButton Href="/login"
               Variant="Variant.Filled"
               Color="Color.Primary"
               Size="Size.Small"
               StartIcon="@Icons.Material.Filled.Login"
               Class="phosphor-signin-btn"
               Style="height:38px;font-weight:600;">
        Sign in
    </MudButton>
}

@code {
    /// <summary>Real account session active (<c>AccountAuthService.IsLoggedIn</c>).</summary>
    [Parameter] public bool IsLoggedIn { get; set; }

    /// <summary>Dev-mode debug auth active (no real account session — see MainLayout's latch).</summary>
    [Parameter] public bool IsDebugAuth { get; set; }

    /// <summary>Name shown in the avatar chip: terminal character name, else account username, else "DebugAdmin".</summary>
    [Parameter] public string DisplayName { get; set; } = "DebugAdmin";

    /// <summary>Single-letter avatar initial derived from <see cref="DisplayName"/>.</summary>
    [Parameter] public string UserInitial { get; set; } = "?";

    /// <summary>Raw account username, shown in the "Account: ..." menu caption (never the terminal override).</summary>
    [Parameter] public string? AccountUsername { get; set; }

    [Parameter] public IReadOnlyList<AccountAuthService.CharacterSummary> Characters { get; set; } = [];

    [Parameter] public EventCallback<AccountAuthService.CharacterSummary> OnSwitchCharacter { get; set; }

    [Parameter] public EventCallback OnLogout { get; set; }
}
