@using SharpMUSH.Client.Services
@inject ProfileService Profiles
@inject ISnackbar Snackbar
@inject IStringLocalizer<SharedResource> Loc

<MudPaper Outlined="true" Class="pa-4">
    <MudText Typo="Typo.h6" Color="Color.Primary" Class="mb-3">@Loc["EditProfile"]</MudText>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_schema?.Sections is null || _schema.Sections.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">@Loc["ProfileUnavailable"]</MudAlert>
    }
    else
    {
        @foreach (var section in _schema.Sections.OrderBy(s => s.Order))
        {
            <MudText Typo="Typo.subtitle1" Class="mt-3 mb-2">@section.Name</MudText>
            @foreach (var field in section.Fields ?? [])
            {
                var key = field.Key;
                <MudTextField T="string"
                              Label="@field.Label"
                              Value="@GetValue(key)"
                              ValueChanged="@(v => _values[key] = v)"
                              Lines="@(IsMultiline(field.Type) ? 4 : 1)"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              HelperText="@FieldHelp(field)"
                              Class="mb-3" />
            }
        }

        <MudStack Row="true" Spacing="2" Class="mt-4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Save"
                       OnClick="SaveAsync" Disabled="_saving">
                @Loc["Save"]
            </MudButton>
            <MudButton Variant="Variant.Text" OnClick="Cancel" Disabled="_saving">@Loc["Cancel"]</MudButton>
        </MudStack>
    }
</MudPaper>

@code {
    [Parameter] public required string CharacterName { get; set; }

    /// <summary>Invoked after a successful save so the parent can refresh the read view.</summary>
    [Parameter] public EventCallback OnSaved { get; set; }

    /// <summary>Invoked when the user cancels editing.</summary>
    [Parameter] public EventCallback OnCancel { get; set; }

    private ProfileService.ProfileSchema? _schema;
    private readonly Dictionary<string, string> _values = new();
    private readonly Dictionary<string, string> _original = new();
    private bool _loading = true;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        _schema = await Profiles.GetSchemaAsync();
        var data = await Profiles.GetProfileAsync(CharacterName);
        if (data?.Fields is not null)
        {
            foreach (var (key, fv) in data.Fields)
            {
                if (fv.Visible && fv.Value is not null)
                {
                    _values[key] = fv.Value;
                    _original[key] = fv.Value;
                }
            }
        }
        _loading = false;
    }

    private string GetValue(string key) => _values.TryGetValue(key, out var v) ? v : string.Empty;

    private static bool IsMultiline(string type) => type is "mstring" or "markdown";

    private string FieldHelp(ProfileService.FieldSchema field)
        => field.EditableBy is "staff" ? Loc["StaffOnlyField"] : string.Empty;

    private async Task SaveAsync()
    {
        // Send only fields the user actually changed; the server enforces which it will apply.
        var changed = _values
            .Where(kv => !_original.TryGetValue(kv.Key, out var orig) || orig != kv.Value)
            .ToDictionary(kv => kv.Key, kv => kv.Value);

        if (changed.Count == 0)
        {
            await OnCancel.InvokeAsync();
            return;
        }

        _saving = true;
        var result = await Profiles.UpdateAsync(CharacterName, changed);
        _saving = false;

        if (result is null)
        {
            Snackbar.Add(Loc["ProfileUpdateFailed"], Severity.Error);
            return;
        }

        var applied = string.IsNullOrWhiteSpace(result.Updated) ? 0 : result.Updated.Split(' ').Length;
        Snackbar.Add(string.Format(Loc["ProfileUpdated"], applied), Severity.Success);
        await OnSaved.InvokeAsync();
    }

    private async Task Cancel() => await OnCancel.InvokeAsync();
}
