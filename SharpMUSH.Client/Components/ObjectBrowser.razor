@using SharpMUSH.Client.Models
@using SharpMUSH.Client.Services
@inject MushQueryService QueryService
@inject ITerminalService Terminal

<div style="display:flex;flex-direction:column;height:100%;min-height:0;">

    <div class="ob-modes">
        <button type="button" class="ob-mode @(_activeTab == 0 ? "ob-mode--on" : "")"
                @onclick="LoadMyObjectsAsync" disabled="@_loading">
            <MudIcon Icon="@Icons.Material.Filled.Person" Style="font-size:0.875rem;" /> Mine
        </button>
        <button type="button" class="ob-mode @(_activeTab == 1 ? "ob-mode--on" : "")"
                @onclick="@(() => _activeTab = 1)">
            <MudIcon Icon="@Icons.Material.Filled.Search" Style="font-size:0.875rem;" /> Search
        </button>
        <button type="button" class="ob-mode @(_activeTab == 2 ? "ob-mode--on" : "")"
                @onclick="LoadHereAsync" disabled="@_loading">
            <MudIcon Icon="@Icons.Material.Filled.Home" Style="font-size:0.875rem;" /> Here
        </button>
    </div>

    @if (_activeTab == 1)
    {
        <div class="ob-searchwrap">
            <div class="ob-search">
                <MudIcon Icon="@Icons.Material.Filled.Search" Style="font-size:0.875rem;color:var(--text-faint);" />
                <input value="@_searchExpr" @oninput="@(e => _searchExpr = e.Value?.ToString() ?? string.Empty)"
                       @onkeydown="OnSearchExprKeyDown"
                       placeholder="lsearch(me, type, thing)" class="ob-search-input" />
                <button type="button" class="ob-go" @onclick="SearchAsync" disabled="@_loading">Go</button>
            </div>
            <span class="ob-hint">e.g. <code>lsearch(me)</code> · <code>lsearch(me, type, room)</code> · <code>lcon(loc(me))</code></span>
        </div>
    }

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="ob-error">@_error</div>
    }

    <div style="flex:1;overflow-y:auto;min-height:0;padding:0.375rem;">
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (_groups.Count == 0)
        {
            <div class="ob-empty">No objects found.</div>
        }
        else
        {
            @foreach (var (typeName, items) in _groups)
            {
                <div class="ob-group-label">@typeName · @items.Count</div>
                @foreach (var item in items)
                {
                    var it = item;
                    var on = _selectedDbref == it.Dbref;
                    <button type="button" class="ob-item @(on ? "ob-item--on" : "")" @onclick="@(() => SelectObject(it))">
                        <MudIcon Icon="@GetTypeIcon(typeName)"
                                 Style="@($"font-size:0.9375rem;flex-shrink:0;color:{(on ? "var(--accent)" : "var(--text-faint)")};")" />
                        <span class="ob-item-name">@it.Name</span>
                        <span class="ob-item-ref">#@it.Dbref</span>
                    </button>
                }
            }
        }
    </div>
</div>

<style>
    .ob-modes { display: flex; gap: 0.25rem; padding: 0.5rem 0.5rem 0.375rem; }
    .ob-mode {
        flex: 1; display: inline-flex; align-items: center; justify-content: center; gap: 0.3125rem; padding: 0.375rem 0.25rem;
        border-radius: var(--radius); cursor: pointer; border: 1px solid var(--border); background: transparent;
        color: var(--text-dim); font-family: var(--font-ui); font-size: 0.71875rem; font-weight: 500; transition: all 0.12s;
    }
    .ob-mode:hover:not(:disabled) { color: var(--text); border-color: rgba(var(--glow), 0.3); }
    .ob-mode--on { background: rgba(var(--glow), 0.12); border-color: rgba(var(--glow), 0.4); color: var(--accent); font-weight: 600; }
    .ob-mode:disabled { opacity: 0.5; cursor: default; }

    .ob-searchwrap { display: flex; flex-direction: column; gap: 0.3125rem; padding: 0 0.5rem 0.375rem; }
    .ob-search { display: flex; align-items: center; gap: 0.5rem; padding: 0 0.625rem; background: var(--surface-3);
        border: 1px solid var(--border); border-radius: var(--radius); }
    .ob-search:focus-within { border-color: var(--accent); }
    .ob-search-input { flex: 1; min-width: 0; padding: 0.5rem 0; background: transparent; border: none; outline: none;
        color: var(--text); font-family: var(--font-mono); font-size: 0.75rem; }
    .ob-search-input::placeholder { color: var(--text-faint); }
    .ob-go { flex-shrink: 0; padding: 0.1875rem 0.625rem; border-radius: 6px; border: 1px solid rgba(var(--glow), 0.3);
        background: rgba(var(--glow), 0.10); color: var(--accent); cursor: pointer; font-family: var(--font-ui);
        font-size: 0.71875rem; font-weight: 600; }
    .ob-go:hover:not(:disabled) { background: rgba(var(--glow), 0.18); }
    .ob-hint { font-family: var(--font-mono); font-size: 0.625rem; color: var(--text-faint); line-height: 1.4; }
    .ob-hint code { background: var(--surface-2); border-radius: 3px; padding: 0 0.1875rem; }

    .ob-error { margin: 0 0.5rem 0.375rem; padding: 0.375rem 0.625rem; border-radius: var(--radius); font-size: 0.71875rem;
        color: #e0b050; background: rgba(217, 162, 58, 0.12); border: 1px solid rgba(217, 162, 58, 0.3); }
    .ob-empty { padding: 0.875rem; text-align: center; font-family: var(--font-mono); font-size: 0.71875rem; color: var(--text-faint); }

    .ob-group-label { font-family: var(--font-mono); font-size: 0.625rem; letter-spacing: 0.14em; text-transform: uppercase;
        color: var(--text-faint); padding: 0.5rem 0.5rem 0.25rem; }
    .ob-item { width: 100%; text-align: left; display: flex; align-items: center; gap: 0.5625rem; padding: 0.4375rem 0.5625rem;
        border-radius: var(--radius); cursor: pointer; border: none; background: transparent; margin-bottom: 0.125rem; transition: background 0.12s; }
    .ob-item:hover { background: var(--surface-2); }
    .ob-item--on { background: rgba(var(--glow), 0.10); box-shadow: inset 2px 0 0 var(--accent); }
    .ob-item-name { flex: 1; min-width: 0; font-family: var(--font-ui); font-size: 0.8125rem; color: var(--text-dim);
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .ob-item--on .ob-item-name { color: var(--text); font-weight: 600; }
    .ob-item-ref { font-family: var(--font-mono); font-size: 0.65625rem; color: var(--text-faint); flex-shrink: 0; }
</style>

@code {
    [Parameter] public EventCallback<int> OnObjectSelected { get; set; }

    private int _activeTab;
    private string _searchExpr = string.Empty;
    private bool _loading;
    private string _error = string.Empty;
    private int _selectedDbref = -1;

    private readonly List<(string TypeName, List<MushSearchResult> Items)> _groups = [];

    protected override async Task OnInitializedAsync()
    {
        if (Terminal.IsConnected)
            await LoadMyObjectsAsync();
    }

    /// <summary>
    /// Public refresh — re-runs whichever tab is currently active.
    /// Can be called from the parent page after mutations (create/delete).
    /// </summary>
    public Task RefreshAsync() => _activeTab switch
    {
        2 => LoadHereAsync(),
        _ => LoadMyObjectsAsync(),
    };

    /// <summary>
    /// Select a dbref in the list and notify parent without re-fetching.
    /// Useful after creating an object to auto-highlight it.
    /// </summary>
    public async Task SelectDbrefAsync(int dbref)
    {
        _selectedDbref = dbref;
        StateHasChanged();
        await OnObjectSelected.InvokeAsync(dbref);
    }

    private async Task LoadMyObjectsAsync()
    {
        _activeTab = 0;
        await FetchResultsAsync(() => QueryService.SearchOwnedAsync());
    }

    private async Task SearchAsync()
    {
        if (string.IsNullOrWhiteSpace(_searchExpr)) return;
        await FetchResultsAsync(() => QueryService.SearchAsync(_searchExpr));
    }

    private async Task OnSearchExprKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchAsync();
    }

    private async Task LoadHereAsync()
    {
        _activeTab = 2;
        await FetchResultsAsync(() => QueryService.GetContentsAsync());
    }

    private async Task FetchResultsAsync(Func<Task<List<MushSearchResult>>> fetch)
    {
        _loading = true;
        _error = string.Empty;
        _groups.Clear();
        StateHasChanged();

        try
        {
            var results = await fetch();
            BuildGroups(results);
        }
        catch (Exception ex)
        {
            _error = $"Error: {ex.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void BuildGroups(List<MushSearchResult> results)
    {
        var grouped = results.GroupBy(r => r.Type.ToString());
        _groups.Clear();
        foreach (var g in grouped.OrderBy(g => g.Key))
            _groups.Add((g.Key, g.ToList()));
    }

    private async Task SelectObject(MushSearchResult item)
    {
        _selectedDbref = item.Dbref;
        await OnObjectSelected.InvokeAsync(item.Dbref);
    }

    private static string GetTypeIcon(string typeName) => typeName switch
    {
        "Thing" => Icons.Material.Filled.Inventory2,
        "Room" => Icons.Material.Filled.MeetingRoom,
        "Exit" => Icons.Material.Filled.ExitToApp,
        "Player" => Icons.Material.Filled.Person,
        _ => Icons.Material.Filled.DataObject,
    };
}
