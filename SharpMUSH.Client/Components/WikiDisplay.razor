@using SharpMUSH.Client.Models
@using SharpMUSH.Client.Services
@using SharpMUSH.Library.Services
@using System.Net
@using System.Text
@using System.Text.RegularExpressions
@inject WikiMarkdigPipeline Pipeline
@inject WikiService Wiki
@inject IStringLocalizer<SharedResource> Loc
@inject IJSRuntime JS

@if (Article is null)
{
    <div class="wiki-article">
        <a class="wiki-back" href="/wiki"><MudIcon Icon="@Icons.Material.Filled.ChevronLeft" Style="font-size:0.875rem;" /> Wiki</a>
        <MudAlert Severity="@Severity.Info" Variant="Variant.Outlined" Class="mt-2">
            <AuthorizeView Policy="wiki.create">
                <Authorized>
                    <MudText>@Loc["WikiPageNotExist"]</MudText>
                    <MudButton EndIcon="@Icons.Material.Filled.Create" Color="Color.Primary" Ripple="true"
                               Style="text-transform:none;"
                               OnClick="@ActivateEditMode">@Loc["CreateThisPage"]</MudButton>
                </Authorized>
                <NotAuthorized>
                    <MudText>@Loc["NothingToSeeHere"]</MudText>
                </NotAuthorized>
            </AuthorizeView>
        </MudAlert>
    </div>
}
else if (DisplayAsHero)
{
    <div class="WikiContent WikiContent--hero" style="text-align:center;">
        <div class="mud-card-content">
            @if (Article.Image is not null)
            {
                <img class="wiki-img" src="@Article.Image" alt="@Article.Title" />
            }
            @RenderSegments
        </div>
    </div>
}
else
{
    <div class="wiki-article-grid">
        <article class="wiki-article-main">
            <a class="wiki-back" href="/wiki"><MudIcon Icon="@Icons.Material.Filled.ChevronLeft" Style="font-size:0.875rem;" /> Wiki</a>
            <div class="wiki-article-kicker">@CategoryLabel</div>
            <h1 class="wiki-article-title">@Article.Title</h1>

            <div class="wiki-article-meta">
                <span class="wiki-article-edit">
                    <MudIcon Icon="@Icons.Material.Filled.Edit" Style="font-size:0.8125rem;" /> anyone can edit
                </span>
                <div style="flex:1;"></div>
                <AuthorizeView Policy="wiki.edit">
                    <Authorized>
                        <button type="button" class="wiki-btn wiki-btn--solid" @onclick="ActivateEditMode">
                            <MudIcon Icon="@Icons.Material.Filled.Edit" Style="font-size:0.875rem;" /> Edit
                        </button>
                    </Authorized>
                </AuthorizeView>
                <a class="wiki-btn" href="@HistoryHref">
                    <MudIcon Icon="@Icons.Material.Filled.History" Style="font-size:0.875rem;" /> History
                </a>
            </div>

            <div class="WikiContent wiki-article-body">
                <div class="mud-card-content">
                    @if (Article.Image is not null)
                    {
                        <img class="wiki-img" src="@Article.Image" alt="@Article.Title" />
                    }
                    @RenderSegments
                </div>
            </div>
        </article>

        <aside class="wiki-toc">
            @if (_toc.Count > 0)
            {
                <div class="wiki-toc-sticky">
                    <div class="wiki-toc-label">On this page</div>
                    <div class="wiki-toc-list">
                        @foreach (var entry in _toc)
                        {
                            <a href="#@entry.Anchor">@entry.Text</a>
                        }
                    </div>
                </div>
            }
        </aside>
    </div>
}

@code {
    [Parameter]
    public required string Slug { get; init; }

    /// <summary>Wiki namespace (e.g. "help"); null means the Main namespace.</summary>
    [Parameter]
    public string? Namespace { get; init; }

    /// <summary>Category segment — part of the page's identity.</summary>
    [Parameter]
    public string? Category { get; init; }

    [Parameter]
    public WikiArticle? Article { get; init; }

    [Parameter]
    public required Func<Task> ActivateEditMode { get; init; }

    /// <summary>Raised after a successful rollback (kept for API compatibility with WikiView;
    /// restore now lives on the dedicated history page).</summary>
    [Parameter]
    public EventCallback<WikiArticle> OnArticleRestored { get; init; }

    /// <summary>
    /// One renderable chunk of the article body: either raw HTML, or a dynamic
    /// directive placeholder (when <c>Directive</c> is non-null).
    /// </summary>
    private sealed record BodySegment(string Html, string? Directive = null, string Arg = "");

    private sealed record TocEntry(string Text, string Anchor);

    private static readonly Regex DirectivePlaceholder = new(
        "<div class=\"wiki-directive\" data-directive=\"([a-z]+)\" data-arg=\"([^\"]*)\"></div>",
        RegexOptions.Compiled);

    private static readonly Regex WikiLinkHref = new(
        "<a href=\"/wiki/([^\"#?]+)\">",
        RegexOptions.Compiled);

    private List<BodySegment> _segments = [];
    private List<TocEntry> _toc = [];

    private string CategoryLabel =>
        string.IsNullOrWhiteSpace(Category) ? "General" : char.ToUpper(Category[0]) + Category[1..];

    private string HistoryHref =>
        $"/wiki/{(Namespace ?? "main").ToLowerInvariant()}/{(string.IsNullOrWhiteSpace(Category) ? "general" : Category)}/{Slug}/history";

    protected override async Task OnParametersSetAsync()
    {
        var html = Article?.RenderedHtml
                   ?? (Article is not null ? Pipeline.RenderToHtml(Article.Content) : string.Empty);

        _segments = SplitOnDirectives(html);
        _toc = BuildToc(Article?.Content);

        var marked = await MarkRedlinksAsync(html);
        if (marked != html)
        {
            _segments = SplitOnDirectives(marked);
        }
    }

    /// <summary>
    /// After the article HTML is in the DOM, hand off to the client post-render pass
    /// (js/wiki-render.js): initialise mermaid once, then on every render turn any
    /// <c>```mermaid</c> blocks into SVG and honour a deep-link URL fragment.
    /// </summary>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("SharpMUSH.WikiRender.init");
        }

        if (Article is not null)
        {
            await JS.InvokeVoidAsync("SharpMUSH.WikiRender.render");
        }
    }

    private RenderFragment RenderSegments => __builder =>
    {
        foreach (var segment in _segments)
        {
            if (segment.Directive is not null)
            {
                <WikiDirectiveBlock Directive="@segment.Directive" Arg="@segment.Arg" />
            }
            else
            {
                @((MarkupString)segment.Html)
            }
        }
    };

    /// <summary>Parses level-2 (##) markdown headings into a table of contents.
    /// Anchors match Markdig's auto-identifier (GitHub-style) so #links resolve.</summary>
    private static List<TocEntry> BuildToc(string? markdown)
    {
        if (string.IsNullOrEmpty(markdown)) return [];
        return markdown.Split('\n')
            .Select(l => l.TrimEnd())
            .Where(l => l.StartsWith("## ", StringComparison.Ordinal))
            .Select(l => l[3..].Trim())
            .Where(t => t.Length > 0)
            .Select(t => new TocEntry(t, Slugify(t)))
            .ToList();
    }

    private static string Slugify(string text)
    {
        var sb = new StringBuilder();
        foreach (var ch in text.ToLowerInvariant())
        {
            if (char.IsLetterOrDigit(ch)) sb.Append(ch);
            else if (ch is ' ' or '-' or '_') sb.Append('-');
        }
        var s = sb.ToString();
        while (s.Contains("--", StringComparison.Ordinal)) s = s.Replace("--", "-");
        return s.Trim('-');
    }

    private async Task<string> MarkRedlinksAsync(string html)
    {
        var refs = WikiLinkHref.Matches(html)
            .Select(m => m.Groups[1].Value)
            .Distinct(StringComparer.Ordinal)
            .ToList();
        if (refs.Count == 0) return html;

        var exists = await Wiki.CheckExistsAsync(refs.Select(WebUtility.HtmlDecode)!);
        foreach (var reference in refs)
        {
            var decoded = WebUtility.HtmlDecode(reference);
            if (exists.TryGetValue(decoded, out var found) && !found)
            {
                html = html.Replace(
                    $"<a href=\"/wiki/{reference}\">",
                    $"<a href=\"/wiki/{reference}\" class=\"wiki-redlink\">");
            }
        }

        return html;
    }

    private static List<BodySegment> SplitOnDirectives(string html)
    {
        var segments = new List<BodySegment>();
        var position = 0;

        foreach (Match match in DirectivePlaceholder.Matches(html))
        {
            if (match.Index > position)
            {
                segments.Add(new BodySegment(html[position..match.Index]));
            }

            segments.Add(new BodySegment(
                Html: string.Empty,
                Directive: match.Groups[1].Value,
                Arg: WebUtility.HtmlDecode(match.Groups[2].Value)));

            position = match.Index + match.Length;
        }

        if (position < html.Length)
        {
            segments.Add(new BodySegment(html[position..]));
        }

        return segments;
    }

    private bool DisplayAsHero => Slug.Equals("home", StringComparison.InvariantCultureIgnoreCase);
}
