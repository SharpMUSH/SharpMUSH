@using MudBlazor
@using Markdig

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6" Class="mud-text-secondary">
            <MudIcon Icon="@Icons.Material.Filled.Help" Class="mr-2" />@Title
        </MudText>
    </TitleContent>
    <DialogContent>
        <div class="mush-help-content" style="max-height:60vh;overflow-y:auto;font-family:inherit;">
            @((MarkupString)_renderedHtml)
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Color="Color.Primary">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Content { get; set; } = string.Empty;

    private string _renderedHtml = string.Empty;

    protected override void OnParametersSet()
    {
        _renderedHtml = string.IsNullOrEmpty(Content)
            ? "<em>No help available.</em>"
            : Markdig.Markdown.ToHtml(Content, new MarkdownPipelineBuilder().UseAdvancedExtensions().Build());
    }

    private void Close() => MudDialog.Close();
}
