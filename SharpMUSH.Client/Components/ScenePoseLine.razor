@using SharpMUSH.Client.Models
@using SharpMUSH.Client.Services

@* Renders a single scene pose: the display persona (ShowAsName → AuthorName),
   an "edited" badge when the pose has been edited, the timestamp, and the pose body
   rendered from its raw Markup client-side. Deleted poses render struck-through. *@
<div class="scene-line scene-line--pose @(Pose.IsDeleted ? "ms-strike" : null)"
     style="@(Pose.IsDeleted ? "opacity:0.55;" : null)">
    <div style="display:flex;align-items:baseline;gap:0.5rem;margin-bottom:0.125rem;">
        <span style="font-weight:600;color:var(--accent);font-size:0.8125rem;">@Pose.DisplayName</span>
        @if (Pose.WasEdited)
        {
            <span class="scene-edited-badge" title="@($"Edited {Pose.EditCount - 1} time(s)")"
                  style="font-size:0.625rem;letter-spacing:0.05em;text-transform:uppercase;color:var(--text-faint);border:1px solid var(--border);border-radius:4px;padding:0 0.3125rem;">edited</span>
        }
        <span style="font-size:0.6875rem;color:var(--text-faint);margin-left:auto;">
            @Pose.CreatedAtUtc.ToLocalTime().ToString("HH:mm")
        </span>
    </div>
    <div class="scene-pose-body">@((MarkupString)SceneMarkupRenderer.ToHtml(Pose.Markup))</div>
    @if (Pose.Tags.Count > 0)
    {
        <div style="display:flex;flex-wrap:wrap;gap:0.25rem;margin-top:0.1875rem;">
            @foreach (var tag in Pose.Tags)
            {
                <span style="font-size:0.625rem;color:var(--text-faint);background:var(--surface-2);border-radius:4px;padding:0 0.3125rem;">@tag</span>
            }
        </div>
    }
</div>

@code {
    [Parameter] public required ScenePoseView Pose { get; set; }
}

<style>
    /* Mobile: keep wide pose text (and long unbroken tokens / pasted URLs) inside
       the column instead of forcing the whole scene log to scroll sideways. */
    @@media (max-width: 760px) {
        .scene-line {
            min-width: 0;
        }
        .scene-line .scene-pose-body {
            min-width: 0;
            overflow-wrap: anywhere;
            word-break: break-word;
        }
    }
</style>
