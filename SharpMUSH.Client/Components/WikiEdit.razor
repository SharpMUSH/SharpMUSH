@using SharpMUSH.Client.Models
@using SharpMUSH.Library.Services
@inject IJSRuntime JsRuntime
@inject WikiMarkdigPipeline Pipeline

@if (Article is not null)
{
    <div class="wiki-edit">
        <div class="wiki-edit-header">
            <button type="button" class="wiki-edit-cancel" @onclick="OnCancel">
                <MudIcon Icon="@Icons.Material.Filled.Close" Style="font-size:0.9375rem;" /> Cancel
            </button>
            <div style="flex:1;"></div>
            <span class="wiki-edit-mode">
                <MudIcon Icon="@Icons.Material.Filled.Visibility" Style="font-size:0.875rem;color:var(--accent);" /> editing · live preview
            </span>
        </div>

        <div class="wiki-edit-titlerow">
            <input class="wiki-edit-title" value="@Article.Title"
                   @oninput="@(e => Article.Title = e.Value?.ToString() ?? string.Empty)"
                   placeholder="Page title" />
            <div class="wiki-edit-cat">
                <MudIcon Icon="@Icons.Material.Filled.Folder" Style="font-size:0.875rem;color:var(--text-faint);" />
                <input value="@Article.Category"
                       @oninput="@(e => Article.Category = e.Value?.ToString())"
                       placeholder="category" />
            </div>
        </div>

        <div class="wiki-edit-toolbar">
            <button type="button" title="Bold" @onclick="@(() => Wrap("**", "**", false))"><b>B</b></button>
            <button type="button" title="Italic" @onclick="@(() => Wrap("*", "*", false))"><i>I</i></button>
            <button type="button" title="Heading" @onclick="@(() => Wrap("## ", "", true))"><b>H</b></button>
            <button type="button" title="List item" @onclick="@(() => Wrap("- ", "", true))">
                <MudIcon Icon="@Icons.Material.Filled.FormatListBulleted" Style="font-size:0.9375rem;" />
            </button>
            <button type="button" title="Quote" @onclick="@(() => Wrap("> ", "", true))">
                <MudIcon Icon="@Icons.Material.Filled.FormatQuote" Style="font-size:0.9375rem;" />
            </button>
            <button type="button" title="Link" @onclick="@(() => Wrap("[", "](https://)", false))">
                <MudIcon Icon="@Icons.Material.Filled.Link" Style="font-size:0.9375rem;" />
            </button>
            <div class="wiki-edit-tooldiv"></div>
            <button type="button" title="Insert image" @onclick="@(() => _showAssetPicker = !_showAssetPicker)">
                <MudIcon Icon="@Icons.Material.Filled.Image" Style="font-size:0.9375rem;" />
            </button>
            <div style="flex:1;"></div>
            <span class="wiki-edit-md">Markdown</span>
        </div>

        @if (_showAssetPicker)
        {
            <div class="wiki-edit-assets">
                <WikiAssetPicker OnAssetSelected="@InsertAssetMarkdown" />
            </div>
        }

        <div class="wiki-edit-split">
            <textarea id="@_taId" class="wiki-edit-textarea" spellcheck="false"
                      value="@Article.Content"
                      @oninput="@(e => Article.Content = e.Value?.ToString() ?? string.Empty)"></textarea>
            <div class="wiki-edit-preview WikiContent">
                <div class="mud-card-content">
                    @((MarkupString)Pipeline.RenderToHtml(Article.Content))
                </div>
            </div>
        </div>

        <div class="wiki-edit-tags">
            <span class="wiki-edit-taglabel">Tags</span>
            @foreach (var tag in Article.Tags)
            {
                var t = tag;
                <span class="wiki-edit-tag">@t
                    <button type="button" @onclick="@(() => RemoveTag(t))">×</button>
                </span>
            }
            <input class="wiki-edit-taginput" value="@_tagEntry"
                   @oninput="@(e => _tagEntry = e.Value?.ToString() ?? string.Empty)"
                   @onkeydown="OnTagKeyDown" placeholder="add tag…" />
            <div style="flex:1;"></div>
            <label class="wiki-edit-pub">
                <input type="checkbox" checked="@Article.Published"
                       @onchange="@(e => Article.Published = (bool)(e.Value ?? false))" />
                Published
            </label>
        </div>

        <div class="wiki-edit-savebar">
            <div class="wiki-edit-summary">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Style="font-size:0.875rem;color:var(--text-faint);" />
                <input value="@_summary" @oninput="@(e => _summary = e.Value?.ToString() ?? string.Empty)"
                       placeholder="Summarize your change (e.g. 'fixed a typo')…" />
            </div>
            <button type="button" class="wiki-edit-minor" @onclick="@(() => _minor = !_minor)">
                <span class="wiki-edit-check @(_minor ? "on" : "")">
                    @if (_minor) { <MudIcon Icon="@Icons.Material.Filled.Check" Style="font-size:0.6875rem;color:var(--accent-on);" /> }
                </span>
                Minor edit
            </button>
            <span class="wiki-edit-delta" style="@(ByteDelta >= 0 ? "color:var(--accent);" : "color:#e57373;")">
                @(ByteDelta >= 0 ? "+" : "")@ByteDelta bytes
            </span>
            <div class="wiki-edit-savediv"></div>
            <button type="button" class="wiki-btn" @onclick="OnCancel" disabled="@_saving">Discard</button>
            <button type="button" class="wiki-edit-publish" @onclick="HandleSave" disabled="@_saving">
                <MudIcon Icon="@Icons.Material.Filled.Check" Style="font-size:0.875rem;" />
                @(_saving ? "Saving…" : "Publish changes")
            </button>
        </div>

        @if (_errorMessage is not null)
        {
            <MudAlert Severity="Severity.Error" Class="mt-2">@_errorMessage</MudAlert>
        }

        <div class="wiki-edit-foot">
            <span>Changes publish immediately and appear for everyone.</span>
            <a href="/wiki/help/general/markdown_guide" target="_blank">Formatting help</a>
        </div>
    </div>
}

<style>
    .wiki-edit {
        padding: var(--cpad);
        height: 100%;
        display: flex;
        flex-direction: column;
        min-height: 0;
    }

    .wiki-edit-header {
        display: flex;
        align-items: center;
        gap: 0.875rem;
        margin-bottom: 0.875rem;
    }
    .wiki-edit-cancel {
        display: inline-flex;
        align-items: center;
        gap: 0.3125rem;
        background: none;
        border: none;
        cursor: pointer;
        color: var(--text-dim);
        font-family: var(--font-ui);
        font-size: 0.8125rem;
    }
    .wiki-edit-cancel:hover { color: var(--text); }
    .wiki-edit-mode {
        display: inline-flex;
        align-items: center;
        gap: 0.4375rem;
        font-family: var(--font-mono);
        font-size: 0.71875rem;
        color: var(--text-faint);
    }

    .wiki-edit-titlerow { display: flex; gap: 0.75rem; margin-bottom: 0.75rem; }
    .wiki-edit-title {
        flex: 1;
        min-width: 0;
        padding: 0.75rem 1rem;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        color: var(--text);
        font-family: var(--font-display);
        font-size: 1.375rem;
        font-weight: 600;
        outline: none;
    }
    .wiki-edit-title:focus { border-color: var(--accent); }
    .wiki-edit-cat {
        display: flex;
        align-items: center;
        gap: 0.5625rem;
        padding: 0 0.875rem;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
    }
    .wiki-edit-cat:focus-within { border-color: var(--accent); }
    .wiki-edit-cat input {
        background: transparent; border: none; outline: none; color: var(--text);
        font-family: var(--font-ui); font-size: 0.8125rem; width: 130px;
    }
    .wiki-edit-cat input::placeholder { color: var(--text-faint); }

    .wiki-edit-toolbar {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.4375rem 0.625rem;
        background: var(--surface-3);
        border: 1px solid var(--border-soft);
        border-bottom: none;
        border-radius: var(--radius) var(--radius) 0 0;
    }
    .wiki-edit-toolbar > button {
        width: 32px; height: 32px; display: grid; place-items: center;
        border: none; background: transparent; color: var(--text-dim); cursor: pointer;
        border-radius: var(--radius); font-family: var(--font-mono); font-size: 0.8125rem;
    }
    .wiki-edit-toolbar > button:hover { background: var(--surface-2); color: var(--text); }
    .wiki-edit-tooldiv { width: 1px; height: 20px; background: var(--border); margin: 0 0.375rem; }
    .wiki-edit-md { font-family: var(--font-mono); font-size: 0.6875rem; color: var(--text-faint); }

    .wiki-edit-assets {
        padding: 0.75rem;
        background: var(--surface);
        border: 1px solid var(--border-soft);
        border-bottom: none;
    }

    .wiki-edit-split {
        flex: 1;
        min-height: 0;
        display: grid;
        grid-template-columns: 1fr 1fr;
        border: 1px solid var(--border-soft);
        border-radius: 0 0 var(--radius) var(--radius);
        overflow: hidden;
    }
    .wiki-edit-textarea {
        resize: none;
        border: none;
        outline: none;
        padding: 1.25rem 1.375rem;
        background: var(--surface-3);
        color: var(--text);
        font-family: var(--font-mono);
        font-size: 0.84375rem;
        line-height: 1.7;
        caret-color: var(--accent);
        border-right: 1px solid var(--border-soft);
    }
    .wiki-edit-preview {
        overflow-y: auto;
        padding: 1.25rem 1.5rem;
        background: var(--surface);
    }

    .wiki-edit-tags {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.4375rem;
        margin-top: 0.75rem;
    }
    .wiki-edit-taglabel {
        font-family: var(--font-mono);
        font-size: 0.625rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--text-faint);
    }
    .wiki-edit-tag {
        display: inline-flex;
        align-items: center;
        gap: 0.3125rem;
        font-family: var(--font-mono);
        font-size: 0.71875rem;
        padding: 0.1875rem 0.3125rem 0.1875rem 0.5625rem;
        border-radius: 99px;
        background: var(--surface-2);
        color: var(--text-dim);
        border: 1px solid var(--border);
    }
    .wiki-edit-tag button {
        border: none; background: transparent; color: inherit; cursor: pointer;
        font-size: 0.875rem; line-height: 1; padding: 0 0.125rem; opacity: 0.7;
    }
    .wiki-edit-tag button:hover { opacity: 1; }
    .wiki-edit-taginput {
        background: transparent; border: none; outline: none; color: var(--text);
        font-family: var(--font-ui); font-size: 0.78125rem; width: 100px;
    }
    .wiki-edit-taginput::placeholder { color: var(--text-faint); }
    .wiki-edit-pub {
        display: inline-flex; align-items: center; gap: 0.375rem;
        font-family: var(--font-ui); font-size: 0.78125rem; color: var(--text-dim); cursor: pointer;
    }

    .wiki-edit-savebar {
        display: flex;
        align-items: center;
        gap: 0.875rem;
        margin-top: 0.75rem;
        padding: 0.75rem 1rem;
        background: var(--surface);
        border: 1px solid var(--border-soft);
        border-radius: var(--radius);
    }
    .wiki-edit-summary {
        flex: 1;
        display: flex;
        align-items: center;
        gap: 0.625rem;
        padding: 0 0.75rem;
        background: var(--surface-3);
        border: 1px solid var(--border);
        border-radius: var(--radius);
    }
    .wiki-edit-summary:focus-within { border-color: var(--accent); }
    .wiki-edit-summary input {
        flex: 1; min-width: 0; padding: 0.5625rem 0; background: transparent; border: none; outline: none;
        color: var(--text); font-family: var(--font-ui); font-size: 0.8125rem;
    }
    .wiki-edit-summary input::placeholder { color: var(--text-faint); }
    .wiki-edit-minor {
        display: flex; align-items: center; gap: 0.5rem; background: none; border: none; cursor: pointer;
        font-family: var(--font-ui); font-size: 0.78125rem; color: var(--text-dim); white-space: nowrap;
    }
    .wiki-edit-check {
        width: 16px; height: 16px; border-radius: 4px; border: 1.5px solid var(--border);
        display: grid; place-items: center;
    }
    .wiki-edit-check.on { border-color: var(--accent); background: var(--accent); }
    .wiki-edit-delta { font-family: var(--font-mono); font-size: 0.6875rem; white-space: nowrap; }
    .wiki-edit-savediv { width: 1px; height: 24px; background: var(--border); }
    .wiki-edit-publish {
        display: inline-flex; align-items: center; gap: 0.375rem; padding: 0.4375rem 0.875rem; border-radius: var(--radius);
        border: none; cursor: pointer; background: var(--accent); color: var(--accent-on);
        font-family: var(--font-ui); font-size: 0.78125rem; font-weight: 600;
        box-shadow: 0 0 18px rgba(var(--glow), 0.25);
    }
    .wiki-edit-publish:hover:not(:disabled) { filter: brightness(1.08); }
    .wiki-edit-publish:disabled { opacity: 0.6; cursor: default; }

    .wiki-edit-foot {
        display: flex;
        justify-content: space-between;
        margin-top: 0.5rem;
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        color: var(--text-faint);
    }
    .wiki-edit-foot a { color: var(--accent); text-decoration: none; }
    .wiki-edit-foot a:hover { text-decoration: underline; }

    @@media (max-width: 760px) {
        .wiki-edit-split { grid-template-columns: 1fr; }
        .wiki-edit-preview { display: none; }
    }
</style>

@code {
    [Parameter] public required WikiArticle? Article { get; set; }

    /// <summary>Invoked after a successful save with the updated article.</summary>
    [Parameter] public EventCallback<WikiArticle> OnSaved { get; set; }

    /// <summary>Invoked when the user clicks Cancel/Discard.</summary>
    [Parameter] public EventCallback OnCancel { get; set; }

    private readonly string _taId = $"wiki-edit-ta-{Guid.NewGuid():N}";
    private bool _saving;
    private bool _showAssetPicker;
    private string? _errorMessage;
    private string _tagEntry = string.Empty;
    private string _summary = string.Empty;
    private bool _minor;
    private int _initialBytes;

    protected override void OnParametersSet()
        => _initialBytes = Article is null ? 0 : System.Text.Encoding.UTF8.GetByteCount(Article.Content);

    private int ByteDelta => Article is null
        ? 0
        : System.Text.Encoding.UTF8.GetByteCount(Article.Content) - _initialBytes;

    private async Task Wrap(string before, string after, bool block)
        => await JsRuntime.InvokeVoidAsync("SharpMUSH.Wiki.wrap", _taId, before, after, block);

    private void AddTag()
    {
        if (Article is null) return;
        var tag = _tagEntry.Trim().ToLowerInvariant();
        if (tag.Length > 0 && !Article.Tags.Contains(tag))
            Article.Tags.Add(tag);
        _tagEntry = string.Empty;
    }

    private void RemoveTag(string tag) => Article?.Tags.Remove(tag);

    private void OnTagKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter") AddTag();
    }

    private void InsertAssetMarkdown(string snippet)
    {
        if (Article is null) return;
        var separator = Article.Content.Length == 0 || Article.Content.EndsWith('\n') ? "\n" : "\n\n";
        Article.Content += $"{separator}{snippet}\n";
        _showAssetPicker = false;
    }

    private async Task HandleSave()
    {
        if (Article is null) return;
        _saving = true;
        _errorMessage = null;
        try
        {
            await OnSaved.InvokeAsync(Article);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }
}
