@using SharpMUSH.Client.Models
@using SharpMUSH.Library.Services
@inject IJSRuntime JsRuntime
@inject WikiMarkdigPipeline Pipeline

@if (Article is not null)
{
    <div class="wiki-edit">
        <div class="wiki-edit-header">
            <button type="button" class="wiki-edit-cancel" @onclick="OnCancel">
                <MudIcon Icon="@Icons.Material.Filled.Close" Style="font-size:0.9375rem;" /> Cancel
            </button>
            <div style="flex:1;"></div>
            <span class="wiki-edit-mode">
                <MudIcon Icon="@Icons.Material.Filled.Visibility" Style="font-size:0.875rem;color:var(--accent);" /> editing · live preview
            </span>
        </div>

        <div class="wiki-edit-titlerow">
            <input class="wiki-edit-title" value="@Article.Title"
                   @oninput="@(e => Article.Title = e.Value?.ToString() ?? string.Empty)"
                   placeholder="Page title" />
            <div class="wiki-edit-cat">
                <MudIcon Icon="@Icons.Material.Filled.Folder" Style="font-size:0.875rem;color:var(--text-faint);" />
                <input value="@Article.Category"
                       @oninput="@(e => Article.Category = e.Value?.ToString())"
                       placeholder="category" />
            </div>
        </div>

        <div class="wiki-edit-toolbar">
            <button type="button" title="Bold" @onclick="@(() => Wrap("**", "**", false))"><b>B</b></button>
            <button type="button" title="Italic" @onclick="@(() => Wrap("*", "*", false))"><i>I</i></button>
            <button type="button" title="Heading" @onclick="@(() => Wrap("## ", "", true))"><b>H</b></button>
            <button type="button" title="List item" @onclick="@(() => Wrap("- ", "", true))">
                <MudIcon Icon="@Icons.Material.Filled.FormatListBulleted" Style="font-size:0.9375rem;" />
            </button>
            <button type="button" title="Quote" @onclick="@(() => Wrap("> ", "", true))">
                <MudIcon Icon="@Icons.Material.Filled.FormatQuote" Style="font-size:0.9375rem;" />
            </button>
            <button type="button" title="Link" @onclick="@(() => Wrap("[", "](https://)", false))">
                <MudIcon Icon="@Icons.Material.Filled.Link" Style="font-size:0.9375rem;" />
            </button>
            <div class="wiki-edit-tooldiv"></div>
            <button type="button" title="Insert image" @onclick="@(() => _showAssetPicker = !_showAssetPicker)">
                <MudIcon Icon="@Icons.Material.Filled.Image" Style="font-size:0.9375rem;" />
            </button>
            <div style="flex:1;"></div>
            <span class="wiki-edit-md">Markdown</span>
        </div>

        @if (_showAssetPicker)
        {
            <div class="wiki-edit-assets">
                <WikiAssetPicker OnAssetSelected="@InsertAssetMarkdown" />
            </div>
        }

        <div class="wiki-edit-split">
            <textarea id="@_taId" class="wiki-edit-textarea" spellcheck="false"
                      value="@Article.Content"
                      @oninput="@(e => Article.Content = e.Value?.ToString() ?? string.Empty)"></textarea>
            <div class="wiki-edit-preview WikiContent">
                <div class="mud-card-content">
                    @((MarkupString)Pipeline.RenderToHtml(Article.Content))
                </div>
            </div>
        </div>

        <div class="wiki-edit-tags">
            <span class="wiki-edit-taglabel">Tags</span>
            @foreach (var tag in Article.Tags)
            {
                var t = tag;
                <span class="wiki-edit-tag">@t
                    <button type="button" @onclick="@(() => RemoveTag(t))">×</button>
                </span>
            }
            <input class="wiki-edit-taginput" value="@_tagEntry"
                   @oninput="@(e => _tagEntry = e.Value?.ToString() ?? string.Empty)"
                   @onkeydown="OnTagKeyDown" placeholder="add tag…" />
            <div style="flex:1;"></div>
            <label class="wiki-edit-pub">
                <input type="checkbox" checked="@Article.Published"
                       @onchange="@(e => Article.Published = (bool)(e.Value ?? false))" />
                Published
            </label>
        </div>

        <div class="wiki-edit-savebar">
            <div class="wiki-edit-summary">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Style="font-size:0.875rem;color:var(--text-faint);" />
                <input value="@_summary" @oninput="@(e => _summary = e.Value?.ToString() ?? string.Empty)"
                       placeholder="Summarize your change (e.g. 'fixed a typo')…" />
            </div>
            <button type="button" class="wiki-edit-minor" @onclick="@(() => _minor = !_minor)">
                <span class="wiki-edit-check @(_minor ? "on" : "")">
                    @if (_minor) { <MudIcon Icon="@Icons.Material.Filled.Check" Style="font-size:0.6875rem;color:var(--accent-on);" /> }
                </span>
                Minor edit
            </button>
            <span class="wiki-edit-delta" style="@(ByteDelta >= 0 ? "color:var(--accent);" : "color:#e57373;")">
                @(ByteDelta >= 0 ? "+" : "")@ByteDelta bytes
            </span>
            <div class="wiki-edit-savediv"></div>
            <button type="button" class="wiki-btn" @onclick="OnCancel" disabled="@_saving">Discard</button>
            <button type="button" class="wiki-edit-publish" @onclick="HandleSave" disabled="@_saving">
                <MudIcon Icon="@Icons.Material.Filled.Check" Style="font-size:0.875rem;" />
                @(_saving ? "Saving…" : "Publish changes")
            </button>
        </div>

        @if (_errorMessage is not null)
        {
            <MudAlert Severity="Severity.Error" Class="mt-2">@_errorMessage</MudAlert>
        }

        <div class="wiki-edit-foot">
            <span>Changes publish immediately and appear for everyone.</span>
            <a href="/wiki/help/general/markdown_guide" target="_blank">Formatting help</a>
        </div>
    </div>
}

@code {
    [Parameter] public required WikiArticle? Article { get; set; }

    /// <summary>Invoked after a successful save with the updated article.</summary>
    [Parameter] public EventCallback<WikiArticle> OnSaved { get; set; }

    /// <summary>Invoked when the user clicks Cancel/Discard.</summary>
    [Parameter] public EventCallback OnCancel { get; set; }

    private readonly string _taId = $"wiki-edit-ta-{Guid.NewGuid():N}";
    private bool _saving;
    private bool _showAssetPicker;
    private string? _errorMessage;
    private string _tagEntry = string.Empty;
    private string _summary = string.Empty;
    private bool _minor;
    private int _initialBytes;

    protected override void OnParametersSet()
        => _initialBytes = Article is null ? 0 : System.Text.Encoding.UTF8.GetByteCount(Article.Content);

    private int ByteDelta => Article is null
        ? 0
        : System.Text.Encoding.UTF8.GetByteCount(Article.Content) - _initialBytes;

    private async Task Wrap(string before, string after, bool block)
        => await JsRuntime.InvokeVoidAsync("SharpMUSH.Wiki.wrap", _taId, before, after, block);

    private void AddTag()
    {
        if (Article is null) return;
        var tag = _tagEntry.Trim().ToLowerInvariant();
        if (tag.Length > 0 && !Article.Tags.Contains(tag))
            Article.Tags.Add(tag);
        _tagEntry = string.Empty;
    }

    private void RemoveTag(string tag) => Article?.Tags.Remove(tag);

    private void OnTagKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter") AddTag();
    }

    private void InsertAssetMarkdown(string snippet)
    {
        if (Article is null) return;
        var separator = Article.Content.Length == 0 || Article.Content.EndsWith('\n') ? "\n" : "\n\n";
        Article.Content += $"{separator}{snippet}\n";
        _showAssetPicker = false;
    }

    private async Task HandleSave()
    {
        if (Article is null) return;
        _saving = true;
        _errorMessage = null;
        try
        {
            await OnSaved.InvokeAsync(Article);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }
}
