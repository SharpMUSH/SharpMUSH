@inject NavigationManager NavigationManager
@inject IStringLocalizer<SharedResource> Loc

<MudStack Spacing="0" Class="config-nav-drawer">
    @* Header *@
    <MudPaper Elevation="0" Class="config-nav-header pa-4">
        <MudText Typo="Typo.h6" Color="Color.Secondary">
            <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Small" /> @Loc["Configuration"]
        </MudText>
        <MudText Typo="Typo.body2" Color="Color.Default">@Loc["ServerSettings"]</MudText>
    </MudPaper>

    @* Search Box *@
    <MudPaper Elevation="0" Class="config-nav-search pa-3">
        <MudTextField @bind-Value="_searchText"
                      Placeholder="@Loc["SearchSettings"].Value"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      IconSize="Size.Small"
                      Immediate="true"
                      OnAdornmentClick="ClearSearch" />
    </MudPaper>

    @* Navigation Menu *@
    <MudPaper Elevation="0" Class="config-nav-menu">
        <MudNavMenu>
            @foreach (var group in FilteredGroups)
            {
                <MudNavGroup Title="@group.Title" Icon="@group.Icon" IconColor="Color.Secondary" Expanded="@IsGroupExpanded(group.Key)">
                    @foreach (var link in group.Links)
                    {
                        <MudNavLink Href="@link.Href" Icon="@link.Icon" Match="NavLinkMatch.All">
                            @link.Label
                        </MudNavLink>
                    }
                </MudNavGroup>
            }
        </MudNavMenu>
    </MudPaper>
</MudStack>

<style>
    .config-nav-drawer {
        height: 100%;
    }

    .config-nav-header {
        border-bottom: 1px solid var(--mud-palette-divider);
    }

    .config-nav-search {
        border-bottom: 1px solid var(--mud-palette-divider);
    }

    .config-nav-menu {
        flex: 1;
        overflow-y: auto;
        padding: 8px 0;
    }

    .change-indicator {
        margin-left: auto;
    }
</style>

@code {
    private string _searchText = string.Empty;

    private record NavLink(string Href, string Icon, string Label);
    private record NavGroupData(string Key, string Title, string Icon, NavLink[] Links);

    private static readonly NavGroupData[] AllGroups =
    [
        new("Server", "Server", Icons.Material.Filled.Computer, [
            new("/admin/config/net", Icons.Material.Filled.NetworkCheck, "Network"),
            new("/admin/config/database", Icons.Material.Filled.Storage, "Database"),
        ]),
        new("Performance", "Performance", Icons.Material.Filled.Speed, [
            new("/admin/config/limit", Icons.Material.Filled.Timer, "Limits"),
            new("/admin/config/command", Icons.Material.Filled.Terminal, "Commands"),
            new("/admin/config/function", Icons.Material.Filled.Functions, "Functions"),
        ]),
        new("Security", "Security", Icons.Material.Filled.Security, [
            new("/admin/config/sitelock", Icons.Material.Filled.Lock, "Sitelock"),
            new("/admin/config/bannednames", Icons.Material.Filled.Block, "Banned Names"),
            new("/admin/config/restrictions", Icons.Material.Filled.GppBad, "Restrictions"),
        ]),
        new("Content", "Content", Icons.Material.Filled.Article, [
            new("/admin/config/message", Icons.Material.Filled.Message, "Messages"),
            new("/admin/config/cosmetic", Icons.Material.Filled.Palette, "Cosmetic"),
            new("/admin/config/chat", Icons.Material.Filled.Chat, "Chat"),
        ]),
        new("Logs", "Logs & Files", Icons.Material.Filled.FolderOpen, [
            new("/admin/config/log", Icons.Material.Filled.Description, "Logging"),
            new("/admin/config/file", Icons.Material.Filled.Folder, "Files"),
            new("/admin/config/textfile", Icons.Material.Filled.TextSnippet, "Text Files"),
            new("/admin/config/dump", Icons.Material.Filled.Save, "Database Dumps"),
        ]),
        new("Advanced", "Advanced", Icons.Material.Filled.Tune, [
            new("/admin/config/attribute", Icons.Material.Filled.Label, "Attributes"),
            new("/admin/config/flag", Icons.Material.Filled.Flag, "Flags"),
            new("/admin/config/cost", Icons.Material.Filled.MonetizationOn, "Costs"),
            new("/admin/config/compatibility", Icons.Material.Filled.Verified, "Compatibility"),
            new("/admin/config/alias", Icons.Material.Filled.Link, "Aliases"),
            new("/admin/config/debug", Icons.Material.Filled.BugReport, "Debug"),
            new("/admin/config/warning", Icons.Material.Filled.Warning, "Warnings"),
        ]),
        new("Danger Zone", "Danger Zone", Icons.Material.Filled.Dangerous, [
            new("/admin/config/import-pennmush", Icons.Material.Filled.ImportExport, "Import PennMUSH"),
        ]),
    ];

    private IEnumerable<NavGroupData> FilteredGroups
    {
        get
        {
            if (string.IsNullOrWhiteSpace(_searchText))
                return AllGroups;

            var search = _searchText.Trim();
            return AllGroups
                .Select(g => g with { Links = g.Links.Where(l => 
                    l.Label.Contains(search, StringComparison.OrdinalIgnoreCase)).ToArray() })
                .Where(g => g.Links.Length > 0 || g.Title.Contains(search, StringComparison.OrdinalIgnoreCase));
        }
    }

    private bool IsGroupExpanded(string groupKey)
    {
        if (!string.IsNullOrWhiteSpace(_searchText))
            return true; // Expand all when filtering

        var currentPath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        return AllGroups.FirstOrDefault(g => g.Key == groupKey)?
            .Links.Any(l => currentPath.Contains(l.Href.TrimStart('/'), StringComparison.OrdinalIgnoreCase)) ?? false;
    }

    private void ClearSearch()
    {
        _searchText = string.Empty;
    }
}
