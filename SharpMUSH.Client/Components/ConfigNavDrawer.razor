@using Microsoft.AspNetCore.Components.Routing
@inject IStringLocalizer<SharedResource> Loc
@inject AdminConfigService AdminConfigService
@inject ISnackbar Snackbar
@inject IJSRuntime JS

@* Prototype AdminScreen section nav: a "Configuration" kicker + grouped section
   buttons (icon + label), active section highlighted in accent. No pop-out drawer. *@
<div class="config-nav-title">@Loc["Configuration"]</div>

<nav>
    @* Server *@
    <div class="config-nav-group-label">@Loc["Server"]</div>
    @SectionLink("/admin/config/net", Icons.Material.Filled.NetworkCheck, Loc["Network"])
    @SectionLink("/admin/config/database", Icons.Material.Filled.Storage, Loc["Database"])

    @* Performance *@
    <div class="config-nav-group-label">@Loc["Performance"]</div>
    @SectionLink("/admin/config/limit", Icons.Material.Filled.Timer, Loc["Limits"])
    @SectionLink("/admin/config/command", Icons.Material.Filled.Terminal, Loc["Commands"])

    @* Security *@
    <div class="config-nav-group-label">@Loc["Security"]</div>
    @SectionLink("/admin/config/sitelock", Icons.Material.Filled.Lock, Loc["Sitelock"])
    @SectionLink("/admin/config/bannednames", Icons.Material.Filled.Block, Loc["BannedNames"])
    @SectionLink("/admin/config/restrictions", Icons.Material.Filled.GppBad, Loc["Restrictions"])

    @* Content *@
    <div class="config-nav-group-label">@Loc["Content"]</div>
    @SectionLink("/admin/config/message", Icons.Material.Filled.Message, Loc["Messages"])
    @SectionLink("/admin/config/cosmetic", Icons.Material.Filled.Palette, Loc["Cosmetic"])
    @SectionLink("/admin/config/chat", Icons.Material.Filled.Chat, Loc["Chat"])

    @* Logs & Files *@
    <div class="config-nav-group-label">@Loc["LogsAndFiles"]</div>
    @SectionLink("/admin/config/log", Icons.Material.Filled.Description, Loc["Logging"])
    @SectionLink("/admin/config/file", Icons.Material.Filled.Folder, Loc["Files"])
    @SectionLink("/admin/config/textfile", Icons.Material.Filled.TextSnippet, Loc["TextFiles"])
    @SectionLink("/admin/config/dump", Icons.Material.Filled.Save, Loc["DatabaseDumps"])

    @* Advanced *@
    <div class="config-nav-group-label">@Loc["Advanced"]</div>
    @SectionLink("/admin/config/attribute", Icons.Material.Filled.Label, Loc["Attributes"])
    @SectionLink("/admin/config/flag", Icons.Material.Filled.Flag, Loc["Flags"])
    @SectionLink("/admin/config/cost", Icons.Material.Filled.MonetizationOn, Loc["Costs"])
    @SectionLink("/admin/config/compatibility", Icons.Material.Filled.Verified, Loc["Compatibility"])
    @SectionLink("/admin/config/alias", Icons.Material.Filled.Link, Loc["Aliases"])
    @SectionLink("/admin/config/debug", Icons.Material.Filled.BugReport, Loc["Debug"])
    @SectionLink("/admin/config/function", Icons.Material.Filled.Functions, Loc["Functions"])
    @SectionLink("/admin/config/warning", Icons.Material.Filled.Warning, Loc["Warnings"])

    @* Maintenance — global config operations, reachable from every config page *@
    <div class="config-nav-sep"></div>
    <div class="config-nav-group-label">@Loc["Maintenance"]</div>
    @SectionLink("/admin/config/import", Icons.Material.Filled.Upload, Loc["Import"])
    <button type="button" class="config-nav-link" @onclick="ExportAsync">
        <MudIcon Icon="@Icons.Material.Filled.Download" Class="config-nav-icon" />
        <span style="flex:1;text-align:left;overflow:hidden;text-overflow:ellipsis;">@Loc["Export"]</span>
    </button>
</nav>

@code {
    private RenderFragment SectionLink(string href, string icon, string label) =>
        @<NavLink class="config-nav-link" href="@href" Match="NavLinkMatch.All">
            <MudIcon Icon="@icon" Class="config-nav-icon" />
            <span style="flex:1;text-align:left;overflow:hidden;text-overflow:ellipsis;">@label</span>
        </NavLink>;

    private async Task ExportAsync()
    {
        var json = await AdminConfigService.ExportConfigAsync();
        if (json == null)
        {
            Snackbar.Add(Loc["ExportFailed"].Value, Severity.Error);
            return;
        }

        var bytes = System.Text.Encoding.UTF8.GetBytes(json);
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("eval",
            $"var a=document.createElement('a');a.href='data:application/json;base64,{base64}';a.download='sharpmush-config.json';a.click()");
        Snackbar.Add(Loc["ConfigurationExported"].Value, Severity.Success);
    }
}
