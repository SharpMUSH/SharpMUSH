@using System.Text.Json
@using SharpMUSH.Client.Models
@using SharpMUSH.Client.Services
@inject SceneService SceneService

@if (_loading)
{
    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="160px" Style="border-radius:var(--radius);" />
}
else if (_activeScenes is { Count: > 0 })
{
    var scene = _activeScenes[0];
    <MudPaper Elevation="0" Style="padding:20px;border-radius:var(--radius);border:1px solid var(--border);background:var(--surface);position:relative;overflow:hidden;height:100%;box-sizing:border-box;">
        <div style="position:absolute;top:0;right:0;bottom:0;width:4px;background:var(--accent);border-radius:0 var(--radius) var(--radius) 0;"></div>
        <div style="display:flex;align-items:flex-start;gap:12px;margin-bottom:8px;">
            <MudChip T="string" Color="Color.Success" Size="Size.Small" Style="font-size:10px;letter-spacing:0.08em;height:20px;">LIVE</MudChip>
            <MudText Typo="Typo.h6" Style="font-weight:600;line-height:1.2;">@SceneTitle(scene)</MudText>
        </div>
        <MudText Style="color:var(--text-dim);font-size:13px;margin-bottom:12px;">
            <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small" Style="vertical-align:middle;margin-right:4px;" />
            @scene.RoomName — @scene.PoseCount pose(s)
        </MudText>
        <MudButton Variant="Variant.Outlined" Size="Size.Small" Href="@($"/scenes/{scene.Id}/live")"
                   Style="border-color:var(--accent);color:var(--accent);">
            Join Scene
        </MudButton>
    </MudPaper>
}
else
{
    <MudPaper Elevation="0" Style="padding:20px;border-radius:var(--radius);border:1px solid var(--border);background:var(--surface);height:100%;box-sizing:border-box;">
        <MudText Style="color:var(--text-dim);">No active scenes right now.</MudText>
        <MudButton Variant="Variant.Text" Href="/scenes" Color="Color.Primary" Size="Size.Small" Class="mt-1">Browse archive</MudButton>
    </MudPaper>
}

@code {
    [Parameter] public JsonElement? Config { get; set; }
    [Parameter] public string Zone { get; set; } = string.Empty;

    private IReadOnlyList<SceneSummary>? _activeScenes;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _activeScenes = await SceneService.GetActiveScenesAsync();
        _loading = false;
    }

    private static string SceneTitle(SceneSummary s) =>
        s.Meta.TryGetValue("title", out var t) && !string.IsNullOrWhiteSpace(t)
            ? t
            : $"Scene in {s.RoomName}";
}
