@using System.Text.Json
@inject IStringLocalizer<SharedResource> Loc

<div class="character-gallery-widget">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="2">
        <MudIcon Icon="@Icons.Material.Filled.PhotoLibrary" Color="Color.Primary" />
        <MudText Typo="Typo.h6">@Loc["Gallery"]</MudText>
    </MudStack>

    @if (_images.Count == 0)
    {
        <MudPaper Outlined="true" Class="pa-6 d-flex flex-column align-center justify-center" Style="border-style:dashed;">
            <MudIcon Icon="@Icons.Material.Filled.AddPhotoAlternate" Size="Size.Large" Color="Color.Secondary" Class="mb-2" />
            <MudText Typo="Typo.body2" Color="Color.Secondary">@Loc["GalleryEmpty"]</MudText>
        </MudPaper>
    }
    else
    {
        <MudGrid Spacing="2">
            @foreach (var image in _images)
            {
                <MudItem xs="6" sm="4" md="3">
                    <MudImage Src="@image" Fluid="true" Class="rounded" ObjectFit="ObjectFit.Cover" />
                </MudItem>
            }
        </MudGrid>
    }
</div>

@code {
    [Parameter] public string? CharacterName { get; set; }
    [Parameter] public JsonElement? Config { get; set; }
    [Parameter] public string Zone { get; set; } = string.Empty;

    // Image-upload/storage support (IFileStorage) is a follow-up; the shell renders an empty
    // state until the gallery API is wired in.
    private readonly List<string> _images = [];
}
