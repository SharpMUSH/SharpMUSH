@using System.Text.Json
@using SharpMUSH.Client.Components.Schema
@using SharpMUSH.Client.Models.Applications
@using SharpMUSH.Client.Services
@inject SchemaAppService Schema
@inject CharacterDirectoryService Directory
@inject IStringLocalizer<SharedResource> Loc

@* The character profile is the canonical schema-driven view (Area 21): the in-game http_handler
   serves a kind:"view" Portal Schema Document at /http/profile/schema and the per-character values
   at /http/profile?objid=…, and the shared SchemaViewRenderer renders them. The portal imposes no
   game policy — sections, fields, labels, and per-viewer visibility all come from softcode. *@

<div class="character-header-widget">
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_schema is null || _data is null)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
            @Loc["ProfileUnavailable"]
        </MudAlert>
    }
    else
    {
        <MudText Typo="Typo.h4" Class="mb-1">@(_resolvedName ?? CharacterName)</MudText>
        @if (!string.IsNullOrEmpty(_dbref))
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-4">@_dbref</MudText>
        }

        <SchemaViewRenderer Document="_schema" Data="_data" />
    }
</div>

@code {
    /// <summary>Character whose profile to render. Falls back to the <c>character</c> key in <see cref="Config"/>.</summary>
    [Parameter] public string? CharacterName { get; set; }

    [Parameter] public JsonElement? Config { get; set; }
    [Parameter] public string Zone { get; set; } = string.Empty;

    private PortalSchemaDocument? _schema;
    private SchemaData? _data;
    private bool _loading = true;
    private string? _resolvedName;
    private string? _dbref;

    protected override async Task OnParametersSetAsync()
    {
        var name = CharacterName ?? ConfigCharacter();
        if (string.IsNullOrWhiteSpace(name) || name == _resolvedName)
        {
            return;
        }

        _resolvedName = name;
        _loading = true;

        // Profiles are addressed by objid (stable across renames); the directory resolves the
        // page's name-based route to the objid. The dbref shown is the objid's leading "#N".
        var objid = await Directory.ResolveObjidAsync(name);
        _dbref = objid is null ? null : objid.Split(':', 2)[0];
        _schema = await Schema.GetSchemaAsync("http/profile/schema");
        _data = objid is null
            ? null
            : await Schema.GetDataAsync($"http/profile?objid={Uri.EscapeDataString(objid)}");
        _loading = false;
    }

    private string? ConfigCharacter()
    {
        if (Config is { } cfg && cfg.ValueKind == JsonValueKind.Object
            && cfg.TryGetProperty("character", out var prop) && prop.ValueKind == JsonValueKind.String)
        {
            return prop.GetString();
        }
        return null;
    }
}
