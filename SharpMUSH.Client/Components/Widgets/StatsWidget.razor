@using System.Text.Json
@using SharpMUSH.Client.Models
@using SharpMUSH.Client.Services
@inject CharacterDirectoryService CharacterDirectory
@inject WikiService WikiService
@inject SceneService SceneService

<MudGrid Spacing="3">
    @foreach (var tile in Tiles)
    {
        <MudItem xs="6" sm="3">
            <MudPaper Elevation="0" Style="padding:20px;border-radius:var(--radius);border:1px solid var(--border);background:var(--surface);">
                <MudText Style="font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-faint);font-family:'JetBrains Mono',monospace;">@tile.Label</MudText>
                <MudText Style="font-size:28px;font-weight:700;color:var(--accent);line-height:1.2;margin-top:4px;">@tile.Value</MudText>
            </MudPaper>
        </MudItem>
    }
</MudGrid>

@code {
    [Parameter] public JsonElement? Config { get; set; }
    [Parameter] public string Zone { get; set; } = string.Empty;

    private int? _recent;
    private int? _characters;
    private int? _activeScenes;

    private (string Label, string Value)[] Tiles =>
    [
        ("Players Online", _characters?.ToString() ?? "—"),
        ("Active Scenes",  _activeScenes?.ToString() ?? "—"),
        ("Recent Changes", _recent?.ToString() ?? "—"),
        ("Characters",     _characters?.ToString() ?? "—"),
    ];

    protected override async Task OnInitializedAsync()
    {
        var recentTask = WikiService.GetRecentChangesAsync(10);
        var charsTask = CharacterDirectory.ListAsync();
        var scenesTask = SceneService.GetActiveScenesAsync();
        await Task.WhenAll(recentTask.AsTask(), charsTask, scenesTask.AsTask());

        _recent = (await recentTask).Count;
        _characters = (await charsTask).Count;
        _activeScenes = (await scenesTask).Count;
    }
}
