@using SharpMUSH.Client.Services
@inject CharacterDirectoryService Directory
@inject IStringLocalizer<SharedResource> Loc

<div>
    <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
        <MudTextField @bind-Value="_search" Immediate="true"
                      Placeholder="@Loc["SearchCharacters"]"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Variant="Variant.Outlined" Margin="Margin.Dense"
                      Style="max-width:320px;" />
        @if (!_loading)
        {
            <MudText Style="color:var(--text-faint);font-size:0.8125rem;">@Filtered.Count found</MudText>
        }
    </div>

    @if (!_loading && _categories.Count > 1)
    {
        <div style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-bottom:1.25rem;">
            <MudChip T="string" Variant="@(_selectedCategory is null ? Variant.Filled : Variant.Outlined)"
                     Color="@(_selectedCategory is null ? Color.Primary : Color.Default)"
                     Size="Size.Small" OnClick="() => _selectedCategory = null"
                     Style="border-radius:var(--radius);">
                All
            </MudChip>
            @foreach (var cat in _categories)
            {
                var c = cat;
                <MudChip T="string" Variant="@(_selectedCategory == c ? Variant.Filled : Variant.Outlined)"
                         Color="@(_selectedCategory == c ? Color.Primary : Color.Default)"
                         Size="Size.Small" OnClick="() => _selectedCategory = c"
                         Style="border-radius:var(--radius);">
                    @(c.Length == 0 ? "Other" : c)
                </MudChip>
            }
        </div>
    }

    @if (_loading)
    {
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:0.875rem;">
            @for (var i = 0; i < 8; i++)
            {
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="80px" Style="border-radius:var(--radius);" />
            }
        </div>
    }
    else if (Filtered.Count == 0)
    {
        <EmptyState>@Loc["NoCharactersFound"]</EmptyState>
    }
    else
    {
        @foreach (var group in Grouped)
        {
            @if (_selectedCategory is null && _categories.Count > 1)
            {
                <MudText Style="font-size:0.6875rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--accent);font-family:'JetBrains Mono',monospace;margin-bottom:0.625rem;margin-top:0.5rem;">
                    @(group.Key.Length == 0 ? "Other" : group.Key)
                </MudText>
            }

            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:0.75rem;margin-bottom:1.25rem;">
                @foreach (var character in group)
                {
                    var hue = Math.Abs(character.Name.GetHashCode()) % 360;
                    <MudLink Href="@($"/character/{Uri.EscapeDataString(character.Name)}")"
                             Underline="Underline.None" Style="display:block;">
                        <MudPaper Elevation="0"
                                  Style="display:flex;align-items:center;gap:0.875rem;padding:0.875rem 1rem;border-radius:var(--radius);border:1px solid var(--border);background:var(--surface);transition:border-color 0.12s,background 0.12s;cursor:pointer;"
                                  Class="char-card">
                            <div style="position:relative;flex-shrink:0;">
                                <MudAvatar Style="@($"background:hsl({hue},50%,30%);color:#fff;font-weight:600;font-size:0.9375rem;width:40px;height:40px;")">
                                    @character.Name[0].ToString().ToUpper()
                                </MudAvatar>
                            </div>
                            <div style="min-width:0;">
                                <MudText Style="font-size:0.875rem;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@character.Name</MudText>
                                <MudText Style="font-size:0.6875rem;color:var(--text-faint);font-family:'JetBrains Mono',monospace;">@character.Dbref</MudText>
                            </div>
                        </MudPaper>
                    </MudLink>
                }
            </div>
        }
    }
</div>

@code {
    [Parameter] public System.Text.Json.JsonElement? Config { get; set; }
    [Parameter] public string Zone { get; set; } = string.Empty;

    private IReadOnlyList<CharacterDirectoryService.CharacterSummary> _all = [];
    private bool _loading = true;
    private string _search = string.Empty;
    private string? _selectedCategory;
    private List<string> _categories = [];

    private IReadOnlyList<CharacterDirectoryService.CharacterSummary> Filtered
    {
        get
        {
            var results = _all.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(_search))
                results = results.Where(c => c.Name.Contains(_search, StringComparison.OrdinalIgnoreCase));
            if (_selectedCategory is not null)
                results = results.Where(c => (c.Category?.Trim() ?? string.Empty) == _selectedCategory);
            return results.ToList();
        }
    }

    private IEnumerable<IGrouping<string, CharacterDirectoryService.CharacterSummary>> Grouped =>
        Filtered.GroupBy(c => c.Category?.Trim() ?? string.Empty)
            .OrderBy(g => g.Key.Length == 0 ? 1 : 0)
            .ThenBy(g => g.Key, StringComparer.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        _all = await Directory.ListAsync();
        _categories = _all
            .Select(c => c.Category?.Trim() ?? string.Empty)
            .Distinct()
            .OrderBy(c => c.Length == 0 ? 1 : 0)
            .ThenBy(c => c, StringComparer.OrdinalIgnoreCase)
            .ToList();
        _loading = false;
    }
}
