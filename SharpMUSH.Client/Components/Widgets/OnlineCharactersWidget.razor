@using System.Text.Json
@using SharpMUSH.Client.Services
@inject CharacterDirectoryService CharacterDirectory

<MudPaper Elevation="0" Style="padding:1.25rem;border-radius:var(--radius);border:1px solid var(--border);background:var(--surface);height:100%;box-sizing:border-box;">
    <MudText Style="font-size:0.6875rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-faint);font-family:'JetBrains Mono',monospace;margin-bottom:0.75rem;">Characters</MudText>
    @if (_loading)
    {
        @for (var i = 0; i < 4; i++) { <MudSkeleton Height="32px" Class="mb-1" /> }
    }
    else if (_characters is { Count: > 0 })
    {
        @foreach (var c in _characters.Take(8))
        {
            <div style="display:flex;align-items:center;gap:0.625rem;padding:0.3125rem 0;border-bottom:1px solid var(--border-soft);">
                <div style="position:relative;">
                    <MudAvatar Size="Size.Small" Style="@($"background:hsl({Math.Abs(c.Name.GetHashCode()) % 360},55%,35%);font-size:0.6875rem;width:28px;height:28px;")">
                        @c.Name[0].ToString().ToUpper()
                    </MudAvatar>
                    <span style="position:absolute;bottom:-1px;right:-1px;width:8px;height:8px;border-radius:50%;background:var(--text-faint);border:2px solid var(--surface);"></span>
                </div>
                <MudLink Href="@($"/characters/{c.Objid}")" Style="color:var(--text);font-size:0.8125rem;">@c.Name</MudLink>
            </div>
        }
        @if (_characters.Count > 8)
        {
            <MudButton Variant="Variant.Text" Href="/characters" Size="Size.Small" Color="Color.Primary" Class="mt-1">
                View all @_characters.Count →
            </MudButton>
        }
    }
    else
    {
        <MudText Style="color:var(--text-faint);font-size:0.8125rem;">No characters found.</MudText>
    }
</MudPaper>

@code {
    [Parameter] public JsonElement? Config { get; set; }
    [Parameter] public string Zone { get; set; } = string.Empty;

    private IReadOnlyList<CharacterDirectoryService.CharacterSummary>? _characters;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _characters = await CharacterDirectory.ListAsync();
        _loading = false;
    }
}
