@using System.Globalization
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@inject IStringLocalizer<SharedResource> Loc

<MudMenu Icon="@Icons.Material.Filled.Language" Color="Color.Inherit" Dense="true" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
    @foreach (var lang in _languages)
    {
        <MudMenuItem OnClick="@(() => SetLanguageAsync(lang.Code))">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudText>@lang.Flag</MudText>
                <MudText Typo="Typo.body2">@lang.DisplayName</MudText>
                @if (lang.Code == _currentLocale)
                {
                    <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Secondary" />
                }
            </MudStack>
        </MudMenuItem>
    }
</MudMenu>

@code {
    private string _currentLocale = "en";

    private readonly record struct LanguageOption(string Code, string DisplayName, string Flag);

    /// <summary>
    /// Supported locale codes and their flag emoji. Display names are derived
    /// automatically from <see cref="CultureInfo.NativeName"/>.
    /// To add a new language, add its code and flag here — the display name
    /// is resolved from the framework.
    /// </summary>
    private static readonly (string Code, string Flag)[] SupportedLocales =
    [
        ("en", "\U0001F1FA\U0001F1F8"),
        ("fr", "\U0001F1EB\U0001F1F7")
    ];

    private static readonly LanguageOption[] _languages = SupportedLocales
        .Select(l =>
        {
            var culture = CultureInfo.GetCultureInfo(l.Code);
            // NativeName gives the language name in its own language (e.g. "français" for "fr").
            // Capitalize the first character for display.
            var name = culture.NativeName;
            if (name.Length > 0 && char.IsLower(name[0]))
                name = char.ToUpper(name[0], culture) + name[1..];
            return new LanguageOption(l.Code, name, l.Flag);
        })
        .ToArray();

    protected override async Task OnInitializedAsync()
    {
        var stored = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", "locale");
        _currentLocale = stored ?? "en";
    }

    private async Task SetLanguageAsync(string locale)
    {
        if (locale == _currentLocale) return;

        _currentLocale = locale;
        await JSRuntime.InvokeVoidAsync("localStorage.setItem", "locale", locale);

        // Reload the app to apply new culture (Blazor WASM requires restart for culture change)
        NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
    }
}
