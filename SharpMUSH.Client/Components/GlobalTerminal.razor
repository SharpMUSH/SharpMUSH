@using SharpMUSH.Client.Models
@using SharpMUSH.Client.Services
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.WebAssembly.Hosting
@using Microsoft.JSInterop
@inject ITerminalService DefaultTerminal
@inject IJSRuntime JsRuntime
@inject CredentialService Credentials
@inject OttAuthService OttAuth
@inject AccountAuthService AccountAuth
@inject IWebAssemblyHostEnvironment HostEnv
@implements IAsyncDisposable

<div class="sharp-terminal-container" style="background:var(--surface-3);color:var(--text);font-family:var(--font-mono);font-size:13.5px;">

    @* Output area *@
    <div id="@_outputId"
         style="flex:1;min-height:0;overflow-y:auto;padding:12px 16px;white-space:pre-wrap;word-break:break-word;line-height:1.6;">
        @foreach (var line in _displayLines)
        {
            <div class="@GetLineClass(line.Source)" title="@line.Timestamp.ToString("HH:mm:ss")">@((Microsoft.AspNetCore.Components.MarkupString)line.Html)</div>
        }
        <div id="@_bottomId"></div>
    </div>

    @* Connection bar *@
    <div class="sharp-terminal-connbar">
        <MudChip T="string"
                 Size="Size.Small"
                 Color="@(_connected ? Color.Success : Color.Error)"
                 Style="min-width:90px;justify-content:center;">
            @(_connected ? "Connected" : "Disconnected")
        </MudChip>

        @if (!_connected)
        {
            <MudTextField @bind-Value="_serverUri"
                          Placeholder="ws://localhost:4202/ws"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Style="flex:1;font-size:12px;"
                          OnKeyDown="OnUriKeyDown" />
            <MudIconButton Icon="@Icons.Material.Filled.Settings" Size="Size.Small"
                           title="Login settings"
                           OnClick="ToggleLoginPanel" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                       OnClick="ConnectAsync">Connect</MudButton>
        }
        else
        {
            <MudText Typo="Typo.caption" Style="color:#888;flex:1;">
                @(_playerName ?? "not logged in")
            </MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small"
                       OnClick="DisconnectAsync">Disconnect</MudButton>
        }
    </div>

    @* Collapsible login settings panel *@
    @if (_showLoginPanel && !_connected)
    {
        <div style="padding:6px 10px;background:var(--surface);border-top:1px solid var(--border-soft);">
            @if (_showCharacterPicker)
            {
                @* Account flow — character picker *@
                <CharacterPicker ServerUri="@_serverUri"
                                 OnConnected="OnCharacterPickerConnected"
                                 OnCancelled="OnCharacterPickerCancelled" />
            }
            else
            {
                <MudTabs Rounded="false" MinimumTabWidth="100px" Style="font-size:12px;">
                    @* ── Character tab (existing OTT flow) ── *@
                    <MudTabPanel Text="Character">
                        <div style="display:flex;flex-direction:column;gap:6px;padding-top:4px;">
                            <MudText Typo="Typo.caption" Style="color:#888;">
                                Player name is saved; password is sent once via HTTPS and never stored.
                            </MudText>
                            <div style="display:flex;gap:8px;align-items:flex-end;">
                                <MudTextField @bind-Value="_loginPlayer"
                                              Label="Player name"
                                              Variant="Variant.Outlined" Margin="Margin.Dense"
                                              Style="flex:1;font-size:12px;" />
                                <MudTextField @bind-Value="_loginPassword"
                                              Label="Password (not stored)"
                                              InputType="InputType.Password"
                                              Variant="Variant.Outlined" Margin="Margin.Dense"
                                              Style="flex:1;font-size:12px;" />
                                <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small"
                                           OnClick="SaveCredentialsAsync">Save name</MudButton>
                                <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small"
                                           OnClick="ClearCredentialsAsync">Clear</MudButton>
                            </div>
                        </div>
                    </MudTabPanel>

                    @* ── Account tab ── *@
                    <MudTabPanel Text="Account">
                        @if (!_showAccountRegister)
                        {
                            <div style="display:flex;flex-direction:column;gap:6px;padding-top:4px;">
                                <MudText Typo="Typo.caption" Style="color:#888;">
                                    Login with your SharpMUSH account to choose a character.
                                </MudText>
                                <div style="display:flex;gap:8px;align-items:flex-end;">
                                    <MudTextField @bind-Value="_accountIdentifier"
                                                  Label="Account name or email"
                                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                                  Style="flex:1;font-size:12px;" />
                                    <MudTextField @bind-Value="_accountPassword"
                                                  Label="Password (not stored)"
                                                  InputType="InputType.Password"
                                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                                  Style="flex:1;font-size:12px;" />
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                               Disabled="_accountBusy"
                                               OnClick="AccountLoginAsync">Login</MudButton>
                                </div>
                                @if (_accountError is not null)
                                {
                                    <MudText Color="Color.Error" Typo="Typo.caption">@_accountError</MudText>
                                }
                                <MudButton Variant="Variant.Text" Size="Size.Small"
                                           OnClick="() => _showAccountRegister = true">
                                    No account? Register →
                                </MudButton>
                            </div>
                        }
                        else
                        {
                            <div style="display:flex;flex-direction:column;gap:6px;padding-top:4px;">
                                <MudText Typo="Typo.caption" Style="color:#888;">
                                    Create a new account. Email is optional.
                                </MudText>
                                <div style="display:flex;gap:8px;align-items:flex-end;flex-wrap:wrap;">
                                    <MudTextField @bind-Value="_regUsername"
                                                  Label="Account name (required)"
                                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                                  Style="flex:1;min-width:140px;font-size:12px;" />
                                    <MudTextField @bind-Value="_regEmail"
                                                  Label="Email (optional)"
                                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                                  Style="flex:1;min-width:140px;font-size:12px;" />
                                    <MudTextField @bind-Value="_regPassword"
                                                  Label="Password"
                                                  InputType="InputType.Password"
                                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                                  Style="flex:1;min-width:140px;font-size:12px;" />
                                    <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small"
                                               Disabled="_accountBusy"
                                               OnClick="AccountRegisterAsync">Register</MudButton>
                                </div>
                                @if (_accountError is not null)
                                {
                                    <MudText Color="Color.Error" Typo="Typo.caption">@_accountError</MudText>
                                }
                                <MudButton Variant="Variant.Text" Size="Size.Small"
                                           OnClick="() => _showAccountRegister = false">← Back to login</MudButton>
                            </div>
                        }
                    </MudTabPanel>
                </MudTabs>
            }
        </div>
    }

    @* Input bar — prototype MushTerminal form: accent caret + bare input + send *@
    <div class="sharp-terminal-input">
        <span class="term-prompt">›</span>
        <input class="term-input"
               value="@_input"
               @oninput="@(e => _input = e.Value?.ToString() ?? string.Empty)"
               @onkeydown="OnInputKeyDown"
               disabled="@(!_connected)"
               placeholder="say hello   ·   pose waves   ·   look   ·   who" />
        <button type="button" class="term-send" @onclick="SendAsync" disabled="@(!_connected)" title="Send">
            <MudIcon Icon="@Icons.Material.Filled.Send" Style="font-size:14px;" />
        </button>
        <button type="button" class="term-clear" @onclick="ClearAsync" title="Clear terminal">
            <MudIcon Icon="@Icons.Material.Filled.ClearAll" Style="font-size:15px;" />
        </button>
    </div>
</div>

@code {
    [Parameter] public string DefaultServerUri { get; set; } = "ws://localhost:4202/ws";

    /// <summary>
    /// Optional terminal service to drive this instance. When null, the injected command terminal
    /// (<c>ITerminalService</c>) is used. The /play page passes its own <c>IPlayTerminalService</c>
    /// so the player session is a separate connection from the command/softcode terminal.
    /// </summary>
    [Parameter] public ITerminalService? TerminalOverride { get; set; }

    /// <summary>
    /// Whether this terminal shows the connection/auto-login <c>[DBG]</c> diagnostic lines.
    /// These are useful on the command terminal while developing the auto-connect flow but
    /// are noise on the player-facing /play terminal, so it opts out. Diagnostics are
    /// additionally gated to the Development environment so production stays clean.
    /// </summary>
    [Parameter] public bool ShowDiagnostics { get; set; } = true;

    private ITerminalService Terminal => TerminalOverride ?? DefaultTerminal;

    /// <summary>Writes a diagnostic line only when this terminal opted in and we are in dev.</summary>
    private void DebugLine(string text)
    {
        if (ShowDiagnostics && HostEnv.IsDevelopment())
            AddLocalLine(text, TerminalLineSource.System);
    }

    // Unique IDs per instance so multiple terminals on the same page don't conflict
    private readonly string _outputId = $"sharp-terminal-output-{Guid.NewGuid():N}";
    private readonly string _bottomId = $"sharp-terminal-bottom-{Guid.NewGuid():N}";

    private string _serverUri = string.Empty;
    private string _input = string.Empty;
    private bool _connected;
    private bool _showLoginPanel;
    private string? _loginPlayer;
    private string? _loginPassword;
    private string? _playerName;
    private readonly List<TerminalLine> _displayLines = [];
    private bool _autoScroll = true;

    // Account tab state
    private string _accountIdentifier = string.Empty;
    private string _accountPassword = string.Empty;
    private bool _showAccountRegister;
    private string _regUsername = string.Empty;
    private string _regEmail = string.Empty;
    private string _regPassword = string.Empty;
    private bool _accountBusy;
    private string? _accountError;
    private bool _showCharacterPicker;

    private DotNetObjectReference<GlobalTerminal>? _selfRef;
    private IJSObjectReference? _cmdLinkHandle;

    protected override async Task OnInitializedAsync()
    {
        _serverUri = DefaultServerUri;
        _connected = Terminal.IsConnected;

        // Populate from existing buffer
        _displayLines.AddRange(Terminal.Lines);

        Terminal.LineReceived += OnLineReceived;
        Terminal.ConnectionStateChanged += OnConnectionChanged;

        // Restore player name from the shared terminal service (survives component re-mounts)
        _playerName = Terminal.ConnectedPlayerName;

        // Load saved credentials
        var (savedPlayer, savedPassword, savedUri) = await Credentials.LoadAsync();
        _loginPlayer = savedPlayer;
        _loginPassword = savedPassword;
        if (!string.IsNullOrWhiteSpace(savedUri))
            _serverUri = savedUri;

        // Restore account session (sessionStorage is tab-scoped)
        await AccountAuth.InitAsync();
        if (!string.IsNullOrWhiteSpace(AccountAuth.Username))
            _accountIdentifier = AccountAuth.Username;

        // If already connected and player name is unknown, try to fill from account
        if (_connected && _playerName is null && AccountAuth.Characters.Count > 0)
            _playerName = AccountAuth.Characters[0].Name;

        DebugLine($"[DBG] init: connected={_connected} isLoggedIn={AccountAuth.IsLoggedIn}");

        if (!_connected)
        {
            if (HostEnv.IsDevelopment() && !AccountAuth.IsLoggedIn)
            {
                // In dev, the Blazor AuthStateProvider hasn't necessarily run yet, so
                // AccountAuth.IsLoggedIn may still be false.  Call GetDebugOttAsync()
                // directly — it both populates AccountSessionToken and returns the OTT
                // in one round-trip, avoiding any ordering dependency.
                DebugLine("[DBG] dev path: fetching debug OTT");
                var debugOtt = await AccountAuth.GetDebugOttAsync();
                DebugLine($"[DBG] dev path: ott={(debugOtt?.Token is null ? "NULL" : "OK")} account={(debugOtt?.AccountId is null ? "NULL" : "OK")}");
                if (debugOtt?.Token is not null)
                {
                    SetPlayerName(debugOtt.PlayerName);
                    await Terminal.ConnectWithOttAsync(_serverUri, debugOtt.Token);
                }
            }
            else if (AccountAuth.IsLoggedIn)
            {
                // Normal account path (production, or dev after a real login)
                DebugLine("[DBG] account path entered");
                var chars = AccountAuth.Characters.Count > 0
                    ? AccountAuth.Characters
                    : await AccountAuth.GetCharactersAsync();

                DebugLine($"[DBG] account path: chars={chars.Count}");
                if (chars.Count == 1)
                {
                    // Single character — auto-connect silently
                    var ott = await AccountAuth.GetOttForCharacterAsync(chars[0]);
                    DebugLine($"[DBG] account path: ott={(ott is null ? "NULL" : "OK")}");
                    if (ott is not null)
                    {
                        SetPlayerName(chars[0].Name);
                        await Terminal.ConnectWithOttAsync(_serverUri, ott);
                    }
                }
                else if (chars.Count > 1)
                {
                    // Multiple characters — show picker
                    _showLoginPanel = true;
                    _showCharacterPicker = true;
                }
            }
        }

        DebugLine($"[DBG] init done: connected={Terminal.IsConnected} isLoggedIn={AccountAuth.IsLoggedIn}");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
            try
            {
                _cmdLinkHandle = await JsRuntime.InvokeAsync<IJSObjectReference>(
                    "SharpMUSH.Terminal.attachCommandLinks", _outputId, _selfRef);
            }
            catch (JSException) { /* ignore if JS not ready */ }
        }

        if (_autoScroll)
            await ScrollToBottomAsync();
    }

    /// <summary>
    /// Invoked from JS when a command link (&lt;a xch_cmd="..."&gt;) is clicked in the
    /// terminal output. Sends the command exactly as if the player had typed it.
    /// </summary>
    [JSInvokable]
    public async Task RunCommandLinkAsync(string command)
    {
        if (string.IsNullOrWhiteSpace(command) || !_connected) return;
        await Terminal.SendAsync(command);
    }

    // ── Account login / register ─────────────────────────────────────────────

    private async Task AccountLoginAsync()
    {
        _accountError = null;
        _accountBusy = true;
        StateHasChanged();

        var (success, error, _) = await AccountAuth.LoginAsync(_accountIdentifier, _accountPassword);
        _accountBusy = false;

        if (!success)
        {
            _accountError = error ?? "Login failed.";
            StateHasChanged();
            return;
        }

        _accountPassword = string.Empty;
        _showCharacterPicker = true;
        StateHasChanged();
    }

    private async Task AccountRegisterAsync()
    {
        _accountError = null;
        _accountBusy = true;
        StateHasChanged();

        var (success, error, _) = await AccountAuth.RegisterAsync(_regUsername, _regEmail, _regPassword);
        _accountBusy = false;

        if (!success)
        {
            _accountError = error ?? "Registration failed.";
            StateHasChanged();
            return;
        }

        _regPassword = string.Empty;
        _showCharacterPicker = true;
        StateHasChanged();
    }

    private void SetPlayerName(string? name)
    {
        _playerName = name;
        Terminal.ConnectedPlayerName = name;
    }

    private Task OnCharacterPickerConnected()
    {
        // CharacterPicker handles connection; grab name from terminal service
        _playerName = Terminal.ConnectedPlayerName;
        _showLoginPanel = false;
        _showCharacterPicker = false;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task OnCharacterPickerCancelled()
    {
        _showCharacterPicker = false;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task ConnectAsync()
    {
        try
        {
            if (!string.IsNullOrWhiteSpace(_loginPlayer) && !string.IsNullOrWhiteSpace(_loginPassword))
            {
                // Use OTT flow: credentials go to API over HTTPS, WS only receives a token
                SetPlayerName(_loginPlayer);
                await Terminal.ConnectAndLoginAsync(_serverUri, _loginPlayer, _loginPassword, OttAuth);
            }
            else
            {
                // No credentials saved — just open the socket; user can type connect manually
                await Terminal.ConnectAsync(_serverUri);
            }
        }
        catch (Exception ex) { AddLocalLine($"[Error] {ex.Message}", TerminalLineSource.System); }
    }

    private async Task DisconnectAsync()
    {
        SetPlayerName(null);
        await Terminal.DisconnectAsync();
    }

    private async Task SendAsync()
    {
        if (string.IsNullOrWhiteSpace(_input) || !_connected) return;

        // Track player name when a manual 'connect <name> ...' is typed
        var trimmed = _input.Trim();
        if (trimmed.StartsWith("connect ", StringComparison.OrdinalIgnoreCase))
        {
            var parts = trimmed.Split(' ', 3, StringSplitOptions.RemoveEmptyEntries);
            if (parts.Length >= 2 && !string.Equals(parts[1], "token", StringComparison.OrdinalIgnoreCase))
                SetPlayerName(parts[1]);
        }

        await Terminal.SendAsync(_input);
        _input = string.Empty;
    }

    private Task ClearAsync()
    {
        _displayLines.Clear();
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void ToggleLoginPanel()
    {
        _showLoginPanel = !_showLoginPanel;
        StateHasChanged();
    }

    private async Task SaveCredentialsAsync()
    {
        // Password is deliberately not saved — it's sent once via HTTPS to get an OTT
        await Credentials.SaveAsync(_loginPlayer, null, _serverUri);
        _showLoginPanel = false;
        AddLocalLine("[System] Player name saved. Password is not stored.", TerminalLineSource.System);
        StateHasChanged();
    }

    private async Task ClearCredentialsAsync()
    {
        await Credentials.ClearAsync();
        _loginPlayer = null;
        _loginPassword = null;
        AddLocalLine("[System] Credentials cleared.", TerminalLineSource.System);
        StateHasChanged();
    }

    private async Task OnInputKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SendAsync();
    }

    private async Task OnUriKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await ConnectAsync();
    }

    private void OnLineReceived(TerminalLine line)
    {
        _displayLines.Add(line);
        if (_displayLines.Count > 2000) _displayLines.RemoveAt(0);
        InvokeAsync(StateHasChanged);
    }

    private void OnConnectionChanged(bool connected)
    {
        _connected = connected;
        if (!connected) SetPlayerName(null);
        InvokeAsync(StateHasChanged);
    }

    private void AddLocalLine(string text, TerminalLineSource source)
    {
        _displayLines.Add(new TerminalLine(DateTime.Now, text, source));
        StateHasChanged();
    }

    private async Task ScrollToBottomAsync()
    {
        try { await JsRuntime.InvokeVoidAsync("SharpMUSH.Terminal.scrollToBottom", _outputId); }
        catch { /* ignore if JS not ready */ }
    }

    private static string GetLineClass(TerminalLineSource source) => source switch
    {
        TerminalLineSource.Client => "terminal-line terminal-sent",
        TerminalLineSource.System => "terminal-line terminal-system",
        _ => "terminal-line"
    };

    public async ValueTask DisposeAsync()
    {
        Terminal.LineReceived -= OnLineReceived;
        Terminal.ConnectionStateChanged -= OnConnectionChanged;

        if (_cmdLinkHandle is not null)
        {
            try { await _cmdLinkHandle.InvokeVoidAsync("dispose"); }
            catch (Exception ex) when (ex is JSException or ObjectDisposedException) { /* ignore during teardown */ }
            try { await _cmdLinkHandle.DisposeAsync(); }
            catch (Exception ex) when (ex is JSException or ObjectDisposedException) { /* ignore during teardown */ }
        }
        _selfRef?.Dispose();
    }
}
