@page "/softcode"
@using BlazorMonaco
@using BlazorMonaco.Editor
@using SharpMUSH.Client.Components
@using SharpMUSH.Client.Models
@using SharpMUSH.Client.Services
@inject ITerminalService Terminal
@inject MushQueryService QueryService
@inject IJSRuntime JsRuntime
@inject IStringLocalizer<SharedResource> Loc
@implements IAsyncDisposable

<PageTitle>Softcode Editor — SharpMUSH</PageTitle>

@* Three-pane layout. IMPORTANT: no CSS transition on widths — Chrome freezes when
   transitioning between px and 1fr. Collapse is an instant class swap. *@
<div class="sc-shell">

    @* ── Pane 1: Objects ─────────────────────────────────────────── *@
    <div class="sc-panel" style="@($"width:{(_objCollapsed ? "46px" : "220px")};flex-shrink:0;background:var(--surface);")">
        @* Pane header *@
        <div style="display:flex;align-items:center;padding:8px 8px 6px;border-bottom:1px solid var(--border-soft);gap:6px;flex-shrink:0;">
            @if (!_objCollapsed)
            {
                <MudText Class="section-kicker" Style="flex:1;">Objects</MudText>
                <MudTooltip Text="Create Thing">
                    <MudIconButton Icon="@Icons.Material.Filled.Inventory2" Size="Size.Small" OnClick="@(() => ShowCreateObjectDialog(MushObjectType.Thing))" />
                </MudTooltip>
                <MudTooltip Text="Create Room">
                    <MudIconButton Icon="@Icons.Material.Filled.MeetingRoom" Size="Size.Small" OnClick="@(() => ShowCreateObjectDialog(MushObjectType.Room))" />
                </MudTooltip>
            }
            <MudIconButton Icon="@(_objCollapsed ? Icons.Material.Filled.ChevronRight : Icons.Material.Filled.ChevronLeft)"
                           Size="Size.Small" OnClick="@(() => _objCollapsed = !_objCollapsed)"
                           title="@(_objCollapsed ? "Expand objects" : "Collapse objects")" />
        </div>

        @if (_objCollapsed)
        {
            @* Rail: show active dbref or icon *@
            <div style="display:flex;flex-direction:column;align-items:center;padding:10px 0;gap:8px;">
                <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="Size.Small" Color="Color.Primary" />
                @if (_selectedObject is not null)
                {
                    <MudText Style="font-size:10px;font-family:'JetBrains Mono',monospace;color:var(--accent);writing-mode:vertical-rl;text-orientation:mixed;">
                        #@_selectedObject.Dbref
                    </MudText>
                }
            </div>
        }
        else
        {
            <div style="flex:1;overflow:hidden;padding:4px;">
                <ObjectBrowser @ref="_objectBrowser" OnObjectSelected="OnObjectSelected" />
            </div>

            @if (_createObjectType.HasValue)
            {
                <div style="padding:6px 8px;background:var(--surface);border-top:1px solid var(--border);display:flex;gap:4px;align-items:center;flex-shrink:0;">
                    <MudText Style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--accent);white-space:nowrap;">
                        @(_createObjectType switch { MushObjectType.Room => "@dig", MushObjectType.Exit => "@open", _ => "@create" })
                    </MudText>
                    <MudTextField @bind-Value="_createObjectName" Placeholder="name"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Style="flex:1;font-size:12px;" OnKeyDown="OnCreateObjectKeyDown" />
                    <MudIconButton Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Success" OnClick="ExecuteCreateObjectAsync" />
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="CancelCreateObject" />
                </div>
            }
        }
    </div>

    @* ── Pane 2: Attributes ───────────────────────────────────────── *@
    <div class="sc-panel" style="@($"width:{(_attrCollapsed ? "46px" : "248px")};flex-shrink:0;background:var(--surface);")">
        @* Pane header *@
        <div style="display:flex;align-items:center;padding:10px 10px 6px;gap:6px;flex-shrink:0;">
            @if (!_attrCollapsed)
            {
                <MudText Class="section-kicker" Style="flex:1;display:flex;align-items:center;gap:6px;">
                    <span>Attributes</span>
                    @if (_selectedObject is not null)
                    {
                        <span style="color:var(--accent);">· #@(_selectedObject?.Dbref)</span>
                    }
                </MudText>
                <button type="button" class="sc-add-btn" @onclick="ShowCreateAttr"
                        disabled="@(_selectedObject is null)" title="Add attribute">
                    <MudIcon Icon="@Icons.Material.Filled.Add" Style="font-size:13px;" /> Add
                </button>
            }
            <MudIconButton Icon="@(_attrCollapsed ? Icons.Material.Filled.ChevronRight : Icons.Material.Filled.ChevronLeft)"
                           Size="Size.Small" OnClick="@(() => _attrCollapsed = !_attrCollapsed)"
                           title="@(_attrCollapsed ? "Expand attributes" : "Collapse attributes")" />
        </div>

        @if (_attrCollapsed)
        {
            <div style="display:flex;flex-direction:column;align-items:center;padding:10px 0;gap:8px;">
                <MudIcon Icon="@Icons.Material.Filled.Code" Size="Size.Small" Color="Color.Primary" />
                @if (ActiveTab is not null)
                {
                    <MudText Style="font-size:10px;font-family:'JetBrains Mono',monospace;color:var(--accent);writing-mode:vertical-rl;text-orientation:mixed;">
                        &amp;@ActiveTab.Attr.Name
                    </MudText>
                }
            </div>
        }
        else
        {
            @* Search — prototype searchBox: clean inline input, no Material chrome *@
            <div class="sc-search">
                <MudIcon Icon="@Icons.Material.Filled.Search" Style="font-size:14px;color:var(--text-faint);" />
                <input value="@_attrSearch" @oninput="@(e => _attrSearch = e.Value?.ToString() ?? string.Empty)"
                       placeholder="Filter attributes…" class="sc-search-input" />
                @if (!string.IsNullOrEmpty(_attrSearch))
                {
                    <button type="button" class="sc-search-clear" @onclick="@(() => _attrSearch = string.Empty)" title="Clear">
                        <MudIcon Icon="@Icons.Material.Filled.Close" Style="font-size:12px;" />
                    </button>
                }
            </div>

            <div style="flex:1;overflow-y:auto;min-height:0;padding:8px;">
                @* Inline add row — appears at the top of the list, autofocused *@
                @if (_showCreateAttr)
                {
                    <div class="sc-add-row">
                        <span class="sc-add-amp">&amp;</span>
                        <input @ref="_newAttrInput" value="@_newAttrName"
                               @oninput="@(e => _newAttrName = e.Value?.ToString() ?? string.Empty)"
                               @onkeydown="OnCreateAttrKeyDown"
                               placeholder="ATTR`NAME" class="sc-add-input" />
                        <button type="button" class="sc-add-icon" @onclick="ExecuteCreateAttrAsync" title="Create">
                            <MudIcon Icon="@Icons.Material.Filled.Check" Style="font-size:14px;" />
                        </button>
                        <button type="button" class="sc-add-icon" @onclick="CancelCreateAttr" title="Cancel">
                            <MudIcon Icon="@Icons.Material.Filled.Close" Style="font-size:14px;" />
                        </button>
                    </div>
                }

                @if (_loadingAttrs)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                }
                else if (_selectedObject is null)
                {
                    <div style="padding:14px;color:var(--text-faint);font-size:12px;">Select an object.</div>
                }
                else
                {
                    var filteredAttrs = string.IsNullOrWhiteSpace(_attrSearch)
                        ? _selectedObject.Attributes
                        : _selectedObject.Attributes.Where(a => a.Name.Contains(_attrSearch, StringComparison.OrdinalIgnoreCase)).ToList();

                    @foreach (var attr in filteredAttrs)
                    {
                        var a = attr;
                        var isActive = ActiveTab?.Attr.Name == a.Name && ActiveTab?.Obj.Dbref == _selectedObject.Dbref;
                        <button type="button" class="sc-attr-item @(isActive ? "sc-attr-item--on" : "")"
                                @onclick="() => OnAttributeSelected(a)">
                            <span class="sc-attr-row1">
                                <span class="sc-kind-badge" style="@KindBadgeStyle(a)" title="@AttrKindLabel(a)">@AttrKindBadge(a)</span>
                                <span class="sc-attr-name">@a.Name</span>
                            </span>
                            <span class="sc-attr-desc">@AttrPreview(a)</span>
                        </button>
                    }

                    @if (filteredAttrs.Count == 0 && !_showCreateAttr)
                    {
                        <div style="padding:12px;color:var(--text-faint);font-size:12px;text-align:center;font-family:'JetBrains Mono',monospace;">
                            @(string.IsNullOrWhiteSpace(_attrSearch) ? "No attributes." : "No match.")
                        </div>
                    }
                }
            </div>
        }
    </div>

    @* ── Pane 3: Editor ───────────────────────────────────────────── *@
    <div class="sc-panel" style="flex:1;min-width:0;background:#0c0f14;">

        @* Breadcrumb header *@
        <div style="display:flex;align-items:center;gap:8px;padding:9px 14px;border-bottom:1px solid var(--border-soft);background:var(--surface-3);flex-shrink:0;min-height:40px;">
            @if (ActiveTab is not null)
            {
                <span class="sc-kind-badge" style="@KindBadgeStyle(ActiveTab.Attr)" title="@AttrKindLabel(ActiveTab.Attr)">@AttrKindBadge(ActiveTab.Attr)</span>
                <MudText Style="font-size:12px;font-family:'JetBrains Mono',monospace;color:var(--text-dim);">
                    @ActiveTab.Obj.Name
                </MudText>
                <MudText Style="font-size:12px;color:var(--text-faint);">›</MudText>
                <MudText Style="font-size:12px;font-family:'JetBrains Mono',monospace;color:var(--accent);font-weight:600;">
                    &amp;@ActiveTab.Attr.Name
                </MudText>
                <MudText Style="font-size:11px;font-family:'JetBrains Mono',monospace;color:var(--text-faint);">
                    #@ActiveTab.Obj.Dbref
                </MudText>
                @foreach (var flag in ActiveTab.Attr.AttributeFlags.Take(3))
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                             Style="height:18px;font-size:10px;padding:0 5px;border-color:var(--border);">@flag</MudChip>
                }
                @if (ActiveTab.IsDirty)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning"
                             Style="height:18px;font-size:10px;padding:0 5px;">unsaved</MudChip>
                }
            }
            else
            {
                <MudText Style="font-size:12px;color:var(--text-faint);">No attribute selected</MudText>
            }
            <MudSpacer />
            @* Toolbar actions — Test runs an eval in one click (think without saving) *@
            <MudTooltip Text="Test — evaluate without saving">
                <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.PlayArrow"
                           OnClick="EvalAsync"
                           Disabled="@(_evalLoading || ActiveTab is null)">
                    Test
                </MudButton>
            </MudTooltip>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Save"
                       OnClick="SaveAsync"
                       Disabled="@(ActiveTab is null)">
                Save
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Delete"
                       OnClick="DeleteAsync"
                       Disabled="@(ActiveTab is null)">
                Delete
            </MudButton>
            <MudTooltip Text="MUSH Help">
                <MudIconButton Icon="@Icons.Material.Filled.MenuBook" Size="Size.Small"
                               OnClick="@(() => _helpDrawer?.Open())" />
            </MudTooltip>
            @if (_selectedObject is not null)
            {
                <MudTooltip Text="Refresh attributes">
                    <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small"
                                   OnClick="RefreshAttributesAsync" />
                </MudTooltip>
            }
        </div>

        @* Open-attribute tab bar *@
        @if (_openTabs.Count > 0)
        {
            <div style="display:flex;overflow-x:auto;background:var(--surface-3);border-bottom:1px solid var(--border);min-height:30px;align-items:stretch;flex-shrink:0;">
                @for (int i = 0; i < _openTabs.Count; i++)
                {
                    var idx = i;
                    var tab = _openTabs[i];
                    var isActive = idx == _activeTabIndex;
                    <div style="@($"display:flex;align-items:center;gap:4px;padding:0 10px 0 12px;cursor:pointer;white-space:nowrap;border-right:1px solid var(--border);font-size:11px;font-family:'JetBrains Mono',monospace;background:{(isActive ? "var(--surface)" : "transparent")};color:{(isActive ? "var(--accent)" : "var(--text-faint)")};border-top:{(isActive ? "2px solid var(--accent)" : "2px solid transparent")}")"
                         @onclick="() => SwitchTabAsync(idx)">
                        <span>#@tab.Obj.Dbref&amp;@tab.Attr.Name@(tab.IsDirty ? " ●" : "")</span>
                        <span @onclick:stopPropagation="true" @onclick="() => CloseTabAsync(idx)">
                            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                           Style="padding:0;min-width:14px;height:14px;width:14px;"
                                           Color="@(tab.IsDirty ? Color.Warning : Color.Default)" />
                        </span>
                    </div>
                }
            </div>
        }

        @* Monaco editor *@
        <div style="flex:1;min-height:0;">
            <StandaloneCodeEditor @ref="_monacoEditor"
                                  Id="mush-editor"
                                  ConstructionOptions="BuildEditorOptions"
                                  OnDidInit="OnEditorInitAsync"
                                  OnDidChangeModelContent="OnEditorChanged"
                                  CssClass="mush-editor-fill" />
        </div>

        @* Eval output *@
        @if (_evalLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Success" Style="height:2px;flex-shrink:0;" />
        }
        else if (_evalOutput is not null)
        {
            <div class="mush-eval-output" style="flex-shrink:0;">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;">
                    <MudText Typo="Typo.caption" Color="Color.Success">▶ Eval result</MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                   Style="padding:0;min-width:0;height:16px;" Color="Color.Default"
                                   OnClick="@(() => { _evalOutput = null; StateHasChanged(); })" />
                </div>
                @_evalOutput
            </div>
        }

        @* Status bar *@
        @if (_saveMessage is not null)
        {
            <MudAlert Severity="@_saveSeverity" Dense="true" ShowCloseIcon="true"
                      CloseIconClicked="() => _saveMessage = null" Style="flex-shrink:0;">
                @_saveMessage
            </MudAlert>
        }
    </div>
</div>

<HelpDrawer @ref="_helpDrawer" />

<style>
    /* ── Editor shell: three rounded panels with a gap (prototype SoftcodeScreen) ── */
    .sc-shell {
        display: flex;
        gap: 14px;
        /* Match the standard content gutter (--cpad) so panels aren't cramped
           against the edges, mirroring the prototype's full-height padding. */
        padding: var(--cpad);
        height: 100%;
        overflow: hidden;
        background: var(--bg);
    }

    .sc-panel {
        display: flex;
        flex-direction: column;
        min-height: 0;
        border: 1px solid var(--border-soft);
        border-radius: var(--radius-lg);
        overflow: hidden;
    }

    /* ── Inline search box (prototype searchBox) ── */
    .sc-search {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 0 10px;
        margin: 0 10px 4px;
        background: var(--surface-3);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        transition: border-color 0.14s;
    }
    .sc-search:focus-within {
        border-color: var(--accent);
    }
    .sc-search-input {
        flex: 1;
        min-width: 0;
        padding: 8px 0;
        background: transparent;
        border: none;
        outline: none;
        color: var(--text);
        font-family: var(--font-ui);
        font-size: 12.5px;
    }
    .sc-search-input::placeholder {
        color: var(--text-faint);
    }
    .sc-search-clear {
        display: grid;
        place-items: center;
        width: 20px;
        height: 20px;
        flex-shrink: 0;
        border: none;
        background: transparent;
        color: var(--text-faint);
        cursor: pointer;
        border-radius: 5px;
    }
    .sc-search-clear:hover {
        color: var(--text);
        background: var(--surface-2);
    }

    /* ── "+ Add" pill in the attribute pane header ── */
    .sc-add-btn {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 9px;
        border-radius: var(--radius);
        cursor: pointer;
        border: 1px solid rgba(var(--glow), 0.3);
        background: rgba(var(--glow), 0.10);
        color: var(--accent);
        font-family: var(--font-ui);
        font-size: 11.5px;
        font-weight: 600;
        transition: background 0.14s;
    }
    .sc-add-btn:hover:not(:disabled) {
        background: rgba(var(--glow), 0.18);
    }
    .sc-add-btn:disabled {
        opacity: 0.4;
        cursor: not-allowed;
    }

    /* ── Inline add-attribute row (top of the list) ── */
    .sc-add-row {
        display: flex;
        align-items: center;
        gap: 7px;
        padding: 6px 8px;
        margin-bottom: 6px;
        border-radius: var(--radius);
        border: 1px dashed rgba(var(--glow), 0.4);
        background: rgba(var(--glow), 0.05);
    }
    .sc-add-amp {
        color: var(--accent);
        font-family: var(--font-mono);
        font-size: 13px;
    }
    .sc-add-input {
        flex: 1;
        min-width: 0;
        background: transparent;
        border: none;
        outline: none;
        color: var(--text);
        font-family: var(--font-mono);
        font-size: 12.5px;
        text-transform: uppercase;
    }
    .sc-add-input::placeholder {
        color: var(--text-faint);
        text-transform: none;
    }
    .sc-add-icon {
        display: grid;
        place-items: center;
        width: 24px;
        height: 24px;
        flex-shrink: 0;
        border: none;
        background: transparent;
        color: var(--accent);
        cursor: pointer;
        border-radius: 6px;
    }
    .sc-add-icon:hover {
        background: rgba(var(--glow), 0.12);
    }

    /* ── Attribute list item: kind badge + name + preview ── */
    .sc-attr-item {
        width: 100%;
        text-align: left;
        display: block;
        padding: 9px 10px;
        border-radius: var(--radius);
        cursor: pointer;
        border: none;
        background: transparent;
        margin-bottom: 3px;
        transition: background 0.12s;
    }
    .sc-attr-item:hover {
        background: var(--surface-2);
    }
    .sc-attr-item--on {
        background: rgba(var(--glow), 0.10);
        box-shadow: inset 2px 0 0 var(--accent);
    }
    .sc-attr-row1 {
        display: flex;
        align-items: center;
        gap: 7px;
        margin-bottom: 3px;
    }
    .sc-kind-badge {
        width: 16px;
        height: 16px;
        flex-shrink: 0;
        border-radius: 4px;
        display: grid;
        place-items: center;
        font-family: var(--font-mono);
        font-size: 10px;
        font-weight: 700;
    }
    .sc-attr-name {
        flex: 1;
        min-width: 0;
        font-family: var(--font-mono);
        font-size: 12.5px;
        font-weight: 500;
        color: var(--text-dim);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .sc-attr-item--on .sc-attr-name {
        color: var(--text);
        font-weight: 600;
    }
    .sc-attr-desc {
        display: block;
        font-family: var(--font-ui);
        font-size: 11px;
        color: var(--text-faint);
        line-height: 1.35;
        padding-left: 23px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
</style>

@code {
    // ── Open attribute tabs ───────────────────────────────────────────────────

    private sealed class AttrTab(MushObject obj, MushAttribute attr)
    {
        public MushObject Obj { get; } = obj;
        public MushAttribute Attr { get; } = attr;
        public string WorkingContent { get; set; } = attr.Value.Replace("%r", "\n").Replace("%R", "\n");
        public bool IsDirty { get; set; }
    }

    private readonly List<AttrTab> _openTabs = [];
    private int _activeTabIndex = -1;
    private AttrTab? ActiveTab => _activeTabIndex >= 0 && _activeTabIndex < _openTabs.Count
        ? _openTabs[_activeTabIndex]
        : null;

    private StandaloneCodeEditor? _monacoEditor;
    private ObjectBrowser? _objectBrowser;
    private HelpDrawer? _helpDrawer;
    private MushObject? _selectedObject;
    private bool _loadingAttrs;
    private string? _saveMessage;
    private Severity _saveSeverity = Severity.Success;
    private string? _evalOutput;
    private bool _evalLoading;

    // Collapse state (no CSS transitions — instant snap)
    private bool _objCollapsed;
    private bool _attrCollapsed;

    // Search
    private string _attrSearch = string.Empty;

    // Create-object inline prompt
    private MushObjectType? _createObjectType;
    private string _createObjectName = string.Empty;

    // Create-attribute inline prompt
    private bool _showCreateAttr;
    private string _newAttrName = string.Empty;
    private ElementReference _newAttrInput;
    private bool _focusNewAttr;

    // ── Attribute kind badges ─────────────────────────────────────────────────

    private static string AttrKindBadge(MushAttribute attr)
    {
        if (attr.Value.TrimStart().StartsWith('$')) return "$";
        if (attr.Value.TrimStart().StartsWith('^')) return "^";
        if (attr.Name.Contains('`', StringComparison.Ordinal) || attr.AttributeFlags.Contains("SAFE", StringComparer.OrdinalIgnoreCase))
            return "ƒ";
        return attr.Value.Length > 0 && (char.IsDigit(attr.Value[0]) || attr.Value == "0" || attr.Value.StartsWith("#-"))
            ? "•"
            : "¶";
    }

    private static string AttrKindColor(MushAttribute attr) => AttrKindBadge(attr) switch
    {
        "$" => "var(--accent)",
        "ƒ" => "#5aa9ff",
        "^" => "#b39cff",
        "•" => "#d9a23a",
        _   => "var(--text-faint)",
    };

    private static string AttrKindLabel(MushAttribute attr) => AttrKindBadge(attr) switch
    {
        "$" => "Command trigger",
        "ƒ" => "Function",
        "^" => "Listen trigger",
        "•" => "Data",
        _   => "Text",
    };

    // Glow rgb tuple per kind, for the badge box bg/border (command uses the live accent).
    private static string AttrKindGlow(MushAttribute attr) => AttrKindBadge(attr) switch
    {
        "$" => "var(--glow)",
        "ƒ" => "90,169,255",
        "^" => "179,156,255",
        "•" => "217,162,58",
        _   => "95,104,112",
    };

    private static string KindBadgeStyle(MushAttribute attr)
        => $"background:rgba({AttrKindGlow(attr)},0.14);border:1px solid rgba({AttrKindGlow(attr)},0.3);color:{AttrKindColor(attr)};";

    // One-line preview of the attribute body for the list sub-label.
    private static string AttrPreview(MushAttribute attr)
    {
        var v = (attr.Value ?? string.Empty).Replace('\n', ' ').Replace('\r', ' ').Trim();
        if (v.Length == 0) return "(empty)";
        return v.Length > 60 ? v[..60] + "…" : v;
    }

    // ── Editor init ────────────────────────────────────────────────────────────

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JsRuntime.InvokeVoidAsync("SharpMUSH.Monaco.initEditor", "mush-editor");

        if (_focusNewAttr)
        {
            _focusNewAttr = false;
            try { await _newAttrInput.FocusAsync(); }
            catch { /* element may have been dismissed before focus */ }
        }
    }

    private StandaloneEditorConstructionOptions BuildEditorOptions(StandaloneCodeEditor editor) => new()
    {
        Language = "plaintext",
        Theme = "vs-dark",
        AutomaticLayout = true,
        Value = ActiveTab?.WorkingContent ?? string.Empty,
        FontFamily = "'JetBrains Mono', Consolas, 'Courier New', monospace",
        FontSize = 13,
        LineNumbers = "on",
        WordWrap = "on",
        Minimap = new EditorMinimapOptions { Enabled = false },
        ScrollBeyondLastLine = false,
        SuggestOnTriggerCharacters = true,
        FixedOverflowWidgets = true,
    };

    private async Task OnEditorInitAsync()
        => await JsRuntime.InvokeVoidAsync("SharpMUSH.Monaco.initEditor", "mush-editor");

    private void OnEditorChanged(ModelContentChangedEvent e)
    {
        if (ActiveTab is not null)
            ActiveTab.IsDirty = true;
    }

    // ── Tab management ─────────────────────────────────────────────────────────

    private async Task OnAttributeSelected(MushAttribute? attr)
    {
        if (attr is null || _selectedObject is null) return;
        _saveMessage = null;

        if (_monacoEditor is not null && ActiveTab is not null)
            ActiveTab.WorkingContent = await _monacoEditor.GetValue();

        var existing = _openTabs.FindIndex(t => t.Obj.Dbref == _selectedObject.Dbref
            && string.Equals(t.Attr.Name, attr.Name, StringComparison.OrdinalIgnoreCase));
        if (existing >= 0)
        {
            _activeTabIndex = existing;
        }
        else
        {
            _openTabs.Add(new AttrTab(_selectedObject, attr));
            _activeTabIndex = _openTabs.Count - 1;
        }

        if (_monacoEditor is not null)
            await _monacoEditor.SetValue(ActiveTab!.WorkingContent);

        StateHasChanged();
    }

    private async Task SwitchTabAsync(int idx)
    {
        if (idx == _activeTabIndex) return;
        if (_monacoEditor is not null && ActiveTab is not null)
            ActiveTab.WorkingContent = await _monacoEditor.GetValue();
        _activeTabIndex = idx;
        if (_monacoEditor is not null && ActiveTab is not null)
            await _monacoEditor.SetValue(ActiveTab.WorkingContent);
        StateHasChanged();
    }

    private async Task CloseTabAsync(int idx)
    {
        if (idx == _activeTabIndex && _monacoEditor is not null && ActiveTab is not null)
            ActiveTab.WorkingContent = await _monacoEditor.GetValue();
        _openTabs.RemoveAt(idx);
        if (_openTabs.Count == 0)
        {
            _activeTabIndex = -1;
            if (_monacoEditor is not null)
                await _monacoEditor.SetValue(string.Empty);
        }
        else
        {
            _activeTabIndex = Math.Clamp(_activeTabIndex, 0, _openTabs.Count - 1);
            if (_monacoEditor is not null)
                await _monacoEditor.SetValue(ActiveTab!.WorkingContent);
        }
        StateHasChanged();
    }

    // ── Object / attribute loading ─────────────────────────────────────────────

    private async Task OnObjectSelected(int dbref)
    {
        _loadingAttrs = true;
        _saveMessage = null;
        _showCreateAttr = false;
        StateHasChanged();
        try
        {
            _selectedObject = await QueryService.GetObjectAsync($"#{dbref}");
            _selectedObject ??= new MushObject
            {
                Dbref = dbref,
                Name = $"#{dbref}",
                Attributes = await QueryService.GetAttributesAsync($"#{dbref}"),
            };
        }
        catch (Exception ex)
        {
            _saveMessage = $"Error loading object: {ex.Message}";
            _saveSeverity = Severity.Error;
        }
        finally
        {
            _loadingAttrs = false;
            StateHasChanged();
        }
    }

    private async Task RefreshAttributesAsync()
    {
        if (_selectedObject is null) return;
        var dbref = _selectedObject.Dbref;
        await OnObjectSelected(dbref);
        if (_selectedObject is not null)
        {
            foreach (var tab in _openTabs.Where(t => t.Obj.Dbref == dbref))
            {
                var refreshed = _selectedObject.Attributes.FirstOrDefault(a =>
                    string.Equals(a.Name, tab.Attr.Name, StringComparison.OrdinalIgnoreCase));
                if (refreshed is not null && !tab.IsDirty)
                    tab.WorkingContent = refreshed.Value.Replace("%r", "\n").Replace("%R", "\n");
            }
        }
        if (_monacoEditor is not null && ActiveTab is not null)
            await _monacoEditor.SetValue(ActiveTab.WorkingContent);
    }

    // ── Save / Delete / Eval ───────────────────────────────────────────────────

    private async Task SaveAsync()
    {
        if (ActiveTab is null || _monacoEditor is null) return;
        var value = await _monacoEditor.GetValue();
        ActiveTab.WorkingContent = value;
        var savedAttrName = ActiveTab.Attr.Name;
        var savedDbref = ActiveTab.Obj.Dbref;
        await QueryService.SetAttributeAsync($"#{savedDbref}", savedAttrName, value);
        ActiveTab.IsDirty = false;
        await RefreshAttributesAsync();
        _saveMessage = $"Saved &{savedAttrName} on #{savedDbref}.";
        _saveSeverity = Severity.Success;
        StateHasChanged();
    }

    private async Task DeleteAsync()
    {
        if (ActiveTab is null) return;
        var deletedName = ActiveTab.Attr.Name;
        var deletedDbref = ActiveTab.Obj.Dbref;
        await QueryService.DeleteAttributeAsync($"#{deletedDbref}", deletedName);
        _saveMessage = $"Deleted &{deletedName}.";
        _saveSeverity = Severity.Info;
        var tabIdx = _openTabs.IndexOf(ActiveTab);
        if (tabIdx >= 0) await CloseTabAsync(tabIdx);
        await RefreshAttributesAsync();
        StateHasChanged();
    }

    private async Task EvalAsync()
    {
        if (_monacoEditor is null || ActiveTab is null) return;
        _evalLoading = true;
        _evalOutput = null;
        StateHasChanged();
        try
        {
            var lines = await QueryService.EvalAsync($"#{ActiveTab.Obj.Dbref}", ActiveTab.Attr.Name);
            _evalOutput = lines.Length > 0
                ? string.Join("\n", lines.Where(l => !string.IsNullOrEmpty(l)))
                : "(no output)";
        }
        catch (Exception ex)
        {
            _evalOutput = $"[Error] {ex.Message}";
        }
        finally
        {
            _evalLoading = false;
            StateHasChanged();
        }
    }

    // ── Create Object ──────────────────────────────────────────────────────────

    private void ShowCreateObjectDialog(MushObjectType type)
    {
        _createObjectType = type;
        _createObjectName = string.Empty;
    }

    private void CancelCreateObject() => _createObjectType = null;

    private async Task ExecuteCreateObjectAsync()
    {
        if (_createObjectType is null || string.IsNullOrWhiteSpace(_createObjectName)) return;
        var type = _createObjectType.Value;
        var name = _createObjectName.Trim();
        _createObjectType = null;
        _createObjectName = string.Empty;
        var newDbref = await QueryService.CreateObjectAsync(name, type);
        if (_objectBrowser is not null)
        {
            await _objectBrowser.RefreshAsync();
            if (newDbref.HasValue)
                await _objectBrowser.SelectDbrefAsync(newDbref.Value);
        }
    }

    private async Task OnCreateObjectKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await ExecuteCreateObjectAsync();
        else if (e.Key == "Escape") CancelCreateObject();
    }

    // ── Create Attribute ───────────────────────────────────────────────────────

    private void ShowCreateAttr() { _showCreateAttr = true; _newAttrName = string.Empty; _focusNewAttr = true; }
    private void CancelCreateAttr() => _showCreateAttr = false;

    private async Task ExecuteCreateAttrAsync()
    {
        if (_selectedObject is null || string.IsNullOrWhiteSpace(_newAttrName)) return;
        var attrName = _newAttrName.Trim().ToUpperInvariant();
        _showCreateAttr = false;
        _newAttrName = string.Empty;
        await QueryService.SetAttributeAsync($"#{_selectedObject.Dbref}", attrName, "null()");
        await RefreshAttributesAsync();
        var created = _selectedObject?.Attributes.FirstOrDefault(a =>
            string.Equals(a.Name, attrName, StringComparison.OrdinalIgnoreCase));
        if (created is not null)
            await OnAttributeSelected(created);
    }

    private async Task OnCreateAttrKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await ExecuteCreateAttrAsync();
        else if (e.Key == "Escape") CancelCreateAttr();
    }

    public ValueTask DisposeAsync() => ValueTask.CompletedTask;
}
