@page "/admin/config/bannednames"
@layout SharpMUSH.Client.Layout.ConfigLayout
@using SharpMUSH.Client.Services
@inject BannedNamesService BannedNamesService
@inject ISnackbar Snackbar
@inject IStringLocalizer<SharedResource> Loc

<PageTitle>@Loc["BannedNames"] - @Loc["Configuration"]</PageTitle>

<div class="config-section-page">
    <div class="config-section-header">
        <MudText Typo="Typo.h4">@Loc["BannedPlayerNames"]</MudText>
        <MudText Typo="Typo.body1" Class="mud-text-secondary mt-2">
            @Loc["BannedNamesDescription"]
        </MudText>
    </div>

    <div class="config-section-content">
        @if (_loading)
        {
            <MudCard Outlined="true" Class="mb-4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudSkeleton Width="30%" Height="32px" />
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudSkeleton Height="56px" Class="mb-4" />
                    <MudSkeleton Height="56px" />
                </MudCardContent>
            </MudCard>
        }
        else
        {
            <MudCard Outlined="true" Class="mb-4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Loc["AddBannedName"]</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid>
                        <MudItem xs="12" md="8">
                            <MudTextField @bind-Value="_newName" 
                                          Label="@Loc["NameToBan"].Value" 
                                          Variant="Variant.Outlined"
                                          Immediate="true"
                                          OnKeyDown="HandleKeyDown" />
                        </MudItem>
                        <MudItem xs="12" md="4" Class="d-flex align-end">
                            <MudButton Variant="Variant.Filled" 
                                       Color="Color.Primary" 
                                       OnClick="AddBannedName"
                                       Disabled="string.IsNullOrWhiteSpace(_newName)"
                                       FullWidth="true"
                                       StartIcon="@Icons.Material.Filled.Add">
                                @Loc["AddName"]
                            </MudButton>
                        </MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>

            <MudCard Outlined="true">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Loc["BannedNamesList"]</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip T="string" Color="Color.Info" Size="Size.Small">@_bannedNames.Count</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    @if (_bannedNames == null || !_bannedNames.Any())
                    {
                        <MudAlert Severity="Severity.Info">@Loc["NoBannedNamesConfigured"]</MudAlert>
                    }
                    else
                    {
                        <MudList T="string" Dense="true">
                            @foreach (var name in _bannedNames.OrderBy(n => n))
                            {
                                <MudListItem T="string">
                                    <div class="d-flex justify-space-between align-center" style="width: 100%">
                                        <MudText>@name</MudText>
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                                       Color="Color.Error" 
                                                       Size="Size.Small"
                                                       OnClick="@(() => DeleteBannedName(name))" />
                                    </div>
                                </MudListItem>
                                <MudDivider />
                            }
                        </MudList>
                    }
                </MudCardContent>
            </MudCard>
        }
    </div>
</div>

<style>
    .config-section-page {
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .config-section-header {
        padding: 24px 32px;
        background: var(--mud-palette-surface);
        border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    }

    .config-section-content {
        flex: 1;
        overflow-y: auto;
        padding: 32px;
    }
</style>

@code {
    private bool _loading = true;
    private List<string> _bannedNames = new();
    private string _newName = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadBannedNames();
    }

    private async Task LoadBannedNames()
    {
        _loading = true;
        try
        {
            var names = await BannedNamesService.GetBannedNamesAsync();
            _bannedNames = names?.ToList() ?? new List<string>();
        }
        catch (Exception ex)
        {
            Snackbar.Add(string.Format(Loc["ErrorLoadingBannedNames"], ex.Message), Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task AddBannedName()
    {
        if (string.IsNullOrWhiteSpace(_newName))
            return;

        try
        {
            var success = await BannedNamesService.AddBannedNameAsync(_newName.Trim());
            if (success)
            {
                Snackbar.Add(string.Format(Loc["BannedNameAdded"], _newName), Severity.Success);
                _newName = string.Empty;
                await LoadBannedNames();
            }
            else
            {
                Snackbar.Add(string.Format(Loc["BannedNameAddFailed"], _newName), Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(string.Format(Loc["ErrorAddingBannedName"], ex.Message), Severity.Error);
        }
    }

    private async Task DeleteBannedName(string name)
    {
        try
        {
            var success = await BannedNamesService.DeleteBannedNameAsync(name);
            if (success)
            {
                Snackbar.Add(string.Format(Loc["BannedNameRemoved"], name), Severity.Success);
                await LoadBannedNames();
            }
            else
            {
                Snackbar.Add(string.Format(Loc["BannedNameRemoveFailed"], name), Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(string.Format(Loc["ErrorRemovingBannedName"], ex.Message), Severity.Error);
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await AddBannedName();
        }
    }
}
