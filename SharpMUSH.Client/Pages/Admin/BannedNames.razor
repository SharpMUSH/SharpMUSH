@page "/admin/config/bannednames"
@layout ConfigLayout
@attribute [Authorize(Policy = "config.admin")]
@using SharpMUSH.Client.Services
@inject BannedNamesService BannedNamesService
@inject ISnackbar Snackbar
@inject IStringLocalizer<SharedResource> Loc

<PageTitle>@Loc["BannedNames"] - @Loc["Configuration"]</PageTitle>

<div class="config-section-page">
    <div class="config-section-header">
        <div>
            <div class="config-kicker">Admin · server settings</div>
            <h1 class="config-title">@Loc["BannedPlayerNames"]</h1>
            <p class="config-desc">@Loc["BannedNamesDescription"]</p>
        </div>
    </div>

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Secondary" Indeterminate="true" />
    }
    else
    {
        <div class="config-group-title">@Loc["AddBannedName"]</div>
        <div class="config-field-card config-pad mb-5">
            <div class="config-add-grid">
                <input class="config-input" placeholder="@Loc["NameToBan"].Value"
                       value="@_newName"
                       @oninput="@(e => _newName = e.Value?.ToString() ?? string.Empty)"
                       @onkeydown="HandleKeyDown" />
                <button type="button" class="config-primary-btn"
                        @onclick="AddBannedName"
                        disabled="@string.IsNullOrWhiteSpace(_newName)">
                    <MudIcon Icon="@Icons.Material.Filled.Add" Style="font-size:16px;" />
                    @Loc["AddName"]
                </button>
            </div>
        </div>

        <div class="config-group-title">@Loc["BannedNamesList"]</div>
        @if (_bannedNames == null || !_bannedNames.Any())
        {
            <div class="config-field-card config-pad">
                <span class="config-empty">@Loc["NoBannedNamesConfigured"]</span>
            </div>
        }
        else
        {
            <div class="config-field-card">
                @foreach (var name in _bannedNames.OrderBy(n => n))
                {
                    <div class="config-list-row">
                        <span class="config-list-name">@name</span>
                        <button type="button" class="config-icon-btn config-icon-btn--danger"
                                title="@Loc["Delete"]"
                                @onclick="@(() => DeleteBannedName(name))">
                            <MudIcon Icon="@Icons.Material.Filled.DeleteOutline" Style="font-size:16px;" />
                        </button>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    private bool _loading = true;
    private List<string> _bannedNames = new();
    private string _newName = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadBannedNames();
    }

    private async Task LoadBannedNames()
    {
        _loading = true;
        try
        {
            var names = await BannedNamesService.GetBannedNamesAsync();
            _bannedNames = names?.ToList() ?? new List<string>();
        }
        catch (Exception ex)
        {
            Snackbar.Add(string.Format(Loc["ErrorLoadingBannedNames"], ex.Message), Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task AddBannedName()
    {
        if (string.IsNullOrWhiteSpace(_newName))
            return;

        try
        {
            var success = await BannedNamesService.AddBannedNameAsync(_newName.Trim());
            if (success)
            {
                Snackbar.Add(string.Format(Loc["BannedNameAdded"], _newName), Severity.Success);
                _newName = string.Empty;
                await LoadBannedNames();
            }
            else
            {
                Snackbar.Add(string.Format(Loc["BannedNameAddFailed"], _newName), Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(string.Format(Loc["ErrorAddingBannedName"], ex.Message), Severity.Error);
        }
    }

    private async Task DeleteBannedName(string name)
    {
        try
        {
            var success = await BannedNamesService.DeleteBannedNameAsync(name);
            if (success)
            {
                Snackbar.Add(string.Format(Loc["BannedNameRemoved"], name), Severity.Success);
                await LoadBannedNames();
            }
            else
            {
                Snackbar.Add(string.Format(Loc["BannedNameRemoveFailed"], name), Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(string.Format(Loc["ErrorRemovingBannedName"], ex.Message), Severity.Error);
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await AddBannedName();
        }
    }
}

<style>
    .config-section-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 20px;
    }

    .config-kicker {
        font-family: var(--font-mono);
        font-size: 11px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 6px;
    }

    .config-title {
        margin: 0;
        font-family: var(--font-display);
        font-size: 26px;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: var(--text);
    }

    .config-desc {
        margin: 6px 0 0;
        font-family: var(--font-ui);
        font-size: 13px;
        color: var(--text-dim);
    }

    .config-group-title {
        font-family: var(--font-ui);
        font-size: 13px;
        font-weight: 600;
        color: var(--text);
        margin: 0 0 8px 2px;
    }

    .config-field-card {
        background: var(--surface);
        border: 1px solid var(--border-soft);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow);
        overflow: hidden;
    }

    .config-pad {
        padding: 18px 22px;
    }

    .config-add-grid {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .config-add-grid .config-input {
        flex: 1;
    }

    .config-input {
        width: 100%;
        padding: 9px 12px;
        background: var(--surface-3);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        color: var(--text);
        font-family: var(--font-mono);
        font-size: 13px;
        outline: none;
        transition: border-color 0.12s;
    }

    .config-input:focus {
        border-color: var(--accent);
    }

    .config-input::placeholder {
        color: var(--text-faint);
    }

    .config-primary-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        flex-shrink: 0;
        padding: 9px 16px;
        border-radius: var(--radius);
        border: none;
        background: var(--accent);
        color: var(--accent-on);
        cursor: pointer;
        font-family: var(--font-ui);
        font-size: 13px;
        font-weight: 600;
        transition: opacity 0.12s;
    }

    .config-primary-btn:hover:not(:disabled) {
        opacity: 0.9;
    }

    .config-primary-btn:disabled {
        opacity: 0.4;
        cursor: not-allowed;
    }

    .config-list-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 12px 22px;
    }

    .config-list-row:not(:first-child) {
        border-top: 1px solid var(--border-soft);
    }

    .config-list-name {
        font-family: var(--font-mono);
        font-size: 13px;
        color: var(--text);
    }

    .config-empty {
        font-family: var(--font-ui);
        font-size: 12.5px;
        color: var(--text-faint);
    }

    .config-icon-btn {
        width: 32px;
        height: 32px;
        flex-shrink: 0;
        display: grid;
        place-items: center;
        border-radius: var(--radius);
        border: 1px solid var(--border);
        background: transparent;
        color: var(--text-dim);
        cursor: pointer;
    }

    .config-icon-btn--danger:hover {
        color: var(--mud-palette-error, #e57373);
        border-color: rgba(229, 115, 115, 0.5);
    }
</style>
