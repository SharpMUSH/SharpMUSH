@page "/admin/server"
@attribute [Authorize(Roles = "God")]
@inject IStringLocalizer<SharedResource> Loc

<PageTitle>Server Settings — Admin — SharpMUSH</PageTitle>

<div class="adminsrv-page">
    <header class="adminsrv-header">
        <div class="adminsrv-kicker">Admin · Server</div>
        <h1 class="adminsrv-title">Server Settings</h1>
    </header>

    <div class="adminsrv-card">
        <MudIcon Icon="@Icons.Material.Filled.Dns" Class="adminsrv-card-icon" />
        <div class="adminsrv-card-body">
            <span class="adminsrv-card-label">God-only server settings</span>
            <span class="adminsrv-card-desc">Server configuration and live metrics are coming soon.</span>
        </div>
    </div>
</div>

<style>
    .adminsrv-page {
        padding: var(--cpad);
    }

    .adminsrv-header {
        margin-bottom: 24px;
    }
    .adminsrv-kicker {
        font-family: var(--font-mono);
        font-size: 11px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 10px;
    }
    .adminsrv-title {
        margin: 0;
        font-family: var(--font-display);
        font-size: 26px;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: var(--text);
    }

    .adminsrv-card {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 18px 20px;
        background: var(--surface);
        border: 1px solid var(--border-soft);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow);
    }
    .adminsrv-card-icon {
        font-size: 24px !important;
        color: var(--accent);
        flex-shrink: 0;
    }
    .adminsrv-card-body {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }
    .adminsrv-card-label {
        font-family: var(--font-ui);
        font-size: 15px;
        font-weight: 600;
        color: var(--text);
    }
    .adminsrv-card-desc {
        font-family: var(--font-ui);
        font-size: 12.5px;
        color: var(--text-dim);
    }
</style>
