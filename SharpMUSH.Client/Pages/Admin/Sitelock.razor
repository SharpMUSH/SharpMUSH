@page "/admin/config/sitelock"
@page "/admin/config/sitelockrules"
@layout SharpMUSH.Client.Layout.ConfigLayout
@using SharpMUSH.Client.Services
@inject SitelockService SitelockService
@inject ISnackbar Snackbar
@inject IStringLocalizer<SharedResource> Loc

<PageTitle>@Loc["SitelockRules"] - @Loc["Configuration"]</PageTitle>

<div class="config-section-page">
    <div class="config-section-header">
        <MudText Typo="Typo.h4">@Loc["SitelockRules"]</MudText>
        <MudText Typo="Typo.body1" Class="mud-text-secondary mt-2">
            @Loc["SitelockDescription"]
            <code>!connect</code>, <code>!create</code>, <code>!guest</code>, <code>register</code>, <code>suspect</code>
        </MudText>
    </div>

    <div class="config-section-content">
        @if (_loading)
        {
            <MudCard Outlined="true" Class="mb-4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudSkeleton Width="30%" Height="32px" />
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudSkeleton Height="56px" Class="mb-4" />
                    <MudSkeleton Height="56px" />
                </MudCardContent>
            </MudCard>
        }
        else
        {
            <MudCard Outlined="true" Class="mb-4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Loc["AddSitelockRule"]</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid>
                        <MudItem xs="12" md="5">
                            <MudTextField @bind-Value="_newHostPattern" 
                                          Label="@Loc["HostPattern"].Value" 
                                          Variant="Variant.Outlined"
                                          HelperText="@Loc["HostPatternHelper"].Value" />
                        </MudItem>
                        <MudItem xs="12" md="5">
                            <MudTextField @bind-Value="_newAccessRulesText" 
                                          Label="@Loc["AccessRulesLabel"].Value" 
                                          Variant="Variant.Outlined"
                                          HelperText="@Loc["AccessRulesHelper"].Value" />
                        </MudItem>
                        <MudItem xs="12" md="2" Class="d-flex align-end">
                            <MudButton Variant="Variant.Filled" 
                                       Color="Color.Primary" 
                                       OnClick="AddSitelockRule"
                                       Disabled="string.IsNullOrWhiteSpace(_newHostPattern) || string.IsNullOrWhiteSpace(_newAccessRulesText)"
                                       FullWidth="true"
                                       StartIcon="@Icons.Material.Filled.Add">
                                @Loc["Add"]
                            </MudButton>
                        </MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>

            <MudCard Outlined="true">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Loc["ConfiguredRules"]</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip T="string" Color="Color.Info" Size="Size.Small">@_sitelockRules.Count</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    @if (_sitelockRules == null || !_sitelockRules.Any())
                    {
                        <MudAlert Severity="Severity.Info">@Loc["NoSitelockRulesConfigured"]</MudAlert>
                    }
                    else
                    {
                        <MudList T="string" Dense="true">
                            @foreach (var rule in _sitelockRules.OrderBy(r => r.Key))
                            {
                                <MudListItem T="string">
                                    <div class="d-flex justify-space-between align-center" style="width: 100%">
                                        <div>
                                            <MudText Typo="Typo.body1"><strong>@rule.Key</strong></MudText>
                                            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                                                @string.Join(", ", rule.Value)
                                            </MudText>
                                        </div>
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                                       Color="Color.Error" 
                                                       Size="Size.Small"
                                                       OnClick="@(() => DeleteSitelockRule(rule.Key))" />
                                    </div>
                                </MudListItem>
                                <MudDivider />
                            }
                        </MudList>
                    }
                </MudCardContent>
            </MudCard>
        }
    </div>
</div>

<style>
    .config-section-page {
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .config-section-header {
        padding: 24px 32px;
        background: var(--mud-palette-surface);
        border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    }

    .config-section-content {
        flex: 1;
        overflow-y: auto;
        padding: 32px;
    }
</style>

@code {
    private bool _loading = true;
    private Dictionary<string, string[]> _sitelockRules = new();
    private string _newHostPattern = string.Empty;
    private string _newAccessRulesText = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadSitelockRules();
    }

    private async Task LoadSitelockRules()
    {
        _loading = true;
        try
        {
            var rules = await SitelockService.GetSitelockRulesAsync();
            _sitelockRules = rules ?? new Dictionary<string, string[]>();
        }
        catch (Exception ex)
        {
            Snackbar.Add(string.Format(Loc["ErrorLoadingSitelockRules"], ex.Message), Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task AddSitelockRule()
    {
        if (string.IsNullOrWhiteSpace(_newHostPattern) || string.IsNullOrWhiteSpace(_newAccessRulesText))
            return;

        try
        {
            var accessRules = _newAccessRulesText
                .Split(',')
                .Select(r => r.Trim())
                .Where(r => !string.IsNullOrWhiteSpace(r))
                .ToArray();

            if (accessRules.Length == 0)
            {
                Snackbar.Add(Loc["AtLeastOneAccessRule"].Value, Severity.Warning);
                return;
            }

            var success = await SitelockService.AddSitelockRuleAsync(_newHostPattern.Trim(), accessRules);
            if (success)
            {
                Snackbar.Add(string.Format(Loc["SitelockRuleAdded"], _newHostPattern), Severity.Success);
                _newHostPattern = string.Empty;
                _newAccessRulesText = string.Empty;
                await LoadSitelockRules();
            }
            else
            {
                Snackbar.Add(Loc["SitelockRuleAddFailed"].Value, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(string.Format(Loc["ErrorAddingSitelockRule"], ex.Message), Severity.Error);
        }
    }

    private async Task DeleteSitelockRule(string hostPattern)
    {
        try
        {
            var success = await SitelockService.DeleteSitelockRuleAsync(hostPattern);
            if (success)
            {
                Snackbar.Add(string.Format(Loc["SitelockRuleRemoved"], hostPattern), Severity.Success);
                await LoadSitelockRules();
            }
            else
            {
                Snackbar.Add(Loc["SitelockRuleRemoveFailed"].Value, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(string.Format(Loc["ErrorRemovingSitelockRule"], ex.Message), Severity.Error);
        }
    }
}
