@page "/admin/config/sitelock"
@page "/admin/config/sitelockrules"
@layout ConfigLayout
@attribute [Authorize(Policy = "config.admin")]
@using SharpMUSH.Client.Services
@inject SitelockService SitelockService
@inject ISnackbar Snackbar
@inject IStringLocalizer<SharedResource> Loc

<PageTitle>@Loc["SitelockRules"] - @Loc["Configuration"]</PageTitle>

<div class="config-section-page">
    <div class="config-section-header">
        <div>
            <div class="config-kicker">Admin · server settings</div>
            <h1 class="config-title">@Loc["SitelockRules"]</h1>
            <p class="config-desc">
                @Loc["SitelockDescription"]
                <code>!connect</code>, <code>!create</code>, <code>!guest</code>, <code>register</code>, <code>suspect</code>
            </p>
        </div>
    </div>

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Secondary" Indeterminate="true" />
    }
    else
    {
        <div class="config-group-title">@Loc["AddSitelockRule"]</div>
        <div class="config-field-card config-pad mb-5">
            <div class="config-add-fields">
                <div class="config-add-field">
                    <label class="config-field-label-text">@Loc["HostPattern"]</label>
                    <input class="config-input" placeholder="@Loc["HostPatternHelper"].Value"
                           value="@_newHostPattern"
                           @oninput="@(e => _newHostPattern = e.Value?.ToString() ?? string.Empty)" />
                </div>
                <div class="config-add-field">
                    <label class="config-field-label-text">@Loc["AccessRulesLabel"]</label>
                    <input class="config-input" placeholder="@Loc["AccessRulesHelper"].Value"
                           value="@_newAccessRulesText"
                           @oninput="@(e => _newAccessRulesText = e.Value?.ToString() ?? string.Empty)" />
                </div>
                <button type="button" class="config-primary-btn"
                        @onclick="AddSitelockRule"
                        disabled="@(string.IsNullOrWhiteSpace(_newHostPattern) || string.IsNullOrWhiteSpace(_newAccessRulesText))">
                    <MudIcon Icon="@Icons.Material.Filled.Add" Style="font-size:16px;" />
                    @Loc["Add"]
                </button>
            </div>
        </div>

        <div class="config-group-title">@Loc["ConfiguredRules"]</div>
        @if (_sitelockRules == null || !_sitelockRules.Any())
        {
            <div class="config-field-card config-pad">
                <span class="config-empty">@Loc["NoSitelockRulesConfigured"]</span>
            </div>
        }
        else
        {
            <div class="config-field-card">
                @foreach (var rule in _sitelockRules.OrderBy(r => r.Key))
                {
                    <div class="config-list-row">
                        <div class="config-list-text">
                            <span class="config-list-name">@rule.Key</span>
                            <span class="config-list-sub">@string.Join(", ", rule.Value)</span>
                        </div>
                        <button type="button" class="config-icon-btn config-icon-btn--danger"
                                title="@Loc["Delete"]"
                                @onclick="@(() => DeleteSitelockRule(rule.Key))">
                            <MudIcon Icon="@Icons.Material.Filled.DeleteOutline" Style="font-size:16px;" />
                        </button>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    private bool _loading = true;
    private Dictionary<string, string[]> _sitelockRules = new();
    private string _newHostPattern = string.Empty;
    private string _newAccessRulesText = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadSitelockRules();
    }

    private async Task LoadSitelockRules()
    {
        _loading = true;
        try
        {
            var rules = await SitelockService.GetSitelockRulesAsync();
            _sitelockRules = rules ?? new Dictionary<string, string[]>();
        }
        catch (Exception ex)
        {
            Snackbar.Add(string.Format(Loc["ErrorLoadingSitelockRules"], ex.Message), Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task AddSitelockRule()
    {
        if (string.IsNullOrWhiteSpace(_newHostPattern) || string.IsNullOrWhiteSpace(_newAccessRulesText))
            return;

        try
        {
            var accessRules = _newAccessRulesText
                .Split(',')
                .Select(r => r.Trim())
                .Where(r => !string.IsNullOrWhiteSpace(r))
                .ToArray();

            if (accessRules.Length == 0)
            {
                Snackbar.Add(Loc["AtLeastOneAccessRule"].Value, Severity.Warning);
                return;
            }

            var success = await SitelockService.AddSitelockRuleAsync(_newHostPattern.Trim(), accessRules);
            if (success)
            {
                Snackbar.Add(string.Format(Loc["SitelockRuleAdded"], _newHostPattern), Severity.Success);
                _newHostPattern = string.Empty;
                _newAccessRulesText = string.Empty;
                await LoadSitelockRules();
            }
            else
            {
                Snackbar.Add(Loc["SitelockRuleAddFailed"].Value, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(string.Format(Loc["ErrorAddingSitelockRule"], ex.Message), Severity.Error);
        }
    }

    private async Task DeleteSitelockRule(string hostPattern)
    {
        try
        {
            var success = await SitelockService.DeleteSitelockRuleAsync(hostPattern);
            if (success)
            {
                Snackbar.Add(string.Format(Loc["SitelockRuleRemoved"], hostPattern), Severity.Success);
                await LoadSitelockRules();
            }
            else
            {
                Snackbar.Add(Loc["SitelockRuleRemoveFailed"].Value, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(string.Format(Loc["ErrorRemovingSitelockRule"], ex.Message), Severity.Error);
        }
    }
}

<style>
    .config-section-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 20px;
    }

    .config-kicker {
        font-family: var(--font-mono);
        font-size: 11px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 6px;
    }

    .config-title {
        margin: 0;
        font-family: var(--font-display);
        font-size: 26px;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: var(--text);
    }

    .config-desc {
        margin: 6px 0 0;
        font-family: var(--font-ui);
        font-size: 13px;
        color: var(--text-dim);
    }

    .config-desc code {
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--accent);
        background: rgba(var(--glow), 0.12);
        border-radius: 4px;
        padding: 1px 5px;
    }

    .config-group-title {
        font-family: var(--font-ui);
        font-size: 13px;
        font-weight: 600;
        color: var(--text);
        margin: 0 0 8px 2px;
    }

    .config-field-card {
        background: var(--surface);
        border: 1px solid var(--border-soft);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow);
        overflow: hidden;
    }

    .config-pad {
        padding: 18px 22px;
    }

    .config-add-fields {
        display: flex;
        gap: 12px;
        align-items: flex-end;
    }

    .config-add-field {
        flex: 1;
        min-width: 0;
    }

    .config-field-label-text {
        display: block;
        font-family: var(--font-mono);
        font-size: 11px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--text-faint);
        margin-bottom: 6px;
    }

    .config-input {
        width: 100%;
        padding: 9px 12px;
        background: var(--surface-3);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        color: var(--text);
        font-family: var(--font-mono);
        font-size: 13px;
        outline: none;
        transition: border-color 0.12s;
    }

    .config-input:focus {
        border-color: var(--accent);
    }

    .config-input::placeholder {
        color: var(--text-faint);
    }

    .config-primary-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        flex-shrink: 0;
        padding: 9px 16px;
        border-radius: var(--radius);
        border: none;
        background: var(--accent);
        color: var(--accent-on);
        cursor: pointer;
        font-family: var(--font-ui);
        font-size: 13px;
        font-weight: 600;
        transition: opacity 0.12s;
    }

    .config-primary-btn:hover:not(:disabled) {
        opacity: 0.9;
    }

    .config-primary-btn:disabled {
        opacity: 0.4;
        cursor: not-allowed;
    }

    .config-list-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 12px 22px;
    }

    .config-list-row:not(:first-child) {
        border-top: 1px solid var(--border-soft);
    }

    .config-list-text {
        display: flex;
        flex-direction: column;
        gap: 2px;
        min-width: 0;
    }

    .config-list-name {
        font-family: var(--font-mono);
        font-size: 13px;
        font-weight: 600;
        color: var(--text);
    }

    .config-list-sub {
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--text-dim);
    }

    .config-empty {
        font-family: var(--font-ui);
        font-size: 12.5px;
        color: var(--text-faint);
    }

    .config-icon-btn {
        width: 32px;
        height: 32px;
        flex-shrink: 0;
        display: grid;
        place-items: center;
        border-radius: var(--radius);
        border: 1px solid var(--border);
        background: transparent;
        color: var(--text-dim);
        cursor: pointer;
    }

    .config-icon-btn--danger:hover {
        color: var(--mud-palette-error, #e57373);
        border-color: rgba(229, 115, 115, 0.5);
    }

    @@media (max-width: 700px) {
        .config-add-fields {
            flex-direction: column;
            align-items: stretch;
        }
    }
</style>
