@page "/admin/roles"
@using SharpMUSH.Client.Models.Roles
@using SharpMUSH.Client.Services
@using SharpMUSH.Library.Authorization
@attribute [Authorize(Policy = "roles.admin")]
@inject RoleRegistryClient Roles
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Roles — Admin — SharpMUSH</PageTitle>

<div class="roleadmin">
    @* ── Header ── *@
    <div class="roleadmin-head">
        <div>
            <div class="roleadmin-kicker">Manage · Access control</div>
            <h1 class="roleadmin-title">Roles &amp; Permissions</h1>
        </div>
        <div class="roleadmin-actions">
            <div class="ra-seg">
                <button type="button" class="ra-seg-btn @(_tab == Tab.Roles ? "ra-seg-btn--on" : "")"
                        @onclick="@(() => _tab = Tab.Roles)">Roles</button>
                <button type="button" class="ra-seg-btn @(_tab == Tab.Assignments ? "ra-seg-btn--on" : "")"
                        @onclick="@(() => _tab = Tab.Assignments)">Assignments</button>
            </div>
            @if (_tab == Tab.Roles)
            {
                <button type="button" class="ra-btn ra-btn--primary" @onclick="NewRole">
                    <MudIcon Icon="@Icons.Material.Filled.Add" Style="font-size:14px;" /> New role
                </button>
            }
        </div>
    </div>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Style="height:2px;" />
    }
    else if (_tab == Tab.Roles)
    {
        <div class="roleadmin-grid">
            @* ── List (master) ── *@
            <div class="roleadmin-list">
                @if (SortedRoles.Count == 0)
                {
                    <div class="ra-empty-list">No roles defined.</div>
                }
                @foreach (var role in SortedRoles)
                {
                    var r = role;
                    var on = _selected?.Slug == r.Slug;
                    <button type="button" class="ra-card @(on ? "ra-card--on" : "")" @onclick="@(() => Select(r))">
                        <span class="ra-dot" style="@($"background:{SafeColor(r.Color)};")"></span>
                        <div style="flex:1;min-width:0;">
                            <div class="ra-card-name">@r.Name</div>
                            <div class="ra-card-sub">@r.Slug</div>
                        </div>
                        @if (r.IsSystem)
                        {
                            <span class="ra-badge">System</span>
                        }
                        <span class="ra-prio">@r.Priority</span>
                    </button>
                }
            </div>

            @* ── Detail / editor ── *@
            <div class="roleadmin-detail">
                @if (_editing is null)
                {
                    <div class="ra-empty-detail">
                        <MudIcon Icon="@Icons.Material.Filled.Shield" Style="font-size:40px;color:var(--text-faint);opacity:0.4;" />
                        <span>Select a role, or create a new one.</span>
                        <button type="button" class="ra-btn ra-btn--primary" @onclick="NewRole">
                            <MudIcon Icon="@Icons.Material.Filled.Add" Style="font-size:14px;" /> New role
                        </button>
                    </div>
                }
                else
                {
                    <div class="ra-detail-head">
                        <span class="ra-detail-dot" style="@($"background:{SafeColor(_editColor)};")"></span>
                        <div style="flex:1;min-width:0;">
                            <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
                                <h2 class="ra-detail-name">@(_editing.IsSystem ? _editing.Name : (string.IsNullOrWhiteSpace(_editName) ? "Untitled" : _editName))</h2>
                                @if (_editing.IsSystem)
                                {
                                    <span class="ra-badge">System</span>
                                }
                            </div>
                            <div class="ra-detail-slug">@_editing.Slug</div>
                        </div>
                    </div>

                    @* Top fields *@
                    <div class="ra-fields">
                        <div class="ra-field">
                            <div class="ra-field-label">Name</div>
                            <input class="ra-input" type="text" value="@_editName"
                                   @oninput="@(e => _editName = e.Value?.ToString() ?? string.Empty)" />
                        </div>
                        <div class="ra-field ra-field--narrow">
                            <div class="ra-field-label">Color</div>
                            <input class="ra-input" type="text" value="@_editColor"
                                   @oninput="@(e => _editColor = e.Value?.ToString() ?? string.Empty)" />
                        </div>
                        <div class="ra-field ra-field--narrow">
                            <div class="ra-field-label">Priority</div>
                            <input class="ra-input" type="number" inputmode="numeric" value="@_editPriority"
                                   @onchange="@(e => OnPriorityChange(e.Value?.ToString()))" />
                        </div>
                    </div>

                    @* Permission matrix *@
                    @foreach (var group in PortalPermission.All.GroupBy(d => d.Group))
                    {
                        <div class="ra-section">
                            <div class="ra-section-label">@group.Key</div>
                            <div class="ra-perm-card">
                                @foreach (var def in group)
                                {
                                    var d = def;
                                    var state = StateFor(d.Scope);
                                    <div class="ra-perm-row">
                                        <div class="ra-perm-label">
                                            <div class="ra-perm-name">@d.Label</div>
                                            <div class="ra-perm-desc">@d.Description</div>
                                            <code class="ra-perm-scope">@d.Scope</code>
                                        </div>
                                        <div class="ra-tristate">
                                            <button type="button"
                                                    class="ra-tri ra-tri--inherit @(state == "Inherit" ? "ra-tri--on" : "")"
                                                    @onclick="@(() => SetState(d.Scope, "Inherit"))">Inherit</button>
                                            <button type="button"
                                                    class="ra-tri ra-tri--allow @(state == "Allow" ? "ra-tri--on" : "")"
                                                    @onclick="@(() => SetState(d.Scope, "Allow"))">Allow</button>
                                            <button type="button"
                                                    class="ra-tri ra-tri--deny @(state == "Deny" ? "ra-tri--on" : "")"
                                                    @onclick="@(() => SetState(d.Scope, "Deny"))">Deny</button>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    @* Save / delete actions *@
                    <div class="ra-section ra-section--actions">
                        <button type="button" class="ra-btn ra-btn--primary" @onclick="SaveRole" disabled="@_saving">
                            <MudIcon Icon="@Icons.Material.Filled.Save" Style="font-size:14px;" /> Save role
                        </button>
                        @if (!_editing.IsSystem)
                        {
                            <button type="button" class="ra-btn ra-btn--danger" @onclick="DeleteRole" disabled="@_saving">
                                <MudIcon Icon="@Icons.Material.Filled.Delete" Style="font-size:14px;" /> Delete
                            </button>
                        }
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        @* ── Assignments ── *@
        <div class="roleadmin-assign">
            <div class="ra-search">
                <MudIcon Icon="@Icons.Material.Filled.Search" Style="font-size:14px;color:var(--text-faint);" />
                <input value="@_lookupName" placeholder="Search by username…"
                       @oninput="@(e => _lookupName = e.Value?.ToString() ?? string.Empty)"
                       @onkeydown="OnLookupKeyDown" />
                <button type="button" class="ra-btn ra-btn--primary" @onclick="Lookup" disabled="@_looking">
                    @if (_looking)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                    }
                    else
                    {
                        <text>Look up</text>
                    }
                </button>
            </div>

            @if (_lookedUp && _account is null)
            {
                <div class="ra-empty-detail">
                    <MudIcon Icon="@Icons.Material.Filled.PersonOff" Style="font-size:40px;color:var(--text-faint);opacity:0.4;" />
                    <span>No account found for &ldquo;@_lookupName&rdquo;.</span>
                </div>
            }
            else if (_account is not null)
            {
                <div class="ra-account-card">
                    <div class="ra-account-head">
                        <div style="flex:1;min-width:0;">
                            <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
                                <h2 class="ra-detail-name">@_account.Username</h2>
                                @if (_account.IsDisabled)
                                {
                                    <span class="ra-badge ra-badge--danger">Disabled</span>
                                }
                            </div>
                            <div class="ra-account-email">@_account.Email</div>
                        </div>
                    </div>

                    <div class="ra-section">
                        <div class="ra-section-label">Assigned roles</div>
                        <div class="ra-chips">
                            @if (_account.RoleSlugs.Length == 0)
                            {
                                <span class="ra-empty">No roles assigned.</span>
                            }
                            @foreach (var slug in _account.RoleSlugs)
                            {
                                var s = slug;
                                var role = _roles.FirstOrDefault(r => r.Slug == s);
                                <span class="ra-chip">
                                    <span class="ra-dot ra-dot--sm" style="@($"background:{SafeColor(role?.Color ?? "#888")};")"></span>
                                    @(role?.Name ?? s)
                                    <button type="button" class="ra-chip-x" title="Remove"
                                            @onclick="@(() => RemoveAssignment(s))">×</button>
                                </span>
                            }
                        </div>
                    </div>

                    @if (Assignable.Count > 0)
                    {
                        <div class="ra-section">
                            <div class="ra-section-label">Add role</div>
                            <div class="ra-chips">
                                @foreach (var role in Assignable)
                                {
                                    var r = role;
                                    <button type="button" class="ra-add-chip" @onclick="@(() => AddAssignment(r.Slug))">
                                        <span class="ra-dot ra-dot--sm" style="@($"background:{SafeColor(r.Color)};")"></span>
                                        @r.Name
                                        <MudIcon Icon="@Icons.Material.Filled.Add" Style="font-size:14px;" />
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="ra-empty-detail">
                    <MudIcon Icon="@Icons.Material.Filled.ManageAccounts" Style="font-size:40px;color:var(--text-faint);opacity:0.4;" />
                    <span>Search for an account to manage its roles.</span>
                </div>
            }
        </div>
    }
</div>

<style>
    .roleadmin { padding: var(--cpad); }

    .roleadmin-head {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
        margin-bottom: 20px;
    }
    .roleadmin-kicker {
        font-family: var(--font-mono);
        font-size: 11px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 6px;
    }
    .roleadmin-title {
        margin: 0;
        font-family: var(--font-display);
        font-size: 26px;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: var(--text);
    }
    .roleadmin-actions { display: flex; gap: 10px; align-items: center; }

    /* Segmented toggle */
    .ra-seg {
        display: inline-flex;
        padding: 3px;
        gap: 2px;
        border-radius: var(--radius);
        border: 1px solid var(--border);
        background: var(--surface-2);
    }
    .ra-seg-btn {
        padding: 6px 14px;
        border: none;
        background: transparent;
        color: var(--text-dim);
        font-family: var(--font-ui);
        font-size: 12.5px;
        font-weight: 500;
        border-radius: calc(var(--radius) - 2px);
        cursor: pointer;
        transition: all 0.12s;
    }
    .ra-seg-btn:hover { color: var(--text); }
    .ra-seg-btn--on {
        background: var(--accent);
        color: var(--accent-on);
        font-weight: 600;
    }

    .ra-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 13px;
        border-radius: var(--radius);
        border: 1px solid var(--border);
        background: var(--surface-2);
        color: var(--text);
        font-family: var(--font-ui);
        font-size: 12.5px;
        font-weight: 500;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.12s;
    }
    .ra-btn:hover { border-color: rgba(var(--glow), 0.4); }
    .ra-btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .ra-btn--primary {
        background: var(--accent);
        color: var(--accent-on);
        border-color: transparent;
        font-weight: 600;
        box-shadow: 0 0 18px rgba(var(--glow), 0.25);
    }
    .ra-btn--primary:hover { filter: brightness(1.08); }
    .ra-btn--danger {
        color: #e57373;
        border-color: rgba(229, 115, 115, 0.4);
        background: transparent;
    }
    .ra-btn--danger:hover { border-color: rgba(229, 115, 115, 0.7); }

    .roleadmin-grid {
        display: grid;
        grid-template-columns: 340px minmax(0, 1fr);
        gap: 16px;
    }
    @@media (max-width: 820px) {
        .roleadmin-grid { grid-template-columns: 1fr; }
    }

    /* List */
    .roleadmin-list { display: flex; flex-direction: column; gap: 8px; }
    .ra-empty-list { padding: 16px; color: var(--text-faint); font-size: 13px; text-align: center; }
    .ra-card {
        display: flex;
        align-items: center;
        gap: 11px;
        text-align: left;
        padding: 14px;
        cursor: pointer;
        background: var(--surface);
        border-radius: var(--radius-lg);
        border: 1px solid var(--border-soft);
        transition: border-color 0.12s, box-shadow 0.12s;
    }
    .ra-card:hover { border-color: rgba(var(--glow), 0.3); }
    .ra-card--on {
        border-color: rgba(var(--glow), 0.45);
        box-shadow: 0 0 0 1px rgba(var(--glow), 0.25);
    }
    .ra-dot {
        width: 12px; height: 12px; border-radius: 99px; flex-shrink: 0;
        box-shadow: 0 0 6px rgba(0,0,0,0.4);
    }
    .ra-dot--sm { width: 9px; height: 9px; }
    .ra-card-name {
        font-family: var(--font-display); font-size: 14px; font-weight: 600; color: var(--text);
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .ra-card-sub { font-family: var(--font-mono); font-size: 10.5px; color: var(--text-faint); }
    .ra-prio {
        font-family: var(--font-mono); font-size: 12px; color: var(--text-dim); flex-shrink: 0;
    }
    .ra-badge {
        font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.04em; text-transform: uppercase;
        padding: 2px 7px; border-radius: 99px; flex-shrink: 0;
        color: #b39cff; background: rgba(179, 156, 255, 0.12); border: 1px solid rgba(179, 156, 255, 0.3);
    }
    .ra-badge--danger {
        color: #e57373; background: rgba(229, 115, 115, 0.12); border-color: rgba(229, 115, 115, 0.3);
    }

    /* Detail */
    .roleadmin-detail, .roleadmin-assign {
        background: var(--surface);
        border: 1px solid var(--border-soft);
        border-radius: var(--radius-lg);
        overflow: hidden;
        align-self: start;
    }
    .ra-empty-detail {
        display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px;
        padding: 60px 20px; color: var(--text-faint); font-family: var(--font-ui); font-size: 14px;
    }
    .ra-detail-head {
        display: flex; align-items: flex-start; gap: 14px; padding: 20px 22px;
        border-bottom: 1px solid var(--border-soft);
    }
    .ra-detail-dot {
        width: 28px; height: 28px; border-radius: 99px; flex-shrink: 0; margin-top: 2px;
        box-shadow: 0 0 10px rgba(0,0,0,0.4);
    }
    .ra-detail-name {
        margin: 0; font-family: var(--font-display); font-size: 19px; font-weight: 600; color: var(--text);
    }
    .ra-detail-slug { font-family: var(--font-mono); font-size: 11.5px; color: var(--accent); margin-top: 3px; }

    .ra-fields {
        display: flex; gap: 16px; flex-wrap: wrap;
        padding: 18px 22px; border-bottom: 1px solid var(--border-soft);
    }
    .ra-field { flex: 1; min-width: 160px; }
    .ra-field--narrow { flex: 0 0 130px; min-width: 110px; }
    .ra-field-label {
        font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase;
        color: var(--text-faint); margin-bottom: 6px;
    }
    .ra-input {
        width: 100%;
        padding: 9px 12px;
        background: var(--surface-3);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        color: var(--text);
        font-family: var(--font-mono);
        font-size: 13px;
        outline: none;
        transition: border-color 0.12s;
    }
    .ra-input:focus { border-color: var(--accent); }

    .ra-section { padding: 18px 22px; border-bottom: 1px solid var(--border-soft); }
    .ra-section:last-child { border-bottom: none; }
    .ra-section--actions { display: flex; gap: 10px; flex-wrap: wrap; }
    .ra-section-label {
        font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase;
        color: var(--text-faint); margin-bottom: 10px;
    }

    /* Permission matrix */
    .ra-perm-card {
        background: var(--surface-3);
        border: 1px solid var(--border-soft);
        border-radius: var(--radius-lg);
        overflow: hidden;
    }
    .ra-perm-row {
        display: flex; align-items: center; gap: 24px;
        padding: 14px 16px;
    }
    .ra-perm-row:not(:first-child) { border-top: 1px solid var(--border-soft); }
    .ra-perm-label { flex: 1; min-width: 0; }
    .ra-perm-name {
        font-family: var(--font-ui); font-size: 14px; font-weight: 600; color: var(--text); margin-bottom: 3px;
    }
    .ra-perm-desc { font-family: var(--font-ui); font-size: 12.5px; color: var(--text-dim); }
    .ra-perm-scope {
        font-family: var(--font-mono); font-size: 11px; color: var(--text-faint); display: block; margin-top: 2px;
    }

    /* Tri-state */
    .ra-tristate {
        display: inline-flex;
        padding: 3px;
        gap: 2px;
        border-radius: var(--radius);
        border: 1px solid var(--border);
        background: var(--surface-2);
        flex-shrink: 0;
    }
    .ra-tri {
        padding: 5px 11px;
        border: none;
        background: transparent;
        color: var(--text-dim);
        font-family: var(--font-ui);
        font-size: 12px;
        font-weight: 500;
        border-radius: calc(var(--radius) - 2px);
        cursor: pointer;
        transition: all 0.12s;
    }
    .ra-tri:hover { color: var(--text); }
    .ra-tri--inherit.ra-tri--on {
        background: var(--surface-3); color: var(--text); border: 1px solid var(--border);
    }
    .ra-tri--allow.ra-tri--on {
        background: rgba(108, 222, 154, 0.16); color: #6cde9a;
        box-shadow: inset 0 0 0 1px rgba(108, 222, 154, 0.4);
    }
    .ra-tri--deny.ra-tri--on {
        background: rgba(229, 115, 115, 0.16); color: #e57373;
        box-shadow: inset 0 0 0 1px rgba(229, 115, 115, 0.4);
    }

    /* Assignments */
    .ra-search {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 6px 6px 6px 14px;
        margin: 18px 22px;
        background: var(--surface-3);
        border: 1px solid var(--border);
        border-radius: var(--radius);
    }
    .ra-search:focus-within { border-color: var(--accent); }
    .ra-search input {
        flex: 1; min-width: 0; padding: 6px 0; background: transparent; border: none; outline: none;
        color: var(--text); font-family: var(--font-ui); font-size: 13px;
    }
    .ra-search input::placeholder { color: var(--text-faint); }

    .ra-account-card { }
    .ra-account-head {
        display: flex; align-items: flex-start; gap: 14px; padding: 4px 22px 18px;
        border-bottom: 1px solid var(--border-soft);
    }
    .ra-account-email { font-family: var(--font-mono); font-size: 11.5px; color: var(--text-dim); margin-top: 3px; }

    .ra-chips { display: flex; gap: 8px; flex-wrap: wrap; }
    .ra-empty { font-family: var(--font-ui); font-size: 12.5px; color: var(--text-faint); }
    .ra-chip {
        display: inline-flex; align-items: center; gap: 7px;
        font-family: var(--font-ui); font-size: 12.5px;
        padding: 5px 7px 5px 11px;
        border-radius: 99px;
        background: var(--surface-2);
        color: var(--text);
        border: 1px solid var(--border);
    }
    .ra-chip-x {
        border: none; background: transparent; color: var(--text-dim);
        cursor: pointer; font-size: 16px; line-height: 1; padding: 0 2px;
    }
    .ra-chip-x:hover { color: #e57373; }
    .ra-add-chip {
        display: inline-flex; align-items: center; gap: 7px;
        font-family: var(--font-ui); font-size: 12.5px;
        padding: 5px 11px;
        border-radius: 99px;
        background: transparent;
        color: var(--text-dim);
        border: 1px dashed var(--border);
        cursor: pointer;
        transition: all 0.12s;
    }
    .ra-add-chip:hover { border-color: rgba(var(--glow), 0.4); color: var(--accent); }
</style>

@code {
    private enum Tab { Roles, Assignments }

    private Tab _tab = Tab.Roles;
    private bool _loading = true;
    private bool _saving;
    private List<PortalRoleModel> _roles = [];

    // Selected / editing role
    private PortalRoleModel? _selected;
    private PortalRoleModel? _editing;
    private string _editName = "";
    private string _editColor = "#6cde9a";
    private int _editPriority;
    private Dictionary<string, string> _editPerms = new();

    // Assignments
    private string _lookupName = "";
    private bool _looking;
    private bool _lookedUp;
    private AccountRolesModel? _account;

    private List<PortalRoleModel> SortedRoles =>
        _roles.OrderByDescending(r => r.Priority).ThenBy(r => r.Name).ToList();

    private List<PortalRoleModel> Assignable =>
        _account is null
            ? []
            : SortedRoles.Where(r => !_account.RoleSlugs.Contains(r.Slug)).ToList();

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _roles = (await Roles.ListAsync()).ToList();
        _loading = false;

        if (_selected is not null)
        {
            var refreshed = _roles.FirstOrDefault(r => r.Slug == _selected.Slug);
            if (refreshed is not null)
            {
                Select(refreshed);
            }
            else
            {
                _selected = null;
                _editing = null;
            }
        }
    }

    private void Select(PortalRoleModel role)
    {
        _selected = role;
        _editing = role;
        _editName = role.Name;
        _editColor = role.Color;
        _editPriority = role.Priority;
        _editPerms = new Dictionary<string, string>(role.Permissions);
    }

    private async Task NewRole()
    {
        var dialog = await DialogService.ShowAsync<RoleEditDialog>("New role");
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            var slug = result.Data as string;
            await LoadAsync();
            if (slug is not null)
            {
                var created = _roles.FirstOrDefault(r => r.Slug == slug);
                if (created is not null) Select(created);
            }
        }
    }

    private void OnPriorityChange(string? raw)
    {
        if (int.TryParse(raw?.Trim(), out var v))
        {
            _editPriority = v;
        }
    }

    private string StateFor(string scope) =>
        _editPerms.TryGetValue(scope, out var s) && !string.IsNullOrEmpty(s) ? s : "Inherit";

    private void SetState(string scope, string state)
    {
        if (state == "Inherit")
        {
            _editPerms[scope] = "Inherit";
        }
        else
        {
            _editPerms[scope] = state;
        }
    }

    private async Task SaveRole()
    {
        if (_editing is null) return;

        if (string.IsNullOrWhiteSpace(_editName))
        {
            Snackbar.Add("Name is required.", Severity.Warning);
            return;
        }

        _saving = true;
        var model = new PortalRoleModel(
            _editing.Slug,
            _editName.Trim(),
            string.IsNullOrWhiteSpace(_editColor) ? "#6cde9a" : _editColor.Trim(),
            _editPriority,
            _editing.IsSystem,
            new Dictionary<string, string>(_editPerms),
            _editing.CreatedAt,
            DateTimeOffset.UtcNow.ToUnixTimeMilliseconds());

        var (ok, error) = await Roles.UpsertAsync(model);
        _saving = false;

        if (ok)
        {
            Snackbar.Add($"Saved {model.Slug}.", Severity.Success);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add(error ?? "Save failed.", Severity.Error);
        }
    }

    private async Task DeleteRole()
    {
        if (_editing is null || _editing.IsSystem) return;

        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete role",
            $"Delete '{_editing.Name}' ({_editing.Slug})? This removes it from any accounts that hold it.",
            yesText: "Delete", cancelText: "Cancel");

        if (confirmed == true)
        {
            var (ok, error) = await Roles.DeleteAsync(_editing.Slug);
            if (ok)
            {
                Snackbar.Add($"Deleted {_editing.Slug}.", Severity.Success);
                _selected = null;
                _editing = null;
                await LoadAsync();
            }
            else
            {
                Snackbar.Add(error ?? "Failed to delete role.", Severity.Error);
            }
        }
    }

    // ── Assignments ──

    private async Task OnLookupKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter") await Lookup();
    }

    private async Task Lookup()
    {
        var name = _lookupName.Trim();
        if (string.IsNullOrEmpty(name))
        {
            Snackbar.Add("Enter a username to look up.", Severity.Warning);
            return;
        }

        _looking = true;
        _account = await Roles.LookupAccountAsync(name);
        _looking = false;
        _lookedUp = true;
    }

    private async Task AddAssignment(string slug)
    {
        if (_account is null) return;

        if (await Roles.AssignAsync(_account.AccountId, slug))
        {
            Snackbar.Add($"Assigned {slug}.", Severity.Success);
            _account = await Roles.LookupAccountAsync(_account.Username);
        }
        else
        {
            Snackbar.Add("Failed to assign role.", Severity.Error);
        }
    }

    private async Task RemoveAssignment(string slug)
    {
        if (_account is null) return;

        if (await Roles.RemoveAsync(_account.AccountId, slug))
        {
            Snackbar.Add($"Removed {slug}.", Severity.Success);
            _account = await Roles.LookupAccountAsync(_account.Username);
        }
        else
        {
            Snackbar.Add("Failed to remove role.", Severity.Error);
        }
    }

    private static string SafeColor(string color) =>
        string.IsNullOrWhiteSpace(color) ? "var(--text-faint)" : color;
}
