@page "/admin/packages/browse"
@attribute [Authorize(Roles = "Wizard")]
@using SharpMUSH.Client.Services
@using SharpMUSH.Library.Models.Packages
@inject PackagesAdminService Packages
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Browse Packages — Admin — SharpMUSH</PageTitle>

<div style="padding:var(--cpad);">
    <div class="pkg-header">
        <div class="pkg-kicker">Build · Package registry</div>
        <h1 class="pkg-title">Browse Packages</h1>
        <p class="pkg-desc">
            Refreshes the remote's repo cache and lists its packages. Versions come from release tags;
            the branch tip is the dev channel.
        </p>
    </div>

    <div class="pkg-toolbar mb-4">
        <MudSelect T="string" @bind-Value="_selectedRemote" Label="Remote" Variant="Variant.Outlined"
                   Margin="Margin.Dense" Style="max-width: 320px">
            @foreach (var remote in _remotes ?? [])
            {
                <MudSelectItem Value="@remote.Name">@remote.Name</MudSelectItem>
            }
        </MudSelect>
        <MudButton Class="pkg-btn-primary" Variant="Variant.Filled" Disabled="@(_busy || string.IsNullOrEmpty(_selectedRemote))"
                   OnClick="@BrowseAsync">Refresh &amp; browse</MudButton>
        @if (_remoteRecord is not null)
        {
            <TrustBadge Trust="@_remoteRecord.Trust" />
        }
    </div>

    @if (_remoteRecord is { Trust: PackageRemoteTrust.Unknown })
    {
        <MudAlert Severity="Severity.Warning" Class="mb-4">
            This source has not been reviewed. Inspect all code on the review screen before applying.
        </MudAlert>
    }

    @if (_busy)
    {
        <MudProgressLinear Indeterminate="true" />
    }

    @if (_snapshot is not null)
    {
        <div class="pkg-snapshot-meta mb-2">
            @_snapshot.Url at @_snapshot.HeadCommit[..Math.Min(10, _snapshot.HeadCommit.Length)]
        </div>
        <div class="pkg-grid">
            @foreach (var entry in _snapshot.Packages)
            {
                <div class="pkg-card">
                    <div class="pkg-card-head">
                        <span style="flex:1;min-width:0;">@(entry.PackageId ?? entry.Path)</span>
                        <MudIconButton Icon="@Icons.Material.Filled.Description" Size="Size.Small" title="README"
                                       OnClick="@(() => ShowReadmeAsync(entry))" />
                    </div>
                    <div class="pkg-card-body">
                        <div style="font-size:13px;color:var(--text-dim);margin-bottom:12px;">@(entry.Description ?? "(no description)")</div>
                        @if (entry.PackageId is null)
                        {
                            <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2">Manifest at the tip did not parse.</MudAlert>
                        }
                        <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
                            <MudSelect T="string" Value="@SelectedVersion(entry)" ValueChanged="@(v => _selectedVersions[entry.Path] = v)"
                                       Label="Version" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width: 220px">
                                @foreach (var version in entry.Versions)
                                {
                                    <MudSelectItem Value="@version.Version">@version.Version</MudSelectItem>
                                }
                                <MudSelectItem Value="@DevChannel">dev channel (@(entry.Version ?? "tip"))</MudSelectItem>
                            </MudSelect>
                            <MudButton Class="pkg-btn-primary" Variant="Variant.Filled" Size="Size.Small"
                                       OnClick="@(() => GoToReview(entry))">Review install</MudButton>
                        </div>
                        @if (entry.Versions.Count == 0)
                        {
                            <div style="font-size:12px;color:var(--text-faint);margin-top:8px;">
                                No release tags — only the dev channel is available.
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

<MudDialog @bind-Visible="_showReadme" Options="@(new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true })">
    <TitleContent><MudText Typo="Typo.h6">@_readmeTitle</MudText></TitleContent>
    <DialogContent>
        @if (_readmeHtml is null)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else
        {
            <div class="wiki-content">@((MarkupString)_readmeHtml)</div>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showReadme = false)">Close</MudButton>
    </DialogActions>
</MudDialog>

<style>
    .pkg-header { margin-bottom: 24px; }
    .pkg-kicker {
        font-family: var(--font-mono);
        font-size: 11px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 6px;
    }
    .pkg-title {
        font-family: var(--font-display);
        font-size: 26px;
        font-weight: 700;
        color: var(--text);
        margin: 0 0 6px;
    }
    .pkg-desc {
        color: var(--text-dim);
        font-size: 14px;
        margin: 0;
        max-width: 760px;
    }
    .pkg-toolbar {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }
    .pkg-snapshot-meta {
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--text-faint);
    }
    .pkg-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
        gap: 16px;
    }
    .pkg-card {
        background: var(--surface);
        border: 1px solid var(--border-soft);
        border-radius: var(--radius-lg);
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.25);
        overflow: hidden;
    }
    .pkg-card-head {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 14px 18px;
        border-bottom: 1px solid var(--border-soft);
        font-family: var(--font-display);
        font-size: 15px;
        font-weight: 600;
        color: var(--text);
    }
    .pkg-card-body { padding: 16px 18px; }
    .pkg-btn-primary {
        background: var(--accent) !important;
        color: var(--accent-on) !important;
    }
</style>

@code {
    private const string DevChannel = "__dev__";

    private IReadOnlyList<PackageRemoteRecord>? _remotes;
    private PackageRemoteRecord? _remoteRecord;
    private string _selectedRemote = "";
    private PackageRepoSnapshot? _snapshot;
    private readonly Dictionary<string, string> _selectedVersions = new();
    private bool _busy;

    private bool _showReadme;
    private string? _readmeTitle;
    private string? _readmeHtml;

    protected override async Task OnInitializedAsync()
    {
        _remotes = await Packages.GetRemotesAsync();

        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var preset = query["remote"];
        if (!string.IsNullOrEmpty(preset) && _remotes.Any(r => r.Name == preset))
        {
            _selectedRemote = preset;
            await BrowseAsync();
        }
        else if (_remotes.Count == 1)
        {
            _selectedRemote = _remotes[0].Name;
        }
    }

    private string SelectedVersion(PackageRepoEntry entry) =>
        _selectedVersions.GetValueOrDefault(entry.Path)
        ?? entry.Versions.FirstOrDefault()?.Version
        ?? DevChannel;

    private async Task BrowseAsync()
    {
        _busy = true;
        _snapshot = null;
        try
        {
            _remoteRecord = (_remotes ?? []).FirstOrDefault(r => r.Name == _selectedRemote);
            var (snapshot, error) = await Packages.BrowseAsync(_selectedRemote);
            if (error is not null)
            {
                Snackbar.Add(error, Severity.Error);
                return;
            }

            _snapshot = snapshot;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ShowReadmeAsync(PackageRepoEntry entry)
    {
        _readmeTitle = entry.PackageId ?? entry.Path;
        _readmeHtml = null;
        _showReadme = true;
        var readme = await Packages.GetRemoteReadmeAsync(_selectedRemote, entry.Path);
        _readmeHtml = readme?.Html ?? "<em>No README available.</em>";
    }

    private void GoToReview(PackageRepoEntry entry)
    {
        var version = SelectedVersion(entry);
        var versionPart = version == DevChannel ? "" : $"&version={Uri.EscapeDataString(version)}";
        Nav.NavigateTo(
            $"/admin/packages/review?remote={Uri.EscapeDataString(_selectedRemote)}&path={Uri.EscapeDataString(entry.Path)}{versionPart}");
    }
}
