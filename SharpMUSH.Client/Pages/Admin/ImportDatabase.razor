@page "/admin/database/import"
@implements IDisposable
@using SharpMUSH.Client.Services
@using SharpMUSH.Library.Services.DatabaseConversion
@inject DatabaseConversionService ConversionService
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> Loc

<div class="dbimport-page">
	<header class="dbimport-header">
		<div class="dbimport-kicker">Admin · Database</div>
		<h1 class="dbimport-title">@Loc["ImportPennMUSHDatabase"]</h1>
		<p class="dbimport-subtitle">@Loc["ImportDatabaseDescription"]</p>
	</header>

	@if (!_isConverting && _result == null)
	{
		<div class="dbimport-card dbimport-dropzone">
			<MudFileUpload T="IBrowserFile"
			               Accept=".db,.txt"
			               FilesChanged="OnFileSelected"
			               MaximumFileCount="1"
			               MaxFileSize="104857600" />
			<div class="dbimport-dropzone-inner">
				<MudIcon Icon="Icons.Material.Filled.CloudUpload" Class="dbimport-dropzone-icon" />
				<span class="dbimport-dropzone-title">@Loc["DropDatabaseFile"]</span>
				<span class="dbimport-dropzone-hint">@Loc["SupportedFormatsDb"]</span>
			</div>
		</div>

		@if (_selectedFile != null)
		{
			<div class="dbimport-card">
				<div class="dbimport-section-label">@Loc["SelectedFile"]</div>
				<div class="dbimport-file-row">
					<MudIcon Icon="Icons.Material.Filled.Description" Class="dbimport-file-icon" />
					<span class="dbimport-file-name">@_selectedFile.Name</span>
					<span class="dbimport-file-size">(@($"{_selectedFile.Size / 1024.0 / 1024.0:F1}") MB)</span>
				</div>

				<div class="dbimport-actions">
					<MudButton StartIcon="Icons.Material.Filled.Clear"
					           Class="dbimport-btn dbimport-btn-ghost"
					           OnClick="ClearSelection">
						@Loc["ClearSelection"]
					</MudButton>

					<MudButton StartIcon="Icons.Material.Filled.Upload"
					           Class="dbimport-btn dbimport-btn-primary"
					           OnClick="StartConversion"
					           Disabled="_isUploading">
						@if (_isUploading)
						{
							<MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
							<MudText Class="ms-2">@Loc["Uploading"]</MudText>
						}
						else
						{
							<MudText>@Loc["StartConversion"]</MudText>
						}
					</MudButton>
				</div>
			</div>
		}
	}
	else if (_isConverting && _progress != null)
	{
		<div class="dbimport-card">
			<div class="dbimport-section-label">@Loc["ConvertingDatabase"]</div>

			<MudProgressLinear Value="@_progress.PercentageComplete"
			                   Color="Color.Primary"
			                   Size="Size.Large"
			                   Class="mt-3 mb-2" />

			<div class="dbimport-progress-caption">
				@($"{_progress.PercentageComplete:F1}% Complete - {_progress.CurrentPhase}")
			</div>

			<div class="dbimport-grid">
				<div class="dbimport-tile">
					<div class="dbimport-tile-label">@Loc["Progress"]</div>
					<div class="dbimport-stat-list">
						<div class="dbimport-stat"><span>@Loc["Phase"]</span><strong>@_progress.CurrentPhase</strong></div>
						<div class="dbimport-stat"><span>@Loc["Elapsed"]</span><strong>@FormatTimeSpan(_progress.ElapsedTime)</strong></div>
						@if (_progress.EstimatedTimeRemaining.HasValue)
						{
							<div class="dbimport-stat"><span>@Loc["EstimatedRemaining"]</span><strong>@FormatTimeSpan(_progress.EstimatedTimeRemaining.Value)</strong></div>
						}
					</div>
				</div>

				<div class="dbimport-tile">
					<div class="dbimport-tile-label">@Loc["ObjectsCreated"]</div>
					<div class="dbimport-stat-list">
						<div class="dbimport-stat"><span>@Loc["Players"]</span><strong>@_progress.PlayersCreated</strong></div>
						<div class="dbimport-stat"><span>@Loc["Rooms"]</span><strong>@_progress.RoomsCreated</strong></div>
						<div class="dbimport-stat"><span>@Loc["Things"]</span><strong>@_progress.ThingsCreated</strong></div>
						<div class="dbimport-stat"><span>@Loc["Exits"]</span><strong>@_progress.ExitsCreated</strong></div>
						<div class="dbimport-stat"><span>@Loc["Total"]</span><strong>@_progress.ProcessedObjects / @_progress.TotalObjects</strong></div>
					</div>
				</div>

				<div class="dbimport-tile">
					<div class="dbimport-tile-label">@Loc["AdditionalData"]</div>
					<div class="dbimport-stat-list">
						<div class="dbimport-stat"><span>@Loc["AttributesLabel"]</span><strong>@_progress.AttributesCreated</strong></div>
						<div class="dbimport-stat"><span>@Loc["Locks"]</span><strong>@_progress.LocksCreated</strong></div>
					</div>
				</div>

				@if (_progress.RecentErrors.Any() || _progress.RecentWarnings.Any())
				{
					<div class="dbimport-tile">
						<div class="dbimport-tile-label">@Loc["Issues"]</div>
						@if (_progress.RecentErrors.Any())
						{
							<MudAlert Severity="Severity.Error" Dense="true" Class="mb-2">
								@_progress.RecentErrors.Count error(s)
							</MudAlert>
						}
						@if (_progress.RecentWarnings.Any())
						{
							<MudAlert Severity="Severity.Warning" Dense="true">
								@_progress.RecentWarnings.Count warning(s)
							</MudAlert>
						}
					</div>
				}
			</div>

			<div class="dbimport-actions dbimport-actions-start">
				<MudButton StartIcon="Icons.Material.Filled.Cancel"
				           Class="dbimport-btn dbimport-btn-danger"
				           OnClick="CancelConversion">
					@Loc["CancelConversion"]
				</MudButton>
			</div>
		</div>
	}
	else if (_result != null)
	{
		<div class="dbimport-card">
			<MudAlert Severity="@(_result.IsSuccessful ? Severity.Success : Severity.Error)" Class="mb-4">
				@if (_result.IsSuccessful)
				{
					<MudText Typo="Typo.h6">@Loc["ConversionSuccess"]</MudText>
				}
				else
				{
					<MudText Typo="Typo.h6">@Loc["ConversionErrors"]</MudText>
				}
			</MudAlert>

			<div class="dbimport-grid">
				<div class="dbimport-tile">
					<div class="dbimport-tile-label">@Loc["ObjectsConverted"]</div>
					<div class="dbimport-stat-list">
						<div class="dbimport-stat"><span>@Loc["Players"]</span><strong>@_result.PlayersConverted</strong></div>
						<div class="dbimport-stat"><span>@Loc["Rooms"]</span><strong>@_result.RoomsConverted</strong></div>
						<div class="dbimport-stat"><span>@Loc["Things"]</span><strong>@_result.ThingsConverted</strong></div>
						<div class="dbimport-stat"><span>@Loc["Exits"]</span><strong>@_result.ExitsConverted</strong></div>
						<div class="dbimport-stat"><span>@Loc["TotalObjects"]</span><strong>@_result.TotalObjects</strong></div>
					</div>
				</div>

				<div class="dbimport-tile">
					<div class="dbimport-tile-label">@Loc["AdditionalData"]</div>
					<div class="dbimport-stat-list">
						<div class="dbimport-stat"><span>@Loc["AttributesLabel"]</span><strong>@_result.AttributesConverted</strong></div>
						<div class="dbimport-stat"><span>@Loc["Locks"]</span><strong>@_result.LocksConverted</strong></div>
						<div class="dbimport-stat"><span>@Loc["Duration"]</span><strong>@FormatTimeSpan(_result.Duration)</strong></div>
					</div>
				</div>

				@if (_result.Errors.Any())
				{
					<div class="dbimport-tile dbimport-tile-wide">
						<div class="dbimport-tile-label dbimport-tile-label-error">Errors (@_result.Errors.Count)</div>
						<MudList T="string" Dense="true">
							@foreach (var error in _result.Errors)
							{
								<MudListItem T="string">
									<MudText Color="Color.Error">@error</MudText>
								</MudListItem>
							}
						</MudList>
					</div>
				}

				@if (_result.Warnings.Any())
				{
					<div class="dbimport-tile dbimport-tile-wide">
						<div class="dbimport-tile-label dbimport-tile-label-warning">Warnings (@_result.Warnings.Count)</div>
						<MudList T="string" Dense="true">
							@foreach (var warning in _result.Warnings)
							{
								<MudListItem T="string">
									<MudText Color="Color.Warning">@warning</MudText>
								</MudListItem>
							}
						</MudList>
					</div>
				}
			</div>

			<div class="dbimport-actions dbimport-actions-start">
				<MudButton StartIcon="Icons.Material.Filled.Refresh"
				           Class="dbimport-btn dbimport-btn-primary"
				           OnClick="Reset">
					@Loc["ImportAnotherDatabase"]
				</MudButton>
			</div>
		</div>
	}
</div>

<style>
	.dbimport-page {
		padding: var(--cpad);
	}

	.dbimport-header {
		margin-bottom: 24px;
	}
	.dbimport-kicker {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 10px;
	}
	.dbimport-title {
		margin: 0;
		font-family: var(--font-display);
		font-size: 26px;
		font-weight: 600;
		letter-spacing: -0.01em;
		color: var(--text);
	}
	.dbimport-subtitle {
		margin: 8px 0 0;
		font-family: var(--font-ui);
		font-size: 13.5px;
		color: var(--text-dim);
		max-width: 70ch;
	}

	.dbimport-card {
		background: var(--surface);
		border: 1px solid var(--border-soft);
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow);
		padding: 20px;
		margin-bottom: 16px;
	}

	.dbimport-dropzone {
		border: 1.5px dashed var(--border);
	}
	.dbimport-dropzone-inner {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 8px;
		min-height: 140px;
		margin-top: 8px;
	}
	.dbimport-dropzone-icon {
		font-size: 44px !important;
		color: var(--accent);
	}
	.dbimport-dropzone-title {
		font-family: var(--font-display);
		font-size: 17px;
		font-weight: 600;
		color: var(--text);
	}
	.dbimport-dropzone-hint {
		font-family: var(--font-ui);
		font-size: 12.5px;
		color: var(--text-dim);
	}

	.dbimport-section-label {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-dim);
		margin-bottom: 14px;
	}

	.dbimport-file-row {
		display: flex;
		align-items: center;
		gap: 10px;
	}
	.dbimport-file-icon {
		font-size: 20px !important;
		color: var(--accent);
	}
	.dbimport-file-name {
		font-family: var(--font-ui);
		font-size: 14px;
		color: var(--text);
	}
	.dbimport-file-size {
		font-family: var(--font-mono);
		font-size: 12px;
		color: var(--text-faint);
	}

	.dbimport-actions {
		display: flex;
		justify-content: space-between;
		gap: 12px;
		margin-top: 18px;
	}
	.dbimport-actions-start {
		justify-content: flex-start;
	}

	.dbimport-progress-caption {
		text-align: center;
		font-family: var(--font-mono);
		font-size: 13px;
		color: var(--text-dim);
		margin-bottom: 18px;
	}

	.dbimport-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 14px;
	}
	.dbimport-tile {
		background: var(--surface-3);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		padding: 16px;
	}
	.dbimport-tile-wide {
		grid-column: 1 / -1;
	}
	.dbimport-tile-label {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-dim);
		margin-bottom: 12px;
	}
	.dbimport-tile-label-error {
		color: #ff6b6b;
	}
	.dbimport-tile-label-warning {
		color: #ffb454;
	}

	.dbimport-stat-list {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}
	.dbimport-stat {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 12px;
		font-family: var(--font-ui);
		font-size: 13.5px;
		color: var(--text-dim);
	}
	.dbimport-stat strong {
		font-family: var(--font-mono);
		font-size: 14px;
		font-weight: 600;
		color: var(--text);
	}

	::deep .dbimport-btn {
		text-transform: none;
		font-family: var(--font-ui);
		font-weight: 600;
		border-radius: var(--radius);
	}
	::deep .dbimport-btn-primary {
		background: var(--accent);
		color: var(--accent-on);
	}
	::deep .dbimport-btn-primary:hover {
		background: var(--accent-dim);
	}
	::deep .dbimport-btn-ghost {
		color: var(--text-dim);
		border: 1px solid var(--border);
		background: var(--surface-2);
	}
	::deep .dbimport-btn-ghost:hover {
		color: var(--text);
		border-color: var(--accent);
	}
	::deep .dbimport-btn-danger {
		color: #ff6b6b;
		border: 1px solid rgba(255, 107, 107, 0.4);
		background: transparent;
	}
	::deep .dbimport-btn-danger:hover {
		background: rgba(255, 107, 107, 0.1);
	}
</style>

@code {
	private IBrowserFile? _selectedFile;
	private bool _isUploading;
	private bool _isConverting;
	private bool _isUpdatingProgress;
	private string? _sessionId;
	private ConversionProgress? _progress;
	private ConversionResult? _result;
	private System.Threading.Timer? _progressTimer;

	private async Task OnFileSelected(IBrowserFile? file)
	{
		_selectedFile = file;
		StateHasChanged();
	}

	private void ClearSelection()
	{
		_selectedFile = null;
		StateHasChanged();
	}

	private async Task StartConversion()
	{
		if (_selectedFile is null)
			return;

		_isUploading = true;
		StateHasChanged();

		try
		{
			await using var stream = _selectedFile.OpenReadStream(maxAllowedSize: 104857600); // 100MB
			_sessionId = await ConversionService.UploadDatabaseAsync(stream, _selectedFile.Name);

			if (_sessionId != null)
			{
				_isUploading = false;
				_isConverting = true;
				StateHasChanged();

				// Start polling for progress with timer callback
				_progressTimer = new System.Threading.Timer(OnTimerCallback, null, TimeSpan.Zero, TimeSpan.FromSeconds(1));
			}
		}
		catch (Exception ex)
		{
			await JSRuntime.InvokeVoidAsync("console.error", $"Error starting conversion: {ex.Message}");
			_isUploading = false;
			StateHasChanged();
		}
	}

	private void OnTimerCallback(object? state)
	{
		// Fire-and-forget with exception handling
		_ = Task.Run(async () =>
		{
			try
			{
				await UpdateProgressAsync();
			}
			catch (Exception ex)
			{
				// Log error and stop polling
				await JSRuntime.InvokeVoidAsync("console.error", $"Progress update failed: {ex.Message}");
				_progressTimer?.Dispose();
				_isConverting = false;
			}
		});
	}

	private async Task UpdateProgressAsync()
	{
		// Prevent concurrent executions
		if (_isUpdatingProgress || _sessionId == null || !_isConverting)
			return;

		_isUpdatingProgress = true;

		try
		{
			_progress = await ConversionService.GetProgressAsync(_sessionId);

			// Check if conversion is complete
			if (_progress?.PercentageComplete >= 100)
			{
				_result = await ConversionService.GetResultAsync(_sessionId);
				_isConverting = false;
				_progressTimer?.Dispose();
			}

			await InvokeAsync(StateHasChanged);
		}
		catch (Exception ex)
		{
			await JSRuntime.InvokeVoidAsync("console.error", $"Error updating progress: {ex.Message}");
			// Stop polling on error
			_progressTimer?.Dispose();
			_isConverting = false;
		}
		finally
		{
			_isUpdatingProgress = false;
		}
	}

	private async Task CancelConversion()
	{
		if (_sessionId == null)
			return;

		try
		{
			await ConversionService.CancelConversionAsync(_sessionId);
			_isConverting = false;
			_progressTimer?.Dispose();
			Reset();
		}
		catch (Exception ex)
		{
			await JSRuntime.InvokeVoidAsync("console.error", $"Error cancelling conversion: {ex.Message}");
		}
	}

	private void Reset()
	{
		_selectedFile = null;
		_sessionId = null;
		_progress = null;
		_result = null;
		_isConverting = false;
		_isUploading = false;
		_progressTimer?.Dispose();
		StateHasChanged();
	}

	private string FormatTimeSpan(TimeSpan ts)
	{
		if (ts.TotalHours >= 1)
			return $"{ts.Hours}h {ts.Minutes}m {ts.Seconds}s";
		if (ts.TotalMinutes >= 1)
			return $"{ts.Minutes}m {ts.Seconds}s";
		return $"{ts.Seconds}s";
	}

	public void Dispose()
	{
		_progressTimer?.Dispose();
	}
}
