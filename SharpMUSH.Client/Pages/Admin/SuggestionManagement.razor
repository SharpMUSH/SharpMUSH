@page "/admin/suggestions"
@using System.Net.Http.Json
@using Microsoft.Extensions.Localization
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IStringLocalizer<SharedResource> Loc

<PageTitle>@Loc["SuggestionManagement"]</PageTitle>

<div style="padding:var(--cpad);">
    <div class="ph-header">
        <div class="ph-kicker">Administration · Spellcheck</div>
        <div class="ph-header-row">
            <h1 class="ph-title">@Loc["SuggestionManagement"]</h1>
            <div class="ph-header-actions">
                <MudButton Variant="Variant.Filled"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="ShowAddCategoryDialog"
                           Style="background:var(--accent);color:var(--accent-on);font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.06em;">
                    @Loc["AddCategory"]
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.Refresh"
                           OnClick="LoadSuggestionsAsync"
                           Style="border-color:var(--border);color:var(--text-dim);font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.06em;">
                    @Loc["Refresh"]
                </MudButton>
            </div>
        </div>
        <p class="ph-subtitle">@Loc["SuggestionsDescription"]</p>
    </div>

    <MudStack Spacing="4">
        @if (_isLoading)
        {
            <div class="d-flex justify-center pa-4">
                <MudProgressCircular Indeterminate="true" Style="color:var(--accent);" />
            </div>
        }
        else if (_categories == null || !_categories.Any())
        {
            <div class="ph-empty">
                <MudIcon Icon="@Icons.Material.Filled.Spellcheck" Class="ph-empty-icon" />
                <div class="ph-empty-text">@Loc["NoSuggestionCategories"]</div>
            </div>
        }

        @if (_categories != null && _categories.Any())
        {
            <div class="ph-tiles">
                <div class="ph-tile">
                    <div class="ph-tile-icon"><MudIcon Icon="@Icons.Material.Filled.Category" /></div>
                    <div class="ph-tile-value">@_categories.Count</div>
                    <div class="ph-tile-label">@Loc["Categories"]</div>
                </div>
                <div class="ph-tile">
                    <div class="ph-tile-icon" style="color:#6cde9a;background:rgba(108,222,154,0.12);"><MudIcon Icon="@Icons.Material.Filled.TextFields" /></div>
                    <div class="ph-tile-value">@_categories.Sum(c => c.Value.Count)</div>
                    <div class="ph-tile-label">@Loc["TotalWords"]</div>
                </div>
                <div class="ph-tile">
                    <div class="ph-tile-icon" style="color:#5aa9ff;background:rgba(90,169,255,0.12);"><MudIcon Icon="@Icons.Material.Filled.TrendingUp" /></div>
                    <div class="ph-tile-value">@(_categories.Any() ? Math.Round(_categories.Average(c => c.Value.Count), 1) : 0)</div>
                    <div class="ph-tile-label">@Loc["AvgWordsPerCategory"]</div>
                </div>
            </div>

            <div class="ph-card" style="padding:0;overflow:hidden;">
                <div class="ph-card-head">@string.Format(Loc["CategoriesCount"], _categories.Count)</div>
                <div style="padding:8px 12px;">
                    <MudExpansionPanels Elevation="0">
                        @foreach (var category in _categories.OrderBy(c => c.Key))
                        {
                            <MudExpansionPanel>
                                <TitleContent>
                                    <div style="display: flex; align-items: center; gap: 8px; width: 100%;">
                                        <MudIcon Icon="@Icons.Material.Filled.Category" Style="color:var(--accent);" />
                                        <span style="font-family:var(--font-display);font-weight:600;color:var(--text);">@category.Key</span>
                                        <span class="ph-chip ph-chip-info">@string.Format(Loc["WordsCount"].Value, category.Value.Count)</span>
                                        <MudSpacer />
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                       Size="Size.Small"
                                                       Style="color:#e57373;"
                                                       OnClick="@(async () => await DeleteCategoryAsync(category.Key))" />
                                    </div>
                                </TitleContent>
                                <ChildContent>
                                    <div class="ph-panel-inner">
                                        <MudStack Spacing="3">
                                            <!-- Add Word Form -->
                                            <MudStack Row="true" AlignItems="AlignItems.Center">
                                                <MudTextField @bind-Value="_newWord"
                                                              Label="@Loc["AddNewWord"].Value"
                                                              Variant="Variant.Outlined"
                                                              Margin="Margin.Dense"
                                                              Adornment="Adornment.End"
                                                              AdornmentIcon="@Icons.Material.Filled.Add"
                                                              OnAdornmentClick="@(async () => await AddWordAsync(category.Key))"
                                                              FullWidth="true" />
                                                 <MudButton Variant="Variant.Filled"
                                                           StartIcon="@Icons.Material.Filled.Add"
                                                           OnClick="@(async () => await AddWordAsync(category.Key))"
                                                           Style="background:var(--accent);color:var(--accent-on);font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.06em;">
                                                    @Loc["Add"]
                                                </MudButton>
                                            </MudStack>

                                            <!-- Word List -->
                                            <div class="ph-words-label">@Loc["Words"]</div>
                                            @if (category.Value.Any())
                                            {
                                                <div class="ph-words-box">
                                                    <MudStack Row="true" Spacing="1" Style="flex-wrap: wrap;">
                                                        @foreach (var word in category.Value.OrderBy(w => w))
                                                        {
                                                            <MudChip T="string" Text="@word"
                                                                     Variant="Variant.Outlined"
                                                                     Size="Size.Small"
                                                                     Style="font-family:var(--font-mono);border-color:rgba(var(--glow),0.3);color:var(--accent);border-radius:99px;"
                                                                     OnClose="@(async () => await DeleteWordAsync(category.Key, word))" />
                                                        }
                                                    </MudStack>
                                                </div>
                                            }
                                            else
                                            {
                                                <MudAlert Severity="Severity.Info" Dense="true">
                                                    @Loc["NoWordsInCategory"]
                                                </MudAlert>
                                            }
                                        </MudStack>
                                    </div>
                                </ChildContent>
                            </MudExpansionPanel>
                        }
                    </MudExpansionPanels>
                </div>
            </div>
        }
    </MudStack>
</div>

<!-- Add Category Dialog -->
<MudDialog @bind-Visible="_showAddCategoryDialog">
    <DialogContent>
        <MudTextField @bind-Value="_newCategoryName"
                      Label="@Loc["CategoryName"].Value"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      HelperText="@Loc["CategoryNameHelper"].Value" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showAddCategoryDialog = false)" Style="color:var(--text-dim);">@Loc["Cancel"]</MudButton>
        <MudButton Variant="Variant.Filled"
                   OnClick="AddCategoryAsync"
                   Style="background:var(--accent);color:var(--accent-on);font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.06em;">
            @Loc["Create"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private Dictionary<string, HashSet<string>>? _categories;
    private bool _isLoading = true;
    private string _newWord = string.Empty;
    private string _newCategoryName = string.Empty;
    private bool _showAddCategoryDialog = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadSuggestionsAsync();
    }

    private async Task LoadSuggestionsAsync()
    {
        _isLoading = true;
        try
        {
            var response = await Http.GetFromJsonAsync<SuggestionDataResponse>("/api/suggestion");
            _categories = response?.Categories ?? new Dictionary<string, HashSet<string>>();
        }
        catch (Exception ex)
        {
            Snackbar.Add(string.Format(Loc["ErrorLoadingSuggestions"], ex.Message), Severity.Error);
            _categories = new Dictionary<string, HashSet<string>>();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void ShowAddCategoryDialog()
    {
        _newCategoryName = string.Empty;
        _showAddCategoryDialog = true;
    }

    private async Task AddCategoryAsync()
    {
        if (string.IsNullOrWhiteSpace(_newCategoryName))
        {
            Snackbar.Add(Loc["CategoryNameEmpty"].Value, Severity.Warning);
            return;
        }

        var categoryKey = _newCategoryName.ToLower().Trim();
        if (_categories?.ContainsKey(categoryKey) == true)
        {
            Snackbar.Add(string.Format(Loc["CategoryAlreadyExists"], categoryKey), Severity.Warning);
            return;
        }

        try
        {
            // Add a category by adding an empty word (which we'll remove)
            var response = await Http.PostAsJsonAsync($"/api/suggestion/{categoryKey}", " ");
            if (response.IsSuccessStatusCode)
            {
                // Remove the placeholder word
                await Http.DeleteAsync($"/api/suggestion/{categoryKey}/{Uri.EscapeDataString(" ")}");
                
                await LoadSuggestionsAsync();
                Snackbar.Add(string.Format(Loc["CategoryCreated"], categoryKey), Severity.Success);
                _showAddCategoryDialog = false;
                _newCategoryName = string.Empty;
            }
            else
            {
                Snackbar.Add(string.Format(Loc["CategoryCreateFailed"], response.ReasonPhrase), Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(string.Format(Loc["ErrorCreatingCategory"], ex.Message), Severity.Error);
        }
    }

    private async Task AddWordAsync(string category)
    {
        if (string.IsNullOrWhiteSpace(_newWord))
        {
            Snackbar.Add(Loc["WordEmpty"].Value, Severity.Warning);
            return;
        }

        try
        {
            var response = await Http.PostAsJsonAsync($"/api/suggestion/{category}", _newWord.ToLower().Trim());
            if (response.IsSuccessStatusCode)
            {
                await LoadSuggestionsAsync();
                Snackbar.Add(string.Format(Loc["WordAdded"], _newWord, category), Severity.Success);
                _newWord = string.Empty;
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add(string.Format(Loc["WordAddFailed"], error), Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(string.Format(Loc["ErrorAddingWord"], ex.Message), Severity.Error);
        }
    }

    private async Task DeleteWordAsync(string category, string word)
    {
        try
        {
            var response = await Http.DeleteAsync($"/api/suggestion/{category}/{word}");
            if (response.IsSuccessStatusCode)
            {
                await LoadSuggestionsAsync();
                Snackbar.Add(string.Format(Loc["WordRemoved"], word, category), Severity.Success);
            }
            else
            {
                Snackbar.Add(string.Format(Loc["WordRemoveFailed"], response.ReasonPhrase), Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(string.Format(Loc["ErrorDeletingWord"], ex.Message), Severity.Error);
        }
    }

    private async Task DeleteCategoryAsync(string category)
    {
        try
        {
            var response = await Http.DeleteAsync($"/api/suggestion/{category}");
            if (response.IsSuccessStatusCode)
            {
                await LoadSuggestionsAsync();
                Snackbar.Add(string.Format(Loc["CategoryDeleted"], category), Severity.Success);
            }
            else
            {
                Snackbar.Add(string.Format(Loc["CategoryDeleteFailed"], response.ReasonPhrase), Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(string.Format(Loc["ErrorDeletingCategory"], ex.Message), Severity.Error);
        }
    }

    // DTO for deserializing API response
    private class SuggestionDataResponse
    {
        public Dictionary<string, HashSet<string>>? Categories { get; set; }
    }
}
