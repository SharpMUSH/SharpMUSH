@page "/admin"
@attribute [Authorize(Policy = "players.view")]
@inject IStringLocalizer<SharedResource> Loc

<PageTitle>Admin Dashboard — SharpMUSH</PageTitle>

<div style="padding:var(--cpad);">
    <div class="ph-header">
        <div class="ph-kicker">Administration</div>
        <h1 class="ph-title">Admin Dashboard</h1>
    </div>

    <div class="ph-grid">
        @foreach (var card in _cards)
        {
            <a href="@card.Href" class="ph-card">
                <div class="ph-card-icon">
                    <MudIcon Icon="@card.Icon" />
                </div>
                <div class="ph-card-body">
                    <div class="ph-card-title">@card.Title</div>
                    <div class="ph-card-action">@card.Action</div>
                </div>
                <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Class="ph-card-chevron" />
            </a>
        }
    </div>
</div>

@code {
    private record AdminCard(string Title, string Action, string Href, string Icon);

    private readonly AdminCard[] _cards =
    [
        new("Players", "View Players", "/admin/players", Icons.Material.Filled.Group),
        new("Characters", "View Characters", "/admin/characters", Icons.Material.Filled.Person),
        new("Profiles", "Character Profiles", "/admin/profiles", Icons.Material.Filled.Badge),
        new("Configuration", "Site Config", "/admin/config", Icons.Material.Filled.Settings),
        new("Roles", "Roles & Permissions", "/admin/roles", Icons.Material.Filled.Shield),
        new("Moderation", "Reports & Bans", "/admin/moderation", Icons.Material.Filled.Gavel),
        new("Suggestions", "Word Suggestions", "/admin/suggestions", Icons.Material.Filled.Lightbulb),
        new("Wiki Admin", "Wiki Admin", "/admin/wiki", Icons.Material.Filled.MenuBook),
        new("Image Library", "Media Assets", "/admin/media", Icons.Material.Filled.PermMedia),
        new("Applications", "Custom Widgets", "/admin/applications", Icons.Material.Filled.Apps),
        new("Packages", "Softcode Packages", "/admin/packages", Icons.Material.Filled.Inventory2),
        new("Layout", "Layout Editor", "/admin/layout", Icons.Material.Filled.Dashboard),
        new("Server", "Server Status", "/admin/server", Icons.Material.Filled.Dns),
        new("Database Import", "Import Database", "/admin/database/import", Icons.Material.Filled.CloudUpload),
    ];
}
