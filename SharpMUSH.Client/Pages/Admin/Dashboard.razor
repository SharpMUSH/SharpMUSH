@page "/admin"
@attribute [Authorize(Roles = "Wizard")]
@inject IStringLocalizer<SharedResource> Loc

<PageTitle>Admin Dashboard — SharpMUSH</PageTitle>

<div style="padding:var(--cpad);">
    <div class="ph-header">
        <div class="ph-kicker">Administration</div>
        <h1 class="ph-title">Admin Dashboard</h1>
    </div>

    <div class="ph-grid">
        @foreach (var card in _cards)
        {
            <a href="@card.Href" class="ph-card">
                <div class="ph-card-icon">
                    <MudIcon Icon="@card.Icon" />
                </div>
                <div class="ph-card-body">
                    <div class="ph-card-title">@card.Title</div>
                    <div class="ph-card-action">@card.Action</div>
                </div>
                <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Class="ph-card-chevron" />
            </a>
        }
    </div>
</div>

@code {
    private record AdminCard(string Title, string Action, string Href, string Icon);

    private readonly AdminCard[] _cards =
    [
        new("Players", "View Players", "/admin/players", Icons.Material.Filled.Group),
        new("Characters", "View Characters", "/admin/characters", Icons.Material.Filled.Person),
        new("Configuration", "Site Config", "/admin/config", Icons.Material.Filled.Settings),
        new("Moderation", "Reports & Bans", "/admin/moderation", Icons.Material.Filled.Gavel),
        new("Wiki Admin", "Wiki Admin", "/admin/wiki", Icons.Material.Filled.MenuBook),
        new("Layout", "Layout Editor", "/admin/layout", Icons.Material.Filled.Dashboard),
    ];
}

<style>
    .ph-header {
        margin-bottom: 24px;
    }
    .ph-kicker {
        font-family: var(--font-mono);
        font-size: 11px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 6px;
    }
    .ph-title {
        font-family: var(--font-display);
        font-size: 26px;
        font-weight: 600;
        color: var(--text);
        margin: 0;
    }

    .ph-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 16px;
    }

    .ph-card {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 18px 20px;
        background: var(--surface);
        border: 1px solid var(--border-soft);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow);
        text-decoration: none;
        transition: border-color 0.15s ease, transform 0.15s ease;
    }
    .ph-card:hover {
        border-color: rgba(var(--glow), 0.4);
        transform: translateY(-1px);
    }

    .ph-card-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 44px;
        height: 44px;
        border-radius: var(--radius);
        background: rgba(var(--glow), 0.12);
        color: var(--accent);
        flex-shrink: 0;
    }

    .ph-card-body {
        flex: 1;
        min-width: 0;
    }
    .ph-card-title {
        font-family: var(--font-display);
        font-size: 16px;
        font-weight: 600;
        color: var(--text);
    }
    .ph-card-action {
        font-family: var(--font-mono);
        font-size: 11px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--text-dim);
        margin-top: 2px;
    }

    .ph-card-chevron {
        color: var(--text-faint);
        flex-shrink: 0;
    }
    .ph-card:hover .ph-card-chevron {
        color: var(--accent);
    }
</style>
