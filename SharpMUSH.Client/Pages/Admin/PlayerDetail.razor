@page "/admin/players/{Id:int}"
@attribute [Authorize(Policy = "players.view")]
@inject IStringLocalizer<SharedResource> Loc

<PageTitle>Player #@Id — Admin — SharpMUSH</PageTitle>

<div style="padding:var(--cpad);">
    <div class="ph-header">
        <div class="ph-kicker">Administration · Player</div>
        <h1 class="ph-title">Player #@Id</h1>
    </div>

    <div class="ph-empty">
        <MudIcon Icon="@Icons.Material.Filled.Person" Class="ph-empty-icon" />
        <div class="ph-empty-text">Player detail coming soon.</div>
    </div>
</div>

@code {
    [Parameter]
    public int Id { get; set; }
}
