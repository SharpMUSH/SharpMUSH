@page "/admin/layout/{Scope}"
@using System.Text.Json
@using SharpMUSH.Library.Authorization
@attribute [Authorize(Policy = "layout.admin")]
@inject ILayoutService LayoutService
@inject IWidgetRegistry Registry
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>@(_scopeInfo?.DisplayName ?? Scope) Layout — Admin — SharpMUSH</PageTitle>

<div class="layedit">
    <div class="layedit-head">
        <div>
            <a class="layedit-back" href="/admin/layout"><MudIcon Icon="@Icons.Material.Filled.ArrowBack" Style="font-size:13px;" /> All layouts</a>
            <h1 class="layedit-title">@(_scopeInfo?.DisplayName ?? Scope)</h1>
            <p class="layedit-blurb">@(_scopeInfo?.Description)</p>
        </div>
        <div class="layedit-actions">
            <button type="button" class="le-btn @(_showPreview ? "le-btn--on" : "")" @onclick="@(() => _showPreview = !_showPreview)">
                <MudIcon Icon="@Icons.Material.Filled.Visibility" Style="font-size:14px;" /> Preview
            </button>
            <button type="button" class="le-btn" @onclick="ResetAsync" disabled="@_saving">
                <MudIcon Icon="@Icons.Material.Filled.RestartAlt" Style="font-size:14px;" /> Reset to default
            </button>
            <button type="button" class="le-btn le-btn--primary" @onclick="SaveAsync" disabled="@(_saving || !_dirty)">
                <MudIcon Icon="@Icons.Material.Filled.Save" Style="font-size:14px;" /> @(_saving ? "Publishing…" : "Publish")
            </button>
        </div>
    </div>

    @if (_scopeInfo is null)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">Unknown layout scope “@Scope”.</MudAlert>
    }
    else if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Style="height:2px;" />
    }
    else
    {
        <MudDropContainer T="EditItem" @ref="_container" Items="_items"
                          ItemsSelector="@((item, zoneId) => item.Zone == zoneId)"
                          ItemsClassSelector="@ItemsClass"
                          ItemDropped="OnDropped" Class="le-board">
            <ChildContent>
                <div class="le-palette">
                    <div class="le-panel-label">Widgets</div>
                    <MudDropZone T="EditItem" Identifier="palette" Class="le-palette-zone" AllowReorder="false" />
                    <div class="le-hint">Drag a widget into a zone. Drag a placed widget back here to remove it.</div>

                    <div class="le-panel-label" style="margin-top:18px;">Sidebars &amp; footer</div>
                    <div class="le-settings">
                        <label class="le-toggle"><input type="checkbox" checked="@_leftOn" @onchange="@(e => { _leftOn = (bool)e.Value!; _dirty = true; })" /> Left sidebar</label>
                        <label class="le-toggle"><input type="checkbox" checked="@_rightOn" @onchange="@(e => { _rightOn = (bool)e.Value!; _dirty = true; })" /> Right sidebar</label>
                        <label class="le-toggle"><input type="checkbox" checked="@_footerOn" @onchange="@(e => { _footerOn = (bool)e.Value!; _dirty = true; })" /> Footer</label>
                    </div>
                </div>

                <div class="le-zones">
                    @foreach (var zone in _scopeInfo.Zones)
                    {
                        <div class="le-zone">
                            <div class="le-zone-head">
                                <MudIcon Icon="@ZoneIcon(zone)" Style="font-size:14px;color:var(--accent);" />
                                <span>@zone</span>
                                <span class="le-zone-hint">@(IsGridZone(zone) ? "12-column grid" : "horizontal — no width")</span>
                            </div>
                            <MudDropZone T="EditItem" Identifier="@zone.ToString()"
                                         Class="@($"le-zone-drop {(IsGridZone(zone) ? "le-zone-drop--grid" : "")}")" />
                        </div>
                    }
                </div>
            </ChildContent>
            <ItemRenderer>
                <div class="le-item @(context.IsTemplate ? "le-item--template" : "")">
                    <MudIcon Icon="@Icons.Material.Filled.DragIndicator" Style="font-size:14px;color:var(--text-faint);" />
                    <span class="le-item-name">@context.DisplayName</span>
                    @if (!context.IsTemplate)
                    {
                        <span style="flex:1;"></span>
                        @if (IsGridZoneName(context.Zone))
                        {
                            <div class="le-width" @onpointerdown:stopPropagation="true" title="Width in columns (1–12)">
                                <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Style="font-size:13px;color:var(--text-faint);" />
                                <input type="range" min="1" max="12" step="1" class="le-span-slider"
                                       value="@ClampSpan(context.Span)"
                                       @oninput="@(e => PreviewSpan(context, e.Value))"
                                       @onchange="@(e => CommitSpan(context, e.Value))"
                                       @onclick:stopPropagation="true" />
                                <span class="le-span-num">@ClampSpan(context.Span)</span>
                            </div>
                        }
                        @if (context.Config is not null)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Tune" Style="font-size:12px;color:var(--accent);" Title="Has config" />
                        }
                        <button type="button" class="le-item-btn" title="Configure" @onclick="@(() => EditConfigAsync(context))" @onclick:stopPropagation="true">
                            <MudIcon Icon="@Icons.Material.Filled.Settings" Style="font-size:13px;" />
                        </button>
                        <button type="button" class="le-item-btn le-item-btn--danger" title="Remove" @onclick="@(() => Remove(context))" @onclick:stopPropagation="true">
                            <MudIcon Icon="@Icons.Material.Filled.Close" Style="font-size:13px;" />
                        </button>
                    }
                </div>
            </ItemRenderer>
        </MudDropContainer>

        @if (_showPreview)
        {
            var preview = BuildPreviewLayout();
            <div class="le-preview">
                <div class="le-preview-head">
                    <MudIcon Icon="@Icons.Material.Filled.Visibility" Style="font-size:14px;color:var(--accent);" />
                    <span>Live preview</span>
                    <span class="le-preview-note">
                        Reflects unsaved changes@(Scope == LayoutScopes.Profile ? " · character widgets show a generic state here" : "")
                    </span>
                </div>
                <div class="le-preview-surface">
                    @foreach (var zone in _scopeInfo.Zones)
                    {
                        <div class="le-preview-zone">
                            <div class="le-preview-zlabel">@zone</div>
                            <ZoneRenderer Zone="zone" Layout="preview" Grid="IsGridZone(zone)" />
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>

<style>
    .layedit { padding: var(--cpad); }
    .layedit-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 16px; flex-wrap: wrap; margin-bottom: 18px; }
    .layedit-back {
        display: inline-flex; align-items: center; gap: 5px; font-family: var(--font-mono); font-size: 11px;
        color: var(--text-faint); text-decoration: none; margin-bottom: 6px;
    }
    .layedit-back:hover { color: var(--accent); }
    .layedit-title { margin: 0; font-family: var(--font-display); font-size: 24px; font-weight: 600; color: var(--text); }
    .layedit-blurb { margin: 6px 0 0; font-family: var(--font-ui); font-size: 13px; color: var(--text-dim); }
    .layedit-actions { display: flex; gap: 10px; }

    .le-btn {
        display: inline-flex; align-items: center; gap: 6px; padding: 7px 13px; border-radius: var(--radius);
        border: 1px solid var(--border); background: var(--surface-2); color: var(--text);
        font-family: var(--font-ui); font-size: 12.5px; font-weight: 500; cursor: pointer; transition: all 0.12s;
    }
    .le-btn:hover:not(:disabled) { border-color: rgba(var(--glow), 0.4); }
    .le-btn:disabled { opacity: 0.5; cursor: default; }
    .le-btn--primary { background: var(--accent); color: var(--accent-on); border-color: transparent; font-weight: 600; }
    .le-btn--primary:hover:not(:disabled) { filter: brightness(1.08); }

    .le-board { display: grid; grid-template-columns: 260px minmax(0, 1fr); gap: 16px; }
    @@media (max-width: 820px) { .le-board { grid-template-columns: 1fr; } }

    .le-palette {
        background: var(--surface); border: 1px solid var(--border-soft); border-radius: var(--radius-lg);
        padding: 16px; align-self: start;
    }
    .le-panel-label {
        font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase;
        color: var(--text-faint); margin-bottom: 10px;
    }
    .le-palette-zone { display: flex; flex-direction: column; gap: 7px; min-height: 40px; }
    .le-hint { font-family: var(--font-ui); font-size: 11px; color: var(--text-faint); margin-top: 10px; line-height: 1.5; }
    .le-settings { display: flex; flex-direction: column; gap: 8px; }
    .le-toggle { display: flex; align-items: center; gap: 8px; font-family: var(--font-ui); font-size: 12.5px; color: var(--text-dim); cursor: pointer; }

    .le-zones { display: flex; flex-direction: column; gap: 14px; }
    .le-zone { background: var(--surface); border: 1px solid var(--border-soft); border-radius: var(--radius-lg); overflow: hidden; }
    .le-zone-head {
        display: flex; align-items: center; gap: 8px; padding: 10px 14px; border-bottom: 1px solid var(--border-soft);
        font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-dim);
    }
    .le-zone-drop { display: flex; flex-direction: column; gap: 7px; padding: 14px; min-height: 64px; }
    .le-zone-drop--grid { display: grid; grid-template-columns: repeat(12, 1fr); gap: 10px; }
    .le-zone-hint {
        font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.06em; text-transform: uppercase;
        color: var(--text-faint); margin-left: auto; padding: 1px 7px; border-radius: 99px;
        background: var(--surface-2); border: 1px solid var(--border);
    }
    /* Grid spans for items inside a grid drop zone (applied to .mud-drop-item via ItemsClassSelector). */
    .le-span-1 { grid-column: span 1; } .le-span-2 { grid-column: span 2; } .le-span-3 { grid-column: span 3; }
    .le-span-4 { grid-column: span 4; } .le-span-5 { grid-column: span 5; } .le-span-6 { grid-column: span 6; }
    .le-span-7 { grid-column: span 7; } .le-span-8 { grid-column: span 8; } .le-span-9 { grid-column: span 9; }
    .le-span-10 { grid-column: span 10; } .le-span-11 { grid-column: span 11; } .le-span-12 { grid-column: span 12; }
    @@media (max-width: 760px) {
        .le-zone-drop--grid { grid-template-columns: 1fr; }
        .le-zone-drop--grid > .mud-drop-item { grid-column: 1 / -1 !important; }
        .layedit-actions { flex-wrap: wrap; }
        .le-btn { flex: 1 1 auto; justify-content: center; }
    }

    .le-width { display: inline-flex; align-items: center; gap: 6px; margin-right: 6px; }
    .le-span-slider { width: 84px; accent-color: var(--accent); cursor: pointer; }
    .le-span-num {
        font-family: var(--font-mono); font-size: 11px; color: var(--text-dim);
        min-width: 16px; text-align: center;
    }

    .le-preview { margin-top: 18px; border: 1px solid var(--border-soft); border-radius: var(--radius-lg); overflow: hidden; }
    .le-preview-head {
        display: flex; align-items: center; gap: 8px; padding: 10px 16px; border-bottom: 1px solid var(--border-soft);
        background: var(--surface); font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em;
        text-transform: uppercase; color: var(--text-dim);
    }
    .le-preview-note {
        margin-left: auto; text-transform: none; letter-spacing: 0;
        font-family: var(--font-ui); font-size: 11px; color: var(--text-faint);
    }
    .le-preview-surface { padding: 16px; background: var(--bg); }
    .le-preview-zone { margin-bottom: 14px; }
    .le-preview-zone:last-child { margin-bottom: 0; }
    .le-preview-zlabel {
        font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase;
        color: var(--text-faint); margin-bottom: 6px;
    }
    .le-btn--on { border-color: rgba(var(--glow), 0.5); color: var(--accent); }

    .le-item {
        display: flex; align-items: center; gap: 8px; padding: 9px 11px; border-radius: var(--radius);
        background: var(--surface-2); border: 1px solid var(--border); cursor: grab; user-select: none;
    }
    .le-item:hover { border-color: rgba(var(--glow), 0.4); }
    .le-item--template { background: rgba(var(--glow), 0.06); border-style: dashed; }
    .le-item-name { font-family: var(--font-ui); font-size: 12.5px; color: var(--text); font-weight: 500; }
    .le-item-btn {
        width: 24px; height: 24px; display: grid; place-items: center; border-radius: 6px;
        border: 1px solid transparent; background: transparent; color: var(--text-faint); cursor: pointer;
    }
    .le-item-btn:hover { color: var(--text); border-color: var(--border); }
    .le-item-btn--danger:hover { color: #e57373; border-color: rgba(229, 115, 115, 0.5); }

    ::deep .mud-drop-zone-drag-block-target { outline: 2px dashed rgba(var(--glow), 0.5); outline-offset: -4px; }
</style>

@code {
    [Parameter] public string Scope { get; set; } = string.Empty;

    private sealed class EditItem
    {
        public string InstanceId { get; init; } = Guid.NewGuid().ToString("N");
        public string WidgetName { get; init; } = string.Empty;
        public string DisplayName { get; init; } = string.Empty;
        public string Zone { get; set; } = "palette";
        public JsonElement? Config { get; set; }
        public bool IsTemplate { get; init; }

        /// <summary>Grid width in columns (1–12). Only meaningful in grid zones.</summary>
        public int Span { get; set; } = 12;
    }

    // Vertical zones lay widgets out in a 12-column grid (per-placement width). The top bar is
    // horizontal, so it stays a simple list with no column-width control.
    private static bool IsGridZone(WidgetZone zone) => zone != WidgetZone.TopBar;

    private static bool IsGridZoneName(string zone)
        => Enum.TryParse<WidgetZone>(zone, out var z) && IsGridZone(z);

    private static int ClampSpan(int span) => span is >= 1 and <= 12 ? span : 12;

    private static int ParseSpan(object? value)
        => int.TryParse(value?.ToString(), out var n) ? Math.Clamp(n, 1, 12) : 12;

    private string ItemsClass(EditItem item, string dropzoneId)
        => !item.IsTemplate && IsGridZoneName(dropzoneId)
            ? $"le-span-{ClampSpan(item.Span)}"
            : string.Empty;

    // While dragging the slider: update the number and the live preview without re-laying the editor
    // grid (which would interrupt the drag). The editor grid cell resizes on release (CommitSpan).
    private void PreviewSpan(EditItem item, object? value)
    {
        item.Span = ParseSpan(value);
        _dirty = true;
        StateHasChanged();
    }

    private void CommitSpan(EditItem item, object? value)
    {
        item.Span = ParseSpan(value);
        _dirty = true;
        RebuildItems();
    }

    private LayoutScope? _scopeInfo;
    private MudDropContainer<EditItem>? _container;
    private bool _loading = true;
    private bool _saving;
    private bool _dirty;

    private List<EditItem> _palette = [];
    private Dictionary<string, List<EditItem>> _zones = [];
    private List<EditItem> _items = [];

    private bool _leftOn, _rightOn, _footerOn;
    private string _leftWidth = "280px", _rightWidth = "280px";
    private bool _showPreview = true;

    protected override async Task OnParametersSetAsync()
    {
        _scopeInfo = LayoutScopes.Find(Scope);
        if (_scopeInfo is null)
        {
            _loading = false;
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        var layout = await LayoutService.GetLayoutAsync(Scope);

        _leftOn = layout.Settings.LeftSidebarEnabled;
        _rightOn = layout.Settings.RightSidebarEnabled;
        _footerOn = layout.Settings.FooterEnabled;
        _leftWidth = layout.Settings.LeftSidebarWidth;
        _rightWidth = layout.Settings.RightSidebarWidth;

        _palette = Registry.GetAllWidgets()
            .Where(w => w.AllowedZones.Any(z => _scopeInfo!.Zones.Contains(z)))
            .OrderBy(w => w.DisplayName)
            .Select(w => new EditItem { WidgetName = w.Name, DisplayName = w.DisplayName, Zone = "palette", IsTemplate = true })
            .ToList();

        _zones = _scopeInfo!.Zones.ToDictionary(
            z => z.ToString(),
            z => (layout.Zones.TryGetValue(z, out var list) ? list : [])
                .OrderBy(p => p.Order)
                .Select(p => new EditItem
                {
                    WidgetName = p.WidgetName,
                    DisplayName = Registry.GetWidget(p.WidgetName)?.DisplayName ?? p.WidgetName,
                    Zone = z.ToString(),
                    Config = p.Config,
                    Span = ClampSpan(p.Span)
                })
                .ToList());

        RebuildItems();
        _dirty = false;
        _loading = false;
    }

    private void RebuildItems()
    {
        _items = _palette
            .Concat(_scopeInfo!.Zones.SelectMany(z => _zones[z.ToString()]))
            .ToList();
        _container?.Refresh();
    }

    private void OnDropped(MudItemDropInfo<EditItem> info)
    {
        if (info.Item is not { } item)
        {
            return;
        }

        var target = info.DropzoneIdentifier;

        if (item.IsTemplate)
        {
            // Adding a fresh placement; the template stays in the palette.
            if (target != "palette" && _zones.TryGetValue(target, out var list))
            {
                var clone = new EditItem
                {
                    WidgetName = item.WidgetName,
                    DisplayName = item.DisplayName,
                    Zone = target
                };
                InsertAt(list, clone, info.IndexInZone);
                _dirty = true;
            }
        }
        else
        {
            RemoveFromZones(item);
            if (target == "palette")
            {
                // Dragged back to the palette → removed.
                _dirty = true;
            }
            else if (_zones.TryGetValue(target, out var list))
            {
                item.Zone = target;
                InsertAt(list, item, info.IndexInZone);
                _dirty = true;
            }
        }

        RebuildItems();
    }

    private static void InsertAt(List<EditItem> list, EditItem item, int index)
    {
        index = Math.Clamp(index, 0, list.Count);
        list.Insert(index, item);
    }

    private void RemoveFromZones(EditItem item)
    {
        foreach (var list in _zones.Values)
        {
            list.Remove(item);
        }
    }

    private void Remove(EditItem item)
    {
        RemoveFromZones(item);
        _dirty = true;
        RebuildItems();
    }

    private async Task EditConfigAsync(EditItem item)
    {
        var parameters = new DialogParameters<WidgetConfigDialog>
        {
            { x => x.WidgetName, item.DisplayName },
            { x => x.WidgetKey, item.WidgetName },
            { x => x.InitialJson, item.Config?.GetRawText() }
        };
        var dialog = await DialogService.ShowAsync<WidgetConfigDialog>($"Configure {item.DisplayName}", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled)
        {
            return;
        }

        var json = result.Data as string;
        // Clone() detaches the element from the parsed document so it survives disposal.
        item.Config = string.IsNullOrWhiteSpace(json)
            ? null
            : JsonDocument.Parse(json).RootElement.Clone();
        _dirty = true;
        StateHasChanged();
    }

    private LayoutConfiguration BuildPreviewLayout()
    {
        var zones = _scopeInfo!.Zones.ToDictionary(
            z => z,
            z => _zones[z.ToString()]
                .Select((it, idx) => new WidgetPlacement(it.WidgetName, idx, it.Config, ClampSpan(it.Span)))
                .ToList());
        return new LayoutConfiguration(zones, new LayoutSettings(_leftOn, _rightOn, _footerOn, _leftWidth, _rightWidth));
    }

    private async Task SaveAsync()
    {
        if (_scopeInfo is null)
        {
            return;
        }

        _saving = true;
        var ok = await LayoutService.SaveLayoutAsync(Scope, BuildPreviewLayout());
        _saving = false;

        if (ok)
        {
            _dirty = false;
            Snackbar.Add($"Published the {_scopeInfo.DisplayName} layout.", Severity.Success);
        }
        else
        {
            Snackbar.Add("Failed to publish layout.", Severity.Error);
        }
    }

    private async Task ResetAsync()
    {
        if (_scopeInfo is null)
        {
            return;
        }

        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Reset layout",
            $"Reset the {_scopeInfo.DisplayName} layout to its default? Any customizations will be discarded.",
            yesText: "Reset", cancelText: "Cancel");

        if (confirmed != true)
        {
            return;
        }

        _saving = true;
        var ok = await LayoutService.ResetLayoutAsync(Scope);
        _saving = false;

        if (ok)
        {
            await LoadAsync();
            Snackbar.Add($"Reset the {_scopeInfo.DisplayName} layout.", Severity.Success);
        }
        else
        {
            Snackbar.Add("Failed to reset layout.", Severity.Error);
        }
    }

    private static string ZoneIcon(WidgetZone zone) => zone switch
    {
        WidgetZone.TopBar => Icons.Material.Filled.ViewHeadline,
        WidgetZone.LeftSidebar => Icons.Material.Filled.ViewSidebar,
        WidgetZone.RightSidebar => Icons.Material.Filled.ViewSidebar,
        WidgetZone.Footer => Icons.Material.Filled.ViewStream,
        _ => Icons.Material.Filled.ViewQuilt
    };
}
