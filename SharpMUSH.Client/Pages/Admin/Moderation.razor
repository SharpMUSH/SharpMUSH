@page "/admin/moderation"
@attribute [Authorize(Policy = "players.moderate")]
@inject IStringLocalizer<SharedResource> Loc

<PageTitle>Moderation — Admin — SharpMUSH</PageTitle>

<div style="padding:var(--cpad);">
    <div class="ph-header">
        <div class="ph-kicker">Administration</div>
        <h1 class="ph-title">Moderation</h1>
