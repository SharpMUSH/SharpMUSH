@page "/admin/moderation"
@attribute [Authorize(Policy = "players.admin")]
@inject IStringLocalizer<SharedResource> Loc

<PageTitle>Moderation — Admin — SharpMUSH</PageTitle>

<div style="padding:var(--cpad);">
    <div class="ph-header">
        <div class="ph-kicker">Administration</div>
        <h1 class="ph-title">Moderation</h1>
    </div>

    <div class="ph-empty">
        <MudIcon Icon="@Icons.Material.Filled.Gavel" Class="ph-empty-icon" />
        <div class="ph-empty-text">Reports, bans, and audit log coming soon.</div>
    </div>
</div>

<style>
    .ph-header { margin-bottom: 24px; }
    .ph-kicker {
        font-family: var(--font-mono);
        font-size: 11px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 6px;
    }
    .ph-title {
        font-family: var(--font-display);
        font-size: 26px;
        font-weight: 600;
        color: var(--text);
        margin: 0;
    }
    .ph-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 14px;
        padding: 56px 24px;
        background: var(--surface);
        border: 1px solid var(--border-soft);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow);
    }
    .ph-empty-icon {
        font-size: 40px;
        color: var(--text-faint);
    }
    .ph-empty-text {
        font-family: var(--font-mono);
        font-size: 13px;
        letter-spacing: 0.04em;
        color: var(--text-dim);
    }
</style>
