@page "/admin/config"
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> Loc

<PageTitle>@Loc["Configuration"] - @Loc["AppTitle"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-6 config-section-page">
    <MudStack Spacing="4">
        @* Header *@
        <MudPaper Elevation="0" Class="pa-4">
            <MudText Typo="Typo.h4" Color="Color.Secondary">
                <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Large" /> @Loc["ServerConfiguration"]
            </MudText>
            <MudText Typo="Typo.body1" Class="mt-2">
                @Loc["ManageAllSettings"]
            </MudText>
        </MudPaper>

        @* Category Cards *@
        <MudGrid>
            @* Server Category *@
            <MudItem xs="12" md="6">
                <MudCard Outlined="true" Class="category-card" @onclick="@(() => Navigation.NavigateTo("/admin/config/network"))">
                    <MudCardContent>
                        <MudStack Spacing="2">
                            <MudStack Row="true" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.Computer" Color="Color.Secondary" Size="Size.Large" />
                                <MudText Typo="Typo.h6">@Loc["Server"]</MudText>
                            </MudStack>
                            <MudText Typo="Typo.body2">
                                @Loc["ServerCategoryDescription"]
                            </MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Text="2 settings" />
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            @* Performance Category *@
            <MudItem xs="12" md="6">
                <MudCard Outlined="true" Class="category-card" @onclick="@(() => Navigation.NavigateTo("/admin/config/limits"))">
                    <MudCardContent>
                        <MudStack Spacing="2">
                            <MudStack Row="true" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.Speed" Color="Color.Secondary" Size="Size.Large" />
                                <MudText Typo="Typo.h6">@Loc["Performance"]</MudText>
                            </MudStack>
                            <MudText Typo="Typo.body2">
                                @Loc["PerformanceCategoryDescription"]
                            </MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Text="@Loc["ComingSoon"].Value" />
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            @* Security Category *@
            <MudItem xs="12" md="6">
                <MudCard Outlined="true" Class="category-card" @onclick="@(() => Navigation.NavigateTo("/admin/config/sitelock"))">
                    <MudCardContent>
                        <MudStack Spacing="2">
                            <MudStack Row="true" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.Security" Color="Color.Secondary" Size="Size.Large" />
                                <MudText Typo="Typo.h6">@Loc["Security"]</MudText>
                            </MudStack>
                            <MudText Typo="Typo.body2">
                                @Loc["SecurityCategoryDescription"]
                            </MudText>
                            <MudStack Row="true" Spacing="2">
                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Text="@Loc["ComingSoon"].Value" />
                                <MudChip T="string" Size="Size.Small" Color="Color.Error" Text="@Loc["Important"].Value" />
                            </MudStack>
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            @* Content Category *@
            <MudItem xs="12" md="6">
                <MudCard Outlined="true" Class="category-card" @onclick="@(() => Navigation.NavigateTo("/admin/config/messages"))">
                    <MudCardContent>
                        <MudStack Spacing="2">
                            <MudStack Row="true" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.Article" Color="Color.Secondary" Size="Size.Large" />
                                <MudText Typo="Typo.h6">@Loc["Content"]</MudText>
                            </MudStack>
                            <MudText Typo="Typo.body2">
                                @Loc["ContentCategoryDescription"]
                            </MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Text="@Loc["ComingSoon"].Value" />
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            @* Logs & Files Category *@
            <MudItem xs="12" md="6">
                <MudCard Outlined="true" Class="category-card" @onclick="@(() => Navigation.NavigateTo("/admin/config/logging"))">
                    <MudCardContent>
                        <MudStack Spacing="2">
                            <MudStack Row="true" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Color="Color.Secondary" Size="Size.Large" />
                                <MudText Typo="Typo.h6">@Loc["LogsAndFiles"]</MudText>
                            </MudStack>
                            <MudText Typo="Typo.body2">
                                @Loc["LogsCategoryDescription"]
                            </MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Text="@Loc["ComingSoon"].Value" />
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            @* Advanced Category *@
            <MudItem xs="12" md="6">
                <MudCard Outlined="true" Class="category-card" @onclick="@(() => Navigation.NavigateTo("/admin/config/attributes"))">
                    <MudCardContent>
                        <MudStack Spacing="2">
                            <MudStack Row="true" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.Tune" Color="Color.Secondary" Size="Size.Large" />
                                <MudText Typo="Typo.h6">@Loc["Advanced"]</MudText>
                            </MudStack>
                            <MudText Typo="Typo.body2">
                                @Loc["AdvancedCategoryDescription"]
                            </MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Text="@Loc["ComingSoon"].Value" />
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>

        @* Quick Actions *@
        <MudPaper Outlined="true" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">@Loc["QuickActions"]</MudText>
            <MudStack Row="true" Spacing="3" Wrap="Wrap.Wrap">
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Secondary" 
                           StartIcon="@Icons.Material.Filled.Search"
                           Disabled="true">
                    @Loc["SearchAllSettings"]
                </MudButton>
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Default" 
                           StartIcon="@Icons.Material.Filled.Upload"
                           Disabled="true">
                    @Loc["ImportConfigFile"]
                </MudButton>
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Default" 
                           StartIcon="@Icons.Material.Filled.Download"
                           Disabled="true">
                    @Loc["ExportConfiguration"]
                </MudButton>
            </MudStack>
        </MudPaper>
    </MudStack>
</MudContainer>

<style>
    .config-section-page {
        padding: 32px;
    }

    .category-card {
        cursor: pointer;
        transition: all 0.2s ease;
        height: 100%;
    }

    .category-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0, 245, 183, 0.2);
    }
</style>
