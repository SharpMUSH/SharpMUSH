@page "/admin/config"
@using SharpMUSH.Client.Services
@using SharpMUSH.Library.API
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> Loc
@inject ConfigSchemaService SchemaService
@inject AdminConfigService AdminConfigService
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>@Loc["Configuration"] - @Loc["AppTitle"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-6 config-section-page">
    <MudStack Spacing="4">
        @* Header *@
        <MudPaper Elevation="0" Class="pa-4">
            <MudText Typo="Typo.h4" Color="Color.Secondary">
                <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Large" /> @Loc["ServerConfiguration"]
            </MudText>
            <MudText Typo="Typo.body1" Class="mt-2">
                @Loc["ManageAllSettings"]
            </MudText>
        </MudPaper>

        @if (_loading)
        {
            <MudProgressLinear Color="Color.Secondary" Indeterminate="true" />
        }
        else
        {
            @* Category Cards *@
            <MudGrid>
                @* Server Category *@
                <MudItem xs="12" md="6">
                    <MudCard Outlined="true" Class="category-card" @onclick="@(() => Navigation.NavigateTo("/admin/config/net"))">
                        <MudCardContent>
                            <MudStack Spacing="2">
                                <MudStack Row="true" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Filled.Computer" Color="Color.Secondary" Size="Size.Large" />
                                    <MudText Typo="Typo.h6">@Loc["Server"]</MudText>
                                </MudStack>
                                <MudText Typo="Typo.body2">@Loc["ServerCategoryDescription"]</MudText>
                                <MudChip T="string" Size="Size.Small" Color="Color.Secondary"
                                         Text="@($"{GetGroupCount("Server")} {Loc["Settings"].Value}")" />
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                @* Performance Category *@
                <MudItem xs="12" md="6">
                    <MudCard Outlined="true" Class="category-card" @onclick="@(() => Navigation.NavigateTo("/admin/config/limit"))">
                        <MudCardContent>
                            <MudStack Spacing="2">
                                <MudStack Row="true" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Filled.Speed" Color="Color.Secondary" Size="Size.Large" />
                                    <MudText Typo="Typo.h6">@Loc["Performance"]</MudText>
                                </MudStack>
                                <MudText Typo="Typo.body2">@Loc["PerformanceCategoryDescription"]</MudText>
                                <MudChip T="string" Size="Size.Small" Color="Color.Secondary"
                                         Text="@($"{GetGroupCount("Performance")} {Loc["Settings"].Value}")" />
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                @* Security Category *@
                <MudItem xs="12" md="6">
                    <MudCard Outlined="true" Class="category-card" @onclick="@(() => Navigation.NavigateTo("/admin/config/sitelock"))">
                        <MudCardContent>
                            <MudStack Spacing="2">
                                <MudStack Row="true" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Filled.Security" Color="Color.Secondary" Size="Size.Large" />
                                    <MudText Typo="Typo.h6">@Loc["Security"]</MudText>
                                </MudStack>
                                <MudText Typo="Typo.body2">@Loc["SecurityCategoryDescription"]</MudText>
                                <MudStack Row="true" Spacing="2">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary"
                                             Text="@($"{GetGroupCount("Security")} {Loc["Settings"].Value}")" />
                                    <MudChip T="string" Size="Size.Small" Color="Color.Error" Text="@Loc["Important"].Value" />
                                </MudStack>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                @* Content Category *@
                <MudItem xs="12" md="6">
                    <MudCard Outlined="true" Class="category-card" @onclick="@(() => Navigation.NavigateTo("/admin/config/message"))">
                        <MudCardContent>
                            <MudStack Spacing="2">
                                <MudStack Row="true" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Filled.Article" Color="Color.Secondary" Size="Size.Large" />
                                    <MudText Typo="Typo.h6">@Loc["Content"]</MudText>
                                </MudStack>
                                <MudText Typo="Typo.body2">@Loc["ContentCategoryDescription"]</MudText>
                                <MudChip T="string" Size="Size.Small" Color="Color.Secondary"
                                         Text="@($"{GetGroupCount("Content")} {Loc["Settings"].Value}")" />
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                @* Logs & Files Category *@
                <MudItem xs="12" md="6">
                    <MudCard Outlined="true" Class="category-card" @onclick="@(() => Navigation.NavigateTo("/admin/config/log"))">
                        <MudCardContent>
                            <MudStack Spacing="2">
                                <MudStack Row="true" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Color="Color.Secondary" Size="Size.Large" />
                                    <MudText Typo="Typo.h6">@Loc["LogsAndFiles"]</MudText>
                                </MudStack>
                                <MudText Typo="Typo.body2">@Loc["LogsCategoryDescription"]</MudText>
                                <MudChip T="string" Size="Size.Small" Color="Color.Secondary"
                                         Text="@($"{GetGroupCount("Logs")} {Loc["Settings"].Value}")" />
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                @* Advanced Category *@
                <MudItem xs="12" md="6">
                    <MudCard Outlined="true" Class="category-card" @onclick="@(() => Navigation.NavigateTo("/admin/config/attribute"))">
                        <MudCardContent>
                            <MudStack Spacing="2">
                                <MudStack Row="true" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Filled.Tune" Color="Color.Secondary" Size="Size.Large" />
                                    <MudText Typo="Typo.h6">@Loc["Advanced"]</MudText>
                                </MudStack>
                                <MudText Typo="Typo.body2">@Loc["AdvancedCategoryDescription"]</MudText>
                                <MudChip T="string" Size="Size.Small" Color="Color.Secondary"
                                         Text="@($"{GetGroupCount("Advanced")} {Loc["Settings"].Value}")" />
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>

            @* Quick Actions *@
            <MudPaper Outlined="true" Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-3">@Loc["QuickActions"]</MudText>
                <MudStack Row="true" Spacing="3" Wrap="Wrap.Wrap">
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.Search"
                               Disabled="true">
                        @Loc["SearchAllSettings"]
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Default"
                               StartIcon="@Icons.Material.Filled.Upload"
                               OnClick="@(() => Navigation.NavigateTo("/admin/config/import"))">
                        @Loc["ImportConfigFile"]
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Default"
                               StartIcon="@Icons.Material.Filled.Download"
                               OnClick="ExportConfig">
                        @Loc["ExportConfiguration"]
                    </MudButton>
                </MudStack>
            </MudPaper>
        }
    </MudStack>
</MudContainer>

<style>
    .config-section-page {
        padding: 32px;
    }

    .category-card {
        cursor: pointer;
        transition: all 0.2s ease;
        height: 100%;
    }

    .category-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0, 245, 183, 0.2);
    }
</style>

@code {
    private bool _loading = true;
    private Dictionary<string, int> _groupCounts = new();

    // Maps nav group names to the schema category names they contain
    private static readonly Dictionary<string, string[]> GroupCategories = new(StringComparer.OrdinalIgnoreCase)
    {
        ["Server"]      = ["Net", "Database"],
        ["Performance"] = ["Limit", "Command"],
        ["Security"]    = ["SitelockRules", "BannedNames", "Restriction"],
        ["Content"]     = ["Message", "Cosmetic", "Chat"],
        ["Logs"]        = ["Log", "File", "TextFile", "Dump"],
        ["Advanced"]    = ["Attribute", "Flag", "Cost", "Compatibility", "Alias", "Debug", "Function", "Warning"]
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var schema = await SchemaService.GetSchemaAsync();
            if (schema != null)
            {
                foreach (var (group, categories) in GroupCategories)
                {
                    _groupCounts[group] = schema.Properties.Values
                        .Count(p => categories.Any(c => c.Equals(p.Category, StringComparison.OrdinalIgnoreCase)));
                }
            }
        }
        catch
        {
            // Counts will just show 0 if schema unavailable
        }
        finally
        {
            _loading = false;
        }
    }

    private int GetGroupCount(string group) =>
        _groupCounts.TryGetValue(group, out var count) ? count : 0;

    private async Task ExportConfig()
    {
        var json = await AdminConfigService.ExportConfigAsync();
        if (json == null)
        {
            Snackbar.Add(Loc["ExportFailed"].Value, Severity.Error);
            return;
        }

        var bytes = System.Text.Encoding.UTF8.GetBytes(json);
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("eval",
            $"var a=document.createElement('a');a.href='data:application/json;base64,{base64}';a.download='sharpmush-config.json';a.click()");
        Snackbar.Add(Loc["ConfigurationExported"].Value, Severity.Success);
    }
}

