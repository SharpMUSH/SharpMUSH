@page "/admin/config"
@attribute [Authorize(Policy = "config.admin")]
@using SharpMUSH.Client.Services
@using SharpMUSH.Library.API
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> Loc
@inject ConfigSchemaService SchemaService

<PageTitle>@Loc["Configuration"] - @Loc["AppTitle"]</PageTitle>

<div class="config-home">
    @* Header — prototype SectionTitle: kicker + title + description *@
    <div class="config-home-header">
        <div class="config-kicker">Admin · server configuration</div>
        <h1 class="config-title">@Loc["ServerConfiguration"]</h1>
        <p class="config-desc">@Loc["ManageAllSettings"]</p>
    </div>

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Style="height:2px;" />
    }
    else
    {
        <div class="config-cat-grid">
            @foreach (var cat in Categories)
            {
                var c = cat;
                <div class="config-cat-card" @onclick="@(() => Navigation.NavigateTo(c.Route))">
                    <div class="config-cat-icon">
                        <MudIcon Icon="@c.Icon" Style="font-size:22px;color:var(--accent);" />
                    </div>
                    <div style="flex:1;min-width:0;">
                        <div class="config-cat-title">
                            @Loc[c.TitleKey]
                            @if (c.Important)
                            {
                                <span class="config-cat-flag">@Loc["Important"]</span>
                            }
                        </div>
                        <div class="config-cat-desc">@Loc[c.DescKey]</div>
                        <div class="config-cat-count">@GetGroupCount(c.Group) @Loc["Settings"]</div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private Dictionary<string, int> _groupCounts = new();

    private sealed record CatCard(string Group, string TitleKey, string DescKey, string Icon, string Route, bool Important = false);

    private static readonly CatCard[] Categories =
    [
        new("Server",      "Server",       "ServerCategoryDescription",      Icons.Material.Filled.Computer,   "/admin/config/net"),
        new("Performance", "Performance",  "PerformanceCategoryDescription", Icons.Material.Filled.Speed,      "/admin/config/limit"),
        new("Security",    "Security",     "SecurityCategoryDescription",    Icons.Material.Filled.Security,   "/admin/config/sitelock", Important: true),
        new("Content",     "Content",      "ContentCategoryDescription",     Icons.Material.Filled.Article,    "/admin/config/message"),
        new("Logs",        "LogsAndFiles", "LogsCategoryDescription",        Icons.Material.Filled.FolderOpen, "/admin/config/log"),
        new("Advanced",    "Advanced",     "AdvancedCategoryDescription",    Icons.Material.Filled.Tune,       "/admin/config/attribute"),
    ];

    // Maps nav group names to the schema category names they contain
    private static readonly Dictionary<string, string[]> GroupCategories = new(StringComparer.OrdinalIgnoreCase)
    {
        ["Server"]      = ["Net", "Database"],
        ["Performance"] = ["Limit", "Command"],
        ["Security"]    = ["SitelockRules", "BannedNames", "Restriction"],
        ["Content"]     = ["Message", "Cosmetic", "Chat"],
        ["Logs"]        = ["Log", "File", "TextFile", "Dump"],
        ["Advanced"]    = ["Attribute", "Flag", "Cost", "Compatibility", "Alias", "Debug", "Function", "Warning"]
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var schema = await SchemaService.GetSchemaAsync();
            if (schema != null)
            {
                foreach (var (group, categories) in GroupCategories)
                {
                    _groupCounts[group] = schema.Properties.Values
                        .Count(p => categories.Any(c => c.Equals(p.Category, StringComparison.OrdinalIgnoreCase)));
                }
            }
        }
        catch
        {
            // Counts will just show 0 if schema unavailable
        }
        finally
        {
            _loading = false;
        }
    }

    private int GetGroupCount(string group) =>
        _groupCounts.TryGetValue(group, out var count) ? count : 0;
}
