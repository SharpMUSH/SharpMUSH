@page "/settings/characters"
@attribute [Authorize]
@inject IStringLocalizer<SharedResource> Loc

<PageTitle>Characters — Settings — SharpMUSH</PageTitle>

<div class="settings-page">
    <header class="settings-header">
        <div class="settings-kicker">@Loc["AppTitle"] · Settings</div>
        <h1 class="settings-title">Character Management</h1>
    </header>

    <section class="settings-card">
        <div class="settings-card-section-label">Coming soon</div>
        <p class="settings-card-text">
            Character management is on the way. For now, see the
            <a class="settings-link" href="/account">account page</a>.
        </p>
    </section>
</div>
