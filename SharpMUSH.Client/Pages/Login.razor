@page "/login"
@layout OnboardingLayout
@using SharpMUSH.Client.Layout
@using SharpMUSH.Client.Services
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResource> Loc
@inject AccountAuthService AccountAuth
@inject ITerminalService Terminal

<PageTitle>Sign In — SharpMUSH</PageTitle>

@* Single centered card — no marketing hero, no scrolling. Mirrors Setup.razor's visual family
   (logo + title above a card) inside OnboardingLayout's shell, which already supplies the
   full-viewport gradient background and glow. *@
<div class="login-page">
    <div class="login-brand">
        <img src="assets/Logo.svg" alt="SharpMUSH" class="login-logo" />
        <h1 class="login-brand-title">SharpMUSH</h1>
    </div>

    <MudPaper Elevation="4" Class="login-card">

        <MudTabs @bind-ActivePanelIndex="_tabIndex" Elevation="0" Rounded="true" Centered="true" Class="mb-3">
            <MudTabPanel Text="Sign In">
                <div class="pa-0 pt-3">
                    <MudTextField id="login-username" @bind-Value="_loginIdentifier" Label="Username or email"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Person"
                                  Disabled="_busy" OnKeyDown="OnKeyDown" />
                    <MudTextField id="login-password" @bind-Value="_loginPassword" Label="Password"
                                  InputType="InputType.Password"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock"
                                  Disabled="_busy" OnKeyDown="OnKeyDown" />

                    @if (_error is not null)
                    {
                        <MudAlert Severity="Severity.Error" Dense="true" Class="mb-3">@_error</MudAlert>
                    }

                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                               Disabled="_busy" OnClick="LoginAsync" Class="login-submit"
                               Style="font-weight:600;font-size:0.9375rem;height:42px;">
                        @if (_busy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                        Connect
                    </MudButton>
                </div>
            </MudTabPanel>

            <MudTabPanel Text="Register">
                <div class="pa-0 pt-3">
                    <MudTextField @bind-Value="_regUsername" Label="Username"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Person"
                                  Disabled="_busy" />
                    <MudTextField @bind-Value="_regEmail" Label="Email (optional)"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email"
                                  Disabled="_busy" />
                    <MudTextField @bind-Value="_regPassword" Label="Password"
                                  InputType="InputType.Password"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock"
                                  Disabled="_busy" />

                    @if (_error is not null)
                    {
                        <MudAlert Severity="Severity.Error" Dense="true" Class="mb-3">@_error</MudAlert>
                    }

                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                               Disabled="_busy" OnClick="RegisterAsync"
                               Style="font-weight:600;font-size:0.9375rem;height:42px;">
                        @if (_busy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                        Create Account
                    </MudButton>
                </div>
            </MudTabPanel>
        </MudTabs>

        <MudDivider Class="my-3" />
        <MudText Align="Align.Center" Style="font-size:0.8125rem;color:var(--text-faint);">
            Or connect directly via the
            <MudLink Href="/play" Style="color:var(--accent);">terminal</MudLink>
        </MudText>
    </MudPaper>
</div>

@code {
    private int _tabIndex = 0;
    private bool _busy;
    private string? _error;

    private string _loginIdentifier = string.Empty;
    private string _loginPassword = string.Empty;

    private string _regUsername = string.Empty;
    private string _regEmail = string.Empty;
    private string _regPassword = string.Empty;

    private string? _returnUrl;

    protected override void OnInitialized()
    {
        // Populated when RedirectToLogin sent an anonymous visitor here off an [Authorize] page
        // (see App.razor's NotAuthorized branch / RedirectToLogin.razor). Parsed by hand rather
        // than via [SupplyParameterFromQuery] or QueryHelpers: this page isn't always reached
        // through the Router's own query-binding path (bUnit renders it directly in tests), and
        // Microsoft.AspNetCore.WebUtilities isn't a package this WASM client references.
        _returnUrl = ExtractReturnUrl(Nav.Uri);
    }

    private static string? ExtractReturnUrl(string uri)
    {
        var query = new Uri(uri).Query;
        if (string.IsNullOrEmpty(query)) return null;

        foreach (var pair in query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var parts = pair.Split('=', 2);
            if (parts.Length == 2 && parts[0] == "returnUrl")
                return Uri.UnescapeDataString(parts[1]);
        }
        return null;
    }

    /// <summary>
    /// Where to send the user after a successful login/registration. Only ever a same-origin
    /// relative path — a bare "/..." not "//..." or "/\..." (both of which browsers/some user
    /// agents treat as protocol-relative, i.e. an open redirect to an attacker-controlled host).
    /// Anything else (absolute URLs, external hosts, garbage) falls back to "/".
    /// </summary>
    private string SuccessUrl()
    {
        var url = _returnUrl;
        if (string.IsNullOrEmpty(url)) return "/";
        if (!url.StartsWith('/')) return "/";
        if (url.StartsWith("//") || url.StartsWith("/\\")) return "/";
        return url;
    }

    private async Task LoginAsync()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(_loginIdentifier) || string.IsNullOrWhiteSpace(_loginPassword))
        {
            _error = "Please enter your credentials.";
            return;
        }
        _busy = true;
        StateHasChanged();
        var (success, error, _) = await AccountAuth.LoginAsync(_loginIdentifier, _loginPassword);
        _busy = false;
        if (success)
            Nav.NavigateTo(SuccessUrl());
        else
            _error = error ?? "Login failed.";
        StateHasChanged();
    }

    private async Task RegisterAsync()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(_regUsername) || string.IsNullOrWhiteSpace(_regPassword))
        {
            _error = "Username and password are required.";
            return;
        }
        _busy = true;
        StateHasChanged();
        var (success, error, _) = await AccountAuth.RegisterAsync(_regUsername, _regEmail, _regPassword);
        _busy = false;
        if (success)
            Nav.NavigateTo(SuccessUrl());
        else
            _error = error ?? "Registration failed.";
        StateHasChanged();
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await LoginAsync();
    }
}
