@page "/scenes/{Id}/live"
@attribute [Authorize]
@inject IStringLocalizer<SharedResource> Loc

<PageTitle>@Loc["LiveScene"] @Id — SharpMUSH</PageTitle>

<div style="padding:var(--cpad);">
    @* TODO(Phase 4/5): live scene via the game.scene.{id} SignalR leg + web pose
       authoring through GameHub.SendCommand. *@
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        Live scene @Id is being rebuilt on the new scene engine.
    </MudAlert>
</div>

@code {
    [Parameter] public string Id { get; set; } = string.Empty;
}
