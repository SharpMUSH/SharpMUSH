@page "/wiki"
@inject IStringLocalizer<SharedResource> Loc

<PageTitle>@Loc["Wiki"] — SharpMUSH</PageTitle>

@* The wiki landing page is composed from the "wiki-index" layout scope, so admins can recompose it
   in the layout editor. Its default layout is a single WikiIndex widget; admins may add sidebars,
   quick links, recent-changes widgets, etc. around it. *@
<ScopedZone Scope="@LayoutScopes.WikiIndex" Zone="WidgetZone.MainContent" />
