@page "/mail/compose"
@attribute [Authorize]
@using SharpMUSH.Client.Services
@inject IStringLocalizer<SharedResource> Loc
@inject MailService Mail
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Compose Mail — SharpMUSH</PageTitle>

<div class="mail-compose-page" style="padding:var(--cpad);">

    <div style="display:flex;align-items:center;gap:0.625rem;margin-bottom:1.25rem;">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/mail"
                       Style="color:var(--text-dim);" />
        <div>
            <div class="mc-kicker">@Loc["Mail"]</div>
            <div class="mc-title">@Loc["ComposeMail"]</div>
        </div>
    </div>

    <div class="mc-card">
        <MudTextField @bind-Value="_to" Label="@Loc["To"]" Variant="Variant.Outlined"
                      Margin="Margin.Dense" Class="mc-field mb-3" Required="true" />
        <MudTextField @bind-Value="_subject" Label="@Loc["Subject"]" Variant="Variant.Outlined"
                      Margin="Margin.Dense" Class="mc-field mb-3" />
        <MudTextField @bind-Value="_body" Label="@Loc["Message"]" Variant="Variant.Outlined"
                      Lines="10" Margin="Margin.Dense" Class="mc-field mb-3" />
        <MudCheckBox @bind-Value="_urgent" Label="@Loc["Urgent"]" Color="Color.Error" Class="mb-4" />

        <div class="mc-actions" style="display:flex;gap:0.625rem;">
            <MudButton Variant="Variant.Filled"
                       Style="background:var(--accent);color:var(--accent-on);text-transform:none;font-weight:600;"
                       StartIcon="@Icons.Material.Filled.Send"
                       OnClick="SendAsync" Disabled="_sending || string.IsNullOrWhiteSpace(_to)">
                @Loc["Send"]
            </MudButton>
            <MudButton Variant="Variant.Text" Href="/mail" Disabled="_sending"
                       Style="color:var(--text-dim);text-transform:none;">@Loc["Cancel"]</MudButton>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "to")] public string? ToQuery { get; set; }
    [SupplyParameterFromQuery(Name = "subject")] public string? SubjectQuery { get; set; }

    private string _to = string.Empty;
    private string _subject = string.Empty;
    private string _body = string.Empty;
    private bool _urgent;
    private bool _sending;

    protected override void OnParametersSet()
    {
        // Mirror the query params each navigation so a prior reply's recipient/subject
        // never persists when the user opens a blank compose form.
        _to = string.IsNullOrWhiteSpace(ToQuery) ? string.Empty : ToQuery!;
        _subject = string.IsNullOrWhiteSpace(SubjectQuery) ? string.Empty : SubjectQuery!;
    }

    private async Task SendAsync()
    {
        _sending = true;
        var ok = await Mail.SendAsync(_to.Trim(), _subject, _body, _urgent);
        _sending = false;

        if (ok)
        {
            Snackbar.Add(Loc["MailSent"], Severity.Success);
            Nav.NavigateTo("/mail");
        }
        else
        {
            Snackbar.Add(Loc["MailSendFailed"], Severity.Error);
        }
    }
}

<style>
    /* Mobile: trim the page padding and make the Send/Cancel buttons full-width,
       comfortably tappable, stacked rows. */
    @@media (max-width: 760px) {
        .mail-compose-page {
            padding: 1rem !important;
        }
        .mail-compose-page .mc-actions {
            flex-direction: column;
        }
        .mail-compose-page .mc-actions .mud-button-root {
            width: 100%;
            min-height: 44px;
        }
    }
</style>
