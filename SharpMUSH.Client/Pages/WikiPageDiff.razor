@page "/wiki/{Ns}/{Category}/{Slug}/diff"
@using SharpMUSH.Client.Models
@using SharpMUSH.Client.Services
@using OneOf
@inject WikiService Wiki
@inject IStringLocalizer<SharedResource> Loc
@inject NavigationManager Nav

<PageTitle>Diff: @Slug — SharpMUSH</PageTitle>

<div class="wikidiff">
    <a class="wikidiff-back" href="@($"/wiki/{Ns}/{Category}/{Slug}/history")">
        <MudIcon Icon="@Icons.Material.Filled.ChevronLeft" Style="font-size:0.875rem;" /> Revision history
    </a>
    <div class="wikidiff-head">
        <div>
            <div class="wikidiff-kicker">Comparing revisions</div>
            <h1 class="wikidiff-title">@_displayTitle</h1>
        </div>
        <div class="wikidiff-toggle">
            <button type="button"
                    class="@($"wikidiff-toggle-btn{(_mode == "unified" ? " active" : "")}")"
                    @onclick="@(() => _mode = "unified")">
                Unified
            </button>
            <button type="button"
                    class="@($"wikidiff-toggle-btn{(_mode == "split" ? " active" : "")}")"
                    @onclick="@(() => _mode = "split")">
                Side by side
            </button>
        </div>
    </div>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        @for (var i = 0; i < 6; i++) { <MudSkeleton Height="22px" Class="mb-1" /> }
    }
    else if (_fromRev is null || _toRev is null)
    {
        <MudAlert Severity="Severity.Warning">Could not load one or both revisions. Check your revision numbers.</MudAlert>
    }
    else
    {
        <div class="wikidiff-revbar">
            <div class="wikidiff-revcard">
                <div class="wikidiff-revdate">@_fromRev.Timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                <div class="wikidiff-revmeta">@_fromRev.EditorDbref · rev #@_fromRev.RevisionNumber</div>
            </div>
            <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Style="font-size:1rem;color:var(--text-faint);flex-shrink:0;" />
            <div class="wikidiff-revcard wikidiff-revcard--new">
                <div class="wikidiff-revdate">@_toRev.Timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                <div class="wikidiff-revmeta">@_toRev.EditorDbref · rev #@_toRev.RevisionNumber</div>
            </div>
        </div>

        <div class="wikidiff-stats">
            <span class="wikidiff-stat-add">+@_addedCount added</span>
            <span class="wikidiff-stat-del">−@_removedCount removed</span>
            @if (!string.IsNullOrWhiteSpace(_toRev.EditSummary))
            {
                <span class="wikidiff-stat-sum">· Summary: <span style="font-style:italic;">@_toRev.EditSummary</span></span>
            }
        </div>

        @if (_mode == "split")
        {
            <div class="wikidiff-body wikidiff-split">
                <div class="wikidiff-split-col">
                    <div class="wikidiff-split-head wikidiff-split-head--old">Rev @_fromRev.RevisionNumber — Old</div>
                    <pre class="wikidiff-pane">@_fromRev.MarkdownSource</pre>
                </div>
                <div class="wikidiff-split-col">
                    <div class="wikidiff-split-head wikidiff-split-head--new">Rev @_toRev.RevisionNumber — New</div>
                    <pre class="wikidiff-pane">@_toRev.MarkdownSource</pre>
                </div>
            </div>
        }
        else
        {
            <div class="wikidiff-body">
                @foreach (var hunk in _hunks)
                {
                    @if (hunk.Kind == DiffLineKind.Header)
                    {
                        <div class="wikidiff-hunk">
                            <MudIcon Icon="@Icons.Material.Filled.Code" Style="font-size:0.8125rem;color:var(--accent);" />
                            <span>@@@@ @hunk.Text @@@@</span>
                        </div>
                    }
                    else if (hunk.Kind == DiffLineKind.Added)
                    {
                        <div class="wikidiff-line wikidiff-line--add">
                            <span class="wikidiff-gutter wikidiff-gutter--add">+</span>
                            <span class="wikidiff-text">@(string.IsNullOrEmpty(hunk.Text) ? " " : hunk.Text)</span>
                        </div>
                    }
                    else if (hunk.Kind == DiffLineKind.Removed)
                    {
                        <div class="wikidiff-line wikidiff-line--del">
                            <span class="wikidiff-gutter wikidiff-gutter--del">−</span>
                            <span class="wikidiff-text">@(string.IsNullOrEmpty(hunk.Text) ? " " : hunk.Text)</span>
                        </div>
                    }
                    else
                    {
                        <div class="wikidiff-line wikidiff-line--ctx">
                            <span class="wikidiff-gutter">&nbsp;</span>
                            <span class="wikidiff-text">@(string.IsNullOrEmpty(hunk.Text) ? " " : hunk.Text)</span>
                        </div>
                    }
                }
            </div>
        }
    }
</div>

<style>
    .wikidiff {
        padding: var(--cpad);
    }
    .wikidiff-back {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        font-family: var(--font-ui);
        font-size: 0.8125rem;
        color: var(--text-dim);
        text-decoration: none;
        margin-bottom: 1rem;
    }
    .wikidiff-back:hover { color: var(--accent); }
    .wikidiff-head {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1.125rem;
    }
    .wikidiff-kicker {
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 0.375rem;
    }
    .wikidiff-title {
        margin: 0;
        font-family: var(--font-display);
        font-size: 1.625rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: var(--text);
    }

    .wikidiff-toggle {
        display: flex;
        gap: 0.25rem;
        padding: 0.1875rem;
        background: var(--surface);
        border: 1px solid var(--border-soft);
        border-radius: var(--radius);
        flex-shrink: 0;
    }
    .wikidiff-toggle-btn {
        padding: 0.375rem 0.75rem;
        border-radius: var(--radius);
        border: none;
        cursor: pointer;
        font-family: var(--font-ui);
        font-size: 0.78125rem;
        font-weight: 600;
        background: transparent;
        color: var(--text-dim);
    }
    .wikidiff-toggle-btn.active {
        background: rgba(var(--glow), 0.12);
        color: var(--accent);
    }

    .wikidiff-revbar {
        display: flex;
        align-items: center;
        gap: 0.875rem;
        margin-bottom: 0.875rem;
    }
    .wikidiff-revcard {
        flex: 1;
        min-width: 0;
        padding: 0.6875rem 0.875rem;
        background: var(--surface);
        border: 1px solid var(--border-soft);
        border-radius: var(--radius);
    }
    .wikidiff-revcard--new {
        border-color: rgba(var(--glow), 0.3);
    }
    .wikidiff-revdate {
        font-family: var(--font-ui);
        font-size: 0.8125rem;
        font-weight: 600;
        color: var(--text);
    }
    .wikidiff-revmeta {
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        color: var(--text-faint);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .wikidiff-stats {
        display: flex;
        align-items: center;
        gap: 0.875rem;
        margin-bottom: 0.75rem;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        flex-wrap: wrap;
    }
    .wikidiff-stat-add { color: var(--accent); }
    .wikidiff-stat-del { color: #e57373; }
    .wikidiff-stat-sum { color: var(--text-faint); }

    .wikidiff-body {
        background: var(--surface-3);
        border: 1px solid var(--border-soft);
        border-radius: var(--radius-lg);
        overflow: hidden;
        font-family: var(--font-mono);
        font-size: 0.8125rem;
        line-height: 1.65;
    }
    .wikidiff-line {
        display: flex;
        border-left: 2px solid transparent;
    }
    .wikidiff-line--add {
        background: rgba(var(--glow), 0.07);
        border-left-color: var(--accent);
    }
    .wikidiff-line--del {
        background: rgba(229, 115, 115, 0.08);
        border-left-color: #e57373;
    }
    .wikidiff-line--ctx { background: transparent; }
    .wikidiff-gutter {
        width: 26px;
        flex-shrink: 0;
        text-align: center;
        user-select: none;
        border-right: 1px solid var(--border-soft);
        padding: 0.125rem 0;
        color: var(--text-faint);
    }
    .wikidiff-gutter--add { color: var(--accent); }
    .wikidiff-gutter--del { color: #e57373; }
    .wikidiff-line--ctx .wikidiff-text { color: var(--text-dim); }
    .wikidiff-line--del .wikidiff-text { color: var(--text-dim); }
    .wikidiff-text {
        padding: 0.125rem 0.875rem;
        color: var(--text);
        white-space: pre-wrap;
        word-break: break-word;
    }
    .wikidiff-hunk {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.375rem 0.875rem;
        background: var(--surface-2);
        border-top: 1px solid var(--border-soft);
        border-bottom: 1px solid var(--border-soft);
        color: var(--text-faint);
        font-size: 0.71875rem;
    }

    .wikidiff-split {
        display: grid;
        grid-template-columns: 1fr 1fr;
        background: transparent;
        border: none;
        border-radius: 0;
        overflow: visible;
    }
    .wikidiff-split-col { min-width: 0; }
    .wikidiff-split-head {
        padding: 0.375rem 0.75rem;
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-dim);
        border: 1px solid var(--border-soft);
        border-bottom: none;
        border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    }
    .wikidiff-split-head--old { background: rgba(229, 115, 115, 0.08); }
    .wikidiff-split-head--new { background: rgba(var(--glow), 0.07); }
    .wikidiff-pane {
        background: var(--surface-3);
        border: 1px solid var(--border-soft);
        border-top: none;
        border-radius: 0 0 var(--radius-lg) var(--radius-lg);
        padding: 0.75rem;
        font-family: var(--font-mono);
        font-size: 0.78125rem;
        line-height: 1.7;
        white-space: pre-wrap;
        word-break: break-word;
        margin: 0;
        max-height: 70vh;
        max-height: 70svh;
        overflow-y: auto;
        color: var(--text);
    }

    /* Phones: drop the page gutter, let the header (title + mode toggle) stack,
       and collapse the side-by-side panes into a single stacked column. Diff
       text already wraps (pre-wrap + break-word), so no horizontal scroll needed. */
    @@media (max-width: 760px) {
        .wikidiff { padding: 1rem 0.75rem; }
        .wikidiff-head { flex-direction: column; align-items: flex-start; }
        .wikidiff-split { grid-template-columns: minmax(0, 1fr); }
        .wikidiff-pane { max-height: 50vh; max-height: 50svh; }
    }
</style>

@code {
    [Parameter] public required string Slug { get; set; }
    [Parameter] public required string Ns { get; set; }
    [Parameter] public required string Category { get; set; }

    [SupplyParameterFromQuery(Name = "from")]
    public int? FromRev { get; set; }

    [SupplyParameterFromQuery(Name = "to")]
    public int? ToRev { get; set; }

    private string _mode = "unified";
    private WikiRevisionInfo? _fromRev;
    private WikiRevisionInfo? _toRev;
    private bool _loading = true;
    private List<DiffLine> _hunks = [];
    private int _addedCount;
    private int _removedCount;
    private string _displayTitle = "Page";

    private enum DiffLineKind { Header, Added, Removed, Context }
    private record DiffLine(DiffLineKind Kind, string Text);

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _displayTitle = string.IsNullOrWhiteSpace(Slug) ? "Page" : Slug.Replace('-', ' ');

        if (FromRev.HasValue && ToRev.HasValue)
        {
            var fromTask = Wiki.GetRevisionAsync(Slug, FromRev.Value, Ns, Category);
            var toTask   = Wiki.GetRevisionAsync(Slug, ToRev.Value, Ns, Category);
            await Task.WhenAll(fromTask.AsTask(), toTask.AsTask());
            var fromResult = await fromTask;
            var toResult   = await toTask;
            _fromRev = fromResult.IsT0 ? fromResult.AsT0 : null;
            _toRev   = toResult.IsT0   ? toResult.AsT0   : null;
        }

        if (_fromRev is not null && _toRev is not null)
            ComputeDiff();

        _loading = false;
    }

    private void ComputeDiff()
    {
        var oldLines = _fromRev!.MarkdownSource.Split('\n');
        var newLines = _toRev!.MarkdownSource.Split('\n');
        _hunks = [];
        _addedCount = 0;
        _removedCount = 0;

        var dp = ComputeLcs(oldLines, newLines);
        var changes = BuildChanges(oldLines, newLines, dp);

        const int ctx = 3;
        var inHunk = false;
        var oldIdx = 0;
        var newIdx = 0;

        for (var i = 0; i < changes.Count; i++)
        {
            var ch = changes[i];
            if (ch.Kind == DiffLineKind.Context)
            {
                var nearChange = false;
                for (var j = Math.Max(0, i - ctx); j <= Math.Min(changes.Count - 1, i + ctx); j++)
                    if (changes[j].Kind != DiffLineKind.Context) { nearChange = true; break; }

                if (nearChange)
                {
                    if (!inHunk)
                    {
                        _hunks.Add(new DiffLine(DiffLineKind.Header, $"-{oldIdx + 1} +{newIdx + 1}"));
                        inHunk = true;
                    }
                    _hunks.Add(ch);
                }
                else { inHunk = false; }
                oldIdx++; newIdx++;
            }
            else if (ch.Kind == DiffLineKind.Removed)
            {
                if (!inHunk)
                {
                    _hunks.Add(new DiffLine(DiffLineKind.Header, $"-{oldIdx + 1} +{newIdx + 1}"));
                    inHunk = true;
                }
                _hunks.Add(ch);
                _removedCount++;
                oldIdx++;
            }
            else
            {
                if (!inHunk)
                {
                    _hunks.Add(new DiffLine(DiffLineKind.Header, $"-{oldIdx + 1} +{newIdx + 1}"));
                    inHunk = true;
                }
                _hunks.Add(ch);
                _addedCount++;
                newIdx++;
            }
        }
    }

    private static List<DiffLine> BuildChanges(string[] old, string[] nw, int[,] dp)
    {
        var result = new List<DiffLine>();
        BuildHelper(old, nw, dp, old.Length, nw.Length, result);
        return result;
    }

    private static void BuildHelper(string[] old, string[] nw, int[,] dp, int i, int j, List<DiffLine> acc)
    {
        if (i == 0 && j == 0) return;
        if (i > 0 && j > 0 && old[i - 1] == nw[j - 1])
        {
            BuildHelper(old, nw, dp, i - 1, j - 1, acc);
            acc.Add(new DiffLine(DiffLineKind.Context, old[i - 1]));
        }
        else if (j > 0 && (i == 0 || dp[i, j - 1] >= dp[i - 1, j]))
        {
            BuildHelper(old, nw, dp, i, j - 1, acc);
            acc.Add(new DiffLine(DiffLineKind.Added, nw[j - 1]));
        }
        else
        {
            BuildHelper(old, nw, dp, i - 1, j, acc);
            acc.Add(new DiffLine(DiffLineKind.Removed, old[i - 1]));
        }
    }

    private static int[,] ComputeLcs(string[] a, string[] b)
    {
        var dp = new int[a.Length + 1, b.Length + 1];
        for (var i = 1; i <= a.Length; i++)
            for (var j = 1; j <= b.Length; j++)
                dp[i, j] = a[i - 1] == b[j - 1] ? dp[i - 1, j - 1] + 1 : Math.Max(dp[i - 1, j], dp[i, j - 1]);
        return dp;
    }
}
