@page "/character/{Name}"
@using Microsoft.AspNetCore.Components.Authorization
@using SharpMUSH.Client.Components
@using SharpMUSH.Client.Components.Widgets
@inject AuthenticationStateProvider AuthStateProvider
@inject IStringLocalizer<SharedResource> Loc

<PageTitle>@Name</PageTitle>

@* Composed from registered portal widgets (CharacterHeader / CharacterGallery) plus the wiki
   body for the Character:Name page. Each widget is an IPortalWidget and can also be placed in
   a zone via the layout editor. Profiles are read-only on the portal for now (the in-game
   http_handler softcode serves the public view; editing happens in-game). *@
<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudGrid Spacing="4">
        <MudItem xs="12" md="8">
            <CharacterHeaderWidget CharacterName="@Name" />

            @* Freeform wiki body lives at the Character:Name wiki page. *@
            <MudPaper Outlined="true" Class="pa-4 mt-4">
                <WikiView Slug="@Name" Mode="WikiView.WikiMode.View" />
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <CharacterGalleryWidget CharacterName="@Name" CanEdit="_canEdit" />
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    [Parameter]
    public required string Name { get; set; }

    private bool _canEdit;

    protected override async Task OnInitializedAsync()
    {
        // Gallery edit affordances for any authenticated user; the server enforces real rights.
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _canEdit = authState.User.Identity?.IsAuthenticated == true;
    }
}
