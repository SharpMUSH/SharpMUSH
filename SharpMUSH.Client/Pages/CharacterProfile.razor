@page "/character/{Name}"
@using Microsoft.AspNetCore.Components.Authorization
@using SharpMUSH.Client.Models.Widgets
@inject AuthenticationStateProvider AuthStateProvider
@inject IStringLocalizer<SharedResource> Loc

<PageTitle>@Name — SharpMUSH</PageTitle>

<div>
    @{
        var hue = Math.Abs((Name ?? "").GetHashCode()) % 360;
    }
    <div class="char-profile-banner" style="@($"height:160px;background:linear-gradient(135deg,hsl({hue},40%,14%) 0%,hsl({(hue+40)%360},30%,10%) 100%);position:relative;")">
        <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 30% 50%,rgba(var(--glow),0.12) 0%,transparent 60%);pointer-events:none;"></div>
    </div>

    <div style="padding:0 var(--cpad) var(--cpad);">
        <div style="margin-top:-40px;margin-bottom:16px;display:flex;align-items:flex-end;gap:16px;">
            <MudAvatar Style="@($"background:hsl({hue},50%,30%);color:#fff;font-size:28px;font-weight:700;width:80px;height:80px;border:3px solid var(--bg);flex-shrink:0;")" >
                @(Name?.Length > 0 ? Name[0].ToString().ToUpper() : "?")
            </MudAvatar>
            <div style="padding-bottom:6px;">
                <MudText Typo="Typo.h5" Style="font-weight:700;line-height:1.2;">@Name</MudText>
            </div>
        </div>

        @* Profile body and right rail compose from the "profile" layout scope. The cascading context
           supplies the character (from the route) and edit rights to whatever widgets the admin places. *@
        <CascadingValue Value="_context" IsFixed="false">
            <MudGrid Spacing="4">
                <MudItem xs="12" md="8">
                    <ScopedZone Scope="@LayoutScopes.Profile" Zone="WidgetZone.MainContent" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <ScopedZone Scope="@LayoutScopes.Profile" Zone="WidgetZone.RightSidebar" />
                </MudItem>
            </MudGrid>
        </CascadingValue>
    </div>
</div>

<style>
    @@media (max-width: 760px) {
        .char-profile-banner {
            height: 110px !important;
        }
    }
</style>

@code {
    [Parameter]
    public required string Name { get; set; }

    private bool _canEdit;
    private ProfilePageContext _context = new(string.Empty, false);

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _canEdit = authState.User.Identity?.IsAuthenticated == true;
        _context = new ProfilePageContext(Name, _canEdit);
    }

    protected override void OnParametersSet()
        => _context = new ProfilePageContext(Name, _canEdit);
}
