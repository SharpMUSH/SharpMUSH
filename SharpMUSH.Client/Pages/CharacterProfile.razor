@page "/character/{Name}"
@using Microsoft.AspNetCore.Components.Authorization
@using SharpMUSH.Client.Components
@using SharpMUSH.Client.Components.Widgets
@inject AuthenticationStateProvider AuthStateProvider
@inject IStringLocalizer<SharedResource> Loc

<PageTitle>@Name — SharpMUSH</PageTitle>

<div>
    @* Banner *@
    @{
        var hue = Math.Abs((Name ?? "").GetHashCode()) % 360;
    }
    <div style="@($"height:160px;background:linear-gradient(135deg,hsl({hue},40%,14%) 0%,hsl({(hue+40)%360},30%,10%) 100%);position:relative;")">
        <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 30% 50%,rgba(var(--glow),0.12) 0%,transparent 60%);pointer-events:none;"></div>
    </div>

    <div style="padding:0 var(--cpad) var(--cpad);">
        @* Avatar overlapping banner *@
        <div style="margin-top:-40px;margin-bottom:16px;display:flex;align-items:flex-end;gap:16px;">
            <MudAvatar Style="@($"background:hsl({hue},50%,30%);color:#fff;font-size:28px;font-weight:700;width:80px;height:80px;border:3px solid var(--bg);flex-shrink:0;")" >
                @(Name?.Length > 0 ? Name[0].ToString().ToUpper() : "?")
            </MudAvatar>
            <div style="padding-bottom:6px;">
                <MudText Typo="Typo.h5" Style="font-weight:700;line-height:1.2;">@Name</MudText>
            </div>
        </div>

        @* Profile content *@
        <MudGrid Spacing="4">
            <MudItem xs="12" md="8">
                <CharacterHeaderWidget CharacterName="@Name" />

                <MudPaper Elevation="0" Style="padding:20px;margin-top:16px;border-radius:var(--radius);border:1px solid var(--border);background:var(--surface);">
                    <WikiView Slug="@Name" Mode="WikiView.WikiMode.View" />
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <CharacterGalleryWidget CharacterName="@Name" CanEdit="_canEdit" />
            </MudItem>
        </MudGrid>
    </div>
</div>

@code {
    [Parameter]
    public required string Name { get; set; }

    private bool _canEdit;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _canEdit = authState.User.Identity?.IsAuthenticated == true;
    }
}
