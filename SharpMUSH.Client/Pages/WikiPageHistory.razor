@page "/wiki/{Ns}/{Category}/{Slug}/history"
@* History is shown as a dialog from the wiki page view, not a separate route. *@
@* Redirect to the wiki page so any direct links or bookmarks still work. *@

@code {
    [Parameter]
    public required string Slug { get; set; }

    [Parameter]
    public required string Ns { get; set; }

    [Parameter]
    public required string Category { get; set; }

    [Inject]
    public required NavigationManager Nav { get; set; }

    protected override void OnInitialized()
    {
        Nav.NavigateTo($"/wiki/{Ns}/{Category}/{Slug}", replace: true);
    }
}
