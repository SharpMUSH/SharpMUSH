@page "/scenes"
@using SharpMUSH.Client.Models
@using SharpMUSH.Client.Services
@inject IStringLocalizer<SharedResource> Loc
@inject SceneService SceneService

<PageTitle>@Loc["SceneArchive"] — SharpMUSH</PageTitle>

<div class="scenes-page" style="padding:var(--cpad);">
    <MudText Typo="Typo.h4" Style="font-weight:700;margin-bottom:4px;">@Loc["SceneArchive"]</MudText>
    <MudText Style="color:var(--text-dim);font-size:14px;margin-bottom:24px;">Browse and watch roleplay sessions.</MudText>

    <MudTabs Elevation="0" Rounded="false" @bind-ActivePanelIndex="_tab">
        <MudTabPanel Text="Recent" BadgeData="@(_recent?.Count)" BadgeColor="Color.Default">
            @SceneList(_recent)
        </MudTabPanel>
        <MudTabPanel Text="Live" BadgeData="@(_active?.Count)" BadgeColor="Color.Success">
            @SceneList(_active)
        </MudTabPanel>
    </MudTabs>
</div>

@code {
    private int _tab;
    private bool _loading = true;
    private IReadOnlyList<SceneSummary>? _recent;
    private IReadOnlyList<SceneSummary>? _active;

    protected override async Task OnInitializedAsync()
    {
        var recentTask = SceneService.GetRecentScenesAsync(50);
        var activeTask = SceneService.GetActiveScenesAsync();
        _recent = await recentTask;
        _active = await activeTask;
        _loading = false;
    }

    private RenderFragment SceneList(IReadOnlyList<SceneSummary>? scenes) => __builder =>
    {
        if (_loading)
        {
            for (var i = 0; i < 4; i++)
            {
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="72px" Class="mb-2" Style="border-radius:var(--radius);" />
            }
        }
        else if (scenes is null || scenes.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">No scenes found.</MudAlert>
        }
        else
        {
            <div style="display:flex;flex-direction:column;gap:10px;">
                @foreach (var scene in scenes)
                {
                    <MudPaper Elevation="0"
                              Style="display:flex;align-items:center;gap:16px;padding:14px 18px;border-radius:var(--radius);border:1px solid var(--border);background:var(--surface);"
                              Class="scene-card">
                        <div style="flex:1;min-width:0;">
                            <div style="display:flex;align-items:center;gap:8px;margin-bottom:3px;">
                                @if (scene.IsLive)
                                {
                                    <MudChip T="string" Color="Color.Success" Size="Size.Small"
                                             Style="font-size:10px;letter-spacing:0.06em;height:20px;padding:0 7px;">LIVE</MudChip>
                                }
                                <MudText Style="font-size:14px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                    @SceneTitle(scene)
                                </MudText>
                            </div>
                            <div class="scene-meta-row" style="display:flex;align-items:center;gap:14px;">
                                <MudText Style="font-size:12px;color:var(--text-dim);">
                                    <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small" Style="vertical-align:middle;margin-right:2px;font-size:13px;" />
                                    @scene.RoomName
                                </MudText>
                                <MudText Style="font-size:12px;color:var(--text-faint);">
                                    <MudIcon Icon="@Icons.Material.Filled.Notes" Size="Size.Small" Style="vertical-align:middle;margin-right:2px;font-size:13px;" />
                                    @scene.PoseCount pose(s)
                                </MudText>
                                <MudText Style="font-size:12px;color:var(--text-faint);">
                                    @scene.LastActivityAtUtc.ToLocalTime().ToString("MMM d, yyyy HH:mm")
                                </MudText>
                            </div>
                        </div>
                        <div class="scene-actions" style="display:flex;gap:8px;flex-shrink:0;">
                            <MudButton Variant="Variant.Text" Size="Size.Small"
                                       Color="Color.Primary" Href="@($"/scenes/{scene.Id}")">
                                Read
                            </MudButton>
                            @if (scene.IsLive)
                            {
                                <MudButton Variant="Variant.Outlined" Size="Size.Small"
                                           Style="border-color:var(--accent);color:var(--accent);"
                                           Href="@($"/scenes/{scene.Id}/live")">
                                    Join
                                </MudButton>
                            }
                        </div>
                    </MudPaper>
                }
            </div>
        }
    };

    private static string SceneTitle(SceneSummary s) =>
        s.Meta.TryGetValue("title", out var t) && !string.IsNullOrWhiteSpace(t)
            ? t
            : $"Scene in {s.RoomName}";
}

<style>
    /* Mobile: stack each scene card so the title block sits above its actions,
       trim the page padding, and let the meta row wrap instead of overflowing. */
    @@media (max-width: 760px) {
        .scenes-page {
            padding: 16px !important;
        }
        .scenes-page .scene-card {
            flex-direction: column !important;
            align-items: stretch !important;
            gap: 10px !important;
            padding: 14px !important;
        }
        .scenes-page .scene-card .scene-meta-row {
            flex-wrap: wrap;
            gap: 8px 14px;
        }
        .scenes-page .scene-card .scene-actions {
            width: 100%;
        }
        .scenes-page .scene-card .scene-actions .mud-button-root {
            flex: 1;
            min-height: 44px;
        }
    }
</style>
