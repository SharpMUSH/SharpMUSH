@page "/scenes"
@inject IStringLocalizer<SharedResource> Loc

<PageTitle>@Loc["SceneArchive"] — SharpMUSH</PageTitle>

<div style="padding:var(--cpad);">
    <MudText Typo="Typo.h4" Style="font-weight:700;margin-bottom:4px;">@Loc["SceneArchive"]</MudText>
    <MudText Style="color:var(--text-dim);font-size:14px;margin-bottom:24px;">Browse and watch roleplay sessions.</MudText>

    @* TODO(Phase 5): wire to the server scene API. The client-only fake
       (InMemorySceneService) was removed in Phase 1; the scene browser is being
       rebuilt on the new graph-backed engine. Prior markup is in git history. *@
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        The scene browser is being rebuilt on the new scene engine.
    </MudAlert>
</div>
