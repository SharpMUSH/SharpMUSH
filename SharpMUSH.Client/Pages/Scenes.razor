@page "/scenes"
@using SharpMUSH.Client.Models
@using SharpMUSH.Client.Services
@inject IStringLocalizer<SharedResource> Loc
@inject SceneService SceneService

<PageTitle>@Loc["SceneArchive"] — SharpMUSH</PageTitle>

<div class="scenes-page" style="padding:var(--cpad);">
    <MudText Typo="Typo.h4" Style="font-weight:700;margin-bottom:0.25rem;">@Loc["SceneArchive"]</MudText>
    <MudText Style="color:var(--text-dim);font-size:0.875rem;margin-bottom:1.5rem;">Browse and watch roleplay sessions.</MudText>

    <MudTabs Elevation="0" Rounded="false" @bind-ActivePanelIndex="_tab">
        <MudTabPanel Text="Recent" BadgeData="@(_recent?.Count)" BadgeColor="Color.Default">
            @SceneList(_recent)
        </MudTabPanel>
        <MudTabPanel Text="Live" BadgeData="@(_active?.Count)" BadgeColor="Color.Success">
            @SceneList(_active)
        </MudTabPanel>
    </MudTabs>
</div>

@code {
    private int _tab;
    private bool _loading = true;
    private IReadOnlyList<SceneSummary>? _recent;
    private IReadOnlyList<SceneSummary>? _active;

    protected override async Task OnInitializedAsync()
    {
        var recentTask = SceneService.GetRecentScenesAsync(50);
        var activeTask = SceneService.GetActiveScenesAsync();
        _recent = await recentTask;
        _active = await activeTask;
        _loading = false;
    }

    private RenderFragment SceneList(IReadOnlyList<SceneSummary>? scenes) => __builder =>
    {
        if (_loading)
        {
            for (var i = 0; i < 4; i++)
            {
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="72px" Class="mb-2" Style="border-radius:var(--radius);" />
            }
        }
        else if (scenes is null || scenes.Count == 0)
        {
            <EmptyState>No scenes found.</EmptyState>
        }
        else
        {
            <div style="display:flex;flex-direction:column;gap:0.625rem;">
                @foreach (var scene in scenes)
                {
                    <MudPaper Elevation="0"
                              Style="display:flex;align-items:center;gap:1rem;padding:0.875rem 1.125rem;border-radius:var(--radius);border:1px solid var(--border);background:var(--surface);"
                              Class="scene-card">
                        <div style="flex:1;min-width:0;">
                            <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.1875rem;">
                                @if (scene.IsLive)
                                {
                                    <MudChip T="string" Color="Color.Success" Size="Size.Small"
                                             Style="font-size:0.625rem;letter-spacing:0.06em;height:20px;padding:0 0.4375rem;">LIVE</MudChip>
                                }
                                <MudText Style="font-size:0.875rem;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                    @SceneTitle(scene)
                                </MudText>
                            </div>
                            <div class="scene-meta-row" style="display:flex;align-items:center;gap:0.875rem;">
                                <MudText Style="font-size:0.75rem;color:var(--text-dim);">
                                    <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small" Style="vertical-align:middle;margin-right:0.125rem;font-size:0.8125rem;" />
                                    @scene.RoomName
                                </MudText>
                                <MudText Style="font-size:0.75rem;color:var(--text-faint);">
                                    <MudIcon Icon="@Icons.Material.Filled.Notes" Size="Size.Small" Style="vertical-align:middle;margin-right:0.125rem;font-size:0.8125rem;" />
                                    @scene.PoseCount pose(s)
                                </MudText>
                                <MudText Style="font-size:0.75rem;color:var(--text-faint);">
                                    @scene.LastActivityAtUtc.ToLocalTime().ToString("MMM d, yyyy HH:mm")
                                </MudText>
                            </div>
                        </div>
                        <div class="scene-actions" style="display:flex;gap:0.5rem;flex-shrink:0;">
                            <MudButton Variant="Variant.Text" Size="Size.Small"
                                       Color="Color.Primary" Href="@($"/scenes/{scene.Id}")">
                                Read
                            </MudButton>
                            @if (scene.IsLive)
                            {
                                <MudButton Variant="Variant.Outlined" Size="Size.Small"
                                           Style="border-color:var(--accent);color:var(--accent);"
                                           Href="@($"/scenes/{scene.Id}/live")">
                                    Join
                                </MudButton>
                            }
                        </div>
                    </MudPaper>
                }
            </div>
        }
    };

    private static string SceneTitle(SceneSummary s) =>
        s.Meta.TryGetValue("title", out var t) && !string.IsNullOrWhiteSpace(t)
            ? t
            : $"Scene in {s.RoomName}";
}
