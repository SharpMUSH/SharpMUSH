@page "/mail/{Id:int}"
@attribute [Authorize]
@using SharpMUSH.Client.Services
@inject IStringLocalizer<SharedResource> Loc
@inject MailService Mail
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Mail #@Id — SharpMUSH</PageTitle>

<div class="mail-detail-page" style="padding:var(--cpad);">

    <div style="display:flex;align-items:center;gap:0.625rem;margin-bottom:1.25rem;">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/mail"
                       Style="color:var(--text-dim);" />
        <div>
            <div class="md-kicker">@Loc["Mail"]</div>
            <div class="md-title">#@Id</div>
        </div>
    </div>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Style="color:var(--accent);" />
    }
    else if (_message is null)
    {
        <div class="md-card" style="color:var(--text-dim);">@Loc["MailNotFound"]</div>
    }
    else
    {
        <div class="md-card">
            <div style="display:flex;align-items:center;gap:0.625rem;margin-bottom:0.375rem;">
                <div style="font-family:var(--font-display);font-size:1.25rem;font-weight:700;color:var(--text);">@_message.Subject</div>
                @if (_message.Urgent)
                {
                    <span class="md-urgent">@Loc["Urgent"]</span>
                }
            </div>
            <div style="font-size:0.8125rem;color:var(--text-dim);margin-bottom:0.125rem;">
                @Loc["From"]: <span style="color:var(--text);">@_message.From</span>
            </div>
            <div style="font-size:0.75rem;color:var(--text-faint);margin-bottom:1rem;">
                @_message.DateSent.LocalDateTime.ToString("f") · @_message.Folder
            </div>

            <div style="height:1px;background:var(--border-soft);margin-bottom:1rem;"></div>

            <div class="md-body" style="white-space:pre-wrap;font-family:var(--font-mono);font-size:0.8125rem;line-height:1.6;color:var(--text);">@_message.Body</div>

            <div class="md-actions" style="display:flex;gap:0.625rem;margin-top:1.75rem;">
                <MudButton Variant="Variant.Filled"
                           Style="background:var(--accent);color:var(--accent-on);text-transform:none;font-weight:600;"
                           StartIcon="@Icons.Material.Filled.Reply" OnClick="Reply">
                    @Loc["Reply"]
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Style="border-color:var(--border);color:var(--text-dim);text-transform:none;"
                           StartIcon="@Icons.Material.Filled.Delete" OnClick="DeleteAsync">
                    @Loc["Delete"]
                </MudButton>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    [SupplyParameterFromQuery(Name = "folder")]
    public string? Folder { get; set; }

    private MailService.MailMessage? _message;
    private bool _loading = true;

    private string FolderName => string.IsNullOrWhiteSpace(Folder) ? "INBOX" : Folder!;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _message = await Mail.ReadAsync(FolderName, Id);
        _loading = false;
    }

    private void Reply()
    {
        if (_message is null) return;
        var subject = _message.Subject.StartsWith("Re:", StringComparison.OrdinalIgnoreCase)
            ? _message.Subject
            : $"Re: {_message.Subject}";
        Nav.NavigateTo($"/mail/compose?to={Uri.EscapeDataString(_message.From)}&subject={Uri.EscapeDataString(subject)}");
    }

    private async Task DeleteAsync()
    {
        if (await Mail.DeleteAsync(FolderName, Id))
        {
            Snackbar.Add(Loc["MailDeleted"], Severity.Success);
            Nav.NavigateTo("/mail");
        }
        else
        {
            Snackbar.Add(Loc["MailDeleteFailed"], Severity.Error);
        }
    }
}
