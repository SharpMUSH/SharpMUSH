@page "/play"
@attribute [Authorize]
@using SharpMUSH.Client.Components
@using SharpMUSH.Client.Models
@using SharpMUSH.Client.Services
@inject IStringLocalizer<SharedResource> Loc
@inject IPlayTerminalService PlayTerminal
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Play — SharpMUSH</PageTitle>

<div class="play-shell @(_focusMode ? "play-shell--focus" : "")">

    <div class="play-term">
        <div class="play-term-header">
            <span class="play-dot @(PlayTerminal.IsConnected ? "play-dot--on" : "")"></span>
            <span class="play-char">@(PlayTerminal.ConnectedPlayerName ?? "Play Terminal")</span>
            <span class="play-loc">@(PlayTerminal.IsConnected ? "in play" : "not connected")</span>
            <div style="flex:1;"></div>
            <span class="play-conn @(PlayTerminal.IsConnected ? "play-conn--on" : "")">
                ● @(PlayTerminal.IsConnected ? "connected" : "disconnected")
            </span>
            <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Dense="true">
                <ActivatorContent>
                    <button type="button" class="play-focus-btn" @onclick="@context.ToggleAsync"
                            title="Terminal settings" aria-label="Terminal settings">
                        <MudIcon Icon="@Icons.Material.Filled.Tune" Style="font-size:1.05rem;" />
                    </button>
                </ActivatorContent>
                <ChildContent>
                    <div class="play-cfg" @onclick:stopPropagation="true">
                        <div class="play-cfg-kicker">Terminal</div>
                        <label class="play-cfg-row"
                               title="Preferred terminal width in columns (min 78). The font autoscales to fill it — more room means a bigger font — and it's reported to the server as your screen width.">
                            <span>Width (cols)</span>
                            <input class="play-cols-input" type="number" min="78" max="240" step="1"
                                   value="@_targetCols" @onchange="OnColsChanged" />
                        </label>
                        <button type="button" class="play-cfg-item" @onclick="ToggleFocus">
                            <MudIcon Icon="@(_focusMode ? Icons.Material.Filled.FullscreenExit : Icons.Material.Filled.Fullscreen)" Style="font-size:1rem;" />
                            <span>@(_focusMode ? "Exit focus mode" : "Focus mode")</span>
                        </button>
                        <button type="button" class="play-cfg-item" @onclick="ClearTerminal">
                            <MudIcon Icon="@Icons.Material.Filled.ClearAll" Style="font-size:1rem;" />
                            <span>Clear terminal</span>
                        </button>
                    </div>
                </ChildContent>
            </MudMenu>
        </div>
        <div style="flex:1;min-height:0;min-width:0;">
            <GlobalTerminal @ref="_playTerm" TerminalOverride="PlayTerminal" ShowDiagnostics="false"
                            TargetColumns="_targetCols" ShowClearButton="false" />
        </div>
    </div>

    <div class="play-side">
        <div class="play-card">
            <div class="play-fieldlabel">Here</div>
            @if (_here.Count == 0)
            {
                <div class="play-empty">— Connect to see who's here —</div>
            }
            else
            {
                @foreach (var e in _here)
                {
                    @if (!string.IsNullOrWhiteSpace(e.Cmd))
                    {
                        <div class="play-entry play-clickable"
                             @onclick="@(() => RunEntry(e))">
                            @(string.IsNullOrWhiteSpace(e.Name) ? "(untitled)" : e.Name)
                        </div>
                    }
                    else
                    {
                        <div class="play-entry">
                            @(string.IsNullOrWhiteSpace(e.Name) ? "(untitled)" : e.Name)
                        </div>
                    }
                }
            }
        </div>

        <div class="play-card">
            <div class="play-fieldlabel">Exits</div>
            @if (_exits.Count == 0)
            {
                <div class="play-empty">— No exits available —</div>
            }
            else
            {
                @foreach (var e in _exits)
                {
                    @if (!string.IsNullOrWhiteSpace(e.Cmd))
                    {
                        <div class="play-entry play-clickable"
                             @onclick="@(() => RunEntry(e))">
                            @(string.IsNullOrWhiteSpace(e.Name) ? "(untitled)" : e.Name)
                        </div>
                    }
                    else
                    {
                        <div class="play-entry">
                            @(string.IsNullOrWhiteSpace(e.Name) ? "(untitled)" : e.Name)
                        </div>
                    }
                }
            }
        </div>

        <div class="play-card">
            <div class="play-fieldlabel">Quick actions</div>
            <div class="play-actions">
                <a class="play-action" href="/characters">
                    <MudIcon Icon="@Icons.Material.Filled.People" Class="play-action-icon" /> @Loc["Characters"]
                </a>
                <a class="play-action" href="/mail">
                    <MudIcon Icon="@Icons.Material.Filled.Mail" Class="play-action-icon" /> @Loc["Mail"]
                </a>
                <a class="play-action" href="/scenes">
                    <MudIcon Icon="@Icons.Material.Filled.Movie" Class="play-action-icon" /> @Loc["SceneArchive"]
                </a>
                <a class="play-action" href="/help">
                    <MudIcon Icon="@Icons.Material.Filled.Help" Class="play-action-icon" /> @Loc["Help"]
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .play-shell {
        display: grid;
        /* minmax(0, 1fr): a bare 1fr track refuses to shrink below its content's
           min-content width, so the wide terminal canvas would push the whole
           page wider than the viewport. minmax(0,…) lets the column shrink. */
        grid-template-columns: minmax(0, 1fr) 270px;
        gap: 1rem;
        padding: var(--cpad);
        height: 100%;
        overflow: hidden;
    }

    .play-term {
        display: flex;
        flex-direction: column;
        min-height: 0;
        min-width: 0;
        border: 1px solid var(--border-soft);
        border-radius: var(--radius-lg);
        overflow: hidden;
    }

    /* Focus mode: the terminal fills the whole play area edge-to-edge — side panel
       hidden, borders gone, no outer padding. Only the header status bar, the output,
       and the input remain (the bottom Connected/player/Disconnect bar is dropped).
       The terminal's font-fit recomputes for the wider column. */
    .play-shell--focus {
        grid-template-columns: minmax(0, 1fr);
        padding: 0;
        gap: 0;
    }
    .play-shell--focus .play-side {
        display: none;
    }
    .play-shell--focus .play-term {
        border: none;
        border-radius: 0;
    }
    /* These terminal classes are global (custom.css), so reach into the component. */
    .play-shell--focus .sharp-terminal-connbar {
        display: none;
    }
    /* Trim the inner inset: the output carries an inline 0.75rem 1rem pad (needs
       !important), and the header/input divider lines go too — so output, header,
       and input read as one seamless surface filling the page. A hair of padding
       keeps glyphs off the very edge. */
    .play-shell--focus .sharp-terminal-output {
        padding: 0.25rem 0.5rem !important;
    }
    .play-shell--focus .play-term-header {
        border-bottom: none;
    }
    .play-shell--focus .sharp-terminal-input {
        border-top: none;
    }

    /* Terminal settings menu (Width / Focus / Clear). */
    .play-cfg {
        display: flex;
        flex-direction: column;
        gap: 0.125rem;
        padding: 0.375rem;
        min-width: 12rem;
    }
    .play-cfg-kicker {
        font-family: var(--font-mono);
        font-size: 0.625rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--text-faint);
        padding: 0.125rem 0.5rem 0.25rem;
    }
    .play-cfg-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        padding: 0.375rem 0.5rem;
        font-family: var(--font-ui);
        font-size: 0.8125rem;
        color: var(--text-dim);
    }
    .play-cfg-item {
        display: flex;
        align-items: center;
        gap: 0.625rem;
        width: 100%;
        padding: 0.5rem;
        background: transparent;
        border: none;
        border-radius: var(--radius);
        color: var(--text-dim);
        font-family: var(--font-ui);
        font-size: 0.8125rem;
        text-align: left;
        cursor: pointer;
        min-height: 36px;
    }
    .play-cfg-item:hover {
        background: var(--surface-2);
        color: var(--text);
    }
    .play-cols-input {
        width: 3.5rem;
        height: 1.625rem;
        padding: 0 0.375rem;
        background: var(--surface-2);
        border: 1px solid var(--border-soft);
        border-radius: var(--radius);
        color: var(--text);
        font-family: var(--font-mono);
        font-size: 0.75rem;
        text-align: right;
    }
    .play-cols-input:focus {
        outline: none;
        border-color: var(--accent);
    }

    /* Header toggle button (Fullscreen / FullscreenExit). */
    .play-focus-btn {
        display: grid;
        place-items: center;
        width: 28px;
        height: 28px;
        flex-shrink: 0;
        padding: 0;
        border: none;
        border-radius: var(--radius);
        background: transparent;
        color: var(--text-faint);
        cursor: pointer;
        transition: background 0.12s, color 0.12s;
    }
    .play-focus-btn:hover {
        background: var(--surface-2);
        color: var(--text);
    }

    .play-term-header {
        display: flex;
        align-items: center;
        gap: 0.625rem;
        padding: 0.6875rem 1rem;
        background: var(--surface-3);
        border-bottom: 1px solid var(--border-soft);
        flex-shrink: 0;
    }

    .play-dot {
        width: 8px;
        height: 8px;
        border-radius: 99px;
        background: var(--text-faint);
        flex-shrink: 0;
    }
    .play-dot--on {
        background: var(--accent);
        box-shadow: 0 0 8px rgba(var(--glow), 0.9);
    }

    .play-char {
        font-family: var(--font-mono);
        font-size: 0.78125rem;
        font-weight: 600;
        color: var(--text);
    }
    .play-loc {
        font-family: var(--font-mono);
        font-size: 0.71875rem;
        color: var(--text-faint);
    }
    .play-conn {
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        color: var(--text-faint);
    }
    .play-conn--on {
        color: var(--accent);
    }

    .play-side {
        display: flex;
        flex-direction: column;
        gap: 0.875rem;
        overflow-y: auto;
        min-height: 0;
        min-width: 0;
    }

    .play-card {
        background: var(--surface);
        border: 1px solid var(--border-soft);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow);
        padding: 0.9375rem;
    }

    .play-fieldlabel {
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--text-faint);
        margin-bottom: 0.625rem;
    }

    .play-empty {
        font-family: var(--font-ui);
        font-size: 0.78125rem;
        color: var(--text-faint);
    }

    .play-entry {
        font-family: var(--font-ui);
        font-size: 0.8125rem;
        color: var(--text-dim);
        padding: 0.25rem 0.375rem;
        border-radius: var(--radius);
    }

    .play-clickable {
        cursor: pointer;
    }

    .play-clickable:hover {
        background: var(--surface-2);
        color: var(--text);
    }

    .play-actions {
        display: flex;
        flex-direction: column;
        gap: 0.4375rem;
    }

    .play-action {
        display: flex;
        align-items: center;
        gap: 0.625rem;
        padding: 0.5rem 0.625rem;
        border-radius: var(--radius);
        border: 1px solid var(--border-soft);
        background: var(--surface-2);
        color: var(--text-dim);
        font-family: var(--font-ui);
        font-size: 0.8125rem;
        text-align: left;
        text-decoration: none;
        cursor: pointer;
        transition: border-color 0.12s, color 0.12s;
    }
    .play-action:hover {
        border-color: rgba(var(--glow), 0.4);
        color: var(--text);
    }
    .play-action-icon {
        font-size: 0.9375rem !important;
        width: 15px;
        height: 15px;
        flex-shrink: 0;
        color: var(--accent) !important;
    }

    /* ── Mobile: stack the terminal over the side panel and let the page scroll.
       The two-column grid + height:100%/overflow:hidden is desktop-only. ── */
    @@media (max-width: 760px) {
        .play-shell {
            grid-template-columns: minmax(0, 1fr);
            height: auto;
            min-height: 100%;
            overflow-x: hidden;
            overflow-y: auto;
            padding: 0.75rem;
            gap: 0.75rem;
        }
        .play-term {
            /* svh sizes to the small viewport (toolbars shown), so the terminal
               input stays on-screen under the mobile address bar without resizing
               on scroll the way dvh would. */
            height: 70vh;
            height: 70svh;
            min-height: 320px;
        }
        .play-term-header {
            flex-wrap: wrap;
            padding: 0.625rem 0.75rem;
        }
        .play-side {
            overflow: visible;
        }
        /* Focus mode on a phone: the terminal fills the content area instead of being
           capped at 70svh with the (now hidden) panel's space left empty below it. */
        .play-shell--focus {
            height: 100%;
            min-height: 0;
            overflow: hidden;
            padding: 0;
        }
        .play-shell--focus .play-term {
            height: 100%;
            min-height: 0;
        }
        /* Comfortable, tappable list entries and quick-action links on a phone. */
        .play-entry {
            font-size: 0.875rem;
            padding: 0.5625rem 0.5rem;
            min-height: 44px;
            display: flex;
            align-items: center;
        }
        .play-action {
            min-height: 44px;
            font-size: 0.875rem;
        }
    }
</style>

@code {
    private IReadOnlyList<OobEntry> _here = [];
    private IReadOnlyList<OobEntry> _exits = [];

    private GlobalTerminal? _playTerm;

    // Focus mode hides the side panel so the terminal fills the whole play area.
    private bool _focusMode;
    private void ToggleFocus() => _focusMode = !_focusMode;

    private void ClearTerminal() => _playTerm?.ClearOutput();

    // The player's preferred terminal width in columns (min 78). The terminal autoscales its
    // font to fill this many columns; the value is also what the client reports over NAWS.
    // Persisted per-browser in localStorage.
    private const int MinCols = 78;
    private const int MaxCols = 240;
    private int _targetCols = MinCols;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            var stored = await JS.InvokeAsync<string?>("localStorage.getItem", "play.cols");
            if (int.TryParse(stored, out var n))
            {
                var clamped = Math.Clamp(n, MinCols, MaxCols);
                if (clamped != _targetCols)
                {
                    _targetCols = clamped;
                    StateHasChanged();
                }
            }
        }
        catch (JSException) { /* localStorage unavailable — keep the default */ }
    }

    private async Task OnColsChanged(ChangeEventArgs e)
    {
        _targetCols = int.TryParse(e.Value?.ToString(), out var n)
            ? Math.Clamp(n, MinCols, MaxCols)
            : MinCols;
        try { await JS.InvokeVoidAsync("localStorage.setItem", "play.cols", _targetCols); }
        catch (JSException) { /* best-effort persistence */ }
        StateHasChanged();
    }

    protected override void OnInitialized()
    {
        PlayTerminal.ConnectionStateChanged += OnConnectionChanged;
        PlayTerminal.OobChannels.ChannelUpdated += OnChannelUpdated;
        RefreshFromStore("room.contents");
        RefreshFromStore("room.exits");
    }

    private void OnConnectionChanged(bool _) => InvokeAsync(StateHasChanged);

    private void OnChannelUpdated(string package) => RefreshFromStore(package);

    private void RefreshFromStore(string package)
    {
        switch (package)
        {
            case "room.contents":
                _here = OobEntryParser.Parse(PlayTerminal.OobChannels.Get(package), "who");
                break;
            case "room.exits":
                _exits = OobEntryParser.Parse(PlayTerminal.OobChannels.Get(package), "exits");
                break;
            default:
                return;
        }
        InvokeAsync(StateHasChanged);
    }

    private async Task RunEntry(OobEntry entry)
    {
        if (!string.IsNullOrWhiteSpace(entry.Cmd))
            await PlayTerminal.SendAsync(entry.Cmd);
    }

    public void Dispose()
    {
        PlayTerminal.ConnectionStateChanged -= OnConnectionChanged;
        PlayTerminal.OobChannels.ChannelUpdated -= OnChannelUpdated;
    }
}
