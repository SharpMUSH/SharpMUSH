@page "/help"
@inject IStringLocalizer<SharedResource> Loc

<PageTitle>Help — SharpMUSH</PageTitle>

<div class="help-page">
    <header class="help-header">
        <div class="help-kicker">Documentation</div>
        <h1 class="help-title">Help</h1>
        <p class="help-subtitle">Browse topics, search references, and read the manual.</p>
    </header>

    <section class="help-body">
        <WikiView Slug="help-index" Mode="WikiView.WikiMode.View" />
    </section>
</div>
