@page "/apps/{Slug}"
@using SharpMUSH.Client.Components.Schema
@using SharpMUSH.Client.Models.Applications
@using SharpMUSH.Client.Services
@using SharpMUSH.Library.Authorization
@inject ApplicationRegistryClient Registry
@inject SchemaAppService Schema
@inject PluginComponentLoader ComponentLoader

<PageTitle>@(_app?.DisplayName ?? "Application")</PageTitle>

<div class="app-page">
    <header class="app-header">
        <div class="app-kicker">Application</div>
        <h1 class="app-title">@(_app?.DisplayName ?? "Application")</h1>
    </header>

    @if (_loading)
    {
        <div class="app-card app-loading">
            <MudProgressLinear Color="Color.Secondary" Indeterminate="true" />
            <span class="app-loading-text">Loading application…</span>
        </div>
    }
    else if (_app is null)
    {
        <div class="app-alert app-alert-warning">
            No application is registered at <code>/apps/@Slug</code>.
        </div>
    }
    else if (!_authorized)
    {
        <div class="app-alert app-alert-error">
            You do not have access to this application.
        </div>
    }
    else if (_app.IsComponent)
    {
        @if (_componentType is not null)
        {
            <DynamicComponent Type="_componentType" />
        }
        else
        {
            <div class="app-alert app-alert-error">
                This application's compiled component could not be loaded. Browser code may be disabled
                (<code>allow_browser_code</code>), or the assembly failed verification.
            </div>
        }
    }
    else if (_schema is null)
    {
        <div class="app-alert app-alert-error">
            The application's schema could not be loaded. The softcode handler at
            <code>@_app.SchemaUrl</code> may be missing or returning invalid JSON.
        </div>
    }
    else if (_schema.IsForm)
    {
        <SchemaFormRenderer Document="_schema" Data="_data" />
    }
    else
    {
        <SchemaViewRenderer Document="_schema" Data="_data" />
    }
</div>

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;

    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _loading = true;
    private bool _authorized;
    private PortalApplication? _app;
    private PortalSchemaDocument? _schema;
    private SchemaData? _data;
    private Type? _componentType;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _schema = null;
        _data = null;
        _componentType = null;
        _app = await Registry.GetAsync(Slug);

        if (_app is not null)
        {
            _authorized = await IsAuthorizedAsync(_app.MinimumRoleEnum);
            if (_authorized)
            {
                if (_app.IsComponent)
                {
                    // Compiled-component app: fetch + load the plugin assembly and resolve the Type by
                    // reflection (no plugin types referenced here). The loader no-ops when the gate is off.
                    if (!string.IsNullOrWhiteSpace(_app.ComponentAssemblyUrl)
                        && !string.IsNullOrWhiteSpace(_app.ComponentTypeName))
                    {
                        _componentType = await ComponentLoader.ResolveComponentAsync(
                            _app.ComponentAssemblyUrl!, _app.ComponentTypeName!);
                    }
                }
                else
                {
                    _schema = await Schema.GetSchemaAsync(_app.SchemaUrl);
                    if (!string.IsNullOrWhiteSpace(_app.DataUrl))
                    {
                        _data = await Schema.GetDataAsync(_app.DataUrl!);
                    }
                }
            }
        }

        _loading = false;
    }

    private async Task<bool> IsAuthorizedAsync(PortalRole minimum)
    {
        if (AuthState is null)
        {
            return minimum <= PortalRole.Guest;
        }

        var state = await AuthState;
        return PortalRoleHelper.Meets(state.User, minimum);
    }
}
