@page "/scenes/active"
@inject IStringLocalizer<SharedResource> Loc
@inject ISceneService SceneService

<PageTitle>@Loc["ActiveScenes"] — SharpMUSH</PageTitle>

<div style="padding:var(--cpad);">

    <div class="sa-kicker">@Loc["Scenes"]</div>
    <div class="sa-title" style="margin-bottom:4px;">@Loc["ActiveScenes"]</div>
    <div style="color:var(--text-dim);font-size:14px;margin-bottom:24px;">Sessions running right now.</div>

    @if (_loading)
    {
        <div style="display:flex;flex-direction:column;gap:10px;">
            @for (var i = 0; i < 4; i++)
            {
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="72px" Style="border-radius:var(--radius);" />
            }
        </div>
    }
    else if (_scenes.Count == 0)
    {
        <div class="sa-empty">@Loc["NoActiveScenesRunning"]</div>
    }
    else
    {
        <div style="display:flex;flex-direction:column;gap:10px;">
            @foreach (var scene in _scenes)
            {
                <div class="sa-card">
                    <div style="flex:1;min-width:0;">
                        <div style="display:flex;align-items:center;gap:8px;margin-bottom:3px;">
                            <span class="sa-live"><span class="sa-live-dot"></span>LIVE</span>
                            <span style="font-size:14px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                @(string.IsNullOrWhiteSpace(scene.Title) ? Loc["Untitled"].ToString() : scene.Title)
                            </span>
                        </div>
                        <div style="display:flex;align-items:center;gap:14px;">
                            <span style="font-size:12px;color:var(--text-dim);">
                                <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small" Style="vertical-align:middle;margin-right:2px;font-size:13px;" />
                                @scene.RoomName
                            </span>
                            <span style="font-size:12px;color:var(--text-faint);">
                                <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Small" Style="vertical-align:middle;margin-right:2px;font-size:13px;" />
                                @scene.ParticipantDbrefs.Count
                            </span>
                            <span style="font-size:12px;color:var(--text-faint);">
                                @Loc["StartedAt"]: @scene.StartedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                            </span>
                        </div>
                    </div>
                    <div style="display:flex;gap:8px;flex-shrink:0;">
                        <MudButton Variant="Variant.Text" Size="Size.Small"
                                   Style="color:var(--text-dim);text-transform:none;"
                                   Href="@($"/scenes/{scene.Id}")">
                            @Loc["ViewLog"]
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Size="Size.Small"
                                   Style="border-color:var(--accent);color:var(--accent);text-transform:none;"
                                   Href="@($"/scenes/{scene.Id}/live")"
                                   Disabled="!scene.IsPublic">
                            @Loc["WatchLive"]
                        </MudButton>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<SceneArchive> _scenes = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _scenes = [..await SceneService.GetActiveScenesAsync()];
        _loading = false;
    }
}
