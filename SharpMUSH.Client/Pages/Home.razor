@page "/"
@inject IStringLocalizer<SharedResource> Loc

<PageTitle>@Loc["Home"] — SharpMUSH</PageTitle>

@* The landing page composes from the "home" layout scope. Its default arranges the stats, active
   scene, recent wiki activity, characters, and quickstart widgets in a 12-column grid; admins can
   recompose it in the layout editor. *@
<div class="home-dash">
    <ScopedZone Scope="@LayoutScopes.Home" Zone="WidgetZone.MainContent" />
</div>
