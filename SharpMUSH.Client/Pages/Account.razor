@page "/account"
@using SharpMUSH.Client.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject AccountAuthService AccountAuth
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>My Account — SharpMUSH</PageTitle>

<div class="acct-page" style="padding:var(--cpad);">

    @if (!AccountAuth.IsLoggedIn)
    {
        <div class="acct-card" style="max-width:560px;">
            @if (_isDebugAuth)
            {
                <MudAlert Severity="Severity.Info" Class="mb-3">
                    <strong>Debug Mode</strong> — You are authenticated as <em>DebugAdmin</em> (development environment).
                    No account session is associated; account management features require a real account login.
                </MudAlert>
            }
            else
            {
                <MudAlert Severity="Severity.Info" Class="mb-3">
                    You are not logged in to an account. Use the terminal login panel to log in.
                </MudAlert>
            }
            <button class="acct-btn acct-btn-primary" @onclick='() => Nav.NavigateTo("/")'>Go to Home</button>
        </div>
    }
    else
    {
        <div class="acct-header">
            <div class="acct-kicker">Account</div>
            <div class="acct-title">@AccountAuth.Username</div>
        </div>

        @if (AccountAuth.MustChangePassword)
        {
            <MudAlert Severity="Severity.Warning" Class="mb-4">
                <strong>Password change required.</strong>
                You must change your password before using the rest of the portal.
            </MudAlert>
        }

        <div class="acct-card">
            @if (!AccountAuth.MustChangePassword)
            {
                <div class="acct-card-title">Profile</div>

                <div class="acct-row" style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.875rem;">
                    @if (_editingUsername)
                    {
                        <MudTextField @bind-Value="_newUsername" Label="Username"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" Class="acct-input" Style="flex:1;" />
                        <button class="acct-btn acct-btn-primary" disabled="@_busy" @onclick="SaveUsernameAsync">Save</button>
                        <button class="acct-btn acct-btn-ghost" @onclick="() => _editingUsername = false">Cancel</button>
                    }
                    else
                    {
                        <div style="flex:1;color:var(--text);"><span class="acct-label">Username</span> @AccountAuth.Username</div>
                        <button class="acct-btn acct-btn-outline"
                                @onclick="() => { _newUsername = AccountAuth.Username ?? string.Empty; _editingUsername = true; }">
                            Edit
                        </button>
                    }
                </div>
            }

            <div class="acct-row" style="display:flex;align-items:flex-start;gap:0.75rem;margin-bottom:0.25rem;">
                @if (_editingPassword)
                {
                    <div style="display:flex;flex-direction:column;gap:0.5rem;flex:1;">
                        <MudTextField @bind-Value="_oldPassword" Label="Current password"
                                      InputType="InputType.Password"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" Class="acct-input" />
                        <MudTextField @bind-Value="_newPassword" Label="New password"
                                      InputType="InputType.Password"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" Class="acct-input" />
                    </div>
                    <div style="display:flex;flex-direction:column;gap:0.375rem;">
                        <button class="acct-btn acct-btn-primary" disabled="@_busy" @onclick="SavePasswordAsync">Save</button>
                        <button class="acct-btn acct-btn-ghost" @onclick="() => _editingPassword = false">Cancel</button>
                    </div>
                }
                else
                {
                    <div style="flex:1;color:var(--text);"><span class="acct-label">Password</span> ••••••••</div>
                    <button class="acct-btn acct-btn-outline" @onclick="() => _editingPassword = true">Change</button>
                }
            </div>

            @if (_profileError is not null)
            {
                <MudAlert Severity="Severity.Error" Class="mt-3">@_profileError</MudAlert>
            }
            @if (_profileSuccess is not null)
            {
                <MudAlert Severity="Severity.Success" Class="mt-3">@_profileSuccess</MudAlert>
            }
        </div>

        @if (!AccountAuth.MustChangePassword)
        {
            <div class="acct-card">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.875rem;">
                    <div class="acct-card-title" style="margin-bottom:0;">Characters</div>
                    <button class="acct-btn acct-btn-outline" @onclick="RefreshCharactersAsync" disabled="@_busy">
                        <MudIcon Icon="@Icons.Material.Filled.Refresh" Size="Size.Small" Class="mr-1" />
                        Refresh
                    </button>
                </div>

                @if (_loadingChars)
                {
                    <MudProgressCircular Indeterminate="true" Size="Size.Small" Style="color:var(--accent);" />
                }
                else if (AccountAuth.Characters.Count == 0)
                {
                    <div style="color:var(--text-faint);">No characters linked to this account.</div>
                }
                else
                {
                    <div class="acct-table-scroll">
                    <MudTable Items="AccountAuth.Characters" Dense="true" Hover="true" Class="acct-table" Elevation="0">
                        <HeaderContent>
                            <MudTh>Name</MudTh>
                            <MudTh>Dbref</MudTh>
                            <MudTh>Flags</MudTh>
                            <MudTh>Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.Name</MudTd>
                            <MudTd>#@context.DbrefNumber</MudTd>
                            <MudTd>
                                @foreach (var flag in (context.Flags ?? "").Split(' ', StringSplitOptions.RemoveEmptyEntries))
                                {
                                    <span class="acct-flag">@flag</span>
                                }
                            </MudTd>
                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Filled.LinkOff" Size="Size.Small"
                                               Color="Color.Warning" aria-label="Unlink character"
                                               OnClick="() => UnlinkCharacterAsync(context.DbrefNumber)" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                    </div>
                }

                @if (_showCreateChar)
                {
                    <div class="acct-divider"></div>
                    <div class="acct-subtitle">Create new character</div>
                    <div style="display:flex;gap:0.625rem;align-items:flex-end;flex-wrap:wrap;">
                        <MudTextField @bind-Value="_newCharName" Label="Character name"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" Class="acct-input" Style="flex:1;min-width:140px;" />
                        <MudTextField @bind-Value="_newCharPassword" Label="Password"
                                      InputType="InputType.Password"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" Class="acct-input" Style="flex:1;min-width:140px;" />
                        <button class="acct-btn acct-btn-primary" disabled="@_busy" @onclick="CreateCharacterAsync">Create</button>
                        <button class="acct-btn acct-btn-ghost" @onclick="() => _showCreateChar = false">Cancel</button>
                    </div>
                    @if (_charError is not null)
                    {
                        <MudAlert Severity="Severity.Error" Class="mt-3">@_charError</MudAlert>
                    }
                }
                else
                {
                    <button class="acct-btn acct-btn-outline" style="margin-top:1rem;"
                            @onclick="() => { _showCreateChar = true; _charError = null; }">
                        + Create new character
                    </button>
                }
            </div>
        }

        <button class="acct-btn acct-btn-danger" @onclick="LogoutAsync">
            Log out of account
        </button>
    }

</div>

@code {
    private bool _editingUsername;
    private bool _editingPassword;
    private string _newUsername = string.Empty;
    private string _oldPassword = string.Empty;
    private string _newPassword = string.Empty;
    private string? _profileError;
    private string? _profileSuccess;
    private bool _busy;
    private bool _loadingChars;
    private bool _showCreateChar;
    private string _newCharName = string.Empty;
    private string _newCharPassword = string.Empty;
    private string? _charError;
    private bool _isDebugAuth;

    protected override async Task OnInitializedAsync()
    {
        await AccountAuth.InitAsync();
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();

        // In debug mode, ensure the account session for #1 is established — unless the user
        // explicitly logged out in this tab (mirrors MainLayout's guard; without it, visiting
        // /account after logout would silently re-authenticate as the debug admin).
        if (!AccountAuth.ExplicitlyLoggedOut && authState.User.Identity?.IsAuthenticated == true && !AccountAuth.IsLoggedIn)
            await AccountAuth.GetDebugOttAsync();

        _isDebugAuth = !AccountAuth.ExplicitlyLoggedOut && authState.User.Identity?.IsAuthenticated == true && !AccountAuth.IsLoggedIn;
        if (AccountAuth.IsLoggedIn && AccountAuth.Characters.Count == 0)
            await RefreshCharactersAsync();
    }

    private async Task RefreshCharactersAsync()
    {
        _loadingChars = true;
        StateHasChanged();
        await AccountAuth.GetCharactersAsync();
        _loadingChars = false;
        StateHasChanged();
    }

    private async Task SaveUsernameAsync()
    {
        ClearMessages();
        _busy = true;
        var (success, error) = await AccountAuth.ChangeUsernameAsync(_newUsername);
        _busy = false;
        _editingUsername = !success;
        if (success) _profileSuccess = "Username updated.";
        else _profileError = error;
        StateHasChanged();
    }

    private async Task SavePasswordAsync()
    {
        ClearMessages();
        _busy = true;
        var (success, error) = await AccountAuth.ChangePasswordAsync(_oldPassword, _newPassword);
        _busy = false;
        _editingPassword = !success;
        _oldPassword = string.Empty;
        _newPassword = string.Empty;
        if (success) _profileSuccess = "Password updated.";
        else _profileError = error;
        StateHasChanged();
    }

    private async Task CreateCharacterAsync()
    {
        _charError = null;
        _busy = true;
        StateHasChanged();
        var (success, error, _) = await AccountAuth.CreateCharacterAsync(_newCharName, _newCharPassword);
        _busy = false;
        if (success)
        {
            _showCreateChar = false;
            _newCharName = string.Empty;
            _newCharPassword = string.Empty;
        }
        else
        {
            _charError = error;
        }
        StateHasChanged();
    }

    private async Task UnlinkCharacterAsync(int dbrefNumber)
    {
        _busy = true;
        var (success, error) = await AccountAuth.UnlinkCharacterAsync(dbrefNumber);
        _busy = false;
        if (!success) _profileError = error;
        StateHasChanged();
    }

    private async Task LogoutAsync()
    {
        await AccountAuth.LogoutAsync();
        // _isDebugAuth is computed once in OnInitializedAsync and otherwise stays true after
        // logout, which would keep this page's "Debug Mode" alert showing the stale DebugAdmin
        // identity instead of the plain "not logged in" message — reset it directly here.
        // (NavMenu's HandleLogoutAsync has no flag of its own to mirror: it just disconnects both
        // terminals and navigates away.) Land on "/" (the anonymous home) rather than /login:
        // logging out returns a visitor to anonymous browsing, not a forced sign-in screen. This
        // won't re-trigger debug re-auth since AccountAuth.LogoutAsync above latches ExplicitlyLoggedOut.
        _isDebugAuth = false;
        Nav.NavigateTo("/", forceLoad: false);
    }

    private void ClearMessages() { _profileError = null; _profileSuccess = null; }
}
