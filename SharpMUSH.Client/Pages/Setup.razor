@page "/setup"
@using SharpMUSH.Client.Services
@inject AccountAuthService AccountAuth
@inject NavigationManager Nav

<PageTitle>First-Run Setup — SharpMUSH</PageTitle>

<div class="setup-page">
	<div class="setup-card">
		<div class="setup-kicker">First-Run Setup</div>
		<h1 class="setup-title">Welcome to SharpMUSH</h1>
		<p class="setup-lead">
			No accounts exist yet. Create your administrator account to get started.
			This account will be linked to player #1 (God).
		</p>

		@if (_error is not null)
		{
			<div class="setup-error" role="alert">@_error</div>
		}

		<div class="setup-field">
			<label class="setup-label" for="setup-username">Username</label>
			<input id="setup-username" class="setup-input" type="text"
				   @bind="_username" @bind:event="oninput" disabled="@_busy" autocomplete="username" />
		</div>

		<div class="setup-field">
			<label class="setup-label" for="setup-password">Password</label>
			<input id="setup-password" class="setup-input" type="password"
				   @bind="_password" @bind:event="oninput" disabled="@_busy" autocomplete="new-password" />
		</div>

		<div class="setup-field">
			<label class="setup-label" for="setup-confirm">Confirm Password</label>
			<input id="setup-confirm" class="setup-input" type="password"
				   @bind="_confirm" @bind:event="oninput" disabled="@_busy" autocomplete="new-password" />
		</div>

		<button class="setup-submit" type="button" disabled="@_busy" @onclick="SubmitAsync">
			@(_busy ? "Setting up…" : "Create Admin Account")
		</button>
	</div>
</div>

<style>
	.setup-page {
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 100%;
		padding: var(--cpad);
	}

	.setup-card {
		width: 100%;
		max-width: 420px;
		background: var(--surface);
		border: 1px solid var(--border-soft);
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow);
		padding: 30px 28px;
	}

	.setup-kicker {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 8px;
	}

	.setup-title {
		margin: 0;
		font-family: var(--font-display);
		font-size: 26px;
		font-weight: 600;
		color: var(--text);
		line-height: 1.15;
	}

	.setup-lead {
		margin: 10px 0 22px;
		font-family: var(--font-ui);
		font-size: 14px;
		line-height: 1.5;
		color: var(--text-dim);
	}

	.setup-error {
		margin-bottom: 18px;
		padding: 10px 12px;
		border-radius: var(--radius);
		background: rgba(244, 67, 54, 0.10);
		border: 1px solid rgba(244, 67, 54, 0.35);
		color: #f4a8a3;
		font-family: var(--font-ui);
		font-size: 13px;
	}

	.setup-field {
		margin-bottom: 16px;
	}

	.setup-label {
		display: block;
		margin-bottom: 6px;
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--text-faint);
	}

	.setup-input {
		width: 100%;
		box-sizing: border-box;
		height: 42px;
		padding: 0 12px;
		background: var(--surface-3);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		color: var(--text);
		font-family: var(--font-ui);
		font-size: 14px;
		outline: none;
		transition: border-color 0.14s ease;
	}

	.setup-input:focus {
		border-color: var(--accent);
	}

	.setup-input:disabled {
		opacity: 0.55;
		cursor: not-allowed;
	}

	.setup-submit {
		width: 100%;
		height: 44px;
		margin-top: 8px;
		border: none;
		border-radius: var(--radius);
		background: var(--accent);
		color: var(--accent-on);
		font-family: var(--font-ui);
		font-size: 14px;
		font-weight: 600;
		cursor: pointer;
		transition: filter 0.12s ease;
	}

	.setup-submit:hover:not(:disabled) {
		filter: brightness(1.08);
	}

	.setup-submit:disabled {
		opacity: 0.6;
		cursor: not-allowed;
	}
</style>

@code {
	private string _username = string.Empty;
	private string _password = string.Empty;
	private string _confirm = string.Empty;
	private string? _error;
	private bool _busy;

	protected override async Task OnInitializedAsync()
	{
		if (!await AccountAuth.NeedsSetupAsync())
			Nav.NavigateTo("/", replace: true);
	}

	private async Task SubmitAsync()
	{
		_error = null;
		if (string.IsNullOrWhiteSpace(_username)) { _error = "Username is required."; return; }
		if (string.IsNullOrWhiteSpace(_password)) { _error = "Password is required."; return; }
		if (_password != _confirm) { _error = "Passwords do not match."; return; }
		if (_password.Length < 8) { _error = "Password must be at least 8 characters."; return; }

		_busy = true;
		StateHasChanged();

		var (success, error) = await AccountAuth.CompleteSetupAsync(_username, _password);
		_busy = false;

		if (!success) { _error = error; StateHasChanged(); return; }

		Nav.NavigateTo("/", replace: true);
	}
}
