@page "/setup"
@layout OnboardingLayout
@using SharpMUSH.Client.Layout
@using SharpMUSH.Client.Services
@inject AccountAuthService AccountAuth
@inject NavigationManager Nav

<PageTitle>First-Run Setup — SharpMUSH</PageTitle>

<div class="setup-page">
    <div class="setup-brand">
        <img src="assets/Logo.svg" alt="SharpMUSH" class="setup-logo" />
        <h1 class="setup-brand-title">Welcome to SharpMUSH</h1>
    </div>

    @if (_success)
    {
        <div class="setup-card">
            <div class="setup-kicker">First-Run Setup</div>
            <h2 class="setup-title">Setup complete. You are the administrator.</h2>
            @if (_autoLoggedIn)
            {
                <p class="setup-lead">
                    The administrator account <strong>@_completedUsername</strong> is now linked to the
                    pre-generated player #1, God. You are signed in as <strong>@_completedUsername</strong>.
                </p>
                <button class="setup-submit setup-signin" type="button" @onclick="EnterPortal">Enter the portal</button>
            }
            else
            {
                <!-- Claim succeeded but post-claim auto-login enrichment degraded server-side
                     (see SetupController.Complete's try/catch) — no session was minted, so send
                     the claimer to a normal sign-in instead of pretending they're logged in. -->
                <p class="setup-lead">
                    The administrator account <strong>@_completedUsername</strong> is now linked to the
                    pre-generated player #1, God. Sign in to start managing your game.
                </p>
                <a class="setup-submit setup-signin" href="/login">Sign in</a>
            }
        </div>
    }
    else
    {
        <div class="setup-card">
            <div class="setup-kicker">First-Run Setup</div>
            <h2 class="setup-title">Claim the administrator account</h2>
            <p class="setup-lead">
                This game hasn't been claimed yet. Choose a username and password for the
                pre-generated administrator account (linked to player #1, God). The first
                person to complete this form becomes the administrator.
            </p>

            @if (_error is not null)
            {
                <div class="setup-error" role="alert">@_error</div>
            }

            <div class="setup-field">
                <label class="setup-label" for="setup-username">Username</label>
                <input id="setup-username" class="setup-input" type="text"
                       @bind="_username" @bind:event="oninput" disabled="@_busy" autocomplete="username" />
            </div>

            <div class="setup-field">
                <label class="setup-label" for="setup-password">Password</label>
                <input id="setup-password" class="setup-input" type="password"
                       @bind="_password" @bind:event="oninput" disabled="@_busy" autocomplete="new-password" />
            </div>

            <div class="setup-field">
                <label class="setup-label" for="setup-confirm">Confirm Password</label>
                <input id="setup-confirm" class="setup-input" type="password"
                       @bind="_confirm" @bind:event="oninput" disabled="@_busy" autocomplete="new-password" />
            </div>

            <button class="setup-submit" type="button" disabled="@_busy" @onclick="SubmitAsync">
                @(_busy ? "Setting up…" : "Create Admin Account")
            </button>
        </div>
    }
</div>

@code {
    private string _username = string.Empty;
    private string _password = string.Empty;
    private string _confirm = string.Empty;
    private string? _error;
    private bool _busy;
    private bool _success;
    private bool _autoLoggedIn;
    private string _completedUsername = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        // Only navigate away on a definitive "setup already done." A null result means the
        // status check couldn't reach/parse the server — stay on the page rather than bounce
        // the user away from the only place they can complete first-run setup; the submit
        // button's own error handling will surface any real server problem.
        if (await AccountAuth.NeedsSetupAsync() == false)
            Nav.NavigateTo("/", replace: true);
    }

    private async Task SubmitAsync()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(_username)) { _error = "Username is required."; return; }
        if (string.IsNullOrWhiteSpace(_password)) { _error = "Password is required."; return; }
        if (_password != _confirm) { _error = "Passwords do not match."; return; }
        if (_password.Length < 8) { _error = "Password must be at least 8 characters."; return; }

        _busy = true;
        StateHasChanged();

        var (success, error, autoLoggedIn) = await AccountAuth.CompleteSetupAsync(_username, _password);
        _busy = false;

        if (!success)
        {
            _error = error switch
            {
                not null when error.Contains("already been completed", StringComparison.OrdinalIgnoreCase)
                    => "Setup was just completed by someone else. If that wasn't you, contact the server operator immediately.",
                not null when error.Contains("already taken", StringComparison.OrdinalIgnoreCase)
                    => "That username is already taken — choose another.",
                _ => error ?? "Setup failed.",
            };
            StateHasChanged();
            return;
        }

        _completedUsername = _username;
        _success = true;
        _autoLoggedIn = autoLoggedIn;
        StateHasChanged();
    }

    private void EnterPortal() => Nav.NavigateTo("/");
}
