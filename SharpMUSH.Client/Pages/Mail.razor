@page "/mail"
@attribute [Authorize]
@using SharpMUSH.Client.Services
@inject IStringLocalizer<SharedResource> Loc
@inject ITerminalService Terminal
@inject MailService MailApi
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Mail — SharpMUSH</PageTitle>

@if (!_characterActive)
{
    <div style="padding:var(--cpad);">
        <EmptyState>
            <MudText>@Loc["MailNeedsCharacter"]</MudText>
            <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/characters" Class="mt-2">
                @Loc["Characters"]
            </MudButton>
        </EmptyState>
    </div>
}
else
{
    <div class="mail-page" style="display:flex;height:100%;overflow:hidden;">

        <div class="mail-folders" style="width:180px;flex-shrink:0;border-right:1px solid var(--border);background:var(--surface-3);display:flex;flex-direction:column;overflow-y:auto;">
            <div style="padding:0.875rem 0.75rem 0.5rem;border-bottom:1px solid var(--border-soft);">
                <MudText Class="section-kicker">Folders</MudText>
            </div>
            <MudNavMenu Dense="true" Style="padding:0.5rem 0.25rem;">
                @foreach (var f in _folders)
                {
                    var folder = f;
                    <MudNavLink Icon="@FolderIcon(folder)" IconColor="Color.Default"
                                OnClick="() => SelectFolderAsync(folder)"
                                Class="@(_folder == folder ? "active-folder" : "")">
                        @folder
                    </MudNavLink>
                }
            </MudNavMenu>
            <div style="margin-top:auto;padding:0.75rem;">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                           StartIcon="@Icons.Material.Filled.Edit" Href="/mail/compose" Size="Size.Small">
                    @Loc["Compose"]
                </MudButton>
            </div>
        </div>

        <div class="mail-list" style="width:320px;flex-shrink:0;border-right:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden;background:var(--surface);">
            <div style="padding:0.625rem 0.875rem;border-bottom:1px solid var(--border-soft);display:flex;align-items:center;gap:0.5rem;">
                <MudText Style="font-size:0.8125rem;font-weight:600;flex:1;">@_folder</MudText>
                @if (_messages.Count > 0)
                {
                    <MudText Style="font-size:0.6875rem;color:var(--text-faint);">@_messages.Count</MudText>
                }
            </div>
            <div style="flex:1;overflow-y:auto;">
                @if (_loading)
                {
                    <div style="padding:0.75rem;">
                        @for (var i = 0; i < 5; i++) { <MudSkeleton Height="52px" Class="mb-1" /> }
                    </div>
                }
                else if (_messages.Count == 0)
                {
                    <div style="padding:1rem;color:var(--text-faint);font-size:0.8125rem;">@Loc["MailEmpty"]</div>
                }
                else
                {
                    @foreach (var msg in _messages)
                    {
                        var m = msg;
                        <div style="@($"padding:0.625rem 0.875rem;border-bottom:1px solid var(--border-soft);cursor:pointer;background:{(_selected?.Number == m.Number ? "var(--surface-2)" : "transparent")};border-left:{(!m.Read ? "3px solid var(--accent)" : "3px solid transparent")}")"
                             @onclick="() => SelectMessage(m)">
                            <div style="display:flex;align-items:center;gap:0.375rem;margin-bottom:0.125rem;">
                                @if (!m.Read)
                                {
                                    <span style="width:6px;height:6px;border-radius:50%;background:var(--accent);flex-shrink:0;"></span>
                                }
                                @if (m.Urgent)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.PriorityHigh" Color="Color.Error" Size="Size.Small" />
                                }
                                <MudText Style="@($"font-size:0.8125rem;font-weight:{(m.Read ? "400" : "600")};flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;")">@m.From</MudText>
                                <MudText Style="font-size:0.6875rem;color:var(--text-faint);flex-shrink:0;">@m.DateSent.LocalDateTime.ToString("MMM d")</MudText>
                            </div>
                            <MudText Style="font-size:0.75rem;color:var(--text-dim);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@m.Subject</MudText>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="mail-reading" style="flex:1;min-width:0;display:flex;flex-direction:column;overflow:hidden;">
            @if (_selected is null)
            {
                <div style="display:flex;align-items:center;justify-content:center;height:100%;color:var(--text-faint);font-size:0.875rem;">
                    Select a message to read
                </div>
            }
            else
            {
                <div style="padding:1.25rem var(--cpad);border-bottom:1px solid var(--border);flex-shrink:0;">
                    <div style="display:flex;align-items:flex-start;gap:0.875rem;">
                        <MudAvatar Style="@($"background:hsl({Math.Abs(_selected.From.GetHashCode()) % 360},50%,30%);color:#fff;font-weight:600;flex-shrink:0;")">
                            @(_selected.From.Length > 0 ? _selected.From[0].ToString().ToUpper() : "?")
                        </MudAvatar>
                        <div style="flex:1;min-width:0;">
                            <MudText Style="font-size:1rem;font-weight:700;margin-bottom:0.125rem;">@_selected.Subject</MudText>
                            <MudText Style="font-size:0.8125rem;color:var(--text-dim);">From: @_selected.From</MudText>
                            <MudText Style="font-size:0.75rem;color:var(--text-faint);">@_selected.DateSent.LocalDateTime.ToString("dddd, MMMM d yyyy, h:mm tt")</MudText>
                        </div>
                    </div>
                </div>
                <div style="flex:1;overflow-y:auto;padding:1.25rem var(--cpad);">
                    <MudButton Variant="Variant.Text" Size="Size.Small"
                               Color="Color.Default" OnClick="OpenDetail">
                        Read full message →
                    </MudButton>
                </div>
                <div style="padding:0.75rem var(--cpad);border-top:1px solid var(--border);display:flex;gap:0.5rem;flex-shrink:0;">
                    <MudButton Variant="Variant.Outlined" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Reply">
                        Reply
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Forward">
                        Forward
                    </MudButton>
                </div>
            }
        </div>
    </div>
}

@code {
    private bool _characterActive;
    private string _folder = "INBOX";
    private IReadOnlyList<string> _folders = ["INBOX"];
    private IReadOnlyList<MailService.MailSummary> _messages = [];
    private MailService.MailSummary? _selected;
    private bool _loading;

    protected override async Task OnInitializedAsync()
    {
        _characterActive = Terminal.IsConnected;
        Terminal.ConnectionStateChanged += OnConnectionChanged;
        if (_characterActive)
            await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _folders = await MailApi.FoldersAsync();
        _messages = await MailApi.ListAsync(_folder);
        _loading = false;
    }

    private async Task SelectFolderAsync(string folder)
    {
        _folder = folder;
        _selected = null;
        _loading = true;
        _messages = await MailApi.ListAsync(_folder);
        _loading = false;
    }

    private void SelectMessage(MailService.MailSummary msg) => _selected = msg;

    private void OpenDetail()
    {
        if (_selected is not null)
            Nav.NavigateTo($"/mail/{_selected.Number}?folder={Uri.EscapeDataString(_selected.Folder)}");
    }

    private static string FolderIcon(string folder) => folder switch
    {
        "INBOX"  => Icons.Material.Filled.Inbox,
        "SENT"   => Icons.Material.Filled.Send,
        "TRASH"  => Icons.Material.Filled.Delete,
        _        => Icons.Material.Filled.Folder
    };

    private void OnConnectionChanged(bool connected)
        => InvokeAsync(async () =>
        {
            _characterActive = connected;
            if (connected) { await LoadAsync(); }
            StateHasChanged();
        });

    public void Dispose() => Terminal.ConnectionStateChanged -= OnConnectionChanged;
}
