{
  "Cors": {
    "AllowedOrigins": []
  },
  "Mcp": {
    "Enabled": false,
    "Path": "/mcp"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "ZiggyCreatures.Caching.Fusion": "Error",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "TelnetNegotiationCore": "Information",
        "SurrealDb": "Error",
        "NATS": "Error"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext" ]
  }
}
