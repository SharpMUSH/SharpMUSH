{
  "Urls": "https://localhost:8081;http://localhost:8080",
  "Mcp": {
    "Enabled": true,
    "Path": "/mcp"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "ZiggyCreatures.Caching.Fusion": "Error",
        "Microsoft.AspNetCore": "Warning",
        "SharpMUSH.Server.Authentication.DebugAuthenticationHandler": "Information",
        "Microsoft.Hosting.Lifetime": "Information",
        "TelnetNegotiationCore": "Information",
        "SurrealDb": "Error",
        "NATS": "Error"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext" ]
  }
}
