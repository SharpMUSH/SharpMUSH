<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <LangVersion>default</LangVersion>
		<TreatWarningsAsErrors>True</TreatWarningsAsErrors>
		<NoWarn>TUnit0038</NoWarn>
	</PropertyGroup>

  <ItemGroup>
    <PackageReference Include="bunit" Version="2.7.2" />
    <PackageReference Include="coverlet.collector" Version="8.0.1">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
		<PackageReference Include="TUnit" Version="1.19.16" />
		<PackageReference Include="TUnit.AspNetCore" Version="1.19.16" />
		<PackageReference Include="System.Linq.Async" Version="6.0.1" ExcludeAssets="compile" />
  </ItemGroup>

  <ItemGroup>
    <!-- Shared test infrastructure (ServerWebAppFactory, TestHelpers, test containers, etc.) -->
    <ProjectReference Include="..\SharpMUSH.Tests.Infrastructure\SharpMUSH.Tests.Infrastructure.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="..\SharpMUSH.Documentation\Helpfiles\SharpMUSH\sharpattr.md">
      <Link>Documentation\Testfile\sharpattr.md</Link>
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
		<Content Include="..\SharpMUSH.Documentation\Helpfiles\SharpMUSH\sharpchat.md">
			<Link>Documentation\Testfile\sharpchat.md</Link>
			<CopyToOutputDirectory>Always</CopyToOutputDirectory>
		</Content>
		<Content Include="Configuration\Testfile\mushcnf.dst">
			<CopyToOutputDirectory>Always</CopyToOutputDirectory>
		</Content>
		<Content Include="Integration\TestData\*.txt">
			<CopyToOutputDirectory>Always</CopyToOutputDirectory>
		</Content>
		<Content Include="..\SharpMUSH.Server\*.txt">
			<Link>txt\%(Filename)%(Extension)</Link>
			<CopyToOutputDirectory>Always</CopyToOutputDirectory>
		</Content>
		<None Include="..\SharpMUSH.Documentation\Helpfiles\SharpMUSH\*.md">
			<Link>TextFiles\help\%(Filename)%(Extension)</Link>
			<CopyToOutputDirectory>Always</CopyToOutputDirectory>
		</None>
		<None Include="..\SharpMUSH.Documentation\Helpfiles\SharpMUSH\ahelp\*.md">
			<Link>TextFiles\ahelp\%(Filename)%(Extension)</Link>
			<CopyToOutputDirectory>Always</CopyToOutputDirectory>
		</None>
		<None Include="..\SharpMUSH.Documentation\Helpfiles\SharpMUSH\news\*.md">
			<Link>TextFiles\news\%(Filename)%(Extension)</Link>
			<CopyToOutputDirectory>Always</CopyToOutputDirectory>
		</None>
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="Functions\UtilityFunctionUnitTests.cs" />
    <!-- Infrastructure files are now in SharpMUSH.Tests.Infrastructure -->
    <Compile Remove="DockerNetwork.cs" />
    <Compile Remove="ArangoDBTestServer.cs" />
    <Compile Remove="MemgraphTestServer.cs" />
    <Compile Remove="NatsTestServer.cs" />
    <Compile Remove="MySqlTestServer.cs" />
    <Compile Remove="PostgreSqlTestServer.cs" />
    <Compile Remove="SqliteTestServer.cs" />
    <Compile Remove="ServerWebAppFactory.cs" />
    <Compile Remove="ServerTestWebApplicationBuilderFactory.cs" />
    <Compile Remove="ConnectionServerWebAppFactory.cs" />
    <Compile Remove="ConnectionServerTestWebApplicationBuilderFactory.cs" />
    <Compile Remove="TestHelpers.cs" />
    <Compile Remove="TestIsolationHelpers.cs" />
  </ItemGroup>

</Project>

