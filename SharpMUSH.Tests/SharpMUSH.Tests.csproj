<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <LangVersion>default</LangVersion>
		<TreatWarningsAsErrors>True</TreatWarningsAsErrors>
		<NoWarn>TUnit0038;TUnitAssertions0002;ASPDEPR004;ASPDEPR008</NoWarn>
	</PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="bunit" Version="2.7.2" />
    <PackageReference Include="coverlet.collector" Version="10.0.1">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
		<PackageReference Include="NSubstitute" Version="5.3.0" />
		<PackageReference Include="TUnit.AspNetCore" Version="1.19.16" />
		<PackageReference Include="System.Linq.Async" Version="6.0.1" ExcludeAssets="compile" />
  </ItemGroup>

  <ItemGroup>
    <!-- Shared test infrastructure (ServerWebAppFactory, TestHelpers, test containers, etc.) -->
    <ProjectReference Include="..\SharpMUSH.Tests.Infrastructure\SharpMUSH.Tests.Infrastructure.csproj" />
    <!-- ConnectionServer protocol handlers -->
    <ProjectReference Include="..\SharpMUSH.ConnectionServer\SharpMUSH.ConnectionServer.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="..\SharpMUSH.Documentation\Helpfiles\SharpMUSH\sharpattr.md">
      <Link>Documentation\Testfile\sharpattr.md</Link>
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
		<Content Include="..\SharpMUSH.Documentation\Helpfiles\SharpMUSH\sharpchat.md">
			<Link>Documentation\Testfile\sharpchat.md</Link>
			<CopyToOutputDirectory>Always</CopyToOutputDirectory>
		</Content>
		<Content Include="Configuration\Testfile\mushcnf.dst">
			<CopyToOutputDirectory>Always</CopyToOutputDirectory>
		</Content>
		<Content Include="Integration\TestData\*.txt">
			<CopyToOutputDirectory>Always</CopyToOutputDirectory>
		</Content>
		<Content Include="..\SharpMUSH.Server\*.txt">
			<Link>txt\%(Filename)%(Extension)</Link>
			<CopyToOutputDirectory>Always</CopyToOutputDirectory>
		</Content>
		<None Include="..\SharpMUSH.Documentation\Helpfiles\SharpMUSH\*.md">
			<Link>TextFiles\help\%(Filename)%(Extension)</Link>
			<CopyToOutputDirectory>Always</CopyToOutputDirectory>
		</None>
		<None Include="..\SharpMUSH.Documentation\Helpfiles\SharpMUSH\ahelp\*.md">
			<Link>TextFiles\ahelp\%(Filename)%(Extension)</Link>
			<CopyToOutputDirectory>Always</CopyToOutputDirectory>
		</None>
		<None Include="..\SharpMUSH.Documentation\Helpfiles\SharpMUSH\news\*.md">
			<Link>TextFiles\news\%(Filename)%(Extension)</Link>
			<CopyToOutputDirectory>Always</CopyToOutputDirectory>
		</None>
  </ItemGroup>

  <ItemGroup>
    <!-- Fixtures/ holds standalone projects (e.g. SamplePlugin) built on their own; never compile
         their sources or globbed obj/ output into this test assembly. -->
    <Compile Remove="Fixtures\**\*.cs" />
    <Content Remove="Fixtures\**\*" />
    <None Remove="Fixtures\**\*" />
    <EmbeddedResource Remove="Fixtures\**\*" />
  </ItemGroup>

  <ItemGroup>
    <!-- Build the command-only Phase 3 fixture before this project so its DLL exists to copy into the
         test output. ReferenceOutputAssembly=false: we do NOT link the plugin; the unload test loads it at
         runtime from disk through PluginLoaderService, exactly as the booting server would. -->
    <ProjectReference Include="Fixtures\CommandOnlyPlugin\CommandOnlyPlugin.csproj" ReferenceOutputAssembly="false" Private="false" PrivateAssets="all" />
    <!-- Build the IApplicationSource fixture before this project so its DLL exists to copy into the test
         output. Loaded at runtime from disk through PluginLoaderService, never linked. -->
    <ProjectReference Include="Fixtures\ApplicationSourcePlugin\ApplicationSourcePlugin.csproj" ReferenceOutputAssembly="false" Private="false" PrivateAssets="all" />
    <!-- Build the examples/plugins/hello-ui worked example (a UI plugin shipped as a managed package) so the
         HelloUiManagedPackageExampleTests can load its DLL from disk, exactly as the booting server would. -->
    <ProjectReference Include="..\examples\plugins\hello-ui\HelloUiPlugin.csproj" ReferenceOutputAssembly="false" Private="false" PrivateAssets="all" />
    <ProjectReference Include="..\SharpMUSH.CodeAnalysis\SharpMUSH.CodeAnalysis.csproj" />
  </ItemGroup>

  <!-- Drop the built CommandOnlyPlugin (DLL + manifest only — its SharpMUSH deps resolve from this host's
       output via sharedTypes) into plugins-unit/command-only/ so the unload unit test can load it from disk
       without colliding with any plugins/ folder an integration host scans. -->
  <Target Name="CopyCommandOnlyPlugin" AfterTargets="Build">
    <PropertyGroup>
      <CommandOnlyPluginOutDir>$(MSBuildThisFileDirectory)Fixtures\CommandOnlyPlugin\bin\$(Configuration)\net10.0</CommandOnlyPluginOutDir>
      <CommandOnlyPluginTargetDir>$(OutDir)plugins-unit\command-only</CommandOnlyPluginTargetDir>
    </PropertyGroup>
    <ItemGroup>
      <CommandOnlyPluginFiles Include="$(CommandOnlyPluginOutDir)\CommandOnlyPlugin.dll" />
      <CommandOnlyPluginFiles Include="$(CommandOnlyPluginOutDir)\CommandOnlyPlugin.deps.json" />
      <CommandOnlyPluginFiles Include="$(MSBuildThisFileDirectory)Fixtures\CommandOnlyPlugin\plugin.json" />
    </ItemGroup>
    <MakeDir Directories="$(CommandOnlyPluginTargetDir)" />
    <Copy SourceFiles="@(CommandOnlyPluginFiles)" DestinationFolder="$(CommandOnlyPluginTargetDir)" SkipUnchangedFiles="false" />
  </Target>

  <!-- Drop the built ApplicationSourcePlugin into plugins-unit/app-source/ so the overlay test can load it
       from disk through PluginLoaderService without colliding with any plugins/ folder an integration host
       scans. -->
  <Target Name="CopyApplicationSourcePlugin" AfterTargets="Build">
    <PropertyGroup>
      <ApplicationSourcePluginOutDir>$(MSBuildThisFileDirectory)Fixtures\ApplicationSourcePlugin\bin\$(Configuration)\net10.0</ApplicationSourcePluginOutDir>
      <ApplicationSourcePluginTargetDir>$(OutDir)plugins-unit\app-source</ApplicationSourcePluginTargetDir>
    </PropertyGroup>
    <ItemGroup>
      <ApplicationSourcePluginFiles Include="$(ApplicationSourcePluginOutDir)\ApplicationSourcePlugin.dll" />
      <ApplicationSourcePluginFiles Include="$(ApplicationSourcePluginOutDir)\ApplicationSourcePlugin.deps.json" />
      <ApplicationSourcePluginFiles Include="$(MSBuildThisFileDirectory)Fixtures\ApplicationSourcePlugin\plugin.json" />
    </ItemGroup>
    <MakeDir Directories="$(ApplicationSourcePluginTargetDir)" />
    <Copy SourceFiles="@(ApplicationSourcePluginFiles)" DestinationFolder="$(ApplicationSourcePluginTargetDir)" SkipUnchangedFiles="false" />
  </Target>

  <!-- Drop the built examples/plugins/hello-ui worked example into plugins-unit/hello-ui/ so
       HelloUiManagedPackageExampleTests can load it from disk through PluginLoaderService. -->
  <Target Name="CopyHelloUiPlugin" AfterTargets="Build">
    <PropertyGroup>
      <HelloUiPluginOutDir>$(MSBuildThisFileDirectory)..\examples\plugins\hello-ui\bin\$(Configuration)\net10.0</HelloUiPluginOutDir>
      <HelloUiPluginTargetDir>$(OutDir)plugins-unit\hello-ui</HelloUiPluginTargetDir>
    </PropertyGroup>
    <ItemGroup>
      <HelloUiPluginFiles Include="$(HelloUiPluginOutDir)\HelloUiPlugin.dll" />
      <HelloUiPluginFiles Include="$(HelloUiPluginOutDir)\HelloUiPlugin.deps.json" />
      <HelloUiPluginFiles Include="$(MSBuildThisFileDirectory)..\examples\plugins\hello-ui\plugin.json" />
    </ItemGroup>
    <MakeDir Directories="$(HelloUiPluginTargetDir)" />
    <Copy SourceFiles="@(HelloUiPluginFiles)" DestinationFolder="$(HelloUiPluginTargetDir)" SkipUnchangedFiles="false" />
  </Target>

  <ItemGroup>
    <Compile Remove="Functions\UtilityFunctionUnitTests.cs" />
    <!-- Infrastructure files are now in SharpMUSH.Tests.Infrastructure -->
    <Compile Remove="DockerNetwork.cs" />
    <Compile Remove="ArangoDBTestServer.cs" />
    <Compile Remove="MemgraphTestServer.cs" />
    <Compile Remove="NatsTestServer.cs" />
    <Compile Remove="MySqlTestServer.cs" />
    <Compile Remove="PostgreSqlTestServer.cs" />
    <Compile Remove="SqliteTestServer.cs" />
    <Compile Remove="ServerWebAppFactory.cs" />
    <Compile Remove="ServerTestWebApplicationBuilderFactory.cs" />
    <Compile Remove="ConnectionServerWebAppFactory.cs" />
    <Compile Remove="ConnectionServerTestWebApplicationBuilderFactory.cs" />
    <Compile Remove="TestHelpers.cs" />
    <Compile Remove="TestIsolationHelpers.cs" />
  </ItemGroup>

</Project>

