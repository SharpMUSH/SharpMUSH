<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<LangVersion>default</LangVersion>
		<IsPackable>false</IsPackable>
		<TreatWarningsAsErrors>true</TreatWarningsAsErrors>
		<RootNamespace>SharpMUSH.Plugins.Scene.Contracts</RootNamespace>
	</PropertyGroup>

	<!-- The scene contract surface (models + ISceneService + SceneEventMessage) shared between the host and
	     the Scene plugin across the plugin isolation boundary. The plugin loader adds this assembly to its
	     host-shared set (PluginLoaderService.DefaultSharedAssemblyNames) so the host's copy is authoritative
	     for both sides and the types unify by identity. ISceneService returns OneOf<…>. -->
	<ItemGroup>
		<PackageReference Include="OneOf" Version="3.0.271" />
	</ItemGroup>

</Project>
