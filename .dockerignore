# Build outputs
**/bin/
**/obj/
**/out/

# NuGet packages
**/packages/
*.nupkg

# ...but keep the bundled example packages: SharpMUSH.Server embeds their
# package.yaml files as resources (see SharpMUSH.Server.csproj), so the
# **/packages/ rule above must not strip examples/packages out of the build context.
!examples/packages
!examples/packages/**

# Visual Studio cache/options
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# IDE files
.idea/
*.swp
*~
.vscode/

# Git
.git/
.gitignore
.gitattributes

# Docker
.dockerignore
Dockerfile*
docker-compose*

# Documentation
*.md
!README.md

# CI/CD
.github/
.azure/

# Other
*.log
